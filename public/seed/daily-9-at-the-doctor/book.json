{"id":"daily-9-at-the-doctor","slug":"daily-9-at-the-doctor","title":"At the Doctor","title_ko":"병원에서","level":"A2","ageBand":"8-10","coverUrl":"/seed/daily-9-at-the-doctor/cover.webp","summary_ko":"열이 나서 엄마와 병원에 가 의사 선생님에게 증상을 말하는 이야기. 몸과 아픔, 진료 대화를 배워요.","wordCount":194,"stage":3,"collection":"daily","pages":[{"id":"daily-9-at-the-doctor-p1","pageNo":1,"spread":"p1","imageUrl":"/seed/daily-9-at-the-doctor/p1.webp","sentences":[{"id":"daily-9-at-the-doctor-p1-s1","ord":0,"text":"I do not feel well today.","translation_ko":"나는 오늘 몸이 좋지 않아요.","audioUrl":"/seed/daily-9-at-the-doctor/audio/p1-s1.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":320},{"word":"do","charStart":2,"charEnd":4,"startMs":320,"endMs":680},{"word":"not","charStart":5,"charEnd":8,"startMs":680,"endMs":940},{"word":"feel","charStart":9,"charEnd":13,"startMs":940,"endMs":1200},{"word":"well","charStart":14,"charEnd":18,"startMs":1200,"endMs":1460},{"word":"today","charStart":19,"charEnd":24,"startMs":1460,"endMs":1760}]},{"id":"daily-9-at-the-doctor-p1-s2","ord":1,"text":"My body feels tired and my head is heavy.","translation_ko":"몸이 피곤하고 머리가 무거워요.","audioUrl":"/seed/daily-9-at-the-doctor/audio/p1-s2.mp3","wordTimings":[{"word":"My","charStart":0,"charEnd":2,"startMs":0,"endMs":320},{"word":"body","charStart":3,"charEnd":7,"startMs":320,"endMs":720},{"word":"feels","charStart":8,"charEnd":13,"startMs":720,"endMs":1240},{"word":"tired","charStart":14,"charEnd":19,"startMs":1240,"endMs":1760},{"word":"and","charStart":20,"charEnd":23,"startMs":2220,"endMs":2320},{"word":"my","charStart":24,"charEnd":26,"startMs":2320,"endMs":2620},{"word":"head","charStart":27,"charEnd":31,"startMs":2620,"endMs":2760},{"word":"is","charStart":32,"charEnd":34,"startMs":2760,"endMs":3260},{"word":"heavy","charStart":35,"charEnd":40,"startMs":3260,"endMs":3260}]},{"id":"daily-9-at-the-doctor-p1-s3","ord":2,"text":"I want to stay in bed.","translation_ko":"침대에 그냥 있고 싶어요.","audioUrl":"/seed/daily-9-at-the-doctor/audio/p1-s3.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":320},{"word":"want","charStart":2,"charEnd":6,"startMs":320,"endMs":640},{"word":"to","charStart":7,"charEnd":9,"startMs":640,"endMs":1100},{"word":"stay","charStart":10,"charEnd":14,"startMs":1100,"endMs":1160},{"word":"in","charStart":15,"charEnd":17,"startMs":1160,"endMs":1700},{"word":"bed","charStart":18,"charEnd":21,"startMs":1700,"endMs":1700}]}]},{"id":"daily-9-at-the-doctor-p2","pageNo":2,"spread":"p2","imageUrl":"/seed/daily-9-at-the-doctor/p2.webp","sentences":[{"id":"daily-9-at-the-doctor-p2-s1","ord":0,"text":"\"You are hot. Let's see the doctor,\" says Mom.","translation_ko":"\"열이 있구나. 의사 선생님께 가자,\" 엄마가 말해요.","audioUrl":"/seed/daily-9-at-the-doctor/audio/p2-s1.mp3","wordTimings":[{"word":"You","charStart":1,"charEnd":4,"startMs":0,"endMs":260},{"word":"are","charStart":5,"charEnd":8,"startMs":260,"endMs":580},{"word":"hot","charStart":9,"charEnd":12,"startMs":580,"endMs":900},{"word":"Let's","charStart":14,"charEnd":19,"startMs":1440,"endMs":1660},{"word":"see","charStart":20,"charEnd":23,"startMs":1660,"endMs":1800},{"word":"the","charStart":24,"charEnd":27,"startMs":1800,"endMs":2000},{"word":"doctor","charStart":28,"charEnd":34,"startMs":2000,"endMs":2880},{"word":"says","charStart":37,"charEnd":41,"startMs":2880,"endMs":2940},{"word":"Mom","charStart":42,"charEnd":45,"startMs":2940,"endMs":3200}]},{"id":"daily-9-at-the-doctor-p2-s2","ord":1,"text":"She helps me put on my jacket.","translation_ko":"엄마가 내 겉옷을 입혀 줘요.","audioUrl":"/seed/daily-9-at-the-doctor/audio/p2-s2.mp3","wordTimings":[{"word":"She","charStart":0,"charEnd":3,"startMs":0,"endMs":300},{"word":"helps","charStart":4,"charEnd":9,"startMs":300,"endMs":580},{"word":"me","charStart":10,"charEnd":12,"startMs":580,"endMs":940},{"word":"put","charStart":13,"charEnd":16,"startMs":940,"endMs":1060},{"word":"on","charStart":17,"charEnd":19,"startMs":1060,"endMs":1300},{"word":"my","charStart":20,"charEnd":22,"startMs":1300,"endMs":1540},{"word":"jacket","charStart":23,"charEnd":29,"startMs":1540,"endMs":1760}]},{"id":"daily-9-at-the-doctor-p2-s3","ord":2,"text":"We walk to the clinic together.","translation_ko":"우리는 함께 병원으로 걸어가요.","audioUrl":"/seed/daily-9-at-the-doctor/audio/p2-s3.mp3","wordTimings":[{"word":"We","charStart":0,"charEnd":2,"startMs":0,"endMs":460},{"word":"walk","charStart":3,"charEnd":7,"startMs":460,"endMs":800},{"word":"to","charStart":8,"charEnd":10,"startMs":800,"endMs":1000},{"word":"the","charStart":11,"charEnd":14,"startMs":1000,"endMs":1280},{"word":"clinic","charStart":15,"charEnd":21,"startMs":1280,"endMs":1600},{"word":"together","charStart":22,"charEnd":30,"startMs":1600,"endMs":2260}]}]},{"id":"daily-9-at-the-doctor-p3","pageNo":3,"spread":"p3","imageUrl":"/seed/daily-9-at-the-doctor/p3.webp","sentences":[{"id":"daily-9-at-the-doctor-p3-s1","ord":0,"text":"\"Hello. What is wrong?\" asks the doctor.","translation_ko":"\"안녕. 어디가 아프니?\" 의사 선생님이 물어요.","audioUrl":"/seed/daily-9-at-the-doctor/audio/p3-s1.mp3","wordTimings":[{"word":"Hello","charStart":1,"charEnd":6,"startMs":0,"endMs":480},{"word":"What","charStart":8,"charEnd":12,"startMs":1320,"endMs":1320},{"word":"is","charStart":13,"charEnd":15,"startMs":1320,"endMs":1560},{"word":"wrong","charStart":16,"charEnd":21,"startMs":1560,"endMs":1860},{"word":"asks","charStart":24,"charEnd":28,"startMs":2640,"endMs":2660},{"word":"the","charStart":29,"charEnd":32,"startMs":2660,"endMs":2860},{"word":"doctor","charStart":33,"charEnd":39,"startMs":2860,"endMs":3220}]},{"id":"daily-9-at-the-doctor-p3-s2","ord":1,"text":"The doctor has a kind smile.","translation_ko":"의사 선생님은 다정하게 웃어요.","audioUrl":"/seed/daily-9-at-the-doctor/audio/p3-s2.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":220},{"word":"doctor","charStart":4,"charEnd":10,"startMs":220,"endMs":580},{"word":"has","charStart":11,"charEnd":14,"startMs":580,"endMs":860},{"word":"a","charStart":15,"charEnd":16,"startMs":860,"endMs":1040},{"word":"kind","charStart":17,"charEnd":21,"startMs":1040,"endMs":1380},{"word":"smile","charStart":22,"charEnd":27,"startMs":1380,"endMs":1780}]},{"id":"daily-9-at-the-doctor-p3-s3","ord":2,"text":"I sit on the chair and look at the doctor.","translation_ko":"나는 의자에 앉아 의사 선생님을 바라봐요.","audioUrl":"/seed/daily-9-at-the-doctor/audio/p3-s3.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":400},{"word":"sit","charStart":2,"charEnd":5,"startMs":400,"endMs":860},{"word":"on","charStart":6,"charEnd":8,"startMs":860,"endMs":1220},{"word":"the","charStart":9,"charEnd":12,"startMs":1220,"endMs":1400},{"word":"chair","charStart":13,"charEnd":18,"startMs":1400,"endMs":1680},{"word":"and","charStart":19,"charEnd":22,"startMs":1680,"endMs":2320},{"word":"look","charStart":23,"charEnd":27,"startMs":2320,"endMs":2480},{"word":"at","charStart":28,"charEnd":30,"startMs":2480,"endMs":2700},{"word":"the","charStart":31,"charEnd":34,"startMs":2700,"endMs":2840},{"word":"doctor","charStart":35,"charEnd":41,"startMs":2840,"endMs":3140}]}]},{"id":"daily-9-at-the-doctor-p4","pageNo":4,"spread":"p4","imageUrl":"/seed/daily-9-at-the-doctor/p4.webp","sentences":[{"id":"daily-9-at-the-doctor-p4-s1","ord":0,"text":"\"My head hurts and I am hot,\" I say.","translation_ko":"\"머리가 아프고 열이 나요,\" 내가 말해요.","audioUrl":"/seed/daily-9-at-the-doctor/audio/p4-s1.mp3","wordTimings":[{"word":"My","charStart":1,"charEnd":3,"startMs":0,"endMs":280},{"word":"head","charStart":4,"charEnd":8,"startMs":280,"endMs":640},{"word":"hurts","charStart":9,"charEnd":14,"startMs":640,"endMs":1060},{"word":"and","charStart":15,"charEnd":18,"startMs":1060,"endMs":1440},{"word":"I","charStart":19,"charEnd":20,"startMs":1440,"endMs":1640},{"word":"am","charStart":21,"charEnd":23,"startMs":1640,"endMs":1820},{"word":"hot","charStart":24,"charEnd":27,"startMs":1820,"endMs":2180},{"word":"I","charStart":30,"charEnd":31,"startMs":2460,"endMs":2640},{"word":"say","charStart":32,"charEnd":35,"startMs":2640,"endMs":2860}]},{"id":"daily-9-at-the-doctor-p4-s2","ord":1,"text":"\"I also have a sore throat,\" I add.","translation_ko":"\"목도 아파요,\" 내가 덧붙여요.","audioUrl":"/seed/daily-9-at-the-doctor/audio/p4-s2.mp3","wordTimings":[{"word":"I","charStart":1,"charEnd":2,"startMs":0,"endMs":680},{"word":"also","charStart":3,"charEnd":7,"startMs":680,"endMs":1040},{"word":"have","charStart":8,"charEnd":12,"startMs":1040,"endMs":1280},{"word":"a","charStart":13,"charEnd":14,"startMs":1280,"endMs":1680},{"word":"sore","charStart":15,"charEnd":19,"startMs":1680,"endMs":1680},{"word":"throat","charStart":20,"charEnd":26,"startMs":1680,"endMs":1980},{"word":"I","charStart":29,"charEnd":30,"startMs":2220,"endMs":2360},{"word":"add","charStart":31,"charEnd":34,"startMs":2360,"endMs":2560}]},{"id":"daily-9-at-the-doctor-p4-s3","ord":2,"text":"The doctor listens carefully to everything I say.","translation_ko":"의사 선생님은 내 말을 귀 기울여 들어요.","audioUrl":"/seed/daily-9-at-the-doctor/audio/p4-s3.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":280},{"word":"doctor","charStart":4,"charEnd":10,"startMs":280,"endMs":860},{"word":"listens","charStart":11,"charEnd":18,"startMs":860,"endMs":1540},{"word":"carefully","charStart":19,"charEnd":28,"startMs":1540,"endMs":2020},{"word":"to","charStart":29,"charEnd":31,"startMs":2020,"endMs":2640},{"word":"everything","charStart":32,"charEnd":42,"startMs":2640,"endMs":3020},{"word":"I","charStart":43,"charEnd":44,"startMs":3020,"endMs":3300},{"word":"say","charStart":45,"charEnd":48,"startMs":3300,"endMs":3500}]}]},{"id":"daily-9-at-the-doctor-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/daily-9-at-the-doctor/p5.webp","sentences":[{"id":"daily-9-at-the-doctor-p5-s1","ord":0,"text":"The doctor checks my ears and my throat.","translation_ko":"의사 선생님이 내 귀와 목을 살펴봐요.","audioUrl":"/seed/daily-9-at-the-doctor/audio/p5-s1.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":200},{"word":"doctor","charStart":4,"charEnd":10,"startMs":200,"endMs":580},{"word":"checks","charStart":11,"charEnd":17,"startMs":580,"endMs":920},{"word":"my","charStart":18,"charEnd":20,"startMs":920,"endMs":1220},{"word":"ears","charStart":21,"charEnd":25,"startMs":1220,"endMs":1580},{"word":"and","charStart":26,"charEnd":29,"startMs":1580,"endMs":1940},{"word":"my","charStart":30,"charEnd":32,"startMs":1940,"endMs":2240},{"word":"throat","charStart":33,"charEnd":39,"startMs":2240,"endMs":2400}]},{"id":"daily-9-at-the-doctor-p5-s2","ord":1,"text":"\"Open wide and say ah,\" she says.","translation_ko":"\"입을 크게 벌리고 아 해봐,\" 선생님이 말해요.","audioUrl":"/seed/daily-9-at-the-doctor/audio/p5-s2.mp3","wordTimings":[{"word":"Open","charStart":1,"charEnd":5,"startMs":0,"endMs":400},{"word":"wide","charStart":6,"charEnd":10,"startMs":400,"endMs":860},{"word":"and","charStart":11,"charEnd":14,"startMs":860,"endMs":1120},{"word":"say","charStart":15,"charEnd":18,"startMs":1120,"endMs":1440},{"word":"ah","charStart":19,"charEnd":21,"startMs":1440,"endMs":1660},{"word":"she","charStart":24,"charEnd":27,"startMs":1960,"endMs":2140},{"word":"says","charStart":28,"charEnd":32,"startMs":2140,"endMs":2480}]},{"id":"daily-9-at-the-doctor-p5-s3","ord":2,"text":"She also checks my temperature with a thermometer.","translation_ko":"체온계로 내 체온도 재요.","audioUrl":"/seed/daily-9-at-the-doctor/audio/p5-s3.mp3","wordTimings":[{"word":"She","charStart":0,"charEnd":3,"startMs":0,"endMs":540},{"word":"also","charStart":4,"charEnd":8,"startMs":540,"endMs":940},{"word":"checks","charStart":9,"charEnd":15,"startMs":940,"endMs":1180},{"word":"my","charStart":16,"charEnd":18,"startMs":1180,"endMs":1460},{"word":"temperature","charStart":19,"charEnd":30,"startMs":1460,"endMs":1820},{"word":"with","charStart":31,"charEnd":35,"startMs":1820,"endMs":2280},{"word":"a","charStart":36,"charEnd":37,"startMs":2280,"endMs":2480},{"word":"thermometer","charStart":38,"charEnd":49,"startMs":2480,"endMs":2780