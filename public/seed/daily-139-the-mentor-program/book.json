"patience","charStart":22,"charEnd":30,"startMs":1160,"endMs":1640},{"word":"was","charStart":31,"charEnd":34,"startMs":1640,"endMs":1820},{"word":"the","charStart":35,"charEnd":38,"startMs":1820,"endMs":2040},{"word":"most","charStart":39,"charEnd":43,"startMs":2040,"endMs":2280},{"word":"important","charStart":44,"charEnd":53,"startMs":2280,"endMs":2760},{"word":"skill","charStart":54,"charEnd":59,"startMs":2760,"endMs":3140}]},{"id":"daily-139-the-mentor-program-p8-s3","ord":2,"text":"Ms. Park watched them and smiled proudly.","translation_ko":"박 선생님은 두 사람을 바라보며 흐뭇하게 미소 지으셨다.","audioUrl":"/seed/daily-139-the-mentor-program/audio/p8-s3.mp3","wordTimings":[{"word":"Ms","charStart":0,"charEnd":2,"startMs":0,"endMs":440},{"word":"Park","charStart":4,"charEnd":8,"startMs":660,"endMs":720},{"word":"watched","charStart":9,"charEnd":16,"startMs":720,"endMs":1060},{"word":"them","charStart":17,"charEnd":21,"startMs":1060,"endMs":1360},{"word":"and","charStart":22,"charEnd":25,"startMs":1360,"endMs":1960},{"word":"smiled","charStart":26,"charEnd":32,"startMs":1960,"endMs":2320},{"word":"proudly","charStart":33,"charEnd":40,"startMs":2320,"endMs":2780}]}]},{"id":"daily-139-the-mentor-program-p9","pageNo":9,"spread":"p9","imageUrl":"/seed/daily-139-the-mentor-program/p9.webp","sentences":[{"id":"daily-139-the-mentor-program-p9-s1","ord":0,"text":"The next week, Soo ran up to Jun smiling.","translation_ko":"다음 주에, Soo가 웃으며 준에게 달려왔다.","audioUrl":"/seed/daily-139-the-mentor-program/audio/p9-s1.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":160},{"word":"next","charStart":4,"charEnd":8,"startMs":160,"endMs":440},{"word":"week","charStart":9,"charEnd":13,"startMs":440,"endMs":760},{"word":"Soo","charStart":15,"charEnd":18,"startMs":1360,"endMs":1360},{"word":"ran","charStart":19,"charEnd":22,"startMs":1360,"endMs":1600},{"word":"up","charStart":23,"charEnd":25,"startMs":1600,"endMs":1780},{"word":"to","charStart":26,"charEnd":28,"startMs":1780,"endMs":2100},{"word":"Jun","charStart":29,"charEnd":32,"startMs":2100,"endMs":2200},{"word":"smiling","charStart":33,"charEnd":40,"startMs":2760,"endMs":2760}]},{"id":"daily-139-the-mentor-program-p9-s2","ord":1,"text":"\"I read a whole page by myself last night!\" Soo said.","translation_ko":"\"저 어젯밤에 혼자서 한 페이지를 다 읽었어요!\" Soo가 말했다.","audioUrl":"/seed/daily-139-the-mentor-program/audio/p9-s2.mp3","wordTimings":[{"word":"I","charStart":1,"charEnd":2,"startMs":0,"endMs":260},{"word":"read","charStart":3,"charEnd":7,"startMs":260,"endMs":440},{"word":"a","charStart":8,"charEnd":9,"startMs":440,"endMs":640},{"word":"whole","charStart":10,"charEnd":15,"startMs":640,"endMs":1000},{"word":"page","charStart":16,"charEnd":20,"startMs":1000,"endMs":1320},{"word":"by","charStart":21,"charEnd":23,"startMs":1320,"endMs":1540},{"word":"myself","charStart":24,"charEnd":30,"startMs":1540,"endMs":2080},{"word":"last","charStart":31,"charEnd":35,"startMs":2080,"endMs":2400},{"word":"night","charStart":36,"charEnd":41,"startMs":2400,"endMs":3440},{"word":"Soo","charStart":44,"charEnd":47,"startMs":3440,"endMs":3440},{"word":"said","charStart":48,"charEnd":52,"startMs":3440,"endMs":3720}]},{"id":"daily-139-the-mentor-program-p9-s3","ord":2,"text":"Jun felt a warm feeling inside.","translation_ko":"준은 가슴 속에서 따뜻한 감정이 올라오는 걸 느꼈다.","audioUrl":"/seed/daily-139-the-mentor-program/audio/p9-s3.mp3","wordTimings":[{"word":"Jun","charStart":0,"charEnd":3,"startMs":0,"endMs":540},{"word":"felt","charStart":4,"charEnd":8,"startMs":540,"endMs":1000},{"word":"a","charStart":9,"charEnd":10,"startMs":1000,"endMs":1320},{"word":"warm","charStart":11,"charEnd":15,"startMs":1320,"endMs":1640},{"word":"feeling","charStart":16,"charEnd":23,"startMs":1640,"endMs":2040},{"word":"inside","charStart":24,"charEnd":30,"startMs":2040,"endMs":2520}]}]},{"id":"daily-139-the-mentor-program-p10","pageNo":10,"spread":"p10","imageUrl":"/seed/daily-139-the-mentor-program/p10.webp","sentences":[{"id":"daily-139-the-mentor-program-p10-s1","ord":0,"text":"Ms. Park asked everyone to write a reflection.","translation_ko":"박 선생님은 모두에게 소감문을 써 보라고 하셨다.","audioUrl":"/seed/daily-139-the-mentor-program/audio/p10-s1.mp3","wordTimings":[{"word":"Ms","charStart":0,"charEnd":2,"startMs":0,"endMs":360},{"word":"Park","charStart":4,"charEnd":8,"startMs":600,"endMs":700},{"word":"asked","charStart":9,"charEnd":14,"startMs":700,"endMs":1000},{"word":"everyone","charStart":15,"charEnd":23,"startMs":1000,"endMs":1480},{"word":"to","charStart":24,"charEnd":26,"startMs":1480,"endMs":1760},{"word":"write","charStart":27,"charEnd":32,"startMs":1760,"endMs":1920},{"word":"a","charStart":33,"charEnd":34,"startMs":1920,"endMs":2120},{"word":"reflection","charStart":35,"charEnd":45,"startMs":2120,"endMs":2440}]},{"id":"daily-139-the-mentor-program-p10-s2","ord":1,"text":"Jun wrote, \"I used to think teaching meant knowing all the answers.\"","translation_ko":"준은 이렇게 썼다. \"저는 가르치는 것이 모든 답을 아는 것이라 생각했어요.\"","audioUrl":"/seed/daily-139-the-mentor-program/audio/p10-s2.mp3","wordTimings":[{"word":"Jun","charStart":0,"charEnd":3,"startMs":0,"endMs":400},{"word":"wrote","charStart":4,"charEnd":9,"startMs":400,"endMs":720},{"word":"I","charStart":12,"charEnd":13,"startMs":1160,"endMs":1320},{"word":"used","charStart":14,"charEnd":18,"startMs":1320,"endMs":1560},{"word":"to","charStart":19,"charEnd":21,"startMs":1560,"endMs":1860},{"word":"think","charStart":22,"charEnd":27,"startMs":1860,"endMs":1920},{"word":"teaching","charStart":28,"charEnd":36,"startMs":1920,"endMs":2340},{"word":"meant","charStart":37,"charEnd":42,"startMs":2340,"endMs":2640},{"word":"knowing","charStart":43,"charEnd":50,"startMs":2640,"endMs":2980},{"word":"all","charStart":51,"charEnd":54,"startMs":2980,"endMs":3320},{"word":"the","charStart":55,"charEnd":58,"startMs":3320,"endMs":3500},{"word":"answers","charStart":59,"charEnd":66,"startMs":3500,"endMs":3780}]},{"id":"daily-139-the-mentor-program-p10-s3","ord":2,"text":"\"But now I know it means helping someone believe in themselves.\"","translation_ko":"\"하지만 이제는 스스로를 믿도록 도와주는 것임을 알았어요.\"","audioUrl":"/seed/daily-139-the-mentor-program/audio/p10-s3.mp3","wordTimings":[{"word":"But","charStart":1,"charEnd":4,"startMs":0,"endMs":180},{"word":"now","charStart":5,"charEnd":8,"startMs":180,"endMs":560},{"word":"I","charStart":9,"charEnd":10,"startMs":560,"endMs":700},{"word":"know","charStart":11,"charEnd":15,"startMs":700,"endMs":920},{"word":"it","charStart":16,"charEnd":18,"startMs":920,"endMs":1160},{"word":"means","charStart":19,"charEnd":24,"startMs":1160,"endMs":1420},{"word":"helping","charStart":25,"charEnd":32,"startMs":1420,"endMs":1760},{"word":"someone","charStart":33,"charEnd":40,"startMs":1760,"endMs":2160},{"word":"believe","charStart":41,"charEnd":48,"startMs":2160,"endMs":2520},{"word":"in","charStart":49,"charEnd":51,"startMs":2520,"endMs":2680},{"word":"themselves","charStart":52,"charEnd":62,"startMs":2680,"endMs":3300}]}]},{"id":"daily-139-the-mentor-program-p11","pageNo":11,"spread":"p11","imageUrl":"/seed/daily-139-the-mentor-program/p11.webp","sentences":[{"id":"daily-139-the-mentor-program-p11-s1","ord":0,"text":"At the end of the program, the school held a celebration.","translation_ko":"프로그램이 끝날 무렵, 학교에서 축하 행사를 열었다.","audioUrl":"/seed/daily-139-the-mentor-program/audio/p11-s1.mp3","wordTimings":[{"word":"At","charStart":0,"charEnd":2,"startMs":0,"endMs":180},{"word":"the","charStart":3,"charEnd":6,"startMs":180,"endMs":580},{"word":"end","charStart":7,"charEnd":10,"startMs":580,"endMs":640},{"word":"of","charStart":11,"charEnd":13,"startMs":640,"endMs":880},{"word":"the","charStart":14,"charEnd":17,"startMs":880,"endMs":980},{"word":"program","charStart":18,"charEnd":25,"startMs":980,"endMs":1400},{"word":"the","charStart":27,"charEnd":30,"startMs":1780,"endMs":1920},{"word":"school","charStart":31,"charEnd":37,"startMs":1920,"endMs":2140},{"word":"held","charStart":38,"charEnd":42,"startMs":2140,"endMs":2460},{"word":"a","charStart":43,"charEnd":44,"startMs":2460,"endMs":2700},{"word":"celebration","charStart":45,"charEnd":56,"startMs":2700,"endMs":3060}]},{"id":"daily-139-the-mentor-program-p11-s2","ord":1,"text":"The second graders made thank-you cards for their mentors.","translation_ko":"2학년 학생들이 멘토들에게 감사 카드를 만들어 주었다.","audioUrl":"/seed/daily-139-the-mentor-program/audio/p11-s2.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":30,"endMs":296},{"word":"second","charStart":4,"charEnd":10,"startMs":296,"endMs":759},{"word":"graders","charStart":11,"charEnd":18,"startMs":759,"endMs":1222},{"word":"made","charStart":19,"charEnd":23,"startMs":1222,"endMs":1488},{"word":"thank-you","charStart":24,"charEnd":33,"startMs":1488,"endMs":1951},{"word":"cards","charStart":34,"charEnd":39,"startMs":1951,"endMs":2217},{"word":"for","charStart":40,"charEnd":43,"startMs":2217,"endMs":2483},{"word":"their","charStart":44,"charEnd":49,"startMs":2483,"endMs":2750},{"word":"mentors","charStart":50,"charEnd":57,"startMs":2750,"endMs":3390}]},{"id":"daily-139-the-mentor-program-p11-s3","ord":2,"text":"Soo's card read, \"You helped me find my courage. Thank you.\"","translation_ko":"Soo의 카드에는 이렇게 쓰여 있었다. \"용기를 찾게 해 줘서 고마워요.\"","audioUrl":"/seed/daily-139-the-mentor-program/audio/p11-s3.mp3","wordTimings":[{"word":"Soo's","charStart":0,"charEnd":5,"startMs":0,"endMs":920},{"word":"card","charStart":6,"charEnd":10,"startMs":920,"endMs":920},{"word":"read","charStart":11,"charEnd":15,"startMs":920,"endMs":1320},{"word":"You","charStart":18,"charEnd":21,"startMs":1840,"endMs":1900},{"word":"helped","charStart":22,"charEnd":28,"startMs":1900,"endMs":2200},{"word":"me","charStart":29,"charEnd":31,"startMs":2200,"endMs":2680},{"word":"find","charStart":32,"charEnd":36,"startMs":2680,"endMs":2720},{"word":"my","charStart":37,"charEnd":39,"startMs":2720,"endMs":3100},{"word":"courage","charStart":40,"charEnd":47,"startMs":3100,"endMs":3400},{"word":"Thank","charStart":49,"charEnd":54,"startMs":3960,"endMs":4120},{"word":"you","charStart":55,"charEnd":58,"startMs":4120,"endMs":4340}]}]},{"id":"daily-139-the-mentor-program-p12","pageNo":12,"spread":"p12","imageUrl":"/seed/daily-139-the-mentor-program/p12.webp","sentences":[{"id":"daily-139-the-mentor-program-p12-s1","ord":0,"text":"Jun read the card and smiled.","translation_ko":"준은 카드를 읽으며 미소 지었다.","audioUrl":"/seed/daily-139-the-mentor-program/audio/p12-s1.mp3","wordTimings":[{"word":"Jun","charStart":0,"charEnd":3,"startMs":0,"endMs":480},{"word":"read","charStart":4,"charEnd":8,"startMs":480,"endMs":740},{"word":"the","charStart":9,"charEnd":12,"startMs":740,"endMs":1260},{"word":"card","charStart":13,"charEnd":17,"startMs":1260,"endMs":1260},{"word":"and","charStart":18,"charEnd":21,"startMs":1260,"endMs":1780},{"word":"smiled","charStart":22,"charEnd":28,"startMs":1780,"endMs":2100}]},{"id":"daily-139-the-mentor-program-p12-s2","ord":1,"text":"He thought, \"I came to teach, but Soo taught me something too.\"","translation_ko":"그는 생각했다. '가르치러 왔는데, Soo도 나에게 무언가를 가르쳐 줬네.'","audioUrl":"/seed/daily-139-the-mentor-program/audio/p12-s2.mp3","wordTimings":[{"word":"He","charStart":0,"charEnd":2,"startMs":0,"endMs":260},{"word":"thought","charStart":3,"charEnd":10,"startMs":260,"endMs":540},{"word":"I","charStart":13,"charEnd":14,"startMs":660,"endMs":1300},{"word":"came","charStart":15,"charEnd":19,"startMs":1300,"endMs":1540},{"word":"to","charStart":20,"charEnd":22,"startMs":1540,"endMs":1740},{"word":"teach","charStart":23,"charEnd":28,"startMs":1740,"endMs":2020},{"word":"but","charStart":30,"charEnd":33,"startMs":2500,"endMs":2660},{"word":"Soo","charStart":34,"charEnd":37,"startMs":2660,"endMs":2860},{"word":"taught","charStart":38,"charEnd":44,"startMs":2860,"endMs":3100},{"word":"me","charStart":45,"charEnd":47,"startMs":3100,"endMs":3320},{"word":"something","charStart":48,"charEnd":57,"startMs":3320,"endMs":3560},{"word":"too","charStart":58,"charEnd":61,"startMs":3860,"endMs":3860}]},{"id":"daily-139-the-mentor-program-p12-s3","ord":2,"text":"Helping others had made him grow.","translation_ko":"다른 사람을 돕는 것이 그를 성장시켜 주었다.","audioUrl":"/seed/daily-139-the-mentor-program/audio/p12-s3.mp3","wordTimings":[{"word":"Helping","charStart":0,"charEnd":7,"startMs":0,"endMs":480},{"word":"others","charStart":8,"charEnd":14,"startMs":480,"endMs":920},{"word":"had","charStart":15,"charEnd":18,"startMs":920,"endMs":1420},{"word":"made","charStart":19,"charEnd":23,"startMs":1420,"endMs":1600},{"word":"him","charStart":24,"charEnd":27,"startMs":1600,"endMs":1800},{"word":"grow","charStart":28,"charEnd":32,"startMs":1800,"endMs":2140}]}]}],"quiz":[{"question_ko":"박 선생님이 준과 미나를 멘토로 뽑은 이유는 무엇인가요?","type":"mc","options":["인내심이 있고 친절하기 때문에","성적이 가장 높기 때문에","이미 가르친 경험이 있기 때문에","목소리가 크기 때문에"],"answerIndex":0,"explain_ko":"선생님은 '인내심이 있고 친절하기 때문에 너희를 뽑았다'고 말씀하셨습니다.","id":"daily-139-the-mentor-program-q1","ord":0},{"question_ko":"미나가 멘티를 가르치면서 처음에 느낀 감정은 무엇이었나요?","type":"mc","options":["매우 자랑스러웠다","무서웠다","너무 신이 났다","조금 짜증이 났다"],"answerIndex":3,"explain_ko":"미나는 멘티가 같은 질문을 반복하자 조금 짜증이 났다고 솔직하게 말했습니다.","id":"daily-139-the-mentor-program-q2","ord":1},{"question_ko":"준이 미나에게 준 조언은 무엇이었나요?","type":"mc","options":["다음엔 다른 방식으로 설명해 보라고 했다","선생님께 부탁하라고 했다","그냥 포기하라고 했다","더 크게 말하라고 했다"],"answerIndex":0,"explain_ko":"준은 미나에게 '다음엔 다른 방식으로 설명해 보는 건 어때?'라고 조언했습니다.","id":"daily-139-the-mentor-program-q3","ord":2},{"question_ko":"Soo가 준에게 준 카드에는 어떤 내용이 담겨 있었나요?","type":"mc","options":["같이 놀아 줘서 고마워요","용기를 찾게 해 줘서 고마워요","맛있는 것을 사 줘서 고마워요","수학을 가르쳐 줘서 고마워요"],"answerIndex":1,"explain_ko":"Soo의 카드에는 '용기를 찾게 해 줘서 고마워요'라고 쓰여 있었습니다.","id":"daily-139-the-mentor-program-q4","ord":3},{"question_ko":"준은 소감문에서 가르친다는 것이 무엇이라고 깨달았나요?","type":"mc","options":["빨리 설명하는 것","모든 정답을 알려 주는 것","어려운 문제를 대신 풀어 주는 것","누군가가 스스로를 믿도록 도와주는 것"],"answerIndex":3,"explain_ko":"준은 소감문에 '스스로를 믿도록 도와주는 것'이 가르침이라고 썼습니다.","id":"daily-139-the-mentor-program-q5","ord":4}]}