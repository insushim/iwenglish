geNo":7,"spread":"p7","imageUrl":"/seed/daily-139-the-mentor-program/p7.webp","sentences":[{"id":"daily-139-the-mentor-program-p7-s1","ord":0,"text":"Mina tried Jun's advice, and it worked.","translation_ko":"미나가 준의 조언을 따라 해 봤더니, 효과가 있었다.","audioUrl":"/seed/daily-139-the-mentor-program/audio/p7-s1.mp3","wordTimings":[{"word":"Mina","charStart":0,"charEnd":4,"startMs":0,"endMs":400},{"word":"tried","charStart":5,"charEnd":10,"startMs":400,"endMs":860},{"word":"Jun's","charStart":11,"charEnd":16,"startMs":860,"endMs":1300},{"word":"advice","charStart":17,"charEnd":23,"startMs":1300,"endMs":1760},{"word":"and","charStart":25,"charEnd":28,"startMs":2080,"endMs":2220},{"word":"it","charStart":29,"charEnd":31,"startMs":2220,"endMs":2400},{"word":"worked","charStart":32,"charEnd":38,"startMs":2400,"endMs":2740}]},{"id":"daily-139-the-mentor-program-p7-s2","ord":1,"text":"Her student finally understood and clapped with joy.","translation_ko":"멘티가 마침내 이해하고 기뻐서 손뼉을 쳤다.","audioUrl":"/seed/daily-139-the-mentor-program/audio/p7-s2.mp3","wordTimings":[{"word":"Her","charStart":0,"charEnd":3,"startMs":0,"endMs":240},{"word":"student","charStart":4,"charEnd":11,"startMs":240,"endMs":620},{"word":"finally","charStart":12,"charEnd":19,"startMs":620,"endMs":1140},{"word":"understood","charStart":20,"charEnd":30,"startMs":1140,"endMs":1560},{"word":"and","charStart":31,"charEnd":34,"startMs":1560,"endMs":2020},{"word":"clapped","charStart":35,"charEnd":42,"startMs":2020,"endMs":2280},{"word":"with","charStart":43,"charEnd":47,"startMs":2280,"endMs":2760},{"word":"joy","charStart":48,"charEnd":51,"startMs":2760,"endMs":2800}]},{"id":"daily-139-the-mentor-program-p7-s3","ord":2,"text":"\"Thank you, Jun. Your tip really helped,\" Mina said.","translation_ko":"\"고마워, 준. 네 조언이 정말 도움이 됐어,\" 미나가 말했다.","audioUrl":"/seed/daily-139-the-mentor-program/audio/p7-s3.mp3","wordTimings":[{"word":"Thank","charStart":1,"charEnd":6,"startMs":0,"endMs":720},{"word":"you","charStart":7,"charEnd":10,"startM