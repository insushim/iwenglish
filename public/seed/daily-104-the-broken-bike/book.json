 bike onto its handlebars.","translation_ko":"준은 아빠와 함께 자전거를 뒤집어 핸들 위에 세웠어요.","audioUrl":"/seed/daily-104-the-broken-bike/audio/p6-s2.mp3","wordTimings":[{"word":"Jun","charStart":0,"charEnd":3,"startMs":0,"endMs":440},{"word":"helped","charStart":4,"charEnd":10,"startMs":440,"endMs":860},{"word":"Dad","charStart":11,"charEnd":14,"startMs":860,"endMs":1260},{"word":"flip","charStart":15,"charEnd":19,"startMs":1260,"endMs":1580},{"word":"the","charStart":20,"charEnd":23,"startMs":1580,"endMs":1800},{"word":"bike","charStart":24,"charEnd":28,"startMs":1800,"endMs":1980},{"word":"onto","charStart":29,"charEnd":33,"startMs":1980,"endMs":2300},{"word":"its","charStart":34,"charEnd":37,"startMs":2300,"endMs":2580},{"word":"handlebars","charStart":38,"charEnd":48,"startMs":2580,"endMs":3080}]}]},{"id":"daily-104-the-broken-bike-p7","pageNo":7,"spread":"p7","imageUrl":"/seed/daily-104-the-broken-bike/p7.webp","sentences":[{"id":"daily-104-the-broken-bike-p7-s1","ord":0,"text":"Dad showed Jun how to loop the chain back onto the gear.","translation_ko":"아빠는 준에게 체인을 기어에 다시 끼우는 방법을 보여 줬어요.","audioUrl":"/seed/daily-104-the-broken-bike/audio/p7-s1.mp3","wordTimings":[{"word":"Dad","charStart":0,"charEnd":3,"startMs":0,"endMs":440},{"word":"showed","charStart":4,"charEnd":10,"startMs":440,"endMs":780},{"word":"Jun","charStart":11,"charEnd":14,"startMs":780,"endMs":1080},{"word":"how","charStart":15,"charEnd":18,"startMs":1080,"endMs":1300},{"word":"to","charStart":19,"charEnd":21,"startMs":1300,"endMs":1620},{"word":"loop","charStart":22,"charEnd":26,"startMs":1620,"endMs":1680},{"word":"the","charStart":27,"charEnd":30,"startMs":1680,"endMs":1940},{"word":"chain","charStart":31,"charEnd":36,"startMs":1940,"endMs":2120},{"word":"back","charStart":37,"charEnd":41,"startMs":2120,"endMs":2400},{"word":"onto","charStart":42,"charEnd":46,"startMs":2400,"endMs":2620},{"word":"the","charStart":47,"charEnd":50,"startMs":2620,"endMs":2780},{"word":"gear","charStart":51,"charEnd":55,"startM