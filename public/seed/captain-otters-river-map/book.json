달은 미소를 지으며 개구리의 말을 적었어요.","audioUrl":"/seed/captain-otters-river-map/audio/p5-s1.mp3","wordTimings":[{"word":"Otter","charStart":0,"charEnd":5,"startMs":0,"endMs":380},{"word":"wrote","charStart":6,"charEnd":11,"startMs":380,"endMs":780},{"word":"her","charStart":12,"charEnd":15,"startMs":780,"endMs":1100},{"word":"note","charStart":16,"charEnd":20,"startMs":1100,"endMs":1280},{"word":"down","charStart":21,"charEnd":25,"startMs":1280,"endMs":1660},{"word":"with","charStart":26,"charEnd":30,"startMs":1660,"endMs":1920},{"word":"a","charStart":31,"charEnd":32,"startMs":1920,"endMs":2180},{"word":"smile","charStart":33,"charEnd":38,"startMs":2180,"endMs":2460}]},{"id":"captain-otters-river-map-p5-s2","ord":1,"text":"Then they floated to a small green island.","translation_ko":"그러고 나서 둘은 작은 초록빛 섬으로 떠내려갔어요.","audioUrl":"/seed/captain-otters-river-map/audio/p5-s2.mp3","wordTimings":[{"word":"Then","charStart":0,"charEnd":4,"startMs":0,"endMs":460},{"word":"they","charStart":5,"charEnd":9,"startMs":600,"endMs":980},{"word":"floated","charStart":10,"charEnd":17,"startMs":980,"endMs":1260},{"word":"to","charStart":18,"charEnd":20,"startMs":1260,"endMs":1560},{"word":"a","charStart":21,"charEnd":22,"startMs":1560,"endMs":1820},{"word":"small","charStart":23,"charEnd":28,"startMs":1820,"endMs":2080},{"word":"green","charStart":29,"charEnd":34,"startMs":2080,"endMs":2520},{"word":"island","charStart":35,"charEnd":41,"startMs":2520,"endMs":2760}]}]},{"id":"captain-otters-river-map-p6","pageNo":6,"spread":"p6","imageUrl":"/seed/captain-otters-river-map/p6.webp","sentences":[{"id":"captain-otters-river-map-p6-s1","ord":0,"text":"A turtle lived there, and he waved hello.","translation_ko":"그곳에는 거북이가 살았고, 그가 손을 흔들며 인사했어요.","audioUrl":"/seed/captain-otters-river-map/audio/p6-s1.mp3","wordTimings":[{"word":"A","charStart":0,"charEnd":1,"startMs":0,"endMs":600},{"word":"turtle","charStart":2,"charEnd":8,"startMs":600,"endMs":600},{"word":"lived","charStart":9,"charEnd":14,"startMs":600,"endMs":1640},{"word":"there","charStart":15,"charEnd":20,"startMs":1640,"endMs":2000},{"word":"and","charStart":22,"charEnd":25,"startMs":2360,"endMs":2780},{"word":"he","charStart":26,"charEnd":28,"startMs":2780,"endMs":3080},{"word":"waved","charStart":29,"charEnd":34,"startMs":3080,"endMs":3140},{"word":"hello","charStart":35,"charEnd":40,"startMs":3140,"endMs":3500}]},{"id":"captain-otters-river-map-p6-s2","ord":1,"text":"\"My island has sweet berries,\" he said.","translation_ko":"\"우리 섬에는 달콤한 열매가 있어,\" 거북이가 말했어요.","audioUrl":"/seed/captain-otters-river-map/audio/p6-s2.mp3","wordTimings":[{"word":"My","charStart":1,"charEnd":3,"startMs":0,"endMs":380},{"word":"island","charStart":4,"charEnd":10,"startMs":380,"endMs":820},{"word":"has","charStart":11,"charEnd":14,"startMs":820,"endMs":1160},{"word":"sweet","charStart":15,"charEnd":20,"startMs":1160,"endMs":1540},{"word":"berries","charStart":21,"charEnd":28,"startMs":1540,"endMs":2020},{"word":"he","charStart":31,"charEnd":33,"startMs":2020,"endMs":2380},{"word":"said","charStart":34,"charEnd":38,"startMs":2380,"endMs":2700}]}]},{"id":"captain-otters-river-map-p7","pageNo":7,"spread":"p7","imageUrl":"/seed/captain-otters-river-map/p7.webp","sentences":[{"id":"captain-otters-river-map-p7-s1","ord":0,"text":"Otter added the island and the berries.","translation_ko":"수달은 섬과 열매를 지도에 그려 넣었어요.","audioUrl":"/seed/captain-otters-river-map/audio/p7-s1.mp3","wordTimings":[{"word":"Otter","charStart":0,"charEnd":5,"startMs":0,"endMs":400},{"word":"added","charStart":6,"charEnd":11,"startMs":400,"endMs":820},{"word":"the","charStart":12,"charEnd":15,"startMs":820,"endMs":1080},{"word":"island","charStart":16,"charEnd":22,"startMs":1080,"endMs":1380},{"word":"and","charStart":23,"charEnd":26,"startMs":1380,"endMs":1800},{"word":"the","charStart":27,"charEnd":30,"startMs":1800,"endMs":1960},{"word":"berries","charStart":31,"charEnd":38,"startMs":1960,"endMs":2440}]},{"id":"captain-otters-river-map-p7-s2","ord":1,"text":"The river turned, and a dark cave appeared.","translation_ko":"강이 굽이쳤고, 어두운 동굴이 나타났어요.","audioUrl":"/seed/captain-otters-river-map/audio/p7-s2.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":240},{"word":"river","charStart":4,"charEnd":9,"startMs":240,"endMs":460},{"word":"turned","charStart":10,"charEnd":16,"startMs":460,"endMs":900},{"word":"and","charStart":18,"charEnd":21,"startMs":1460,"endMs":1540},{"word":"a","charStart":22,"charEnd":23,"startMs":1540,"endMs":1740},{"word":"dark","charStart":24,"charEnd":28,"startMs":1740,"endMs":2040},{"word":"cave","charStart":29,"charEnd":33,"startMs":2040,"endMs":2320},{"word":"appeared","charStart":34,"charEnd":42,"startMs":2320,"endMs":2720}]}]},{"id":"captain-otters-river-map-p8","pageNo":8,"spread":"p8","imageUrl":"/seed/captain-otters-river-map/p8.webp","sentences":[{"id":"captain-otters-river-map-p8-s1","ord":0,"text":"A little bat peeked out of the dark cave.","translation_ko":"작은 박쥐 한 마리가 어두운 동굴 밖으로 빼꼼 내다보았어요.","audioUrl":"/seed/captain-otters-river-map/audio/p8-s1.mp3","wordTimings":[{"word":"A","charStart":0,"charEnd":1,"startMs":0,"endMs":200},{"word":"little","charStart":2,"charEnd":8,"startMs":200,"endMs":380},{"word":"bat","charStart":9,"charEnd":12,"startMs":380,"endMs":800},{"word":"peeked","charStart":13,"charEnd":19,"startMs":800,"endMs":1280},{"word":"out","charStart":20,"charEnd":23,"startMs":1280,"endMs":1380},{"word":"of","charStart":24,"charEnd":26,"startMs":1380,"endMs":1500},{"word":"the","charStart":27,"charEnd":30,"startMs":1500,"endMs":1680},{"word":"dark","charStart":31,"charEnd":35,"startMs":1680,"endMs":1880},{"word":"cave","charStart":36,"charEnd":40,"startMs":1880,"endMs":2220}]},{"id":"captain-otters-river-map-p8-s2","ord":1,"text":"\"The cave is cool and quiet,\" the bat said.","translation_ko":"\"동굴은 시원하고 조용해,\" 박쥐가 말했어요.","audioUrl":"/seed/captain-otters-river-map/audio/p8-s2.mp3","wordTimings":[{"word":"The","charStart":1,"charEnd":4,"startMs":0,"endMs":20