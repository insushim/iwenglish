},{"word":"pencil","charStart":19,"charEnd":25,"startMs":1300,"endMs":1480},{"word":"ready","charStart":26,"charEnd":31,"startMs":1480,"endMs":1820}]}]},{"id":"captain-otters-river-map-p3","pageNo":3,"spread":"p3","imageUrl":"/seed/captain-otters-river-map/p3.webp","sentences":[{"id":"captain-otters-river-map-p3-s1","ord":0,"text":"Soon he heard a loud roar ahead.","translation_ko":"곧 그는 앞에서 우렁찬 소리를 들었어요.","audioUrl":"/seed/captain-otters-river-map/audio/p3-s1.mp3","wordTimings":[{"word":"Soon","charStart":0,"charEnd":4,"startMs":0,"endMs":420},{"word":"he","charStart":5,"charEnd":7,"startMs":420,"endMs":700},{"word":"heard","charStart":8,"charEnd":13,"startMs":700,"endMs":980},{"word":"a","charStart":14,"charEnd":15,"startMs":980,"endMs":1220},{"word":"loud","charStart":16,"charEnd":20,"startMs":1220,"endMs":1540},{"word":"roar","charStart":21,"charEnd":25,"startMs":1540,"endMs":1820},{"word":"ahead","charStart":26,"charEnd":31,"startMs":1820,"endMs":2280}]},{"id":"captain-otters-river-map-p3-s2","ord":1,"text":"It was a tall waterfall, so he drew it.","translation_ko":"그건 높은 폭포였고, 그래서 그는 지도에 그렸어요.","audioUrl":"/seed/captain-otters-river-map/audio/p3-s2.mp3","wordTimings":[{"word":"It","charStart":0,"charEnd":2,"startMs":0,"endMs":160},{"word":"was","charStart":3,"charEnd":6,"startMs":160,"endMs":360},{"word":"a","charStart":7,"charEnd":8,"startMs":360,"endMs":760},{"word":"tall","charStart":9,"charEnd":13,"startMs":760,"endMs":900},{"word":"waterfall","charStart":14,"charEnd":23,"startMs":900,"endMs":1440},{"word":"so","charStart":25,"charEnd":27,"startMs":1820,"endMs":2160},{"word":"he","charStart":28,"charEnd":30,"startMs":2160,"endMs":2420},{"word":"drew","charStart":31,"charEnd":35,"startMs":2420,"endMs":2520},{"word":"it","charStart":36,"charEnd":38,"startMs":2520,"endMs":2800}]}]},{"id":"captain-otters-river-map-p4","pageNo":4,"spread":"p4","imageUrl":"/seed/captain-otters-river-map/p4.webp","sentences":[{"id":"captain-otters-river-map-p4-s1","ord":0,"text":