{"id":"the-fox-and-the-bridge","slug":"the-fox-and-the-bridge","title":"The Fox and the Bridge","title_ko":"여우와 다리","level":"A2","ageBand":"8-10","coverUrl":"/seed/the-fox-and-the-bridge/cover.webp","summary_ko":"강 건너 친구들을 만나려고 여우가 동물들과 힘을 모아 다리를 놓는 이야기.","wordCount":152,"pages":[{"id":"the-fox-and-the-bridge-p1","pageNo":1,"spread":"p1","imageUrl":"/seed/the-fox-and-the-bridge/p1.webp","sentences":[{"id":"the-fox-and-the-bridge-p1-s1","ord":0,"text":"A little fox lived by a wide river.","translation_ko":"작은 여우가 넓은 강가에 살았어요.","audioUrl":"/seed/the-fox-and-the-bridge/audio/p1-s1.mp3","wordTimings":[{"word":"A","charStart":0,"charEnd":1,"startMs":0,"endMs":200},{"word":"little","charStart":2,"charEnd":8,"startMs":200,"endMs":440},{"word":"fox","charStart":9,"charEnd":12,"startMs":440,"endMs":960},{"word":"lived","charStart":13,"charEnd":18,"startMs":960,"endMs":1500},{"word":"by","charStart":19,"charEnd":21,"startMs":1500,"endMs":1720},{"word":"a","charStart":22,"charEnd":23,"startMs":1720,"endMs":2300},{"word":"wide","charStart":24,"charEnd":28,"startMs":2300,"endMs":2300},{"word":"river","charStart":29,"charEnd":34,"startMs":2300,"endMs":2560}]},{"id":"the-fox-and-the-bridge-p1-s2","ord":1,"text":"His friends lived on the other side.","translation_ko":"여우의 친구들은 강 건너편에 살았어요.","audioUrl":"/seed/the-fox-and-the-bridge/audio/p1-s2.mp3","wordTimings":[{"word":"His","charStart":0,"charEnd":3,"startMs":0,"endMs":340},{"word":"friends","charStart":4,"charEnd":11,"startMs":340,"endMs":680},{"word":"lived","charStart":12,"charEnd":17,"startMs":680,"endMs":1020},{"word":"on","charStart":18,"charEnd":20,"startMs":1020,"endMs":1220},{"word":"the","charStart":21,"charEnd":24,"startMs":1220,"endMs":1380},{"word":"other","charStart":25,"charEnd":30,"startMs":1380,"endMs":1580},{"word":"side","charStart":31,"charEnd":35,"startMs":1580,"endMs":1840}]}]},{"id":"the-fox-and-the-bridge-p2","pageNo":2,"spread":"p2","imageUrl":"/seed/the-fox-and-the-bridge/p2.webp","sentences":[{"id":"the-fox-and-the-bridge-p2-s1","ord":0,"text":"The fox wanted to play with them.","translation_ko":"여우는 친구들과 놀고 싶었어요.","audioUrl":"/seed/the-fox-and-the-bridge/audio/p2-s1.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":300},{"word":"fox","charStart":4,"charEnd":7,"startMs":300,"endMs":620},{"word":"wanted","charStart":8,"charEnd":14,"startMs":620,"endMs":940},{"word":"to","charStart":15,"charEnd":17,"startMs":940,"endMs":1220},{"word":"play","charStart":18,"charEnd":22,"startMs":1220,"endMs":1360},{"word":"with","charStart":23,"charEnd":27,"startMs":1360,"endMs":1580},{"word":"them","charStart":28,"charEnd":32,"startMs":1580,"endMs":1760}]},{"id":"the-fox-and-the-bridge-p2-s2","ord":1,"text":"But the water was deep and fast.","translation_ko":"그런데 강물이 깊고 빠르게 흘렀어요.","audioUrl":"/seed/the-fox-and-the-bridge/audio/p2-s2.mp3","wordTimings":[{"word":"But","charStart":0,"charEnd":3,"startMs":0,"endMs":300},{"word":"the","charStart":4,"charEnd":7,"startMs":300,"endMs":580},{"word":"water","charStart":8,"charEnd":13,"startMs":580,"endMs":880},{"word":"was","charStart":14,"charEnd":17,"startMs":880,"endMs":1300},{"word":"deep","charStart":18,"charEnd":22,"startMs":1300,"endMs":1600},{"word":"and","charStart":23,"charEnd":26,"startMs":1600,"endMs":2120},{"word":"fast","charStart":27,"charEnd":31,"startMs":2120,"endMs":2500}]}]},{"id":"the-fox-and-the-bridge-p3","pageNo":3,"spread":"p3","imageUrl":"/seed/the-fox-and-the-bridge/p3.webp","sentences":[{"id":"the-fox-and-the-bridge-p3-s1","ord":0,"text":"He could not jump across the river.","translation_ko":"여우는 강을 뛰어 건널 수 없었어요.","audioUrl":"/seed/the-fox-and-the-bridge/audio/p3-s1.mp3","wordTimings":[{"word":"He","charStart":0,"charEnd":2,"startMs":0,"endMs":180},{"word":"could","charStart":3,"charEnd":8,"startMs":180,"endMs":380},{"word":"not","charStart":9,"charEnd":12,"startMs":380,"endMs":720},{"word":"jump","charStart":13,"charEnd":17,"startMs":720,"endMs":960},{"word":"across","charStart":18,"charEnd":24,"startMs":960,"endMs":1320},{"word":"the","charStart":25,"charEnd":28,"startMs":1320,"endMs":1600},{"word":"river","charStart":29,"charEnd":34,"startMs":1600,"endMs":1720}]},{"id":"the-fox-and-the-bridge-p3-s2","ord":1,"text":"\"What can I do?\" he asked sadly.","translation_ko":"\"어떻게 하지?\" 여우가 슬프게 말했어요.","audioUrl":"/seed/the-fox-and-the-bridge/audio/p3-s2.mp3","wordTimings":[{"word":"What","charStart":1,"charEnd":5,"startMs":0,"endMs":680},{"word":"can","charStart":6,"charEnd":9,"startMs":680,"endMs":920},{"word":"I","charStart":10,"charEnd":11,"startMs":920,"endMs":1160},{"word":"do","charStart":12,"charEnd":14,"startMs":1160,"endMs":1380},{"word":"he","charStart":17,"charEnd":19,"startMs":1940,"endMs":2080},{"word":"asked","charStart":20,"charEnd":25,"startMs":2080,"endMs":2400},{"word":"sadly","charStart":26,"charEnd":31,"startMs":2400,"endMs":2820}]}]},{"id":"the-fox-and-the-bridge-p4","pageNo":4,"spread":"p4","imageUrl":"/seed/the-fox-and-the-bridge/p4.webp","sentences":[{"id":"the-fox-and-the-bridge-p4-s1","ord":0,"text":"Then the fox saw a busy beaver.","translation_ko":"그때 여우는 부지런한 비버를 보았어요.","audioUrl":"/seed/the-fox-and-the-bridge/audio/p4-s1.mp3","wordTimings":[{"word":"Then","charStart":0,"charEnd":4,"startMs":0,"endMs":400},{"word":"the","charStart":5,"charEnd":8,"startMs":400,"endMs":660},{"word":"fox","charStart":9,"charEnd":12,"startMs":660,"endMs":1000},{"word":"saw","charStart":13,"charEnd":16,"startMs":1000,"endMs":1420},{"word":"a","charStart":17,"charEnd":18,"startMs":1420,"endMs":1740},{"word":"busy","charStart":19,"charEnd":23,"startMs":1740,"endMs":2000},{"word":"beaver","charStart":24,"charEnd":30,"startMs":2000,"endMs":2360}]},{"id":"the-fox-and-the-bridge-p4-s2","ord":1,"text":"\"Can you help me cross?\" he asked.","translation_ko":"\"강 건너게 도와줄래?\" 여우가 물었어요.","audioUrl":"/seed/the-fox-and-the-bridge/audio/p4-s2.mp3","wordTimings":[{"word":"Can","charStart":1,"charEnd":4,"startMs":0,"endMs":640},{"word":"you","charStart":5,"charEnd":8,"startMs":640,"endMs":860},{"word":"help","charStart":9,"charEnd":13,"startMs":860,"endMs":980},{"word":"me","charStart":14,"charEnd":16,"startMs":980,"endMs":1260},{"word":"cross","charStart":17,"charEnd":22,"startMs":1260,"endMs":1560},{"word":"he","charStart":25,"charEnd":27,"startMs":1940,"endMs":2120},{"word":"asked","charStart":28,"charEnd":33,"startMs":2120,"endMs":2460}]}]},{"id":"the-fox-and-the-bridge-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/the-fox-and-the-bridge/p5.webp","sentences":[{"id":"the-fox-and-the-bridge-p5-s1","ord":0,"text":"\"Yes,\" said the beaver with a smile.","translation_ko":"\"좋아.\" 비버가 웃으며 말했어요.","audioUrl":"/seed/the-fox-and-the-bridge/audio/p5-s1.mp3","wordTimings":[{"word":"Yes","charStart":1,"charEnd":4,"startMs":0,"endMs":540},{"word":"said","charStart":7,"charEnd":11,"startMs":860,"endMs":1340},{"word":"the","charStart":12,"charEnd":15,"startMs":1340,"endMs":1640},{"word":"beaver","charStart":16,"charEnd":22,"startMs":1640,"endMs":1840},{"word":"with","charStart":23,"charEnd":27,"startMs":1840,"endMs":2160},{"word":"a","charStart":28,"charEnd":29,"startMs":2160,"endMs":2420},{"word":"smile","charStart":30,"charEnd":35,"startMs":2420,"endMs":2680}]},{"id":"the-fox-and-the-bridge-p5-s2","ord":1,"text":"She cut a long log for them.","translation_ko":"비버는 긴 통나무 하나를 잘랐어요.","audioUrl":"/seed/the-fox-and-the-bridge/audio/p5-s2.mp3","wordTimings":[{"word":"She","charStart":0,"charEnd":3,"startMs":0,"endMs":300},{"word":"cut","charStart":4,"charEnd":7,"startMs":300,"endMs":580},{"word":"a","charStart":8,"charEnd":9,"startMs":580,"endMs":880},{"word":"long","charStart":10,"charEnd":14,"startMs":880,"endMs":1160},{"word":"log","charStart":15,"charEnd":18,"startMs":1160,"endMs":1420},{"word":"for","charStart":19,"charEnd":22,"startMs":1420,"endMs":1680},{"word":"them","charStart":23,"charEnd":27,"startMs":1680,"endMs":1840}]}]},{"id":"the-fox-and-the-bridge-p6","pageNo":6,"spread":"p6","imageUrl":"/seed/the-fox-and-the-bridge/p6.webp","sentences":[{"id":"the-fox-and-the-bridge-p6-s1","ord":0,"text":"The log was too heavy to lift.","translation_ko":"통나무는 너무 무거워서 들 수 없었어요.","audioUrl":"/seed/the-fox-and-the-bridge/audio/p6-s1.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":300},{"word":"log","charStart":4,"charEnd":7,"startMs":300,"endMs":640},{"word":"was","charStart":8,"charEnd":11,"startMs":640,"endMs":1080},{"word":"too","charStart":12,"charEnd":15,"startMs":1080,"endMs":1440},{"word":"heavy","charStart":16,"charEnd":21,"startMs":1440,"endMs":1660},{"word":"to","charStart":22,"charEnd":24,"startMs":1660,"endMs":2260},{"word":"lift","charStart":25,"charEnd":29,"startMs":2260,"endMs":2260}]},{"id":"the-fox-and-the-bridge-p6-s2","ord":1,"text":"So the fox called two strong birds.","translation_ko":"그래서 여우는 힘센 새 두 마리를 불렀어요.","audioUrl":"/seed/the-fox-and-the-bridge/audio/p6-s2.mp3","wordTimings":[{"word":"So","charStart":0,"charEnd":2,"startMs":0,"endMs":580},{"word":"the","charStart":3,"charEnd":6,"startMs":580,"endMs":940},{"word":"fox","charStart":7,"charEnd":10,"startMs":940,"endMs":1300},{"word":"called","charStart":11,"charEnd":17,"startMs":1300,"endMs":1740},{"word":"two","charStart":18,"charEnd":21,"startMs":1740,"endMs":2320},{"word":"strong","charStart":22,"charEnd":28,"startMs":2320,"endMs":2760},{"word":"birds","charStart":29,"charEnd":34,"startMs":2760,"endMs":3080}]}]},{"id":"the-fox-and-the-bridge-p7","pageNo":7,"spread":"p7","imageUrl":"/seed/the-fox-and-the-bridge/p7.webp","sentences":[{"id":"the-fox-and-the-bridge-p7-s1","ord":0,"text":"The birds pulled the log up high.","translation_ko":"새들이 통나무를 높이 끌어 올렸어요.","audioUrl":"/seed/the-fox-and-the-bridge/audio/p7-s1.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":320},{"word":"birds","charStart":4,"charEnd":9,"startMs":320,"endMs":580},{"word":"pulled","charStart":10,"charEnd":16,"startMs":580,"endMs":960},{"word":"the","charStart":17,"charEnd":20,"startMs":960,"endMs":1420},{"word":"log","charStart":21,"charEnd":24,"startMs":1420,"endMs":1480},{"word":"up","charStart":25,"charEnd":27,"startMs":1480,"endMs":1840},{"word":"high","charStart":28,"charEnd":32,"startMs":1840,"endMs":2140}]},{"id":"the-fox-and-the-bridge-p7-s2","ord":1,"text":"Three little mice pushed from below.","translation_ko":"작은 생쥐 세 마리가 아래에서 밀었어요.","audioUrl":"/seed/the-fox-and-the-bridge/audio/p7-s2.mp3","wordTimings":[{"word":"Three","charStart":0,"charEnd":5,"startMs":0,"endMs":380},{"word":"little","charStart":6,"charEnd":12,"startMs":380,"endMs":680},{"word":"mice","charStart":13,"charEnd":17,"startMs":680,"endMs":960},{"word":"pushed","charStart":18,"charEnd":24,"startMs":960,"endMs":1300},{"word":"from","charStart":25,"charEnd":29,"startMs":1300,"endMs":1580},{"word":"below","charStart":30,"charEnd":35,"startMs":1580,"endMs":1840}]}]},{"id":"the-fox-and-the-bridge-p8","pageNo":8,"spread":"p8","imageUrl":"/seed/the-fox-and-the-bridge/p8.webp","sentences":[{"id":"the-fox-and-the-bridge-p8-s1","ord":0,"text":"When the log fell, it made a bridge.","translation_ko":"통나무가 내려앉자 다리가 되었어요.","audioUrl":"/seed/the-fox-and-the-bridge/audio/p8-s1.mp3","wordTimings":[{"word":"When","charStart":0,"charEnd":4,"startMs":0,"endMs":280},{"word":"the","charStart":5,"charEnd":8,"startMs":280,"endMs":500},{"word":"log","charStart":9,"charEnd":12,"startMs":500,"endMs":720},{"word":"fell","charStart":13,"charEnd":17,"startMs":720,"endMs":1140},{"word":"it","charStart":19,"charEnd":21,"startMs":1440,"endMs":1600},{"word":"made","charStart":22,"charEnd":26,"startMs":1600,"endMs":1760},{"word":"a","charStart":27,"charEnd":28,"startMs":1760,"endMs":2220},{"word":"bridge","charStart":29,"charEnd":35,"startMs":2220,"endMs":2240}]},{"id":"the-fox-and-the-bridge-p8-s2","ord":1,"text":"Everyone cheered because they did it together.","translation_ko":"모두 함께 해냈기에 다 같이 환호했어요.","audioUrl":"/seed/the-fox-and-the-bridge/audio/p8-s2.mp3","wordTimings":[{"word":"Everyone","charStart":0,"cha