-photo/audio/p9-s1.mp3","wordTimings":[{"word":"Jun","charStart":0,"charEnd":3,"startMs":0,"endMs":500},{"word":"stands","charStart":4,"charEnd":10,"startMs":500,"endMs":940},{"word":"next","charStart":11,"charEnd":15,"startMs":940,"endMs":1300},{"word":"to","charStart":16,"charEnd":18,"startMs":1300,"endMs":1520},{"word":"Mina","charStart":19,"charEnd":23,"startMs":1520,"endMs":1700},{"word":"and","charStart":24,"charEnd":27,"startMs":1700,"endMs":2180},{"word":"smiles","charStart":28,"charEnd":34,"startMs":2180,"endMs":2560},{"word":"his","charStart":35,"charEnd":38,"startMs":2560,"endMs":2880},{"word":"biggest","charStart":39,"charEnd":46,"startMs":2880,"endMs":3280},{"word":"smile","charStart":47,"charEnd":52,"startMs":3280,"endMs":3720}]},{"id":"daily-117-the-class-photo-p9-s2","ord":1,"text":"He is so happy because his friend helped him.","translation_ko":"친구가 도와준 덕분에 정말 행복해요.","audioUrl":"/seed/daily-117-the-class-photo/audio/p9-s2.mp3","wordTimings":[{"word":"He","charStart":0,"charEnd":2,"startMs":0,"endMs":260},{"word":"is","charStart":3,"charEnd":5,"startMs":260,"endMs":500},{"word":"so","charStart":6,"charEnd":8,"startMs":500,"endMs":880},{"word":"happy","charStart":9,"charEnd":14,"startMs":880,"endMs":1200},{"word":"because","charStart":15,"charEnd":22,"startMs":1200,"endMs":1740},{"word":"his","charStart":23,"charEnd":26,"startMs":1740,"endMs":2020},{"word":"friend","charStart":27,"charEnd":33,"startMs":2020,"endMs":2280},{"word":"helped","charStart":34,"charEnd":40,"startMs":2280,"endMs":2620},{"word":"him","charStart":41,"charEnd":44,"startMs":2620,"endMs":2840}]}]},{"id":"daily-117-the-class-photo-p10","pageNo":10,"spread":"p10","imageUrl":"/seed/daily-117-the-class-photo/p10.webp","sentences":[{"id":"daily-117-the-class-photo-p10-s1","ord":0,"text":"When the photo comes out, Jun and Mina look at it together.","translation_ko":"사진이 나오자 준과 미나는 함께 사진을 봐요.","audioUrl":"/seed/daily-117-the-class-photo/audio/p10-s1.mp3","wordTimings":[{"word":"When","charStart":0,"charEnd":4,"startMs":0,"endMs":260},{"word":"the","charStart":5,"charEnd":8,"startMs":260,"endMs":480},{"word":"photo","charStart":9,"charEnd":14,"startMs":480,"endMs":740},{"word":"comes","charStart":15,"charEnd":20,"startMs":740,"endMs":1080},{"word":"out","charStart":21,"charEnd":24,"startMs":1080,"endMs":1340},{"word":"Jun","charStart":26,"charEnd":29,"startMs":1780,"endMs":2000},{"word":"and","charStart":30,"charEnd":33,"startMs":2000,"endMs":2320},{"word":"Mina","charStart":34,"charEnd":38,"startMs":2320,"endMs":2560},{"word":"look","charStart":39,"charEnd":43,"startMs":2560,"endMs":2860},{"word":"at","charStart":44,"charEnd":46,"startMs":2860,"endMs":3040},{"word":"it","charStart":47,"charEnd":49,"startMs":3040,"endMs":3220},{"word":"together","charStart":50,"charEnd":58,"startMs":3220,"endMs":3460}]},{"id":"daily-117-the-class-photo-p10-s2","ord":1,"text":"\"This is the best class photo ever!\" says Jun.","translation_ko":"\"이게 역대 최고의 단체 사진이야!\" 준이 말해요.","audioUrl":"/seed/daily-117-the-class-photo/audio/p10-s2.mp3","wordTimings":[{"word":"This","charStart":1,"charEnd":5,"startMs":0,"endMs":300},{"word":"is","charStart":6,"charEnd":8,"startMs":300,"endMs":560},{"word":"the","charStart":9,"charEnd":12,"startMs":560,"endMs":820},{"word":"best","charStart":13,"charEnd":17,"startMs":820,"endMs":1100},{"word":"class","charStart":18,"charEnd":23,"startMs":1100,"endMs":1480},{"word":"photo","charStart":24,"charEnd":29,"startMs":1480,"endMs":1740},{"word":"ever","charStart":30,"charEnd":34,"startMs":1740,"endMs":2540},{"word":"says","charStart":37,"charEnd":41,"startMs":2540,"endMs":2640},{"word":"Jun","charStart":42,"charEnd":45,"startMs":2640,"endMs":2960}]}]}],"quiz":[{"question_ko":"준의 셔츠에 생긴 문제는 무엇인가요?","type":"mc","options":["주스를 쏟아서 얼룩이 생겼다","셔츠를 학교에 두고 왔다","셔츠가 너무 작아졌다","셔츠가 찢어졌다"],"answerIndex":0,"explain_ko":"준은 아침에 주스를 쏟아 흰 셔츠에 주황색 얼룩이 생겼어요.","id":"daily-117-the-class-photo-q1","ord":0},{"question_ko":"미나는 준을 어떻게 도와주었나요?","type":"mc","options":["가방에서 재킷을 꺼내 빌려주었다","선생님께 달려가 말했다","얼룩을 물로 씻어 주었다","새 셔츠를 사 주었다"],"answerIndex":0,"explain_ko":"미나는 가방에 있던 진한 파란색 재킷을 꺼내 준에게 빌려주어 얼룩을 가렸어요.","id":"daily-117-the-class-photo-q2","ord":1},{"question_ko":"사진을 찍을 때 박 선생님이 한 말은 무엇인가요?","type":"mc","options":["\"Smile, everyone! Say cheese!\"","\"Stand up straight!\"","\"Look at me!\"","\"Hurry up, class!\""],"answerIndex":0,"explain_ko":"박 선생님은 \"Smile, everyone! Say cheese!\"라고 말했어요.","id":"daily-117-the-class-photo-q3","ord":2},{"question_ko":"준이 재킷을 입은 후 어떻게 되었나요?","type":"mc","options":["얼룩이 완전히 가려졌다","재킷이 너무 커서 벗었다","선생님이 재킷을 벗으라고 했다","얼룩이 더 커졌다"],"answerIndex":0,"explain_ko":"준이 재킷을 입자 셔츠의 얼룩이 완전히 가려졌어요.","id":"daily-117-the-class-photo-q4","ord":3},{"question_ko":"사진이 나온 후 준은 어떤 기분이었나요?","type":"mc","options":["친구 덕분에 행복하고 만족스러웠다","사진이 마음에 들지 않아 속상했다","재킷을 돌려줘야 해서 아쉬웠다","사진 찍기가 싫어서 화가 났다"],"answerIndex":0,"explain_ko":"준은 미나 덕분에 사진을 잘 찍을 수 있어서 행복했고, 이 사진이 역대 최고라고 말했어요.","id":"daily-117-the-class-photo-q5","ord":4}]}