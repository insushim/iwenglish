art":4,"charEnd":9,"startMs":300,"endMs":720},{"word":"and","charStart":10,"charEnd":13,"startMs":720,"endMs":1060},{"word":"calls","charStart":14,"charEnd":19,"startMs":1060,"endMs":1420},{"word":"Cold","charStart":22,"charEnd":26,"startMs":2000,"endMs":2340},{"word":"lemonade","charStart":27,"charEnd":35,"startMs":2340,"endMs":2820},{"word":"It's","charStart":37,"charEnd":41,"startMs":3260,"endMs":3480},{"word":"yummy","charStart":42,"charEnd":47,"startMs":3480,"endMs":3740}]},{"id":"daily-97-the-lemonade-stand-p6-s2","ord":1,"text":"When people hear her, they walk over because they are thirsty.","translation_ko":"사람들은 목이 말라서 미나의 목소리를 듣고 다가왔어요.","audioUrl":"/seed/daily-97-the-lemonade-stand/audio/p6-s2.mp3","wordTimings":[{"word":"When","charStart":0,"charEnd":4,"startMs":0,"endMs":240},{"word":"people","charStart":5,"charEnd":11,"startMs":240,"endMs":540},{"word":"hear","charStart":12,"charEnd":16,"startMs":540,"endMs":840},{"word":"her","charStart":17,"charEnd":20,"startMs":840,"endMs":1080},{"word":"they","charStart":22,"charEnd":26,"startMs":1440,"endMs":1620},{"word":"walk","charStart":27,"charEnd":31,"startMs":1620,"endMs":1840},{"word":"over","charStart":32,"charEnd":36,"startMs":1840,"endMs":2120},{"word":"because","charStart":37,"charEnd":44,"startMs":2120,"endMs":2440},{"word":"they","charStart":45,"charEnd":49,"startMs":2440,"endMs":2600},{"word":"are","charStart":50,"charEnd":53,"startMs":2600,"endMs":2800},{"word":"thirsty","charStart":54,"charEnd":61,"startMs":2800,"endMs":3080}]}]},{"id":"daily-97-the-lemonade-stand-p7","pageNo":7,"spread":"p7","imageUrl":"/seed/daily-97-the-lemonade-stand/p7.webp","sentences":[{"id":"daily-97-the-lemonade-stand-p7-s1","ord":0,"text":"An old woman buys a cup and says it is very good.","translation_ko":"한 할머니가 한 컵을 사서 정말 맛있다고 하셨어요.","audioUrl":"/seed/daily-97-the-lemonade-stand/audio/p7-s1.mp3","wordTimings":[{"word":"An","charStart":0,"charEnd":2,"startMs":0,"endMs":180},{"word":"old","charStart":3,"charEnd":6,"star