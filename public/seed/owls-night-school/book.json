{"id":"owls-night-school","slug":"owls-night-school","title":"Owl's Night School","title_ko":"부엉이의 밤 학교","level":"A2","ageBand":"8-10","coverUrl":"/seed/owls-night-school/cover.webp","summary_ko":"부엉이 선생님이 밤 동물 친구들에게 별과 바람을 가르치는 즐거운 밤 수업 이야기예요.","wordCount":176,"pages":[{"id":"owls-night-school-p1","pageNo":1,"spread":"p1","imageUrl":"/seed/owls-night-school/p1.webp","sentences":[{"id":"owls-night-school-p1-s1","ord":0,"text":"When the sun went down, the night school opened.","translation_ko":"해가 지자 밤 학교가 문을 열었어요.","audioUrl":"/seed/owls-night-school/audio/p1-s1.mp3","wordTimings":[{"word":"When","charStart":0,"charEnd":4,"startMs":0,"endMs":700},{"word":"the","charStart":5,"charEnd":8,"startMs":700,"endMs":900},{"word":"sun","charStart":9,"charEnd":12,"startMs":900,"endMs":1080},{"word":"went","charStart":13,"charEnd":17,"startMs":1080,"endMs":1320},{"word":"down","charStart":18,"charEnd":22,"startMs":1320,"endMs":1660},{"word":"the","charStart":24,"charEnd":27,"startMs":1980,"endMs":2140},{"word":"night","charStart":28,"charEnd":33,"startMs":2140,"endMs":2440},{"word":"school","charStart":34,"charEnd":40,"startMs":2440,"endMs":2680},{"word":"opened","charStart":41,"charEnd":47,"startMs":2680,"endMs":3100}]},{"id":"owls-night-school-p1-s2","ord":1,"text":"Owl waited with her round glasses and a soft smile.","translation_ko":"부엉이 선생님은 동그란 안경을 쓰고 부드러운 미소로 기다렸어요.","audioUrl":"/seed/owls-night-school/audio/p1-s2.mp3","wordTimings":[{"word":"Owl","charStart":0,"charEnd":3,"startMs":0,"endMs":400},{"word":"waited","charStart":4,"charEnd":10,"startMs":400,"endMs":760},{"word":"with","charStart":11,"charEnd":15,"startMs":760,"endMs":1020},{"word":"her","charStart":16,"charEnd":19,"startMs":1020,"endMs":1320},{"word":"round","charStart":20,"charEnd":25,"startMs":1320,"endMs":1600},{"word":"glasses","charStart":26,"charEnd":33,"startMs":1600,"endMs":1980},{"word":"and","charStart":34,"charEnd":37,"startMs":1980,"endMs":2320},{"word":"a","charStart":38,"charEnd":39,"startMs":2320,"endMs":2560},{"word":"soft","charStart":40,"charEnd":44,"startMs":2560,"endMs":2820},{"word":"smile","charStart":45,"charEnd":50,"startMs":2820,"endMs":3200}]}]},{"id":"owls-night-school-p2","pageNo":2,"spread":"p2","imageUrl":"/seed/owls-night-school/p2.webp","sentences":[{"id":"owls-night-school-p2-s1","ord":0,"text":"A mouse, a fox, and a little bat came inside.","translation_ko":"생쥐와 여우, 그리고 작은 박쥐가 안으로 들어왔어요.","audioUrl":"/seed/owls-night-school/audio/p2-s1.mp3","wordTimings":[{"word":"A","charStart":0,"charEnd":1,"startMs":0,"endMs":300},{"word":"mouse","charStart":2,"charEnd":7,"startMs":300,"endMs":560},{"word":"a","charStart":9,"charEnd":10,"startMs":1060,"endMs":1460},{"word":"fox","charStart":11,"charEnd":14,"startMs":1460,"endMs":1460},{"word":"and","charStart":16,"charEnd":19,"startMs":1880,"endMs":2000},{"word":"a","charStart":20,"charEnd":21,"startMs":2000,"endMs":2160},{"word":"little","charStart":22,"charEnd":28,"startMs":2160,"endMs":2340},{"word":"bat","charStart":29,"charEnd":32,"startMs":2340,"endMs":2680},{"word":"came","charStart":33,"charEnd":37,"startMs":2680,"endMs":3080},{"word":"inside","charStart":38,"charEnd":44,"startMs":3080,"endMs":3520}]},{"id":"owls-night-school-p2-s2","ord":1,"text":"\"Welcome, friends,\" Owl said warmly.","translation_ko":"\"어서 오렴, 얘들아.\" 부엉이 선생님이 따뜻하게 말했어요.","audioUrl":"/seed/owls-night-school/audio/p2-s2.mp3","wordTimings":[{"word":"Welcome","charStart":1,"charEnd":8,"startMs":0,"endMs":600},{"word":"friends","charStart":10,"charEnd":17,"startMs":1300,"endMs":2120},{"word":"Owl","charStart":20,"charEnd":23,"startMs":2120,"endMs":2120},{"word":"said","charStart":24,"charEnd":28,"startMs":2120,"endMs":2500},{"word":"warmly","charStart":29,"charEnd":35,"startMs":2500,"endMs":3200}]}]},{"id":"owls-night-school-p3","pageNo":3,"spread":"p3","imageUrl":"/seed/owls-night-school/p3.webp","sentences":[{"id":"owls-night-school-p3-s1","ord":0,"text":"First, Owl taught them about the bright stars.","translation_ko":"먼저 부엉이 선생님은 반짝이는 별에 대해 가르쳤어요.","audioUrl":"/seed/owls-night-school/audio/p3-s1.mp3","wordTimings":[{"word":"First","charStart":0,"charEnd":5,"startMs":0,"endMs":740},{"word":"Owl","charStart":7,"charEnd":10,"startMs":980,"endMs":1200},{"word":"taught","charStart":11,"charEnd":17,"startMs":1200,"endMs":1500},{"word":"them","charStart":18,"charEnd":22,"startMs":1500,"endMs":1640},{"word":"about","charStart":23,"charEnd":28,"startMs":1640,"endMs":1900},{"word":"the","charStart":29,"charEnd":32,"startMs":1900,"endMs":2140},{"word":"bright","charStart":33,"charEnd":39,"startMs":2140,"endMs":2380},{"word":"stars","charStart":40,"charEnd":45,"startMs":2380,"endMs":2780}]},{"id":"owls-night-school-p3-s2","ord":1,"text":"\"Each star has its own quiet light,\" she said.","translation_ko":"\"별마다 저마다의 고요한 빛이 있단다.\" 선생님이 말했어요.","audioUrl":"/seed/owls-night-school/audio/p3-s2.mp3","wordTimings":[{"word":"Each","charStart":1,"charEnd":5,"startMs":0,"endMs":420},{"word":"star","charStart":6,"charEnd":10,"startMs":420,"endMs":840},{"word":"has","charStart":11,"charEnd":14,"startMs":840,"endMs":1160},{"word":"its","charStart":15,"charEnd":18,"startMs":1160,"endMs":1340},{"word":"own","charStart":19,"charEnd":22,"startMs":1340,"endMs":1760},{"word":"quiet","charStart":23,"charEnd":28,"startMs":1760,"endMs":2140},{"word":"light","charStart":29,"charEnd":34,"startMs":2140,"endMs":2500},{"word":"she","charStart":37,"charEnd":40,"startMs":2840,"endMs":3020},{"word":"said","charStart":41,"charEnd":45,"startMs":3020,"endMs":3260}]}]},{"id":"owls-night-school-p4","pageNo":4,"spread":"p4","imageUrl":"/seed/owls-night-school/p4.webp","sentences":[{"id":"owls-night-school-p4-s1","ord":0,"text":"Then she showed them the round, silver moon.","translation_ko":"그다음 선생님은 둥글고 은빛인 달을 보여 주었어요.","audioUrl":"/seed/owls-night-school/audio/p4-s1.mp3","wordTimings":[{"word":"Then","charStart":0,"charEnd":4,"startMs":0,"endMs":440},{"word":"she","charStart":5,"charEnd":8,"startMs":440,"endMs":880},{"word":"showed","charStart":9,"charEnd":15,"startMs":880,"endMs":1120},{"word":"them","charStart":16,"charEnd":20,"startMs":1120,"endMs":1320},{"word":"the","charStart":21,"charEnd":24,"startMs":1320,"endMs":1560},{"word":"round","charStart":25,"charEnd":30,"startMs":1560,"endMs":2020},{"word":"silver","charStart":32,"charEnd":38,"startMs":2420,"endMs":2580},{"word":"moon","charStart":39,"charEnd":43,"startMs":2580,"endMs":3000}]},{"id":"owls-night-school-p4-s2","ord":1,"text":"The little animals looked up and smiled.","translation_ko":"작은 동물들은 위를 올려다보며 미소 지었어요.","audioUrl":"/seed/owls-night-school/audio/p4-s2.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":260},{"word":"little","charStart":4,"charEnd":10,"startMs":260,"endMs":520},{"word":"animals","charStart":11,"charEnd":18,"startMs":520,"endMs":980},{"word":"looked","charStart":19,"charEnd":25,"startMs":980,"endMs":1260},{"word":"up","charStart":26,"charEnd":28,"startMs":1260,"endMs":1580},{"word":"and","charStart":29,"charEnd":32,"startMs":1580,"endMs":2100},{"word":"smiled","charStart":33,"charEnd":39,"startMs":2100,"endMs":2360}]}]},{"id":"owls-night-school-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/owls-night-school/p5.webp","sentences":[{"id":"owls-night-school-p5-s1","ord":0,"text":"\"Now let's learn to fly quietly,\" Owl said.","translation_ko":"\"이제 소리 없이 나는 법을 배워 보자.\" 부엉이 선생님이 말했어요.","audioUrl":"/seed/owls-night-school/audio/p5-s1.mp3","wordTimings":[{"word":"Now","charStart":1,"charEnd":4,"startMs":0,"endMs":300},{"word":"let's","charStart":5,"charEnd":10,"startMs":300,"endMs":620},{"word":"learn","charStart":11,"charEnd":16,"startMs":620,"endMs":800},{"word":"to","charStart":17,"charEnd":19,"startMs":800,"endMs":1080},{"word":"fly","charStart":20,"charEnd":23,"startMs":1080,"endMs":1320},{"word":"quietly","charStart":24,"charEnd":31,"startMs":1320,"endMs":2660},{"word":"Owl","charStart":34,"charEnd":37,"startMs":2660,"endMs":2780},{"word":"said","charStart":38,"charEnd":42,"startMs":2780,"endMs":3100}]},{"id":"owls-night-school-p5-s2","ord":1,"text":"She spread her wings and floated without a sound.","translation_ko":"선생님은 날개를 펼치고 소리 없이 떠올랐어요.","audioUrl":"/seed/owls-night-school/audio/p5-s2.mp3","wordTimings":[{"word":"She","charStart":0,"charEnd":3,"startMs":0,"endMs":300},{"word":"spread","charStart":4,"charEnd":10,"startMs":300,"endMs":600},{"word":"her","charStart":11,"charEnd":14,"startMs":600,"endMs":860},{"word":"wings","charStart":15,"charEnd":20,"startMs":860,"endMs":1100},{"word":"and","charStart":21,"charEnd":24,"startMs":1100,"endMs":1520},{"word":"floated","charStart":25,"charEnd":32,"startMs":1520,"endMs":1740},{"word":"without","charStart":33,"charEnd":40,"startMs":1740,"endMs":2080},{"word":"a","charStart":41,"charEnd":42,"startMs":2080,"endMs":2460},{"word":"sound","charStart":43,"charEnd":48,"startMs":2460,"endMs":2640}]}]},{"id":"owls-night-school-p6","pageNo":6,"spread":"p6","imageUrl":"/seed/owls-night-school/p6.webp","sentences":[{"id":"owls-night-school-p6-s1","ord":0,"text":"The bat tried to glide, but he was afraid.","translation_ko":"박쥐가 미끄러지듯 날아 보려 했지만 무서웠어요.","audioUrl":"/seed/owls-night-school/audio/p6-s1.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":220},{"word":"bat","charStart":4,"charEnd":7,"startMs":220,"endMs":520},{"word":"tried","charStart":8,"charEnd":13,"startMs":520,"endMs":860},{"word":"to","charStart":14,"charEnd":16,"startMs":860,"endMs":1160},{"word":"glide","charStart":17,"charEnd":22,"startMs":1160,"endMs":1400},{"word":"but","charStart":24,"charEnd":27,"startMs":1660,"endMs":1900},{"word":"he","charStart":28,"charEnd":30,"startMs":1900,"endMs":2040},{"word":"was","charStart":31,"charEnd":34,"startMs":2040,"endMs":2200},{"word":"afraid","charStart":35,"charEnd":41,"startMs":2200,"endMs":2620}]},{"id":"owls-night-school-p6-s2","ord":1,"text":"\"I think I will fall,\" he whispered.","translation_ko":"\"떨어질 것 같아.\" 박쥐가 작게 속삭였어요.","audioUrl":"/seed/owls-night-school/audio/p6-s2.mp3","wordTimings":[{"word":"I","charStart":1,"charEnd":2,"startMs":0,"endMs":160},{"word":"think","charStart":3,"charEnd":8,"startMs":160,"endMs":460},{"word":"I","charStart":9,"charEnd":10,"startMs":460,"endMs":840},{"word":"will","charStart":11,"charEnd":15,"startMs":840,"endMs":1160},{"word":"fall","charStart":16,"charEnd":20,"startMs":1160,"endMs":1520},{"word":"he","charStart":23,"charEnd":25,"startMs":1900,"endMs":2080},{"word":"whispered","charStart":26,"charEnd":35,"startMs":2080,"endMs":2500}]}]},{"id":"owls-night-school-p7","pageNo":7,"spread":"p7","imageUrl":"/seed/owls-night-school/p7.webp","sentences":[{"id":"owls-night-school-p7-s1","ord":0,"text":"\"Don't worry, because I am right beside you,\" said Owl.","translation_ko":"\"걱정 마, 내가 바로 옆에 있으니까.\" 부엉이 선생님이 말했어요.","audioUrl":"/seed/owls-night-school/audio/p7-s1.mp3","wordTimings":[{"word":"Don't","charStart":1,"charEnd":6,"startMs":0,"endMs":360},{"word":"worry","charStart":7,"charEnd":12,"startMs":360,"endMs":640},{"word":"because","charStart":14,"charEnd":21,"startMs":960,"endMs":1180},{"word":"I","charStart":22,"charEnd":23,"startMs":1180,"endMs":1300},{"word":"am","charStart":24,"charEnd":26,"startMs":1300,"endMs":1440},{"word":"right","charStart":27,"charEnd":32,"startMs":1440,"endMs":1700},{"word":"beside","charStart":33,"charEnd":39,"startMs":1700,"endMs":2100},{"word":"you","charStart":40,"charEnd":43,"startMs":2100,"endMs":2820},{"word":"said","charStart":46,"charEnd":50,"startMs":2820,"endMs":2880},{"word":"Owl","charStart":51,"charEnd":54,"startMs":2880,"endMs":3140}]},{"id":"owls-night-school-p7-s2","ord":1,"text":"She felt the wind and showed him how to ride it.","translation_ko":"선생님은 바람을 느끼며 바람을 타는 법을 보여 주었어요.","audioUrl":"/seed/owls-night-school/audio/p7-s2.mp3","wordTimings":[{"word":"She","charStart":0,"charEnd":3,"startMs":0,"endMs":300},{"word":"felt","charStart":4,"charEnd":8,"startMs":300,"endMs":580},{"word":"the","charStart":9,"charEnd":12,"startMs":580,"endMs":800},{"word":"wind","charStart":13,"charEnd":17,"startMs":800,"endMs":1040},{"word":"and","charStart":18,"charEnd":21,"startMs":1040,"endMs":1540},{"word":"showed","charStart":22,"charEnd":28,"startMs":1540,"endMs":1780},{"word":"him","charStart":29,"charEnd":32,"startMs":1780,"endMs":2000},{"word":"how","charStart":33,"charEnd":36,"startMs":2000,"endMs":2260},{"word":"to","charStart":37,"charEnd":39,"startMs":2260,"endMs":2540},{"word":"ride","charStart":40,"charEnd":44,"startMs":2540,"endMs":2700},{"word":"it","charStart":45,"charEnd":47,"startMs":2700,"endMs":2940}]}]},{"id":"owls-night-school-p8","pageNo":8,"spread":"p8","imageUrl":"/seed/owls-night-school/p8.webp","sentences":[{"id":"owls-night-school-p8-s1","ord":0,"text":"So the bat took a deep breath and opened his wings.","translation_ko":"그래서 박쥐는 깊게 숨을 쉬고 날개를 펼쳤어요.","audioUrl":"/seed/owls-night-school/audio/p8-s1.mp3","wordTimings":[{"word":"So","charStart":0,"charEnd":2,"startMs":0,"endMs":340},{"word":"the","charStart":3,"charEnd":6,"startMs":340,"endMs":560},{"word":"bat","charStart":7,"charEnd":10,"startMs":560,"endMs":840},{"word":"took","charStart":11,"charEnd":15,"startMs":840,"endMs":1080},{"word":"a","charStart":16,"charEnd":17,"startMs":1080,"endMs":1380},{"word":"deep","charStart":18,"charEnd":22,"startMs":1380,"endMs":1600},{"word":"breath","charStart":23,"charEnd":29,"startMs":1600,"endMs":1920},{"word":"and","charStart":30,"charEnd":33,"startMs":1920,"endMs":2480},{"word":"opened","charStart":34,"charEnd":40,"startMs":2480,"endMs":2780},{"word":"his","charStart":41,"charEnd":44,"startMs":2780,"endMs":3060},{"word":"wings","charStart":45,"charEnd":50,"startMs":3060,"endMs":3300}]},{"id":"owls-night-school-p8-s2","ord":1,"text":"This time he glided smoothly across the dark sky.","translation_ko":"이번에는 어두운 하늘을 부드럽게 미끄러지듯 날았어요.","audioUrl":"/seed/owls-night-school/audio/p8-s2.mp3","wordTimings":[{"word":"This","charStart":0,"charEnd":4,"startMs":0,"endMs":340},{"word":"time","charStart":5,"char