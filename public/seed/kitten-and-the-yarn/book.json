{"id":"kitten-and-the-yarn","slug":"kitten-and-the-yarn","title":"Kitten and the Yarn","title_ko":"아기 고양이와 실뭉치","level":"preA1","ageBand":"5-7","coverUrl":"/seed/kitten-and-the-yarn/cover.webp","summary_ko":"아기 고양이가 실을 가지고 신나게 노는 이야기.","wordCount":54,"pages":[{"id":"kitten-and-the-yarn-p1","pageNo":1,"spread":"p1","imageUrl":"/seed/kitten-and-the-yarn/p1.webp","sentences":[{"id":"kitten-and-the-yarn-p1-s1","ord":0,"text":"A little kitten sees yarn. The kitten is happy.","translation_ko":"작은 아기 고양이가 실을 봐요. 고양이는 신나요.","audioUrl":"/seed/kitten-and-the-yarn/audio/p1-s1.mp3","wordTimings":[{"word":"A","charStart":0,"charEnd":1,"startMs":0,"endMs":180},{"word":"little","charStart":2,"charEnd":8,"startMs":180,"endMs":500},{"word":"kitten","charStart":9,"charEnd":15,"startMs":500,"endMs":760},{"word":"sees","charStart":16,"charEnd":20,"startMs":760,"endMs":1440},{"word":"yarn","charStart":21,"charEnd":25,"startMs":1440,"endMs":1840},{"word":"The","charStart":27,"charEnd":30,"startMs":2840,"endMs":2980},{"word":"kitten","charStart":31,"charEnd":37,"startMs":2980,"endMs":3180},{"word":"is","charStart":38,"charEnd":40,"startMs":3180,"endMs":3580},{"word":"happy","charStart":41,"charEnd":46,"startMs":3580,"endMs":3860}]}]},{"id":"kitten-and-the-yarn-p2","pageNo":2,"spread":"p2","imageUrl":"/seed/kitten-and-the-yarn/p2.webp","sentences":[{"id":"kitten-and-the-yarn-p2-s1","ord":0,"text":"The kitten taps it. It taps and taps.","translation_ko":"고양이가 실을 톡 쳐요. 톡톡 쳐요.","audioUrl":"/seed/kitten-and-the-yarn/audio/p2-s1.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":400},{"word":"kitten","charStart":4,"charEnd":10,"startMs":400,"endMs":640},{"word":"taps","charStart":11,"charEnd":15,"startMs":640,"endMs":1040},{"word":"it","charStart":16,"charEnd":18,"startMs":1040,"endMs":1320},{"word":"It","charStart":20,"charEnd":22,"startMs":2020,"endMs":2220},{"word":"taps","charStart":23,"charEnd":27,"startMs":2220,"endMs":2540},{"word":"and","charStart":28,"charE