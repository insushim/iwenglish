,"endMs":5760},{"word":"shapes","charStart":99,"charEnd":105,"startMs":5760,"endMs":6080}]}]},{"id":"the-long-road-to-sunrise-p10","pageNo":10,"spread":"p10","imageUrl":"/seed/the-long-road-to-sunrise/p10.webp","sentences":[{"id":"the-long-road-to-sunrise-p10-s1","ord":0,"text":"The sunrise spread slowly, giving every tree and rooftop a gold edge. I was glad we had not spent the whole walk racing it.","translation_ko":"해돋이는 천천히 퍼지며 나무와 지붕마다 금빛 가장자리를 주었어요. 나는 우리가 내내 그것과 경주하지 않아서 다행이라고 생각했어요.","audioUrl":"/seed/the-long-road-to-sunrise/audio/p10-s1.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":500},{"word":"sunrise","charStart":4,"charEnd":11,"startMs":500,"endMs":1040},{"word":"spread","charStart":12,"charEnd":18,"startMs":1040,"endMs":1480},{"word":"slowly","charStart":19,"charEnd":25,"startMs":1480,"endMs":1960},{"word":"giving","charStart":27,"charEnd":33,"startMs":2500,"endMs":2560},{"word":"every","charStart":34,"charEnd":39,"startMs":2560,"endMs":2940},{"word":"tree","charStart":40,"charEnd":44,"startMs":2940,"endMs":3220},{"word":"and","charStart":45,"charEnd":48,"startMs":3220,"endMs":3820},{"word":"rooftop","charStart":49,"charEnd":56,"startMs":3820,"endMs":3820},{"word":"a","charStart":57,"charEnd":58,"startMs":3820,"endMs":4060},{"word":"gold","charStart":59,"charEnd":63,"startMs":4060,"endMs":4260},{"word":"edge","charStart":64,"charEnd":68,"startMs":4260,"endMs":4660},{"word":"I","charStart":70,"charEnd":71,"startMs":5360,"endMs":5420},{"word":"was","charStart":72,"charEnd":75,"startMs":5420,"endMs":5660},{"word":"glad","charStart":76,"charEnd":80,"startMs":5660,"endMs":5860},{"word":"we","charStart":81,"charEnd":83,"startMs":5860,"endMs":6040},{"word":"had","charStart":84,"charEnd":87,"startMs":6040,"endMs":6160},{"word":"not","charStart":88,"charEnd":91,"startMs":6160,"endMs":6460},{"word":"spent","charStart":92,"charEnd":97,"startMs":6460,"endMs":6660},{"word":"the","charStart":98,"charEnd":101,"startMs":6660,"endMs":