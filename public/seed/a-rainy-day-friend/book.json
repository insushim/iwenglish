Ms":1800,"endMs":2000},{"word":"the","charStart":31,"charEnd":34,"startMs":2000,"endMs":2180},{"word":"puddles","charStart":35,"charEnd":42,"startMs":2180,"endMs":2520}]},{"id":"a-rainy-day-friend-p7-s2","ord":1,"text":"Splash, splash!","translation_ko":"첨벙, 첨벙!","audioUrl":"/seed/a-rainy-day-friend/audio/p7-s2.mp3","wordTimings":[{"word":"Splash","charStart":0,"charEnd":6,"startMs":0,"endMs":860},{"word":"splash","charStart":8,"charEnd":14,"startMs":1580,"endMs":1600}]}]},{"id":"a-rainy-day-friend-p8","pageNo":8,"spread":"p8","imageUrl":"/seed/a-rainy-day-friend/p8.webp","sentences":[{"id":"a-rainy-day-friend-p8-s1","ord":0,"text":"Now rainy days are not so bad.","translation_ko":"이제 비 오는 날도 그리 나쁘지 않아요.","audioUrl":"/seed/a-rainy-day-friend/audio/p8-s1.mp3","wordTimings":[{"word":"Now","charStart":0,"charEnd":3,"startMs":0,"endMs":520},{"word":"rainy","charStart":4,"charEnd":9,"startMs":760,"endMs":940},{"word":"days","charStart":10,"charEnd":14,"startMs":940,"endMs":1260},{"word":"are","charStart":15,"charEnd":18,"startMs":1260,"endMs":1460},{"word":"not","charStart":19,"charEnd":22,"startMs":1460,"endMs":1720},{"word":"so","charStart":23,"charEnd":25,"startMs":1720,"endMs":1980},{"word":"bad","charStart":26,"charEnd":29,"startMs":1980,"endMs":2160}]},{"id":"a-rainy-day-friend-p8-s2","ord":1,"text":"Mia has a new friend.","translation_ko":"미아에게 새 친구가 생겼거든요.","audioUrl":"/seed/a-rainy-day-friend/audio/p8-s2.mp3","wordTimings":[{"word":"Mia","charStart":0,"charEnd":3,"startMs":0,"endMs":380},{"word":"has","charStart":4,"charEnd":7,"startMs":380,"endMs":800},{"word":"a","charStart":8,"charEnd":9,"startMs":800,"endMs":1080},{"word":"new","charStart":10,"charEnd":13,"startMs":1080,"endMs":1280},{"word":"friend","charStart":14,"charEnd":20,"startMs":1280,"endMs":1460}]}]}],"quiz":[{"question_ko":"미아는 어떤 날을 좋아하지 않았나요?","type":"mc","options":["비 오는 날","눈 오는 날","더운 날","바람 부는 날"],"answerIndex":0,"explain_ko":"미아는 잿빛 하늘과 차가운 비가 내리는 비 오는 날을 좋아하지 않았어요.","id":"a-rainy-day-frien