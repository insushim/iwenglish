":"the-mountain-echo-p3-s1","ord":0,"text":"Mina felt happy, so she cupped her hands and shouted.","translation_ko":"기분이 좋아진 미나는 손을 모아 입에 대고 소리쳤어요.","audioUrl":"/seed/the-mountain-echo/audio/p3-s1.mp3","wordTimings":[{"word":"Mina","charStart":0,"charEnd":4,"startMs":0,"endMs":380},{"word":"felt","charStart":5,"charEnd":9,"startMs":380,"endMs":760},{"word":"happy","charStart":10,"charEnd":15,"startMs":760,"endMs":1220},{"word":"so","charStart":17,"charEnd":19,"startMs":2040,"endMs":2120},{"word":"she","charStart":20,"charEnd":23,"startMs":2120,"endMs":2320},{"word":"cupped","charStart":24,"charEnd":30,"startMs":2320,"endMs":2560},{"word":"her","charStart":31,"charEnd":34,"startMs":2560,"endMs":2780},{"word":"hands","charStart":35,"charEnd":40,"startMs":2780,"endMs":3020},{"word":"and","charStart":41,"charEnd":44,"startMs":3020,"endMs":3340},{"word":"shouted","charStart":45,"charEnd":52,"startMs":3340,"endMs":3560}]},{"id":"the-mountain-echo-p3-s2","ord":1,"text":"\"Hello!\" she called across the mountains.","translation_ko":"\"안녕!\" 그녀가 산을 향해 외쳤어요.","audioUrl":"/seed/the-mountain-echo/audio/p3-s2.mp3","wordTimings":[{"word":"Hello","charStart":1,"charEnd":6,"startMs":0,"endMs":580},{"word":"she","charStart":9,"charEnd":12,"startMs":800,"endMs":1320},{"word":"called","charStart":13,"charEnd":19,"startMs":1320,"endMs":1560},{"word":"across","charStart":20,"charEnd":26,"startMs":1560,"endMs":1900},{"word":"the","charStart":27,"charEnd":30,"startMs":1900,"endMs":2540},{"word":"mountains","charStart":31,"charEnd":40,"startMs":2540,"endMs":2540}]}]},{"id":"the-mountain-echo-p4","pageNo":4,"spread":"p4","imageUrl":"/seed/the-mountain-echo/p4.webp","sentences":[{"id":"the-mountain-echo-p4-s1","ord":0,"text":"Then a voice answered, \"Hello! Hello!\"","translation_ko":"그러자 어떤 목소리가 대답했어요. \"안녕! 안녕!\"","audioUrl":"/seed/the-mountain-echo/audio/p4-s1.mp3","wordTimings":[{"word":"Then","charStart":0,"charEnd":4,"startMs":0,"endMs":300},{"word":"a","charStart":5,"charEnd":6,"startMs":300,"endMs":560},{"word":"voice","charStart":7,"charEnd":12,"startMs":560,"endMs":860},{"word":"answered","charStart":13,"charEnd":21,"startMs":860,"endMs":1300},{"word":"Hello","charStart":24,"charEnd":29,"startMs":1840,"endMs":2140},{"word":"Hello","charStart":31,"charEnd":36,"startMs":2740,"endMs":3000}]},{"id":"the-mountain-echo-p4-s2","ord":1,"text":"Mina stopped and looked around.","translation_ko":"미나는 걸음을 멈추고 주위를 둘러봤어요.","audioUrl":"/seed/the-mountain-echo/audio/p4-s2.mp3","wordTimings":[{"word":"Mina","charStart":0,"charEnd":4,"startMs":0,"endMs":400},{"word":"stopped","charStart":5,"charEnd":12,"startMs":400,"endMs":960},{"word":"and","charStart":13,"charEnd":16,"startMs":960,"endMs":1520},{"word":"looked","charStart":17,"charEnd":23,"startMs":1520,"endMs":1760},{"word":"around","charStart":24,"charEnd":30,"startMs":1760,"endMs":2160}]}]},{"id":"the-mountain-echo-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/the-mountain-echo/p5.webp","sentences":[{"id":"the-mountain-echo-p5-s1","ord":0,"text":"She did not see anyone, so she became a little scared.","translation_ko":"아무도 보이지 않자 미나는 조금 무서워졌어요.","audioUrl":"/seed/the-mountain-echo/audio/p5-s1.mp3","wordTimings":[{"word":"She","charStart":0,"charEnd":3,"startMs":0,"endMs":260},{"word":"did","charStart":4,"charEnd":7,"startMs":260,"endMs":480},{"word":"not","charStart":8,"charEnd":11,"startMs":480,"endMs":760},{"word":"see","charStart":12,"charEnd":15,"startMs":760,"endMs":960},{"word":"anyone","charStart":16,"charEnd":22,"startMs":960,"endMs":1320},{"word":"so","charStart":24,"charEnd":26,"startMs":1760,"endMs":1900},{"word":"she","charStart":27,"charEnd":30,"startMs":1900,"endMs":2100},{"word":"became","charStart":31,"charEnd":37,"startMs":2100,"endMs":2340},{"word":"a","charStart":38,"charEnd":39,"startMs":2340,"endMs":2520},{"word":"little","charStart":40,"charEnd":46,"startMs":2520,"endMs":2680},{"word":"scared","charStart":47,"charEnd":53,"startMs":2680,"endMs":3020}]},{"id":"the-mountain-echo-p5-s2","ord":1,"text":"\"Who are you?\" she asked in a small voice.","translation_ko":"\"누구세요?\" 그녀가 작은 목소리로 물었어요.","audioUrl":"/seed/the-mountain-echo/audio/p5-s2.mp3","wordTimings":[{"word":"Who","charStart":1,"charEnd":4,"startMs":0,"endMs":500},{"word":"are","charStart":5,"charEnd":8,"startMs":500,"endMs":780},{"word":"you","charStart":9,"charEnd":12,"startMs":780,"endMs":1020},{"word":"she","charStart":15,"charEnd":18,"startMs":1280,"endMs":1620},{"word":"asked","charStart":19,"charEnd":24,"startMs":1620,"endMs":1960},{"word":"in","charStart":25,"charEnd":27,"startMs":1960,"endMs":2100},{"word":"a","charStart":28,"charEnd":29,"startMs":2100,"endMs":2300},{"word":"small","charStart":30,"charEnd":35,"startMs":2300,"endMs":2520},{"word":"voice","charStart":36,"charEnd":41,"startMs":2520,"endMs":2880}]}]},{"id":"the-mountain-echo-p6","pageNo":6,"spread":"p6","imageUrl":"/seed/the-mountain-echo/p6.webp","sentences":[{"id":"the-mountain-echo-p6-s1","ord":0,"text":"The voice answered back, \"Who are you?\"","translation_ko":"목소리가 그대로 되받았어요. \"누구세요?\"","audioUrl":"/seed/the-mountain-echo/audio/p6-s1.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":660},{"word":"voice","charStart":4,"charEnd":9,"startMs":660,"endMs":1000},{"word":"answered","charStart":10,"charEnd":18,"startMs":1000,"endMs":1320},{"word":"back","charStart":19,"charEnd":23,"startMs":1320,"endMs":1740},{"word":"Who","charStart":26,"charEnd":29,"startMs":2160,"endMs":2260},{"word":"are","charStart":30,"charEnd":33,"startMs":2260,"endMs":2520},{"word":"you","charStart":34,"charEnd":37,"startMs":2520,"endMs":2700}]},{"id":"the-mountain-echo-p6-s2","ord":1,"text":"It said exactly the same words every time.","translation_ko":"그것은 매번 똑같은 말을 그대로 따라 했어요.","audioUrl":"/seed/the-mountain-echo/audio/p6-s2.mp3","wordTimings":[{"word":"It","charStart":0,"charEnd":2,"startMs":0,"endMs":300},{"word":"said","charStart":3,"charEnd":7,"startMs":300,"endMs":500},{"word":"exactly","charStart":8,"charEnd":15,"startMs":500,"endMs":1120},{"word":"the","charStart":16,"charEnd":19,"startMs":1120,"endMs":1360},{"word":"same","charStart":20,"charEnd":24,"startMs":1360,"endMs":1620},{"word":"words","charStart":25,"charEnd":30,"startMs":1620,"endMs":1940},{"word":"every","charStart":31,"charEnd":36,"startMs":1940,"endMs":2480},{"word":"time","charStart":37,"charEnd":41,"startMs":2480,"endMs":2760}]}]},{"id":"the-mountain-echo-p7","pageNo":7,"spread":"p7","imageUrl":"/seed/the-mountain-echo/p7.webp","sentences":[{"id":"the-mountain-echo-p7-s1","ord":0,"text":"Mina was not scared anymore. Now she felt curious.","translation_ko":"이제 미나는 무섭지 않았어요. 호기심이 생겼거든요.","audioUrl":"/seed/the-mountain-echo/audio/p7-s1.mp3","wordTimings":[{"word":"Mina","charStart":0,"charEnd":4,"startMs":0,"endMs":320},{"word":"was","charStart":5,"charEnd":8,"startMs":320,"endMs":600},{"word":"not","charStart":9,"charEnd":12,"startMs":600,"endMs":1040},{"word":"scared","charStart":13,"charEnd":19,"startMs":1040,"endMs":1300},{"word":"anymore","charStart":20,"charEnd":27,"startMs":1300,"endMs":1780},{"word":"Now","charStart":29,"charEnd":32,"startMs":2240,"endMs":2360},{"word":"she","charStart":33,"charEnd":36,"startMs":2360,"endMs":2580},{"word":"felt","charStart":37,"charEnd":41,"startMs":2580,"endMs":2820},{"word":"curious","charStart":42,"charEnd":49,"startMs":2820,"endMs":3260}]},{"id":"the-mountain-echo-p7-s2","ord":1,"text":"She remembered something her grandmother once told her.","translation_ko":"할머니가 예전에 들려주신 이야기가 떠올랐어요.","audioUrl":"/seed/the-mountain-echo/audio/p7-s2.mp3","wordTimings":[{"word":"She","charStart":0,"charEnd":3,"startMs":0,"endMs":460},{"word":"remembered","charStart":4,"charEnd":14,"startMs":460,"endMs":900},{"word":"something","charStart":15,"charEnd":24,"startMs":900,"endMs":1320},{"word":"her","charStart":25,"charEnd":28,"startMs":1320,"endMs":1520},{"word":"grandmother","charStart":29,"charEnd":40,"startMs":1520,"endMs":1940},{"word":"once","charStart":41,"charEnd":45,"