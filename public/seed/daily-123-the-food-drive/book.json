, and tuna.","translation_ko":"하교 후, 준은 찬장을 열었더니 옥수수, 콩, 참치 통조림이 있었어요.","audioUrl":"/seed/daily-123-the-food-drive/audio/p3-s1.mp3","wordTimings":[{"word":"After","charStart":0,"charEnd":5,"startMs":0,"endMs":320},{"word":"school","charStart":6,"charEnd":12,"startMs":320,"endMs":760},{"word":"Jun","charStart":14,"charEnd":17,"startMs":1420,"endMs":1500},{"word":"opened","charStart":18,"charEnd":24,"startMs":1500,"endMs":1840},{"word":"the","charStart":25,"charEnd":28,"startMs":1840,"endMs":2140},{"word":"cabinet","charStart":29,"charEnd":36,"startMs":2140,"endMs":2360},{"word":"and","charStart":37,"charEnd":40,"startMs":2360,"endMs":2900},{"word":"found","charStart":41,"charEnd":46,"startMs":2900,"endMs":3080},{"word":"cans","charStart":47,"charEnd":51,"startMs":3080,"endMs":3400},{"word":"of","charStart":52,"charEnd":54,"startMs":3400,"endMs":3920},{"word":"corn","charStart":55,"charEnd":59,"startMs":3920,"endMs":3920},{"word":"beans","charStart":61,"charEnd":66,"startMs":4580,"endMs":4580},{"word":"and","charStart":68,"charEnd":71,"startMs":4740,"endMs":5240},{"word":"tuna","charStart":72,"charEnd":76,"startMs":5240,"endMs":5240}]},{"id":"daily-123-the-food-drive-p3-s2","ord":1,"text":"He felt hopeful because he knew these would help someone.","translation_ko":"이것들이 누군가에게 도움이 될 거라는 생각에 마음이 따뜻해졌어요.","audioUrl":"/seed/daily-123-the-food-drive/audio/p3-s2.mp3","wordTimings":[{"word":"He","charStart":0,"charEnd":2,"startMs":0,"endMs":240},{"word":"felt","charStart":3,"charEnd":7,"startMs":240,"endMs":480},{"word":"hopeful","charStart":8,"charEnd":15,"startMs":480,"endMs":940},{"word":"because","charStart":16,"charEnd":23,"startMs":940,"endMs":1540},{"word":"he","charStart":24,"charEnd":26,"startMs":1540,"endMs":1800},{"word":"knew","charStart":27,"charEnd":31,"startMs":1800,"endMs":1880},{"word":"these","charStart":32,"charEnd":37,"startMs":1880,"endMs":2160},{"word":"would","charStart":38,"charEnd":43,"startMs":2160,"endMs":2340},{"word":"help","charStart":44,"charEn