{"id":"daily-3-my-new-friend","slug":"daily-3-my-new-friend","title":"My New Friend","title_ko":"내 새 친구","level":"A2","ageBand":"8-10","coverUrl":"/seed/daily-3-my-new-friend/cover.webp","summary_ko":"교실에서 새 친구를 만나 이름과 좋아하는 것을 묻고 답하는 이야기. 자기소개와 친구 사귀는 표현을 배워요.","wordCount":163,"stage":3,"collection":"daily","pages":[{"id":"daily-3-my-new-friend-p1","pageNo":1,"spread":"p1","imageUrl":"/seed/daily-3-my-new-friend/p1.webp","sentences":[{"id":"daily-3-my-new-friend-p1-s1","ord":0,"text":"A new boy is in my class.","translation_ko":"우리 반에 새 친구가 왔어요.","audioUrl":"/seed/daily-3-my-new-friend/audio/p1-s1.mp3","wordTimings":[{"word":"A","charStart":0,"charEnd":1,"startMs":0,"endMs":640},{"word":"new","charStart":2,"charEnd":5,"startMs":640,"endMs":840},{"word":"boy","charStart":6,"charEnd":9,"startMs":840,"endMs":1040},{"word":"is","charStart":10,"charEnd":12,"startMs":1040,"endMs":1220},{"word":"in","charStart":13,"charEnd":15,"startMs":1220,"endMs":1320},{"word":"my","charStart":16,"charEnd":18,"startMs":1320,"endMs":1560},{"word":"class","charStart":19,"charEnd":24,"startMs":1560,"endMs":1840}]},{"id":"daily-3-my-new-friend-p1-s2","ord":1,"text":"He looks a little nervous.","translation_ko":"그는 조금 긴장해 보여요.","audioUrl":"/seed/daily-3-my-new-friend/audio/p1-s2.mp3","wordTimings":[{"word":"He","charStart":0,"charEnd":2,"startMs":0,"endMs":360},{"word":"looks","charStart":3,"charEnd":8,"startMs":360,"endMs":680},{"word":"a","charStart":9,"charEnd":10,"startMs":680,"endMs":840},{"word":"little","charStart":11,"charEnd":17,"startMs":840,"endMs":1060},{"word":"nervous","charStart":18,"charEnd":25,"startMs":1060,"endMs":1480}]},{"id":"daily-3-my-new-friend-p1-s3","ord":2,"text":"I want to say hello.","translation_ko":"나는 인사를 건네고 싶어요.","audioUrl":"/seed/daily-3-my-new-friend/audio/p1-s3.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":280},{"word":"want","charStart":2,"charEnd":6,"startMs":280,"endMs":580},{"word":"to","charStart":7,"charEnd":9,"startMs":580,"endMs":860},{"word":"say","charStart":10,"charEnd":13,"startMs":860,"endMs":1000},{"word":"hello","charStart":14,"charEnd":19,"startMs":1000,"endMs":1340}]}]},{"id":"daily-3-my-new-friend-p2","pageNo":2,"spread":"p2","imageUrl":"/seed/daily-3-my-new-friend/p2.webp","sentences":[{"id":"daily-3-my-new-friend-p2-s1","ord":0,"text":"I walk up to him.","translation_ko":"나는 그에게 다가가요.","audioUrl":"/seed/daily-3-my-new-friend/audio/p2-s1.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":340},{"word":"walk","charStart":2,"charEnd":6,"startMs":340,"endMs":600},{"word":"up","charStart":7,"charEnd":9,"startMs":600,"endMs":780},{"word":"to","charStart":10,"charEnd":12,"startMs":780,"endMs":900},{"word":"him","charStart":13,"charEnd":16,"startMs":900,"endMs":1080}]},{"id":"daily-3-my-new-friend-p2-s2","ord":1,"text":"I smile and wave my hand.","translation_ko":"나는 미소를 지으며 손을 흔들어요.","audioUrl":"/seed/daily-3-my-new-friend/audio/p2-s2.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":300},{"word":"smile","charStart":2,"charEnd":7,"startMs":300,"endMs":660},{"word":"and","charStart":8,"charEnd":11,"startMs":660,"endMs":1460},{"word":"wave","charStart":12,"charEnd":16,"startMs":1460,"endMs":1620},{"word":"my","charStart":17,"charEnd":19,"startMs":1620,"endMs":1900},{"word":"hand","charStart":20,"charEnd":24,"startMs":1900,"endMs":2140}]},{"id":"daily-3-my-new-friend-p2-s3","ord":2,"text":"\"Hi! My name is Sam.\"","translation_ko":"\"안녕! 내 이름은 샘이야.\"","audioUrl":"/seed/daily-3-my-new-friend/audio/p2-s3.mp3","wordTimings":[{"word":"Hi","charStart":1,"charEnd":3,"startMs":0,"endMs":440},{"word":"My","charStart":5,"charEnd":7,"startMs":540,"endMs":1220},{"word":"name","charStart":8,"charEnd":12,"startMs":1220,"endMs":1340},{"word":"is","charStart":13,"charEnd":15,"startMs":1340,"endMs":1560},{"word":"Sam","charStart":16,"charEnd":19,"startMs":1560,"endMs":1780}]}]},{"id":"daily-3-my-new-friend-p3","pageNo":3,"spread":"p3","imageUrl":"/seed/daily-3-my-new-friend/p3.webp","sentences":[{"id":"daily-3-my-new-friend-p3-s1","ord":0,"text":"\"Hello, Sam. I am Leo,\" he says.","translation_ko":"\"안녕, 샘. 나는 레오야,\" 그가 말해요.","audioUrl":"/seed/daily-3-my-new-friend/audio/p3-s1.mp3","wordTimings":[{"word":"Hello","charStart":1,"charEnd":6,"startMs":0,"endMs":780},{"word":"Sam","charStart":8,"charEnd":11,"startMs":1160,"endMs":1280},{"word":"I","charStart":13,"charEnd":14,"startMs":1780,"endMs":1980},{"word":"am","charStart":15,"charEnd":17,"startMs":1980,"endMs":2160},{"word":"Leo","charStart":18,"charEnd":21,"startMs":2160,"endMs":2500},{"word":"he","charStart":24,"charEnd":26,"startMs":2940,"endMs":2940},{"word":"says","charStart":27,"charEnd":31,"startMs":2940,"endMs":3240}]},{"id":"daily-3-my-new-friend-p3-s2","ord":1,"text":"He smiles back at me.","translation_ko":"그도 나에게 미소를 지어요.","audioUrl":"/seed/daily-3-my-new-friend/audio/p3-s2.mp3","wordTimings":[{"word":"He","charStart":0,"charEnd":2,"startMs":0,"endMs":760},{"word":"smiles","charStart":3,"charEnd":9,"startMs":760,"endMs":1080},{"word":"back","charStart":10,"charEnd":14,"startMs":1080,"endMs":1380},{"word":"at","charStart":15,"charEnd":17,"startMs":1380,"endMs":1560},{"word":"me","charStart":18,"charEnd":20,"startMs":1560,"endMs":1680}]},{"id":"daily-3-my-new-friend-p3-s3","ord":2,"text":"I am happy that he is not shy anymore.","translation_ko":"그가 더 이상 부끄러워하지 않아서 나는 기뻐요.","audioUrl":"/seed/daily-3-my-new-friend/audio/p3-s3.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":280},{"word":"am","charStart":2,"charEnd":4,"startMs":280,"endMs":560},{"word":"happy","charStart":5,"charEnd":10,"startMs":560,"endMs":880},{"word":"that","charStart":11,"charEnd":15,"startMs":880,"endMs":1140},{"word":"he","charStart":16,"charEnd":18,"startMs":1140,"endMs":1300},{"word":"is","charStart":19,"charEnd":21,"startMs":1300,"endMs":1440},{"word":"not","charStart":22,"charEnd":25,"startMs":1440,"endMs":1840},{"word":"shy","charStart":26,"charEnd":29,"startMs":1840,"endMs":2140},{"word":"anymore","charStart":30,"charEnd":37,"startMs":2140,"endMs":2620}]}]},{"id":"daily-3-my-new-friend-p4","pageNo":4,"spread":"p4","imageUrl":"/seed/daily-3-my-new-friend/p4.webp","sentences":[{"id":"daily-3-my-new-friend-p4-s1","ord":0,"text":"\"What do you like, Leo?\"","translation_ko":"\"레오, 너는 뭘 좋아해?\"","audioUrl":"/seed/daily-3-my-new-friend/audio/p4-s1.mp3","wordTimings":[{"word":"What","charStart":1,"charEnd":5,"startMs":620,"endMs":1060},{"word":"do","charStart":6,"charEnd":8,"startMs":1060,"endMs":1220},{"word":"you","charStart":9,"charEnd":12,"startMs":1220,"endMs":1420},{"word":"like","charStart":13,"charEnd":17,"startMs":1420,"endMs":1660},{"word":"Leo","charStart":19,"charEnd":22,"startMs":1980,"endMs":1980}]},{"id":"daily-3-my-new-friend-p4-s2","ord":1,"text":"I am really curious about him.","translation_ko":"나는 그가 정말 궁금해요.","audioUrl":"/seed/daily-3-my-new-friend/audio/p4-s2.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":260},{"word":"am","charStart":2,"charEnd":4,"startMs":260,"endMs":520},{"word":"really","charStart":5,"charEnd":11,"startMs":520,"endMs":880},{"word":"curious","charStart":12,"charEnd":19,"startMs":880,"endMs":1500},{"word":"about","charStart":20,"charEnd":25,"startMs":1500,"endMs":1820},{"word":"him","charStart":26,"charEnd":29,"startMs":1820,"endMs":2000}]},{"id":"daily-3-my-new-friend-p4-s3","ord":2,"text":"I hope we like the same things.","translation_ko":"우리가 같은 것을 좋아하면 좋겠어요.","audioUrl":"/seed/daily-3-my-new-friend/audio/p4-s3.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":800},{"word":"hope","charStart":2,"charEnd":6,"startMs":800,"endMs":980},{"word":"we","charStart":7,"charEnd":9,"startMs":980,"endMs":1160},{"word":"like","charStart":10,"charEnd":14,"startMs":1160,"endMs":1380},{"word":"the","charStart":15,"charEnd":18,"startMs":1380,"endMs":1540},{"word":"same","charStart":19,"charEnd":23,"startMs":1540,"endMs":1800},{"word":"things","charStart":24,"charEnd":30,"startMs":1800,"endMs":2100}]}]},{"id":"daily-3-my-new-friend-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/daily-3-my-new-friend/p5.webp","sentences":[{"id":"daily-3-my-new-friend-p5-s1","ord":0,"text":"\"I like dogs and soccer,\" says Leo.","translation_ko":"\"나는 개와 축구를 좋아해,\" 레오가 말해요.","audioUrl":"/seed/daily-3-my-new-friend/audio/p5-s1.mp3","wordTimings":[{"word":"I","charStart":1,"charEnd":2,"startMs":0,"endMs":400},{"word":"like","charStart":3,"charEnd":7,"startMs":400,"endMs":760},{"word":"dogs","charStart":8,"charEnd":12,"startMs":760,"endMs":1120},{"word":"and","charStart":13,"charEnd":16,"startMs":1120,"endMs":1820},{"word":"soccer","charStart":17,"charEnd":23,"startMs":1820,"endMs":2260},{"word":"says","charStart":26,"charEnd":30,"startMs":2260,"endMs":2360},{"word":"Leo","charStart":31,"charEnd":34,"startMs":2360,"endMs":2640}]},{"id":"daily-3-my-new-friend-p5-s2","ord":1,"text":"\"I have a big brown dog at home.\"","translation_ko":"\"우리 집에 큰 갈색 강아지가 있어.\"","audioUrl":"/seed/daily-3-my-new-friend/audio/p5-s2.mp3","wordTimings":[{"word":"I","charStart":1,"charEnd":2,"startMs":0,"endMs":240},{"word":"have","charStart":3,"charEnd":7,"startMs":240,"endMs":460},{"word":"a","charStart":8,"charEnd":9,"startMs":460,"endMs":740},{"word":"big","charStart":10,"charEnd":13,"startMs":740,"endMs":1100},{"word":"brown","charStart":14,"charEnd":19,"startMs":1100,"endMs":1460},{"word":"dog","charStart":20,"charEnd":23,"startMs":1460,"endMs":1780},{"word":"at","charStart":24,"charEnd":26,"startMs":1780,"endMs":2080},{"word":"home","charStart":27,"charEnd":31,"startMs":2080,"endMs":2260}]},{"id":"daily-3-my-new-friend-p5-s3","ord":2,"text":"His eyes get bright when he talks about his dog.","translation_ko":"강아지 이야기를 할 때 그의 눈이 반짝여요.","audioUrl":"/seed/daily-3-my-new-friend/audio/p5-s3.mp3","wordTimings":[{"word":"His","charStart":0,"charEnd":3,"startMs":0,"endMs":560},{"word":"eyes","charStart":4,"charEnd":8,"startMs":560,"endMs":940},{"word":"get","charStart":9,"charEnd":12,"startMs":940,"endMs":1200},{"word":"bright","charStart":13,"charEnd":19,"startMs":1200,"endMs":1560},{"word":"when","charStart":20,"charEnd":24,"startMs":1560,"endMs":1920},{"word":"he","charStart":25,"charEnd":27,"startMs":1920,"endMs":2320},{"word":"talks","charStart":28,"charEnd":33,"startMs":2320,"endMs":2320},{"word":"about","charStart":34,"charEnd":39,"startMs":2320,"endMs":2600},{"word":"his","charStart":40,"charEnd":43,"startMs":2600,"endMs":2840},{"word":"dog","charStart":44,"charEnd":47,"startMs":2840,"endMs":3080}]}]},{"id":"daily-3-my-new-friend-p6","pageNo":6,"spread":"p6","imageUrl":"/seed/daily-3-my-new-friend/p6.webp","sentences":[{"id":"daily-3-my-new-friend-p6-s1","ord":0,"text":"\"Me too! I like soccer,\" I say.","translation_ko":"\"나도! 나도 축구를 좋아해,\" 내가 말해요.","audioUrl":"/seed/daily-3-my-new-friend/audio/p6-s1.mp3","wordTimings":[{"word":"Me","charStart":1,"charEnd":3,"startMs":0,"endMs":320},{"word":"too","charStart":4,"charEnd":7,"startMs":320,"endMs":640},{"word":"I","charStart":9,"charEnd":10,"startMs":1140,"endMs":1360},{"word":"like","charStart":11,"charEnd":15,"startMs":1360,"endMs":1560},{"word":"soccer","charStart":16,"charEnd":22,"startMs":1560,"endMs":1880},{"word":"I","charStart":25,"charEnd":26,"startMs":2200,"endMs":2320},{"word":"say","charStart":27,"charEnd":30,"startMs":2320,"endMs":2540}]},{"id":"daily-3-my-new-friend-p6-s2","ord":1,"text":"\"We can play soccer together after school!\"","translation_ko":"\"우리 학교 끝나고 같이 축구할 수 있어!\"","audioUrl":"/seed/daily-3-my-new-friend/audio/p6-s2.mp3","wordTimings":[{"word":"We","charStart":1,"charEnd":3,"startMs":0,"endMs":300},{"word":"can","charStart":4,"charEnd":7,"startMs":300,"endMs":560},{"word":"play","charStart":8,"charEnd":12,"startMs":560,"endMs":940},{"word":"soccer","charStart":13,"charEnd":19,"startMs":940,"endMs":1300},{"word":"together","charStart":20,"charEnd":28,"startMs":1300,"endMs":1800},{"word":"after","charStar