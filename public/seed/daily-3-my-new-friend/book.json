,"charEnd":15,"startMs":840,"endMs":860},{"word":"the","charStart":16,"charEnd":19,"startMs":860,"endMs":1080},{"word":"ball","charStart":20,"charEnd":24,"startMs":1080,"endMs":1300},{"word":"and","charStart":25,"charEnd":28,"startMs":1300,"endMs":1740},{"word":"laugh","charStart":29,"charEnd":34,"startMs":1740,"endMs":1980},{"word":"a","charStart":35,"charEnd":36,"startMs":1980,"endMs":2160},{"word":"lot","charStart":37,"charEnd":40,"startMs":2160,"endMs":2340}]},{"id":"daily-3-my-new-friend-p7-s3","ord":2,"text":"Now we are friends.","translation_ko":"이제 우리는 친구예요.","audioUrl":"/seed/daily-3-my-new-friend/audio/p7-s3.mp3","wordTimings":[{"word":"Now","charStart":0,"charEnd":3,"startMs":0,"endMs":380},{"word":"we","charStart":4,"charEnd":6,"startMs":380,"endMs":580},{"word":"are","charStart":7,"charEnd":10,"startMs":580,"endMs":820},{"word":"friends","charStart":11,"charEnd":18,"startMs":820,"endMs":1220}]}]},{"id":"daily-3-my-new-friend-p8","pageNo":8,"spread":"p8","imageUrl":"/seed/daily-3-my-new-friend/p8.webp","sentences":[{"id":"daily-3-my-new-friend-p8-s1","ord":0,"text":"Now we sit together and read the same book.","translation_ko":"이제 우리는 함께 앉아 같은 책을 읽어요.","audioUrl":"/seed/daily-3-my-new-friend/audio/p8-s1.mp3","wordTimings":[{"word":"Now","charStart":0,"charEnd":3,"startMs":0,"endMs":340},{"word":"we","charStart":4,"charEnd":6,"startMs":340,"endMs":620},{"word":"sit","charStart":7,"charEnd":10,"startMs":620,"endMs":800},{"word":"together","charStart":11,"charEnd":19,"startMs":800,"endMs":1180},{"word":"and","charStart":20,"charEnd":23,"startMs":1180,"endMs":1720},{"word":"read","charStart":24,"charEnd":28,"startMs":1720,"endMs":1840},{"word":"the","charStart":29,"charEnd":32,"startMs":1840,"endMs":2040},{"word":"same","charStart":33,"charEnd":37,"startMs":2040,"endMs":2320},{"word":"book","charStart":38,"charEnd":42,"startMs":2320,"endMs":2520}]},{"id":"daily-3-my-new-friend-p8-s2","ord":1,"text":"It feels so good to have a new friend.","translation_ko":"새 친구가 생기니 정말 기분이 좋아요.","audioUrl":"/seed/daily-3-my-new-friend/audio/p8-s2.mp3","wordTimings":[{"word":"It","charStart":0,"charEnd":2,"startMs":0,"endMs":220},{"word":"feels","charStart":3,"charEnd":8,"startMs":220,"endMs":560},{"word":"so","charStart":9,"charEnd":11,"startMs":560,"endMs":1160},{"word":"good","charStart":12,"charEnd":16,"startMs":1160,"endMs":1500},{"word":"to","charStart":17,"charEnd":19,"startMs":1500,"endMs":1920},{"word":"have","charStart":20,"charEnd":24,"startMs":1920,"endMs":2020},{"word":"a","charStart":25,"charEnd":26,"startMs":2020,"endMs":2220},{"word":"new","charStart":27,"charEnd":30,"startMs":2220,"endMs":2400},{"word":"friend","charStart":31,"charEnd":37,"startMs":2400,"endMs":2500}]},{"id":"daily-3-my-new-friend-p8-s3","ord":2,"text":"I am glad I said hello first.","translation_ko":"내가 먼저 인사했길 잘했어요.","audioUrl":"/seed/daily-3-my-new-friend/audio/p8-s3.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":180},{"word":"am","charStart":2,"charEnd":4,"startMs":180,"endMs":420},{"word":"glad","charStart":5,"charEnd":9,"startMs":420,"endMs":760},{"word":"I","charStart":10,"charEnd":11,"startMs":760,"endMs":1100},{"word":"said","charStart":12,"charEnd":16,"startMs":1100,"endMs":1220},{"word":"hello","charStart":17,"charEnd":22,"startMs":1220,"endMs":1480},{"word":"first","charStart":23,"charEnd":28,"startMs":1480,"endMs":1880}]}]}],"quiz":[{"question_ko":"새 친구의 이름은 무엇인가요?","type":"mc","options":["톰","믹","샘","레오"],"answerIndex":3,"explain_ko":"새 친구의 이름은 레오예요. (말하는 아이는 샘)","id":"daily-3-my-new-friend-q1","ord":0},{"question_ko":"레오가 좋아하는 것은 무엇인가요?","type":"mc","options":["개와 축구","물고기와 야구","고양이와 농구","새와 달리기"],"answerIndex":0,"explain_ko":"dogs and soccer — 개와 축구를 좋아해요.","id":"daily-3-my-new-friend-q2","ord":1},{"question_ko":"\"What do you like?\"는 무슨 뜻일까요?","type":"mc","options":["어디 살아?","이름이 뭐야?","뭘 좋아해?","몇 살이야?"],"answerIndex":2,"explain_ko":"like는 좋아하다 — 무엇을 좋아하는지 묻는 말이에요.","id":"daily-3-my-new-friend-q3","ord":2},{"question_ko":"두 친구는 언제 함께 놀았나요?","type":"mc","options":["저녁","아침","점심시간","주말"],"answerIndex":2,"explain_ko":"at lunch — 점심시간에 함께 놀았어요.","id":"daily-3-my-new-friend-q4","ord":3},{"question_ko":"\"Me too\"는 어떤 뜻인가요?","type":"mc","options":["나도 그래","아니야","고마워","잘 가"],"answerIndex":0,"explain_ko":"Me too는 \"나도 그래\"라는 뜻이에요.","id":"daily-3-my-new-friend-q5","ord":4}]}