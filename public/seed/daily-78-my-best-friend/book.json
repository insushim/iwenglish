{"id":"daily-78-my-best-friend","slug":"daily-78-my-best-friend","title":"My Best Friend","title_ko":"내 단짝","level":"A1","ageBand":"8-10","coverUrl":"/seed/daily-78-my-best-friend/cover.webp","summary_ko":"준과 단짝 미나가 함께 놀며 즐거운 하루를 보내는 이야기입니다.","wordCount":105,"stage":2,"collection":"daily","pages":[{"id":"daily-78-my-best-friend-p1","pageNo":1,"spread":"p1","imageUrl":"/seed/daily-78-my-best-friend/p1.webp","sentences":[{"id":"daily-78-my-best-friend-p1-s1","ord":0,"text":"Mina is my best friend.","translation_ko":"미나는 내 단짝이에요.","audioUrl":"/seed/daily-78-my-best-friend/audio/p1-s1.mp3","wordTimings":[{"word":"Mina","charStart":0,"charEnd":4,"startMs":0,"endMs":520},{"word":"is","charStart":5,"charEnd":7,"startMs":520,"endMs":980},{"word":"my","charStart":8,"charEnd":10,"startMs":980,"endMs":1240},{"word":"best","charStart":11,"charEnd":15,"startMs":1240,"endMs":1600},{"word":"friend","charStart":16,"charEnd":22,"startMs":1600,"endMs":1920}]},{"id":"daily-78-my-best-friend-p1-s2","ord":1,"text":"She lives next door.","translation_ko":"미나는 바로 옆집에 살아요.","audioUrl":"/seed/daily-78-my-best-friend/audio/p1-s2.mp3","wordTimings":[{"word":"She","charStart":0,"charEnd":3,"startMs":0,"endMs":740},{"word":"lives","charStart":4,"charEnd":9,"startMs":740,"endMs":1100},{"word":"next","charStart":10,"charEnd":14,"startMs":1100,"endMs":1760},{"word":"door","charStart":15,"charEnd":19,"startMs":1760,"endMs":1980}]}]},{"id":"daily-78-my-best-friend-p2","pageNo":2,"spread":"p2","imageUrl":"/seed/daily-78-my-best-friend/p2.webp","sentences":[{"id":"daily-78-my-best-friend-p2-s1","ord":0,"text":"On Saturday, I called Mina.","translation_ko":"토요일에 나는 미나에게 전화했어요.","audioUrl":"/seed/daily-78-my-best-friend/audio/p2-s1.mp3","wordTimings":[{"word":"On","charStart":0,"charEnd":2,"startMs":0,"endMs":700},{"word":"Saturday","charStart":3,"charEnd":11,"startMs":700,"endMs":1140},{"word":"I","charStart":13,"charEnd":14,"startMs":1620,"endMs":1780},{"word":"called","charStart":15,"charEnd":21,"startMs":1780,"endMs":2020},{"word":"Mina","charStart":22,"charEnd":26,"startMs":2020,"endMs":2300}]},{"id":"daily-78-my-best-friend-p2-s2","ord":1,"text":"\"Do you want to play?\" I asked.","translation_ko":"\"같이 놀래?\" 하고 내가 물었어요.","audioUrl":"/seed/daily-78-my-best-friend/audio/p2-s2.mp3","wordTimings":[{"word":"Do","charStart":1,"charEnd":3,"startMs":0,"endMs":520},{"word":"you","charStart":4,"charEnd":7,"startMs":520,"endMs":760},{"word":"want","charStart":8,"charEnd":12,"startMs":760,"endMs":980},{"word":"to","charStart":13,"charEnd":15,"startMs":980,"endMs":1440},{"word":"play","charStart":16,"charEnd":20,"startMs":1440,"endMs":1440},{"word":"I","charStart":23,"charEnd":24,"startMs":1980,"endMs":2220},{"word":"asked","charStart":25,"charEnd":30,"startMs":2220,"endMs":2500}]}]},{"id":"daily-78-my-best-friend-p3","pageNo":3,"spread":"p3","imageUrl":"/seed/daily-78-my-best-friend/p3.webp","sentences":[{"id":"daily-78-my-best-friend-p3-s1","ord":0,"text":"\"Yes! Come over!\" said Mina.","translation_ko":"\"응! 우리 집으로 와!\" 미나가 말했어요.","audioUrl":"/seed/daily-78-my-best-friend/audio/p3-s1.mp3","wordTimings":[{"word":"Yes","charStart":1,"charEnd":4,"startMs":0,"endMs":840},{"word":"Come","charStart":6,"charEnd":10,"startMs":1320,"endMs":1540},{"word":"over","charStart":11,"charEnd":15,"startMs":1540,"endMs":2300},{"word":"said","charStart":18,"charEnd":22,"startMs":2300,"endMs":2400},{"word":"Mina","charStart":23,"charEnd":27,"startMs":2400,"endMs":2600}]}]},{"id":"daily-78-my-best-friend-p4","pageNo":4,"spread":"p4","imageUrl":"/seed/daily-78-my-best-friend/p4.webp","sentences":[{"id":"daily-78-my-best-friend-p4-s1","ord":0,"text":"We played in the park and ran fast.","translation_ko":"우리는 공원에서 놀며 빠르게 달렸어요.","audioUrl":"/seed/daily-78-my-best-friend/audio/p4-s1.mp3","wordTimings":[{"word":"We","charStart":0,"charEnd":2,"startMs":0,"endMs":700},{"word":"played","charStart":3,"charEnd":9,"startMs":700,"endMs":960},{"word":"in","charStart":10,"charEnd":12,"startMs":960,"endMs":1100},{"word":"the","charStart":13,"charEnd":16,"startMs":1100,"endMs":1480},{"word":"park","charStart":17,"charEnd":21,"startMs":1480,"endMs":1500},{"word":"and","charStart":22,"charEnd":25,"startMs":1500,"endMs":1960},{"word":"ran","charStart":26,"charEnd":29,"startMs":1960,"endMs":2160},{"word":"fast","charStart":30,"charEnd":34,"startMs":2160,"endMs":2660}]},{"id":"daily-78-my-best-friend-p4-s2","ord":1,"text":"Mina won, but I did not give up.","translation_ko":"미나가 이겼지만 나는 포기하지 않았어요.","audioUrl":"/seed/daily-78-my-best-friend/audio/p4-s2.mp3","wordTimings":[{"word":"Mina","charStart":0,"charEnd":4,"startMs":0,"endMs":480},{"word":"won","charStart":5,"charEnd":8,"startMs":480,"endMs":860},{"word":"but","charStart":10,"charEnd":13,"startMs":1320,"endMs":1400},{"word":"I","charStart":14,"charEnd":15,"startMs":1400,"endMs":1560},{"word":"did","charStart":16,"charEnd":19,"startMs":1560,"endMs":1700},{"word":"not","charStart":20,"charEnd":23,"startMs":1700,"endMs":1960},{"word":"give","charStart":24,"charEnd":28,"startMs":1960,"endMs":2120},{"word":"up","charStart":29,"charEnd":31,"startMs":2120,"endMs":2320}]}]},{"id":"daily-78-my-best-friend-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/daily-78-my-best-friend/p5.webp","sentences":[{"id":"daily-78-my-best-friend-p5-s1","ord":0,"text":"We found a little cat near the swing.","translation_ko":"우리는 그네 근처에서 작은 고양이를 발견했어요.","audioUrl":"/seed/daily-78-my-best-friend/audio/p5-s1.mp3","wordTimings":[{"word":"We","charStart":0,"charEnd":2,"startMs":0,"endMs":340},{"word":"found","charStart":3,"charEnd":8,"startMs":340,"endMs":740},{"word":"a","charStart":9,"charEnd":10,"startMs":740,"endMs":1040},{"word":"little","charStart":11,"charEnd":17,"startMs":1040,"endMs":1300},{"word":"cat","charStart":18,"charEnd":21,"startMs":1300,"endMs":1680},{"word":"near","charStart":22,"charEnd":26,"startMs":1680,"endMs":2000},{"word":"the","charStart":27,"charEnd":30,"startMs":2000,"endMs":2260},{"word":"swing","charStart":31,"charEnd":36,"startMs":2260,"endMs":2480}]},{"id":"daily-78-my-best-friend-p5-s2","ord":1,"text":"\"It is so cute!\" I said.","translation_ko":"\"너무 귀엽다!\" 준이 말했어요.","audioUrl":"/seed/daily-78-my-best-friend/audio/p5-s2.mp3","wordTimings":[{"word":"It","charStart":1,"charEnd":3,"startMs":0,"endMs":380},{"word":"is","charStart":4,"charEnd":6,"startMs":380,"endMs":780},{"word":"so","charStart":7,"charEnd":9,"startMs":780,"endMs":1440},{"word":"cute","charStart":10,"charEnd":14,"startMs":1440,"endMs":2240},{"word":"I","charStart":17,"charEnd":18,"startMs":2240,"endMs":2820},{"word":"said","charStart":19,"charEnd":23,"startMs":2820,"endMs":3020}]}]},{"id":"daily-78-my-best-friend-p6","pageNo":6,"spread":"p6","imageUrl":"/seed/daily-78-my-best-friend/p6.webp","sentences":[{"id":"daily-78-my-best-friend-p6-s1","ord":0,"text":"We gave the cat some water.","translation_ko":"우리는 고양이에게 물을 줬어요.","audioUrl":"/seed/daily-78-my-best-friend/audio/p6-s1.mp3","wordTimings":[{"word":"We","charStart":0,"charEnd":2,"startMs":0,"endMs":320},{"word":"gave","charStart":3,"charEnd":7,"startMs":320,"endMs":500},{"word":"the","charStart":8,"charEnd":11,"startMs":500,"endMs":720},{"word":"cat","charStart":12,"charEnd":15,"startMs":720,"endMs":1000},{"word":"some","charStart":16,"charEnd":20,"startMs":1000,"endMs":1520},{"word":"water","charStart":21,"charEnd":26,"startMs":1520,"endMs":1740}]},{"id":"daily-78-my-best-friend-p6-s2","ord":1,"text":"The cat drank it and purred.","translation_ko":"고양이는 물을 마시고 골골댔어요.","audioUrl":"/seed/daily-78-my-best-friend/audio/p6-s2.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":200},{"word":"cat","charStart":4,"charEnd":7,"startMs":200,"endMs":500},{"word":"drank","charStart":8,"charEnd":13,"startMs":500,"endMs":800},{"word":"it","charStart":14,"charEnd":16,"startMs":800,"endMs":1060},{"word":"and","charStart":17,"charEnd":20,"startMs":1060,"endMs":1560},{"word":"purred","charStart":21,"charEnd":27,"startMs":1560,"endMs":1740}]}]},{"id"