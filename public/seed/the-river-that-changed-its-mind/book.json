":"이제 아이들은 다시 물장구를 치고, 텃밭은 물을 마음껏 마셔요.","audioUrl":"/seed/the-river-that-changed-its-mind/audio/p13-s1.mp3","wordTimings":[{"word":"Now","charStart":0,"charEnd":3,"startMs":0,"endMs":340},{"word":"the","charStart":4,"charEnd":7,"startMs":340,"endMs":600},{"word":"children","charStart":8,"charEnd":16,"startMs":600,"endMs":900},{"word":"splash","charStart":17,"charEnd":23,"startMs":900,"endMs":1480},{"word":"again","charStart":24,"charEnd":29,"startMs":1480,"endMs":1860},{"word":"and","charStart":31,"charEnd":34,"startMs":2360,"endMs":2360},{"word":"the","charStart":35,"charEnd":38,"startMs":2360,"endMs":2560},{"word":"gardens","charStart":39,"charEnd":46,"startMs":2560,"endMs":2880},{"word":"drink","charStart":47,"charEnd":52,"startMs":2880,"endMs":3280},{"word":"their","charStart":53,"charEnd":58,"startMs":3280,"endMs":3600},{"word":"fill","charStart":59,"charEnd":63,"startMs":3600,"endMs":3820}]},{"id":"the-river-that-changed-its-mind-p13-s2","ord":1,"text":"The village learned that when something changes, you can grow and change with it.","translation_ko":"마을은 무언가 변할 때 함께 자라고 변할 수 있다는 것을 배웠어요.","audioUrl":"/seed/the-river-that-changed-its-mind/audio/p13-s2.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":260},{"word":"village","charStart":4,"charEnd":11,"startMs":260,"endMs":600},{"word":"learned","charStart":12,"charEnd":19,"startMs":600,"endMs":960},{"word":"that","charStart":20,"charEnd":24,"startMs":960,"endMs":1240},{"word":"when","charStart":25,"charEnd":29,"startMs":1240,"endMs":1420},{"word":"something","charStart":30,"charEnd":39,"startMs":1420,"endMs":1740},{"word":"changes","charStart":40,"charEnd":47,"startMs":1740,"endMs":2260},{"word":"you","charStart":49,"charEnd":52,"startMs":2640,"endMs":2660},{"word":"can","charStart":53,"charEnd":56,"startMs":2660,"endMs":2900},{"word":"grow","charStart":57,"charEnd":61,"startMs":2900,"endMs":3160},{"word":"and","charStart":62,"charEnd":65,"startMs":3160,"endMs":3500},{"word":"chan