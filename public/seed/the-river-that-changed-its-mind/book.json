ordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":320},{"word":"thin","charStart":4,"charEnd":8,"startMs":320,"endMs":700},{"word":"branches","charStart":9,"charEnd":17,"startMs":700,"endMs":1160},{"word":"leaned","charStart":18,"charEnd":24,"startMs":1160,"endMs":1520},{"word":"toward","charStart":25,"charEnd":31,"startMs":1520,"endMs":1780},{"word":"the","charStart":32,"charEnd":35,"startMs":1780,"endMs":1980},{"word":"new","charStart":36,"charEnd":39,"startMs":1980,"endMs":2220},{"word":"path","charStart":40,"charEnd":44,"startMs":2220,"endMs":2560},{"word":"as","charStart":46,"charEnd":48,"startMs":3020,"endMs":3080},{"word":"if","charStart":49,"charEnd":51,"startMs":3080,"endMs":3200},{"word":"to","charStart":52,"charEnd":54,"startMs":3200,"endMs":3400},{"word":"call","charStart":55,"charEnd":59,"startMs":3400,"endMs":3580},{"word":"the","charStart":60,"charEnd":63,"startMs":3580,"endMs":3820},{"word":"river","charStart":64,"charEnd":69,"startMs":3820,"endMs":4000},{"word":"home","charStart":70,"charEnd":74,"startMs":4000,"endMs":4380}]}]},{"id":"the-river-that-changed-its-mind-p11","pageNo":11,"spread":"p11","imageUrl":"/seed/the-river-that-changed-its-mind/p11.webp","sentences":[{"id":"the-river-that-changed-its-mind-p11-s1","ord":0,"text":"Day after day the people waited and watched the sky.","translation_ko":"사람들은 날마다 하늘을 바라보며 기다렸어요.","audioUrl":"/seed/the-river-that-changed-its-mind/audio/p11-s1.mp3","wordTimings":[{"word":"Day","charStart":0,"charEnd":3,"startMs":0,"endMs":380},{"word":"after","charStart":4,"charEnd":9,"startMs":380,"endMs":860},{"word":"day","charStart":10,"charEnd":13,"startMs":860,"endMs":1060},{"word":"the","charStart":14,"charEnd":17,"startMs":1200,"endMs":1340},{"word":"people","charStart":18,"charEnd":24,"startMs":1340,"endMs":1640},{"word":"waited","charStart":25,"charEnd":31,"startMs":1640,"endMs":2000},{"word":"and","charStart":32,"charEnd":35,"startMs":2000,"endMs":2460},{"word":"watched","charStart":36,"