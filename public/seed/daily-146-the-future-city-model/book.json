 empty, and Jun frowned at it.","translation_ko":"그런데 한쪽 귀퉁이가 여전히 비어 있어서 준이 찡그렸어요.","audioUrl":"/seed/daily-146-the-future-city-model/audio/p7-s2.mp3","wordTimings":[{"word":"But","charStart":0,"charEnd":3,"startMs":0,"endMs":200},{"word":"one","charStart":4,"charEnd":7,"startMs":200,"endMs":540},{"word":"corner","charStart":8,"charEnd":14,"startMs":540,"endMs":840},{"word":"was","charStart":15,"charEnd":18,"startMs":840,"endMs":1160},{"word":"still","charStart":19,"charEnd":24,"startMs":1160,"endMs":1420},{"word":"empty","charStart":25,"charEnd":30,"startMs":1420,"endMs":1720},{"word":"and","charStart":32,"charEnd":35,"startMs":2320,"endMs":2440},{"word":"Jun","charStart":36,"charEnd":39,"startMs":2440,"endMs":2720},{"word":"frowned","charStart":40,"charEnd":47,"startMs":2720,"endMs":3020},{"word":"at","charStart":48,"charEnd":50,"startMs":3020,"endMs":3260},{"word":"it","charStart":51,"charEnd":53,"startMs":3260,"endMs":3380}]}]},{"id":"daily-146-the-future-city-model-p8","pageNo":8,"spread":"p8","imageUrl":"/seed/daily-146-the-future-city-model/p8.webp","sentences":[{"id":"daily-146-the-future-city-model-p8-s1","ord":0,"text":"Mina looked closely and then clapped her hands.","translation_ko":"미나가 가까이서 살피다가 손뼉을 쳤어요.","audioUrl":"/seed/daily-146-the-future-city-model/audio/p8-s1.mp3","wordTimings":[{"word":"Mina","charStart":0,"charEnd":4,"startMs":0,"endMs":400},{"word":"looked","charStart":5,"charEnd":11,"startMs":400,"endMs":760},{"word":"closely","charStart":12,"charEnd":19,"startMs":760,"endMs":1280},{"word":"and","charStart":20,"charEnd":23,"startMs":1280,"endMs":2060},{"word":"then","charStart":24,"charEnd":28,"startMs":2060,"endMs":2400},{"word":"clapped","charStart":29,"charEnd":36,"startMs":2400,"endMs":2600},{"word":"her","charStart":37,"charEnd":40,"startMs":2600,"endMs":2900},{"word":"hands","charStart":41,"charEnd":46,"startMs":2900,"endMs":3320}]},{"id":"daily-146-the-future-city-model-p8-s2","ord":1,"text":"\"People need a place to gather,\" she sai