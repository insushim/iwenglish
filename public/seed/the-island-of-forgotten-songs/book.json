land-of-forgotten-songs/audio/p8-s1.mp3","wordTimings":[{"word":"Tiny","charStart":0,"charEnd":4,"startMs":0,"endMs":880},{"word":"lights","charStart":5,"charEnd":11,"startMs":880,"endMs":1200},{"word":"floated","charStart":12,"charEnd":19,"startMs":1200,"endMs":1600},{"word":"among","charStart":20,"charEnd":25,"startMs":1600,"endMs":1840},{"word":"the","charStart":26,"charEnd":29,"startMs":1840,"endMs":2400},{"word":"trees","charStart":30,"charEnd":35,"startMs":2400,"endMs":2400},{"word":"and","charStart":37,"charEnd":40,"startMs":3260,"endMs":3300},{"word":"each","charStart":41,"charEnd":45,"startMs":3300,"endMs":3620},{"word":"one","charStart":46,"charEnd":49,"startMs":3620,"endMs":3820},{"word":"was","charStart":50,"charEnd":53,"startMs":3820,"endMs":4000},{"word":"a","charStart":54,"charEnd":55,"startMs":4000,"endMs":4380},{"word":"melody","charStart":56,"charEnd":62,"startMs":4380,"endMs":4380}]},{"id":"the-island-of-forgotten-songs-p8-s2","ord":1,"text":"These were the songs that no one in the world still sang.","translation_ko":"이것들은 세상 누구도 더는 부르지 않는 노래들이었어요.","audioUrl":"/seed/the-island-of-forgotten-songs/audio/p8-s2.mp3","wordTimings":[{"word":"These","charStart":0,"charEnd":5,"startMs":0,"endMs":340},{"word":"were","charStart":6,"charEnd":10,"startMs":340,"endMs":480},{"word":"the","charStart":11,"charEnd":14,"startMs":480,"endMs":740},{"word":"songs","charStart":15,"charEnd":20,"startMs":740,"endMs":1040},{"word":"that","charStart":21,"charEnd":25,"startMs":1040,"endMs":1420},{"word":"no","charStart":26,"charEnd":28,"startMs":1420,"endMs":1600},{"word":"one","charStart":29,"charEnd":32,"startMs":1600,"endMs":1760},{"word":"in","charStart":33,"charEnd":35,"startMs":1760,"endMs":1880},{"word":"the","charStart":36,"charEnd":39,"startMs":1880,"endMs":2180},{"word":"world","charStart":40,"charEnd":45,"startMs":2180,"endMs":2360},{"word":"still","charStart":46,"charEnd":51,"startMs":2360,"endMs":2720},{"word":"sang","charStart":52,"charEnd":56,"startMs":2720,"endMs":3120}]}]},{"id":"the-island-of-forgotten-songs-p9","pageNo":9,"spread":"p9","imageUrl":"/seed/the-island-of-forgotten-songs/p9.webp","sentences":[{"id":"the-island-of-forgotten-songs-p9-s1","ord":0,"text":"One light drifted close and brushed against Mara's hand.","translation_ko":"빛 하나가 가까이 떠와 마라의 손을 스쳤어요.","audioUrl":"/seed/the-island-of-forgotten-songs/audio/p9-s1.mp3","wordTimings":[{"word":"One","charStart":0,"charEnd":3,"startMs":0,"endMs":420},{"word":"light","charStart":4,"charEnd":9,"startMs":420,"endMs":920},{"word":"drifted","charStart":10,"charEnd":17,"startMs":920,"endMs":1620},{"word":"close","charStart":18,"charEnd":23,"startMs":1620,"endMs":2000},{"word":"and","charStart":24,"charEnd":27,"startMs":2000,"endMs":2380},{"word":"brushed","charStart":28,"charEnd":35,"startMs":2380,"endMs":2680},{"word":"against","charStart":36,"charEnd":43,"startMs":2680,"endMs":3160},{"word":"Mara's","charStart":44,"charEnd":50,"startMs":3160,"endMs":3680},{"word":"hand","charStart":51,"charEnd":55,"startMs":3680,"endMs":3900}]},{"id":"the-island-of-forgotten-songs-p9-s2","ord":1,"text":"Suddenly she felt warm, because she knew this song.","translation_ko":"갑자기 그녀는 따뜻함을 느꼈어요. 이 노래를 알고 있었기 때문이에요.","audioUrl":"/seed/the-island-of-forgotten-songs/audio/p9-s2.mp3","wordTimings":[{"word":"Suddenly","charStart":0,"charEnd":8,"startMs":0,"endMs":420},{"word":"she","charStart":9,"charEnd":12,"startMs":420,"endMs":720},{"word":"felt","charStart":13,"charEnd":17,"startMs":720,"endMs":980},{"word":"warm","charStart":18,"charEnd":22,"startMs":980,"endMs":1360},{"word":"because","charStart":24,"charEnd":31,"startMs":1360,"endMs":1940},{"word":"she","charStart":32,"charEnd":35,"startMs":1940,"endMs":2240},{"word":"knew","charStart":36,"charEnd":40,"startMs":2240,"endMs":2380},{"word":"this","charStart":41,"charEnd":45,"startMs":2380,"endMs":2680},{"word":"song","charStart":46,"charEnd":50,"startMs":2680,"endMs":2980}]}]},{"id":"the-island-of-forgotten-songs-p10","pageNo":10,"spread":"p10","imageUrl":"/seed/the-island-of-forgotten-songs/p10.webp","sentences":[{"id":"the-island-of-forgotten-songs-p10-s1","ord":0,"text":"It was her grandmother's lullaby, soft and slow and kind.","translation_ko":"그것은 할머니의 자장가였어요. 부드럽고 느리고 다정한 노래였죠.","audioUrl":"/seed/the-island-of-forgotten-songs/audio/p10-s1.mp3","wordTimings":[{"word":"It","charStart":0,"charEnd":2,"startMs":0,"endMs":740},{"word":"was","charStart":3,"charEnd":6,"startMs":740,"endMs":980},{"word":"her","charStart":7,"charEnd":10,"startMs":980,"endMs":1180},{"word":"grandmother's","charStart":11,"charEnd":24,"startMs":1180,"endMs":1880},{"word":"lullaby","charStart":25,"charEnd":32,"startMs":1880,"endMs":2220},{"word":"soft","charStart":34,"charEnd":38,"startMs":2680,"endMs":3000},{"word":"and","charStart":39,"charEnd":42,"startMs":3000,"endMs":3420},{"word":"slow","charStart":43,"charEnd":47,"startMs":3420,"endMs":3580},{"word":"and","charStart":48,"charEnd":51,"startMs":3580,"endMs":3880},{"word":"kind","charStart":52,"charEnd":56,"startMs":3880,"endMs":4160}]},{"id":"the-island-of-forgotten-songs-p10-s2","ord":1,"text":"Mara closed her eyes and listened until she could sing it too.","translation_ko":"마라는 눈을 감고 자기도 부를 수 있을 때까지 귀를 기울였어요.","audioUrl":"/seed/the-island-of-forgotten-songs/audio/p10-s2.mp3","wordTimings":[{"word":"Mara","charStart":0,"charEnd":4,"startMs":0,"endMs":400},{"word":"closed","charStart":5,"charEnd":11,"startMs":400,"endMs":820},{"word":"her","charStart":12,"charEnd":15,"startMs":820,"endMs":1100},{"word":"eyes","charStart":16,"charEnd":20,"startMs":1100,"endMs":1460},{"word":"and","charStart":21,"charEnd":24,"startMs":1460,"endMs":2060},{"word":"listened","charStart":25,"charEnd":33,"startMs":2060,"endMs":2360},{"word":"until","charStart":34,"charEnd":39,"startMs":2360,"endMs":2840},{"word":"she","charStart":40,"charEnd":43,"startMs":2840,"endMs":3060},{"word":"could","charStart":44,"charEnd":49,"startMs":3060,"endMs":3280},{"word":"sing","charStart":50,"charEnd":54,"startMs":3280,"endMs":3440},{"word":"it","charStart":55,"charEnd":57,"startMs":3440,"endMs":3680},{"word":"too","charStart":58,"charEnd":61,"startMs":3820,"endMs":3880}]}]},{"id":"the-island-of-forgotten-songs-p11","pageNo":11,"spread":"p11","imageUrl":"/seed/the-island-of-forgotten-songs/p11.webp","sentences":[{"id":"the-island-of-forgotten-songs-p11-s1","ord":0,"text":"\"We cannot carry every song,\" Theo said quietly.","translation_ko":"\"우리가 모든 노래를 가져갈 수는 없어.\" 테오가 조용히 말했어요.","audioUrl":"/seed/the-island-of-forgotten-songs/audio/p11-s1.mp3","wordTimings":[{"word":"We","charStart":1,"charEnd":3,"startMs":0,"endMs":220},{"word":"cannot","charStart":4,"charEnd":10,"startMs":220,"endMs":620},{"word":"carry","charStart":11,"charEnd":16,"startMs":620,"endMs":940},{"word":"every","charStart":17,"charEnd":22,"startMs":940,"endMs":1380},{"word":"song","charStart":23,"charEnd":27,"startMs":1380,"endMs":2220},{"word":"Theo","charStart":30,"charEnd":34,"startMs":2220,"endMs":2220},{"word":"said","charStart":35,"charEnd":39,"startMs":2220,"endMs":2420},{"word":"quietly","charStart":40,"charEnd":47,"startMs":2420,"endMs":2820}]},{"id":"the-island-of-forgotten-songs-p11-s2","ord":1,"text":"\"But one is enough, if we sing it for others.\"","translation_ko":"\"하지만 한 곡이면 충분해. 우리가 다른 사람들에게 불러 준다면 말이야.\"","audioUrl":"/seed/the-island-of-forgotten-songs/audio/p11-s2.mp3","wordTimings":[{"word":"But","charStart":1,"charEnd":4,"startMs":0,"endMs":260},{"word":"one","charStart":5,"charEnd":8,"startMs":260,"endMs":620},{"word":"is","charStart":9,"charEnd":11,"startMs":620,"endMs":880},{"word":"enough","charStart":12,"charEnd":18,"startMs":880,"endMs":1280},{"word":"if","charStart":20,"charEnd":22,"startMs":1280,"endMs":1960},{"word":"we","charStart":23,"charEnd":25,"startMs":1960,"endMs":2240},{"word":"sing","charStart":26,"charEnd":30,"startMs":2240,"endMs":2360},{"word":"it","charStart":31,"charEnd":33,"startMs":2360,"endMs":2520},{"word":"for","charStart":34,"charEnd":37,"startMs":2520,"endMs":2780},{"word":"others","charStart":38,"charEnd":44,"startMs":2780,"endMs":3060}]}]},{"id":"the-island-of-forgotten-songs-p12","pageNo":12,"spread":"p12","imageUrl":"/seed/the-island-of-forgotten-songs/p12.webp","sentences":[{"id":"the-island-of-forgotten-songs-p12-s1","ord":0,"text":"They sailed home as the lullaby grew strong inside them.","translation_ko":"자장가가 마음속에서 점점 또렷해지는 동안 둘은 집으로 향했어요.","audioUrl":"/seed/the-island-of-forgotten-songs/audio/p12-s1.mp3","wordTimings":[{"word":"They","charStart":0,"charEnd":4,"startMs":0,"endMs":400},{"word":"sailed","charStart":5,"charEnd":11,"startMs":400,"endMs":760},{"word":"home","charStart":12,"charEnd":16,"startMs":760,"endMs":1180},{"word":"as","charStart":17,"charEnd":19,"startMs":1180,"endMs":1520},{"word":"the","charStart":20,"charEnd":23,"startMs":1520,"endMs":1800},{"word":"lullaby","charStart":24,"charEnd":31,"startMs":1800,"endMs":2240},{"word":"grew","charStart":32,"charEnd":36,"startMs":2240,"endMs":2540},{"word":"strong","charStart":37,"charEnd":43,"startMs":2540,"endMs":3060},{"word":"inside","charStart":44,"charEnd":50,"startMs":3060,"endMs":3540},{"word":"them","charStart":51,"charEnd":55,"startMs":3540,"endMs":3780}]},{"id":"the-island-of-forgotten-songs-p12-s2","ord":1,"text":"The mist let them pass, as if it had been waiting for this.","translation_ko":"안개는 마치 이 순간을 기다렸다는 듯이 그들을 보내 주었어요.","audioUrl":"/seed/the-island-of-forgotten-songs/audio/p12-s2.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":280},{"word":"mist","charStart":4,"charEnd":8,"startMs":280,"endMs":640},{"word":"let","charStart":9,"charEnd":12,"startMs":640,"endMs":1100},{"word":"them","charStart":13,"charEnd":17,"startMs":1100,"endMs":1280},{"word":"pass","charStart":18,"charEnd":22,"startMs":1280,"endMs":1720},{"word":"as","charStart":24,"charEnd":26,"startMs":2220,"endMs":2300},{"word":"if","charStart":27,"charEnd":29,"startMs":2300,"endMs":2400},{"word":"it","charStart":30,"charEnd":32,"startMs":2400,"endMs":2540},{"word":"had","charStart":33,"charEnd":36,"startMs":2540,"endMs":2660},{"word":"been","charStart":37,"charEnd":41,"startMs":2660,"endMs":2880},{"word":"waiting","charStart":42,"charEnd":49,"startMs":2880,"endMs":3060},{"word":"for","charStart":50,"charEnd":53,"startMs":3060,"endMs":3320},{"word":"this","charStart":54,"charEnd":58,"startMs":3320,"endMs":3600}]}]},{"id":"the-island-of-forgotten-songs-p13","pageNo":13,"spread":"p13","imageUrl":"/seed/the-island-of-forgotten-songs/p13.webp","sentences":[{"id":"the-island-of-forgotten-songs-p13-s1","ord":0,"text":"That night, Mara sang the old lullaby on the village dock.","translation_ko":"그날 밤, 마라는 마을 부두에서 그 오래된 자장가를 불렀어요.","audioUrl":"/seed/the-island-of-forgotten-songs/audio/p13-s1.mp3","wordTimings":[{"word":"That","charStart":0,"charEnd":4,"startMs":0,"endMs":300},{"word":"night","charStart":5,"charEnd":10,"startMs":300,"endMs":660},{"word":"Mara","charStart":12,"charEnd":16,"startMs":960,"endMs":1260},{"word":"sang","charStart":17,"charEnd":21,"startMs":1260,"endMs":1520},{"word":"the","charStart":22,"charEnd":25,"startMs":1520,"endMs":1700},{"word":"old","charStart":26,"charEnd":29,"startMs":1700,"endMs":2040},{"word":"lullaby","charStart":30,"charEnd":37,"startMs":2040,"endMs":2420},{"word":"on","charStart":38,"charEnd":40,"startMs":2420,"endMs":2660},{"word":"the","charStart":41,"charEnd":44,"startMs":2660,"endMs":2840},{"word":"village","charStart":45,"charEnd":52,"startMs":2840,"endMs":3060},{"word":"dock","charStart":53,"charEnd":57,"startMs":3060,"endMs":3400}]},{"id":"the-island-of-forgotten-songs-p13-s2","ord":1,"text":"Children learned it, then their parents, until the whole village hummed along.","translation_ko":"아이들이 그 노래를 배웠고, 그다음엔 부모들이 배워서, 마침내 온 마을이 함께 흥얼거렸어요.","audioUrl":"/seed/the-island-of-forgotten-songs/audio/p13-s2.mp3","wordTimings":[{"word":"Children","charStart":0,"charEnd":8,"startMs":0,"endMs":500},{"word":"learned","charStart":9,"charEnd":16,"startMs":500,"endMs":880},{"word":"it","charStart":17,"charEnd":19,"startMs":880,"endMs":1160},{"word":"then","charStart":21,"charEnd":25,"startMs":1600,"endMs":1740},{"word":"their","charStart":26,"charEnd":31,"startMs":1740,"endMs":1940},{"word":"parents","charStart":32,"charEnd":39,"startMs":1940,"endMs":2360},{"word":"until","charStart":41,"charEnd":46,"startMs":2920,"endMs":3020},{"word":"the","charStart":47,"charEnd":50,"startMs":3020,"endMs":3240},{"word":"whole","charStart":51,"charEnd":56,"startMs":3240,"endMs":3560},{"word":"village","charStart":57,"charEnd":64,"startMs":3560,"endMs":3920},{"word":"hummed","charStart":65,"charEnd":71,"startMs":3920,"endMs":4320},{"word":"along","charStart":72,"charEnd":77,"startMs":4320,"endMs":4620}]},{"id":"the-island-of-forgotten-songs-p13-s3","ord":2,"text":"A forgotten song was forgotten no more.","translation_ko":"잊혔던 노래는 이제 더 이상 잊힌 노래가 아니었어요.","audioUrl":"/seed/the-island-of-forgotten-songs/audio/p13-s3.mp3","wordTimings":[{"word":"A","charStart":0,"charEnd":1,"startMs":0,"endMs":180},{"word":"forgotten","charStart":2,"charEnd":11,"startMs":180,"endMs":600},{"word":"song","charStart":12,"charEnd":16,"startMs":600,"endMs":980},{"word":"was","charStart":17,"charEnd":20,"startMs":980,"endMs":1220},{"word":"forgotten","charStart":21,"charEnd":30,"startMs":1220,"endMs":1580},{"word":"no","charStart":31,"charEnd":33,"startMs":1580,"endMs":1880},{"word":"more","charStart":34,"charEnd":38,"startMs":1880,"endMs":2100}]}]}],"quiz":[{"question_ko":"어부의 이야기에 따르면, 잊힌 노래의 섬에는 무엇이 모여 있나요?","type":"mc","options":["사람들이 더는 부르지 않는 노래들","잃어버린 보물들","오래된 배들","낯선 동물들"],"answerIndex":0,"explain_ko":"어부는 사람들이 부르기를 멈춘 노래가 그 섬으로 떠내려가 기다린다고 말했어요.","id":"the-island-of-forgotten-songs-q1","ord":0},{"question_ko":"마라가 그 섬을 찾고 싶어 한 이유는 무엇인가요?","type":"mc","options":["새 배를 얻고 싶어서","할머니의 자장가 가락을 다시 기억하고 싶어서","어부를 만나고 싶어서","보물을 찾고 싶어서"],"answerIndex":1,"explain_ko":"마라는 할머니의 자장가를 떠올렸지만 가락이 기억나지 않아 섬을 찾아 나섰어요.","id":"the-island-of-forgotten-songs-q2","ord":1},{"question_ko":"두 친구가 섬으로 가는 길에 마주친 것은 무엇인가요?","type":"mc","options":["거센 폭풍","짙은 잿빛 안개","커다란 고래","다른 배들"],"answerIndex":1,"explain_ko":"저녁이 되자 짙은 안개가 배를 감쌌고, 그 안에서 흥얼거리는 소리를 들었어요.","id":"the-island-of-forgotten-songs-q3","ord":2},{"question_ko":"섬에서 마라가 결국 배운 노래는 무엇이었나요?","type":"mc","options":["뱃사람들의 노래","할머니의 자장가","마을 축제 노래","테오가 지은 노래"],"answerIndex":1,"explain_ko":"마라의 손을 스친 빛은 바로 할머니의 부드러운 자장가였어요.","id":"the-island-of-forgotten-songs-q4","ord":3},{"question_ko":"이 이야기가 전하려는 마음은 무엇에 가깝나요?","type":"mc","options":["혼자 간직할 때 노래가 가장 소중하다","함께 나누고 불러 줄 때 노래가 다시 살아난다","새 노래만이 의미가 있다","여행은 위험하니 피해야 한다"],"answerIndex":1,"explain_ko":"마라가 노래를 마을 사람들과 나누자, 잊혔던 노래가 다시 살아났어요.","id":"the-island-of-forgotten-songs-q5","ord":4}]}