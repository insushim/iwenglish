o/p9-s1.mp3","wordTimings":[{"word":"On","charStart":0,"charEnd":2,"startMs":0,"endMs":280},{"word":"Friday","charStart":3,"charEnd":9,"startMs":280,"endMs":680},{"word":"Jun","charStart":11,"charEnd":14,"startMs":1100,"endMs":1260},{"word":"and","charStart":15,"charEnd":18,"startMs":1260,"endMs":1420},{"word":"Mina","charStart":19,"charEnd":23,"startMs":1420,"endMs":1640},{"word":"set","charStart":24,"charEnd":27,"startMs":1640,"endMs":1920},{"word":"up","charStart":28,"charEnd":30,"startMs":1920,"endMs":2060},{"word":"their","charStart":31,"charEnd":36,"startMs":2060,"endMs":2240},{"word":"table","charStart":37,"charEnd":42,"startMs":2240,"endMs":2520},{"word":"in","charStart":43,"charEnd":45,"startMs":2520,"endMs":2740},{"word":"the","charStart":46,"charEnd":49,"startMs":2740,"endMs":2920},{"word":"hallway","charStart":50,"charEnd":57,"startMs":2920,"endMs":3120}]},{"id":"daily-108-the-class-bake-sale-p9-s2","ord":1,"text":"Their classmates come quickly because the cookies smell so good.","translation_ko":"쿠키 냄새가 너무 좋아서 반 친구들이 빠르게 몰려와요.","audioUrl":"/seed/daily-108-the-class-bake-sale/audio/p9-s2.mp3","wordTimings":[{"word":"Their","charStart":0,"charEnd":5,"startMs":0,"endMs":380},{"word":"classmates","charStart":6,"charEnd":16,"startMs":380,"endMs":860},{"word":"come","charStart":17,"charEnd":21,"startMs":860,"endMs":1180},{"word":"quickly","charStart":22,"charEnd":29,"startMs":1180,"endMs":1620},{"word":"because","charStart":30,"charEnd":37,"startMs":2040,"endMs":2260},{"word":"the","charStart":38,"charEnd":41,"startMs":2260,"endMs":2540},{"word":"cookies","charStart":42,"charEnd":49,"startMs":2540,"endMs":2800},{"word":"smell","charStart":50,"charEnd":55,"startMs":2800,"endMs":3220},{"word":"so","charStart":56,"charEnd":58,"startMs":3220,"endMs":3800},{"word":"good","charStart":59,"charEnd":63,"startMs":3800,"endMs":4220}]}]},{"id":"daily-108-the-class-bake-sale-p10","pageNo":10,"spread":"p10","imageUrl":"/seed/daily-108-the-class-bake-sale/p10.webp","sentenc