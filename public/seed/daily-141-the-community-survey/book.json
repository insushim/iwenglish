"startMs":880,"endMs":1340},{"word":"people","charStart":21,"charEnd":27,"startMs":1340,"endMs":1760},{"word":"in","charStart":28,"charEnd":30,"startMs":1760,"endMs":1900},{"word":"our","charStart":31,"charEnd":34,"startMs":1900,"endMs":2060},{"word":"community","charStart":35,"charEnd":44,"startMs":2060,"endMs":2900},{"word":"Jun","charStart":47,"charEnd":50,"startMs":2900,"endMs":2980},{"word":"said","charStart":51,"charEnd":55,"startMs":2980,"endMs":3260}]},{"id":"daily-141-the-community-survey-p11-s2","ord":1,"text":"\"Most chose a garden because it brings people outdoors together.\"","translation_ko":"\"대부분의 분들이 텃밭을 선택했는데, 함께 야외에서 시간을 보낼 수 있기 때문이에요.\"","audioUrl":"/seed/daily-141-the-community-survey/audio/p11-s2.mp3","wordTimings":[{"word":"Most","charStart":1,"charEnd":5,"startMs":0,"endMs":480},{"word":"chose","charStart":6,"charEnd":11,"startMs":480,"endMs":1020},{"word":"a","charStart":12,"charEnd":13,"startMs":1020,"endMs":1420},{"word":"garden","charStart":14,"charEnd":20,"startMs":1420,"endMs":1420},{"word":"because","charStart":21,"charEnd":28,"startMs":1420,"endMs":1880},{"word":"it","charStart":29,"charEnd":31,"startMs":1880,"endMs":2100},{"word":"brings","charStart":32,"charEnd":38,"startMs":2100,"endMs":2380},{"word":"people","charStart":39,"charEnd":45,"startMs":2380,"endMs":2900},{"word":"outdoors","charStart":46,"charEnd":54,"startMs":2900,"endMs":3320},{"word":"together","charStart":55,"charEnd":63,"startMs":3320,"endMs":3740}]},{"id":"daily-141-the-community-survey-p11-s3","ord":2,"text":"His classmates listened and asked questions.","translation_ko":"반 친구들은 귀 기울여 듣다가 질문을 했다.","audioUrl":"/seed/daily-141-the-community-survey/audio/p11-s3.mp3","wordTimings":[{"word":"His","charStart":0,"charEnd":3,"startMs":0,"endMs":280},{"word":"classmates","charStart":4,"charEnd":14,"startMs":280,"endMs":800},{"word":"listened","charStart":15,"charEnd":23,"startMs":800,"endMs":1240},{"word":"and","charStart":24,"charEnd":27,"startMs":1240,"endMs":1760},{"wor