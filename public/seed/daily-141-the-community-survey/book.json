s":2580},{"word":"the","charStart":49,"charEnd":52,"startMs":2580,"endMs":2940},{"word":"answer","charStart":53,"charEnd":59,"startMs":2940,"endMs":3080},{"word":"she","charStart":62,"charEnd":65,"startMs":3340,"endMs":3480},{"word":"said","charStart":66,"charEnd":70,"startMs":3480,"endMs":3760}]},{"id":"daily-141-the-community-survey-p12-s3","ord":2,"text":"\"That is what good researchers do.\"","translation_ko":"\"그게 바로 훌륭한 연구자가 하는 일이에요.\"","audioUrl":"/seed/daily-141-the-community-survey/audio/p12-s3.mp3","wordTimings":[{"word":"That","charStart":1,"charEnd":5,"startMs":0,"endMs":320},{"word":"is","charStart":6,"charEnd":8,"startMs":320,"endMs":520},{"word":"what","charStart":9,"charEnd":13,"startMs":520,"endMs":740},{"word":"good","charStart":14,"charEnd":18,"startMs":740,"endMs":1020},{"word":"researchers","charStart":19,"charEnd":30,"startMs":1020,"endMs":1500},{"word":"do","charStart":31,"charEnd":33,"startMs":1500,"endMs":1880}]}]},{"id":"daily-141-the-community-survey-p13","pageNo":13,"spread":"p13","imageUrl":"/seed/daily-141-the-community-survey/p13.webp","sentences":[{"id":"daily-141-the-community-survey-p13-s1","ord":0,"text":"Walking home, Jun and Mina felt proud.","translation_ko":"집으로 걸어가면서 준과 미나는 뿌듯했다.","audioUrl":"/seed/daily-141-the-community-survey/audio/p13-s1.mp3","wordTimings":[{"word":"Walking","charStart":0,"charEnd":7,"startMs":0,"endMs":440},{"word":"home","charStart":8,"charEnd":12,"startMs":440,"endMs":840},{"word":"Jun","charStart":14,"charEnd":17,"startMs":1260,"endMs":1480},{"word":"and","charStart":18,"charEnd":21,"startMs":1480,"endMs":1680},{"word":"Mina","charStart":22,"charEnd":26,"startMs":1680,"endMs":1900},{"word":"felt","charStart":27,"charEnd":31,"startMs":1900,"endMs":2300},{"word":"proud","charStart":32,"charEnd":37,"startMs":2300,"endMs":2640}]},{"id":"daily-141-the-community-survey-p13-s2","ord":1,"text":"\"We found out what neighbors really need,\" Mina said.","translation_ko":"\"우리가 이웃이 진짜로 필요한 게 뭔지 알아낸 거잖아,\" 미나가 말했다.