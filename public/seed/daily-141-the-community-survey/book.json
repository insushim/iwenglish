,{"id":"daily-141-the-community-survey-p3-s2","ord":1,"text":"\"Let's do this together,\" Mina said.","translation_ko":"\"같이 하자,\" 미나가 말했다.","audioUrl":"/seed/daily-141-the-community-survey/audio/p3-s2.mp3","wordTimings":[{"word":"Let's","charStart":1,"charEnd":6,"startMs":0,"endMs":1060},{"word":"do","charStart":7,"charEnd":9,"startMs":1060,"endMs":1200},{"word":"this","charStart":10,"charEnd":14,"startMs":1200,"endMs":1480},{"word":"together","charStart":15,"charEnd":23,"startMs":1480,"endMs":2380},{"word":"Mina","charStart":26,"charEnd":30,"startMs":2380,"endMs":2580},{"word":"said","charStart":31,"charEnd":35,"startMs":2580,"endMs":2880}]},{"id":"daily-141-the-community-survey-p3-s3","ord":2,"text":"They walked to the apartment building near the park.","translation_ko":"둘은 공원 근처 아파트로 걸어갔다.","audioUrl":"/seed/daily-141-the-community-survey/audio/p3-s3.mp3","wordTimings":[{"word":"They","charStart":0,"charEnd":4,"startMs":0,"endMs":320},{"word":"walked","charStart":5,"charEnd":11,"startMs":320,"endMs":660},{"word":"to","charStart":12,"charEnd":14,"startMs":660,"endMs":980},{"word":"the","charStart":15,"charEnd":18,"startMs":980,"endMs":1200},{"word":"apartment","charStart":19,"charEnd":28,"startMs":1200,"endMs":1520},{"word":"building","charStart":29,"charEnd":37,"startMs":1520,"endMs":1900},{"word":"near","charStart":38,"charEnd":42,"startMs":1900,"endMs":2100},{"word":"the","charStart":43,"charEnd":46,"startMs":2100,"endMs":2520},{"word":"park","charStart":47,"charEnd":51,"startMs":2520,"endMs":2520}]}]},{"id":"daily-141-the-community-survey-p4","pageNo":4,"spread":"p4","imageUrl":"/seed/daily-141-the-community-survey/p4.webp","sentences":[{"id":"daily-141-the-community-survey-p4-s1","ord":0,"text":"They knocked on the first door.","translation_ko":"두 사람은 첫 번째 집 문을 두드렸다.","audioUrl":"/seed/daily-141-the-community-survey/audio/p4-s1.mp3","wordTimings":[{"word":"They","charStart":0,"charEnd":4,"startMs":0,"endMs":300},{"word":"knocked","charStart":5,"charEnd":12,"startMs":300,"endMs":600},{"word":"on","charStart":13,"charEnd":15,"startMs":600,"endMs":920},{"word":"the","charStart":16,"charEnd":19,"startMs":920,"endMs":1080},{"word":"first","charStart":20,"charEnd":25,"startMs":1080,"endMs":1380},{"word":"door","charStart":26,"charEnd":30,"startMs":1380,"endMs":1680}]},{"id":"daily-141-the-community-survey-p4-s2","ord":1,"text":"An elderly man opened it and smiled.","translation_ko":"나이 드신 할아버지가 문을 열고 미소 지으셨다.","audioUrl":"/seed/daily-141-the-community-survey/audio/p4-s2.mp3","wordTimings":[{"word":"An","charStart":0,"charEnd":2,"startMs":0,"endMs":240},{"word":"elderly","charStart":3,"charEnd":10,"startMs":240,"endMs":660},{"word":"man","charStart":11,"charEnd":14,"startMs":660,"endMs":1120},{"word":"opened","charStart":15,"charEnd":21,"startMs":1120,"endMs":1500},{"word":"it","charStart":22,"charEnd":24,"startMs":1500,"endMs":1780},{"word":"and","charStart":25,"charEnd":28,"startMs":1780,"endMs":2240},{"word":"smiled","charStart":29,"charEnd":35,"startMs":2240,"endMs":2560}]},{"id":"daily-141-the-community-survey-p4-s3","ord":2,"text":"\"Excuse me. We are doing a school survey. Can you help us?\" Jun asked.","translation_ko":"\"실례합니다. 학교 설문조사를 하고 있어요. 도와주실 수 있으세요?\" 준이 물었다.","audioUrl":"/seed/daily-141-the-community-survey/audio/p4-s3.mp3","wordTimings":[{"word":"Excuse","charStart":1,"charEnd":7,"startMs":0,"endMs":440},{"word":"me","charStart":8,"charEnd":10,"startMs":440,"endMs":700},{"word":"We","charStart":12,"charEnd":14,"startMs":1000,"endMs":1340},{"word":"are","charStart":15,"charEnd":18,"startMs":1340,"endMs":1520},{"word":"doing","charStart":19,"charEnd":24,"startMs":1520,"endMs":1700},{"word":"a","charStart":25,"charEnd":26,"startMs":1700,"endMs":1920},{"word":"school","charStart":27,"charEnd":33,"startMs":1920,"endMs":2160},{"word":"survey","charStart":34,"charEnd":40,"startMs":2160,"endMs":2560},{"word":"Can","charStart":42,"charEnd":45,"startMs":3220,"endMs":3280},{"word":"you","charStart":46,"charEnd":49,"startMs":3280,"endMs":3460},{"word":"help","charStart":50,"charEnd":54,"startMs":3460,"endMs":3600},{"word":"us","charStart":55,"charEnd":57,"startMs":3600,"endMs":3920},{"word":"Jun","charStart":60,"charEnd":63,"startMs":4280,"endMs":4420},{"word":"asked","charStart":64,"charEnd":69,"startMs":4420,"endMs":4840}]}]},{"id":"daily-141-the-community-survey-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/daily-141-the-community-survey/p5.webp","sentences":[{"id":"daily-141-the-community-survey-p5-s1","ord":0,"text":"The man chose a garden because he loved growing vegetables.","translation_ko":"할아버지는 채소 키우는 것을 좋아해서 텃밭을 골랐다.","audioUrl":"/seed/daily-141-the-community-survey/audio/p5-s1.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":200},{"word":"man","charStart":4,"charEnd":7,"startMs":200,"endMs":540},{"word":"chose","charStart":8,"charEnd":13,"startMs":540,"endMs":840},{"word":"a","charStart":14,"charEnd":15,"startMs":840,"endMs":1320},{"word":"garden","charStart":16,"charEnd":22,"startMs":1320,"endMs":1320},{"word":"because","charStart":23,"charEnd":30,"startMs":1320,"endMs":1820},{"word":"he","charStart":31,"charEnd":33,"startMs":1820,"endMs":2120},{"word":"loved","charStart":34,"charEnd":39,"startMs":2120,"endMs":2400},{"word":"growing","charStart":40,"charEnd":47,"startMs":2400,"endMs":2780},{"word":"vegetables","charStart":48,"charEnd":58,"startMs":2780,"endMs":3200}]},{"id":"daily-141-the-community-survey-p5-s2","ord":1,"text":"\"Fresh food brings people together,\" he said.","translation_ko":"\"신선한 먹거리가 사람들을 하나로 모아 주지,\" 할아버지가 말했다.","audioUrl":"/seed/daily-141-the-community-survey/audio/p5-s2.mp3","wordTimings":[{"word":"Fresh","charStart":1,"charEnd":6,"startMs":0,"endMs":440},{"word":"food","charStart":7,"charEnd":11,"startMs":440,"endMs":860},{"word":"brings","charStart":12,"charEnd":18,"startMs":860,"endMs":1320},{"word":"people","charStart":19,"charEnd":25,"startMs":1320,"endMs":1760},{"word":"together","charStart":26,"charEnd":34,"startMs":1760,"endMs":2140},{"word":"he","charStart":37,"charEnd":39,"startMs":2500,"endMs":2680},{"word":"said","charStart":40,"charEnd":44,"startMs":2680,"endMs":2920}]},{"id":"daily-141-the-community-survey-p5-s3","ord":2,"text":"Jun wrote it down and thanked him.","translation_ko":"준은 받아 적고 감사 인사를 드렸다.","audioUrl":"/seed/daily-141-the-community-survey/audio/p5-s3.mp3","wordTimings":[{"word":"Jun","charStart":0,"charEnd":3,"startMs":0,"endMs":520},{"word":"wrote","charStart":4,"charEnd":9,"startMs":520,"endMs":920},{"word":"it","charStart":10,"charEnd":12,"startMs":920,"endMs":1080},{"word":"down","charStart":13,"charEnd":17,"startMs":1080,"endMs":1440},{"word":"and","charStart":18,"charEnd":21,"startMs":1440,"endMs":1900},{"word":"thanked","charStart":22,"charEnd":29,"startMs":1900,"endMs":2160},{"word":"him","charStart":30,"charEnd":33,"startMs":2160,"endMs":2340}]}]},{"id":"daily-141-the-community-survey-p6","pageNo":6,"spread":"p6","imageUrl":"/seed/daily-141-the-community-survey/p6.webp","sentences":[{"id":"daily-141-the-community-survey-p6-s1","ord":0,"text":"At the next house, a young mother answered.","translation_ko":"다음 집에서는 젊은 엄마가 문을 열었다.","audioUrl":"/seed/daily-141-the-community-survey/audio/p6-s1.mp3","wordTimings":[{"word":"At","charStart":0,"charEnd":2,"startMs":0,"endMs":240},{"word":"the","charStart":3,"charEnd":6,"startMs":240,"endMs":420},{"word":"next","charStart":7,"charEnd":11,"startMs":420,"endMs":800},{"word":"house","charStart":12,"charEnd":17,"startMs":800,"endMs":1180},{"word":"a","charStart":19,"charEnd":20,"startMs":1540,"endMs":1740},{"word":"young","charStart":21,"charEnd":26,"startMs":1740,"endMs":2000},{"word":"mother","charStart":27,"charEnd":33,"startMs":2000,"endMs":2220},{"word":"answered","charStart":34,"charEnd":42,"startMs":2220,"endMs":2620}]},{"id":"daily-141-the-community-survey-p6-s2","ord":1,"text":"\"I wish we had a bigger park. My kids need space,\" she said.","translation_ko":"\"공원이 더 넓으면 좋겠어요. 아이들이 뛰어놀 공간이 필요하거든요,\" 엄마가 말했다.","audioUrl":"/seed/daily-141-the-community-survey/audio/p6-s2.mp3","wordTimings":[{"word":"I","charStart":1,"charEnd":2,"startMs":0,"endMs":380},{"word":"wish","charStart":3,"charEnd":7,"startMs":380,"endMs":920},{"word":"we","charStart":8,"charEnd":10,"startMs":920,"endMs":1260},{"word":"had","charStart":11,"charEnd":14,"startMs":1260,"endMs":1500},{"word":"a","charStart":15,"charEnd":16,"startMs":1500,"endMs":1820},{"word":"bigger","charStart":17,"charEnd":23,"startMs":1820,"endMs":2040},{"word":"park","charStart":24,"charEnd":28,"startMs":2040,"endMs":2400},{"word":"My","charStart":30,"charEnd":32,"startMs":3060,"endMs":3260},{"word":"kids","charStart":33,"charEnd":37,"startMs":3260,"endMs":3520},{"word":"need","charStart":38,"charEnd":42,"startMs":3520,"endMs":3900},{"word":"space","charStart":43,"charEnd":48,"startMs":3900,"endMs":4680},{"word":"she","charStart":51,"charEnd":54,"startMs":4680,"endMs":4840},{"word":"said","charStart":55,"charEnd":59,"startMs":4840,"endMs":5120}]},{"id":"daily-141-the-community-survey-p6-s3","ord":2,"text":"Mina marked the park option on her sheet.","translation_ko":"미나는 설문지에 공원을 표시했다.","audioUrl":"/seed/daily-141-the-community-survey/audio/p6-s3.mp3","wordTimings":[{"word":"Mina","charStart":0,"charEnd":4,"startMs":0,"endMs":440},{"word":"marked","charStart":5,"charEnd":11,"startMs":440,"endMs":880},{"word":"the","charStart":12,"charEnd":15,"startMs":880,"endMs":1180},{"word":"park","charStart":16,"charEnd":20,"startMs":1180,"endMs":1420},{"word":"option","charStart":21,"charEnd":27,"startMs":1420,"endMs":1800},{"word":"on","charStart":28,"charEnd":30,"startMs":1800,"endMs":2080},{"word":"her","charStart":31,"charEnd":34,"startMs":2080,"endMs":2280},{"word":"sheet","charStart":35,"charEnd":40,"startMs":2280,"endMs":2480}]}]},{"id":"daily-141-the-community-survey-p7","pageNo":7,"spread":"p7","imageUrl":"/seed/daily-141-the-community-survey/p7.webp","sentences":[{"id":"daily-141-the-community-survey-p7-s1","ord":0,"text":"They visited many more homes before dark.","translation_ko":"해가 지기 전에 두 사람은 더 많은 집을 방문했다.","audioUrl":"/seed/daily-141-the-community-survey/audio/p7-s1.mp3","wordTimings":[{"word":"They","charStart":0,"charEnd":4,"startMs":0,"endMs":280},{"word":"visited","charStart":5,"charEnd":12,"startMs":280,"endMs":680},{"word":"many","charStart":13,"charEnd":17,"startMs":680,"endMs":1160},{"word":"more","charStart":18,"charEnd":22,"startMs":1160,"endMs":1500},{"word":"homes","charStart":23,"charEnd":28,"startMs":1500,"endMs":1780},{"word":"before","charStart":29,"charEnd":35,"startMs":1780,"endMs":2160},{"word":"dark","charStart":36,"charEnd":40,"startMs":2160,"endMs":2500}]},{"id":"daily-141-the-community-survey-p7-s2","ord":1,"text":"Some wanted a sports center, others a recycling station.","translation_ko":"스포츠 센터를 원하는 사람도 있었고, 재활용 센터를 원하는 사람도 있었다.","audioUrl":"/seed/daily-141-the-community-survey/audio/p7-s2.mp3","wordTimings":[{"word":"Some","charStart":0,"charEnd":4,"startMs":0,"endMs":400},{"word":"wanted","charStart":5,"charEnd":11,"startMs":400,"endMs":780},{"word":"a","charStart":12,"charEnd":13,"startMs":780,"endMs":1060},{"word":"sports","charStart":14,"charEnd":20,"startMs":1060,"endMs":1340},{"word":"center","charStart":21,"charEnd":27,"startMs":1340,"endMs":1700},{"word":"others","charStart":29,"charEnd":35,"startMs":2200,"endMs":2440},{"word":"a","charStart":36,"charEnd":37,"startMs":2440,"endMs":2740},{"word":"recycling","charStart":38,"charEnd":47,"startMs":2740,"endMs":3100},{"word":"station","charStart":48,"charEnd":55,"startMs":3100,"endMs":3520}]},{"id":"daily-141-the-community-survey-p7-s3","ord":2,"text":"\"People have such different needs,\" Mina said.","translation_ko":"\"사람마다 필요한 게 정말 다르네,\" 미나가 말했다.","audioUrl":"/seed/daily-141-the-community-survey/audio/p7-s3.mp3","wordTimings":[{"word":"People","charStart":1,"charEnd":7,"startMs":0,"endMs":600},{"word":"have","charStart":8,"charEnd":12,"startMs":600,"endMs":900},{"word":"such","charStart":13,"charEnd":17,"startMs":900,"endMs":1200},{"word":"different","charStart":18,"charEnd":27,"startMs":1200,"endMs":1580},{"word":"needs","charStart":28,"charEnd":33,"startMs":1580,"endMs":1920},{"word":"Mina","charStart":36,"charEnd":40,"startMs":2400,"endMs":2400},{"word":"said","charStart":41,"charEnd":45,"startMs":2400,"endMs":2700}]}]},{"id":"daily-141-the-community-survey-p8","pageNo":8,"spread":"p8","imageUrl":"/seed/daily-141-the-community-survey/p8.webp","sentences":[{"id":"daily-141-the-community-survey-p8-s1","ord":0,"text":"That evening, Jun counted all the answers.","translation_ko":"그날 저녁, 준은 답변을 모두 세었다.","audioUrl":"/seed/daily-141-the-community-survey/audio/p8-s1.mp3","wordTimings":[{"word":"That","charStart":0,"charEnd":4,"startMs":0,"endMs":340},{"word":"evening","charStart":5,"charEnd":12,"startMs":340,"endMs":700},{"word":"Jun","charStart":14,"charEnd":17,"startMs":1260,"endMs":1460},{"word":"counted","charStart":18,"charEnd":25,"startMs":1460,"endMs":1820},{"word":"all","charStart":26,"charEnd":29,"startMs":1820,"endMs":2180},{"word":"the","charStart":30,"charEnd":33,"startMs":2180,"endMs":2360},{"word":"answers","charStart":34,"charEnd":41,"startMs":2360,"endMs":2620}]},{"id":"daily-141-the-community-survey-p8-s2","ord":1,"text":"The garden got the most votes, followed by the park.","translation_ko":"텃밭이 가장 많은 표를 받았고, 공원이 그다음이었다.","audioUrl":"/seed/daily-141-the-community-survey/audio/p8-s2.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":320},{"word":"garden","charStart":4,"charEnd":10,"startMs":320,"endMs":700},{"word":"got","charStart":11,"charEnd":14,"startMs":700,"endMs":1240},{"word":"the","charStart":15,"charEnd":18,"startMs":1240,"endMs":1400},{"word":"most","charStart":19,"charEnd":23,"startMs":1400,"endMs":1800},{"word":"votes","charStart":24,"charEnd":29,"startMs":1800,"endMs":2160},{"word":"followed","charStart":31,"charEnd":39,"startMs":2860,"endMs":2860},{"word":"by","charStart":40,"charEnd":42,"start