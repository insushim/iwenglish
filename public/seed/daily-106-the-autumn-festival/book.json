Ms":4080},{"word":"fun","charStart":42,"charEnd":45,"startMs":4080,"endMs":4300}]}]}],"quiz":[{"question_ko":"준과 미나는 첫 번째 부스에서 무엇을 했나요?","type":"mc","options":["나뭇잎 그림을 그렸어요.","호떡을 먹었어요.","고리 던지기 게임을 했어요.","사진을 찍었어요."],"answerIndex":2,"explain_ko":"첫 번째 부스에서 준과 미나는 고리 던지기 게임을 하고 작은 상품을 받았어요.","id":"daily-106-the-autumn-festival-q1","ord":0},{"question_ko":"미나가 페인팅 부스로 가고 싶었던 이유는 무엇인가요?","type":"mc","options":["미나는 미술을 좋아하기 때문이에요.","상품을 받고 싶었기 때문이에요.","엄마가 시켰기 때문이에요.","음식이 맛있기 때문이에요."],"answerIndex":0,"explain_ko":"미나가 미술(art)을 좋아하기 때문에 페인팅 부스로 갔어요.","id":"daily-106-the-autumn-festival-q2","ord":1},{"question_ko":"준이 음식 부스에서 고른 것은 무엇인가요?","type":"mc","options":["군밤","사탕","호떡","떡볶이"],"answerIndex":2,"explain_ko":"준은 따뜻하고 달콤한 냄새에 호떡(hotteok)을 골랐어요.","id":"daily-106-the-autumn-festival-q3","ord":2},{"question_ko":"포토존에서 엄마는 무엇을 했나요?","type":"mc","options":["나뭇잎을 색칠했어요.","준과 미나의 사진을 찍어 주었어요.","고리 던지기를 했어요.","군밤을 샀어요."],"answerIndex":1,"explain_ko":"허수아비 옆에 선 준과 미나를 엄마가 사진으로 찍어 주었어요.","id":"daily-106-the-autumn-festival-q4","ord":3},{"question_ko":"집으로 돌아오는 길에 준은 뭐라고 말했나요?","type":"mc","options":["상품이 마음에 안 든다고 했어요.","내년에도 꼭 오고 싶다고 했어요.","다음엔 혼자 오겠다고 했어요.","가을 음식이 맛없다고 했어요."],"answerIndex":1,"explain_ko":"준은 축제가 너무 즐거워서 내년에도 다시 오고 싶다고 말했어요.","id":"daily-106-the-autumn-festival-q5","ord":4}]}