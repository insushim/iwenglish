{"id":"the-rain-painter","slug":"the-rain-painter","title":"The Rain Painter","title_ko":"비 그림 화가","level":"A2","ageBand":"8-10","coverUrl":"/seed/the-rain-painter/cover.webp","summary_ko":"비가 색을 번지게 하자 아이가 실수를 새로운 그림 기법으로 바꾸는 이야기예요.","wordCount":93,"pages":[{"id":"the-rain-painter-p1","pageNo":1,"spread":"p1","imageUrl":"/seed/the-rain-painter/p1.webp","sentences":[{"id":"the-rain-painter-p1-s1","ord":0,"text":"Nari carried her paints outside because the sky looked silver.","translation_ko":"나리는 하늘이 은빛처럼 보여서 물감을 밖으로 들고 나갔어요.","audioUrl":"/seed/the-rain-painter/audio/p1-s1.mp3","wordTimings":[{"word":"Nari","charStart":0,"charEnd":4,"startMs":0,"endMs":420},{"word":"carried","charStart":5,"charEnd":12,"startMs":420,"endMs":880},{"word":"her","charStart":13,"charEnd":16,"startMs":880,"endMs":1120},{"word":"paints","charStart":17,"charEnd":23,"startMs":1120,"endMs":1380},{"word":"outside","charStart":24,"charEnd":31,"startMs":1380,"endMs":1960},{"word":"because","charStart":32,"charEnd":39,"startMs":1960,"endMs":2420},{"word":"the","charStart":40,"charEnd":43,"startMs":2420,"endMs":2720},{"word":"sky","charStart":44,"charEnd":47,"startMs":2720,"endMs":2880},{"word":"looked","charStart":48,"charEnd":54,"startMs":2880,"endMs":3200},{"word":"silver","charStart":55,"charEnd":61,"startMs":3200,"endMs":3520}]}]},{"id":"the-rain-painter-p2","pageNo":2,"spread":"p2","imageUrl":"/seed/the-rain-painter/p2.webp","sentences":[{"id":"the-rain-painter-p2-s1","ord":0,"text":"She painted a red kite above the garden fence.","translation_ko":"나리는 정원 울타리 위에 빨간 연을 그렸어요.","audioUrl":"/seed/the-rain-painter/audio/p2-s1.mp3","wordTimings":[{"word":"She","charStart":0,"charEnd":3,"startMs":0,"endMs":320},{"word":"painted","charStart":4,"charEnd":11,"startMs":320,"endMs":620},{"word":"a","charStart":12,"charEnd":13,"startMs":620,"endMs":880},{"word":"red","charStart":14,"charEnd":17,"startMs":880,"endMs":1060},{"word":"kite","charStart":18,"charEnd":22,"startMs":1060,"endMs":1420},{"word":"above","charStart":23,"charEnd":28,"startMs":1420,"endMs":1920},{"word":"the","charStart":29,"charEnd":32,"startMs":1920,"endMs":2200},{"word":"garden","charStart":33,"charEnd":39,"startMs":2200,"endMs":2460},{"word":"fence","charStart":40,"charEnd":45,"startMs":2460,"endMs":2900}]}]},{"id":"the-rain-painter-p3","pageNo":3,"spread":"p3","imageUrl":"/seed/the-rain-painter/p3.webp","sentences":[{"id":"the-rain-painter-p3-s1","ord":0,"text":"Then rain began to tap the paper before she could finish.","translation_ko":"그런데 완성하기도 전에 비가 종이를 톡톡 두드리기 시작했어요.","audioUrl":"/seed/the-rain-painter/audio/p3-s1.mp3","wordTimings":[{"word":"Then","charStart":0,"charEnd":4,"startMs":0,"endMs":420},{"word":"rain","charStart":5,"charEnd":9,"startMs":860,"endMs":920},{"word":"began","charStart":10,"charEnd":15,"startMs":920,"endMs":1300},{"word":"to","charStart":16,"charEnd":18,"startMs":1300,"endMs":1580},{"word":"tap","charStart":19,"charEnd":22,"startMs":1580,"endMs":1780},{"word":"the","charStart":23,"charEnd":26,"startMs":1780,"endMs":2020},{"word":"paper","charStart":27,"charEnd":32,"startMs":2020,"endMs":2280},{"word":"before","charStart":33,"charEnd":39,"startMs":2280,"endMs":2760},{"word":"she","charStart":40,"charEnd":43,"startMs":2760,"endMs":3020},{"word":"could","charStart":44,"charEnd":49,"startMs":3020,"endMs":3220},{"word":"finish","charStart":50,"charEnd":56,"startMs":3220,"endMs":3520}]}]},{"id":"the-rain-painter-p4","pageNo":4,"spread":"p4","imageUrl":"/seed/the-rain-painter/p4.webp","sentences":[{"id":"the-rain-painter-p4-s1","ord":0,"text":"The red paint ran down like tiny rivers.","translation_ko":"빨간 물감은 작은 강처럼 아래로 흘렀어요.","audioUrl":"/seed/the-rain-painter/audio/p4-s1.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":300},{"word":"red","charStart":4,"charEnd":7,"startMs":300,"endMs":660},{"word":"paint","charStart":8,"charEnd":13,"startMs":660,"endMs":1120},{"word":"ran","charStart":14,"charEnd":17,"startMs":1120,"endMs":1540},{"word":"down","charStart":18,"charEnd":22,"startMs":1540,"endMs":1920},{"word":"like","charStart":23,"charEnd":27,"startMs":1920,"endMs":2220},{"word":"tiny","charStart":28,"charEnd":32,"startMs":2220,"endMs":2600},{"word":"rivers","charStart":33,"charEnd":39,"startMs":2600,"endMs":2900}]}]},{"id":"the-rain-painter-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/the-rain-painter/p5.webp","sentences":[{"id":"the-rain-painter-p5-s1","ord":0,"text":"Nari almost cried, but she watched the lines carefully.","translation_ko":"나리는 울 뻔했지만 그 선들을 자세히 보았어요.","audioUrl":"/seed/the-rain-painter/audio/p5-s1.mp3","wordTimings":[{"word":"Nari","charStart":0,"charEnd":4,"startMs":0,"endMs":440},{"word":"almost","charStart":5,"charEnd":11,"startMs":440,"endMs":1060},{"word":"cried","charStart":12,"charEnd":17,"startMs":1060,"endMs":1420},{"word":"but","charStart":19,"charEnd":22,"startMs":1820,"endMs":2080},{"word":"she","charStart":23,"charEnd":26,"startMs":2080,"endMs":2320},{"word":"watched","charStart":27,"charEnd":34,"startMs":2320,"endMs":2580},{"word":"the","charStart":35,"charEnd":38,"startMs":2580,"endMs":2840},{"word":"lines","charStart":39,"charEnd":44,"startMs":2840,"endMs":3120},{"word":"carefully","charStart":45,"charEnd":54,"startMs":3120,"endMs":3580}]}]},{"id":"the-rain-painter-p6","pageNo":6,"spread":"p6","imageUrl":"/seed/the-rain-painter/p6.webp","sentences":[{"id":"the-rain-painter-p6-s1","ord":0,"text":"They looked like ribbons flying from the kite.","translation_ko":"그 선들은 연에서 날리는 리본처럼 보였어요.","audioUrl":"/seed/the-rain-painter/audio/p6-s1.mp3","wordTimings":[{"word":"They","charStart":0,"charEnd":4,"startMs":0,"endMs":300},{"word":"looked","charStart":5,"charEnd":11,"startMs":300,"endMs":580},{"word":"like","charStart":12,"charEnd":16,"startMs":580,"endMs":1000},{"word":"ribbons","charStart":17,"charEnd":24,"startMs":1000,"endMs":1280},{"word":"flying","charStart":25,"charEnd":31,"startMs":1280,"endMs":1740},{"word":"from","charStart":32,"charEnd":36,"startMs":1740,"end