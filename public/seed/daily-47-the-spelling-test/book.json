,"startMs":3220,"endMs":3460},{"word":"every","charStart":54,"charEnd":59,"startMs":3460,"endMs":3900},{"word":"sound","charStart":60,"charEnd":65,"startMs":3900,"endMs":4260}]}]},{"id":"daily-47-the-spelling-test-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/daily-47-the-spelling-test/p5.webp","sentences":[{"id":"daily-47-the-spelling-test-p5-s1","ord":0,"text":"When I made a mistake, I tried again.","translation_ko":"틀리면 나는 다시 시도했어요.","audioUrl":"/seed/daily-47-the-spelling-test/audio/p5-s1.mp3","wordTimings":[{"word":"When","charStart":0,"charEnd":4,"startMs":0,"endMs":300},{"word":"I","charStart":5,"charEnd":6,"startMs":300,"endMs":660},{"word":"made","charStart":7,"charEnd":11,"startMs":660,"endMs":760},{"word":"a","charStart":12,"charEnd":13,"startMs":760,"endMs":1040},{"word":"mistake","charStart":14,"charEnd":21,"startMs":1040,"endMs":1340},{"word":"I","charStart":23,"charEnd":24,"startMs":1460,"endMs":1900},{"word":"tried","charStart":25,"charEnd":30,"startMs":1900,"endMs":2120},{"word":"again","charStart":31,"charEnd":36,"startMs":2120,"endMs":2480}]},{"id":"daily-47-the-spelling-test-p5-s2","ord":1,"text":"I said the word out loud and wrote it three more times.","translation_ko":"소리 내어 말한 다음 세 번 더 썼어요.","audioUrl":"/seed/daily-47-the-spelling-test/audio/p5-s2.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":300},{"word":"said","charStart":2,"charEnd":6,"startMs":300,"endMs":500},{"word":"the","charStart":7,"charEnd":10,"startMs":500,"endMs":880},{"word":"word","charStart":11,"charEnd":15,"startMs":880,"endMs":1100},{"word":"out","charStart":16,"charEnd":19,"startMs":1100,"endMs":1380},{"word":"loud","charStart":20,"charEnd":24,"startMs":1380,"endMs":1680},{"word":"and","charStart":25,"charEnd":28,"startMs":1680,"endMs":2160},{"word":"wrote","charStart":29,"charEnd":34,"startMs":2160,"endMs":2300},{"word":"it","charStart":35,"charEnd":37,"startMs":2300,"endMs":2520},{"word":"three","charStart":38,"charEnd":43,"startMs":2520,"e