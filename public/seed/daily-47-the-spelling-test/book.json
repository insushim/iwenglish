40,"startMs":2140,"endMs":2440}]},{"id":"daily-47-the-spelling-test-p6-s2","ord":1,"text":"I took a deep breath and told myself, \"I practiced hard. I can do this.\"","translation_ko":"심호흡을 하고 속으로 말했어요. \"열심히 연습했잖아. 할 수 있어.\"","audioUrl":"/seed/daily-47-the-spelling-test/audio/p6-s2.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":300},{"word":"took","charStart":2,"charEnd":6,"startMs":300,"endMs":300},{"word":"a","charStart":7,"charEnd":8,"startMs":300,"endMs":540},{"word":"deep","charStart":9,"charEnd":13,"startMs":540,"endMs":780},{"word":"breath","charStart":14,"charEnd":20,"startMs":780,"endMs":1100},{"word":"and","charStart":21,"charEnd":24,"startMs":1100,"endMs":1700},{"word":"told","charStart":25,"charEnd":29,"startMs":1700,"endMs":1900},{"word":"myself","charStart":30,"charEnd":36,"startMs":1900,"endMs":2400},{"word":"I","charStart":39,"charEnd":40,"startMs":2860,"endMs":3040},{"word":"practiced","charStart":41,"charEnd":50,"startMs":3040,"endMs":3420},{"word":"hard","charStart":51,"charEnd":55,"startMs":3420,"endMs":3900},{"word":"I","charStart":57,"charEnd":58,"startMs":4100,"endMs":4640},{"word":"can","charStart":59,"charEnd":62,"startMs":4640,"endMs":4820},{"word":"do","charStart":63,"charEnd":65,"startMs":4820,"endMs":4960},{"word":"this","charStart":66,"charEnd":70,"startMs":4960,"endMs":5280}]}]},{"id":"daily-47-the-spelling-test-p7","pageNo":7,"spread":"p7","imageUrl":"/seed/daily-47-the-spelling-test/p7.webp","sentences":[{"id":"daily-47-the-spelling-test-p7-s1","ord":0,"text":"But I remembered the words because I practiced.","translation_ko":"그래도 연습한 덕분에 단어가 기억났어요.","audioUrl":"/seed/daily-47-the-spelling-test/audio/p7-s1.mp3","wordTimings":[{"word":"But","charStart":0,"charEnd":3,"startMs":0,"endMs":220},{"word":"I","charStart":4,"charEnd":5,"startMs":220,"endMs":560},{"word":"remembered","charStart":6,"charEnd":16,"startMs":560,"endMs":840},{"word":"the","charStart":17,"charEnd":20,"startMs":840,"endMs":1100},{"word"