.","translation_ko":"준은 항상 이야기를 좋아했지만, 이제는 나눌 때 더 좋아진다는 걸 알았어요.","audioUrl":"/seed/daily-122-the-story-corner/audio/p12-s2.mp3","wordTimings":[{"word":"He","charStart":0,"charEnd":2,"startMs":0,"endMs":720},{"word":"had","charStart":3,"charEnd":6,"startMs":720,"endMs":940},{"word":"always","charStart":7,"charEnd":13,"startMs":940,"endMs":1420},{"word":"loved","charStart":14,"charEnd":19,"startMs":1420,"endMs":1800},{"word":"stories","charStart":20,"charEnd":27,"startMs":1800,"endMs":2320},{"word":"but","charStart":29,"charEnd":32,"startMs":2860,"endMs":2940},{"word":"now","charStart":33,"charEnd":36,"startMs":2940,"endMs":3180},{"word":"he","charStart":37,"charEnd":39,"startMs":3180,"endMs":3340},{"word":"knew","charStart":40,"charEnd":44,"startMs":3340,"endMs":3500},{"word":"sharing","charStart":45,"charEnd":52,"startMs":3500,"endMs":3880},{"word":"made","charStart":53,"charEnd":57,"startMs":3880,"endMs":4120},{"word":"them","charStart":58,"charEnd":62,"startMs":4120,"endMs":4300},{"word":"better","charStart":63,"charEnd":69,"startMs":4300,"endMs":4500}]},{"id":"daily-122-the-story-corner-p12-s3","ord":2,"text":"He could not wait for next Saturday.","translation_ko":"다음 토요일이 어서 오기를 기다릴 수가 없었어요.","audioUrl":"/seed/daily-122-the-story-corner/audio/p12-s3.mp3","wordTimings":[{"word":"He","charStart":0,"charEnd":2,"startMs":0,"endMs":240},{"word":"could","charStart":3,"charEnd":8,"startMs":240,"endMs":480},{"word":"not","charStart":9,"charEnd":12,"startMs":480,"endMs":880},{"word":"wait","charStart":13,"charEnd":17,"startMs":880,"endMs":1160},{"word":"for","charStart":18,"charEnd":21,"startMs":1160,"endMs":1560},{"word":"next","charStart":22,"charEnd":26,"startMs":1560,"endMs":1800},{"word":"Saturday","charStart":27,"charEnd":35,"startMs":1800,"endMs":2100}]}]}],"quiz":[{"question_ko":"준과 미나는 이야기 코너에서 무엇을 했나요?","type":"mc","options":["어린 동생들에게 그림책을 읽어 주었어요.","도서관 책을 정리했어요.","사서 선생님과 함께 그림을 그렸어요.","새 책을 골라 집에 빌려 갔어요."],"answerIndex":0,"explain_ko":"준과 미나는 어린 동생들을 위해 이야기 코너에서 그림책을 소리 내어 읽어 주었어요.","id":"daily-122-the-story-corner-q1","ord":0},{"question_ko":"준이 이야기 읽기를 하고 싶었던 이유와 가장 관련 있는 것은 무엇인가요?","type":"mc","options":["어렸을 때 할머니가 책을 읽어 주셨던 따뜻한 기억이 있었기 때문이에요.","사서 선생님이 읽어 달라고 부탁했기 때문이에요.","미나가 먼저 신청해서 같이 하게 되었기 때문이에요.","그날 도서관에서 읽을 다른 책이 없었기 때문이에요."],"answerIndex":0,"explain_ko":"준은 어린 시절 할머니가 곁에서 책을 읽어 주시던 따뜻한 기억이 있어서 이야기 읽기를 하고 싶었어요.","id":"daily-122-the-story-corner-q2","ord":1},{"question_ko":"두 아이가 골라 읽어 준 책은 어떤 내용이었나요?","type":"mc","options":["용감한 작은 여우가 집을 찾아가는 이야기예요.","도서관을 사랑하는 소년이 사서가 되는 이야기예요.","두 친구가 비 오는 날 함께 모험을 떠나는 이야기예요.","할머니가 손자에게 선물을 주는 이야기예요."],"answerIndex":0,"explain_ko":"준과 미나는 집을 찾아가는 용감한 작은 여우 이야기를 골라 동생들에게 읽어 주었어요.","id":"daily-122-the-story-corner-q3","ord":2},{"question_ko":"이야기를 다 들은 아이들의 반응은 어땠나요?","type":"mc","options":["손뼉을 치며 또 읽어 달라고 외쳤어요.","조용히 자리에서 일어나 각자 책을 읽으러 갔어요.","이야기가 너무 어렵다며 질문을 많이 했어요.","이야기가 슬프다며 눈물을 흘렸어요."],"answerIndex":0,"explain_ko":"아이들은 손뼉을 치며 '또 해요!'라고 외쳤어요. 이야기가 무척 재미있었던 거예요.","id":"daily-122-the-story-corner-q4","ord":3},{"question_ko":"할머니께서 준에게 해 주신 말씀의 핵심은 무엇인가요?","type":"mc","options":["이야기는 나누어도 닳지 않는 선물이라는 것이에요.","도서관에 더 자주 가야 한다는 것이에요.","사서 선생님이 되는 것이 좋은 꿈이라는 것이에요.","책은 천천히 읽어야 내용을 잘 이해할 수 있다는 것이에요."],"answerIndex":0,"explain_ko":"할머니께서는 이야기는 나누어 줄수록 더 좋아지는, 절대 닳지 않는 선물이라고 말씀하셨어요.","id":"daily-122-the-story-corner-q5","ord":4}]}