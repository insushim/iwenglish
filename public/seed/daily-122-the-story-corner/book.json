ion_ko":"낭독이 끝난 후 사서 선생님이 웃으며 말씀하셨어요. '정말 훌륭했어요.'","audioUrl":"/seed/daily-122-the-story-corner/audio/p10-s1.mp3","wordTimings":[{"word":"After","charStart":0,"charEnd":5,"startMs":0,"endMs":440},{"word":"the","charStart":6,"charEnd":9,"startMs":440,"endMs":880},{"word":"session","charStart":10,"charEnd":17,"startMs":880,"endMs":1180},{"word":"the","charStart":19,"charEnd":22,"startMs":1720,"endMs":1860},{"word":"librarian","charStart":23,"charEnd":32,"startMs":1860,"endMs":2320},{"word":"smiled","charStart":33,"charEnd":39,"startMs":2320,"endMs":2860},{"word":"and","charStart":40,"charEnd":43,"startMs":2860,"endMs":3240},{"word":"said","charStart":44,"charEnd":48,"startMs":3240,"endMs":3380},{"word":"You","charStart":51,"charEnd":54,"startMs":3980,"endMs":4120},{"word":"two","charStart":55,"charEnd":58,"startMs":4120,"endMs":4380},{"word":"were","charStart":59,"charEnd":63,"startMs":4380,"endMs":4600},{"word":"wonderful","charStart":64,"charEnd":73,"startMs":4600,"endMs":5000}]},{"id":"daily-122-the-story-corner-p10-s2","ord":1,"text":"Jun felt a warm glow in his chest he had never felt before.","translation_ko":"준의 가슴 속에는 전에 느껴 본 적 없는 따뜻한 빛이 번졌어요.","audioUrl":"/seed/daily-122-the-story-corner/audio/p10-s2.mp3","wordTimings":[{"word":"Jun","charStart":0,"charEnd":3,"startMs":0,"endMs":380},{"word":"felt","charStart":4,"charEnd":8,"startMs":380,"endMs":760},{"word":"a","charStart":9,"charEnd":10,"startMs":760,"endMs":1120},{"word":"warm","charStart":11,"charEnd":15,"startMs":1120,"endMs":1340},{"word":"glow","charStart":16,"charEnd":20,"startMs":1340,"endMs":1660},{"word":"in","charStart":21,"charEnd":23,"startMs":1660,"endMs":1900},{"word":"his","charStart":24,"charEnd":27,"startMs":1900,"endMs":2140},{"word":"chest","charStart":28,"charEnd":33,"startMs":2140,"endMs":2460},{"word":"he","charStart":34,"charEnd":36,"startMs":2460,"endMs":2880},{"word":"had","charStart":37,"charEnd":40,"startMs":2880,"endMs":3100},{"word":"never","charStart":41,"charEnd":46,"startMs":3100,"endMs":3340},{"word":"felt","charStart":47,"charEnd":51,"startMs":3340,"endMs":3620},{"word":"before","charStart":52,"charEnd":58,"startMs":3620,"endMs":4020}]}]},{"id":"daily-122-the-story-corner-p11","pageNo":11,"spread":"p11","imageUrl":"/seed/daily-122-the-story-corner/p11.webp","sentences":[{"id":"daily-122-the-story-corner-p11-s1","ord":0,"text":"That evening, Jun called Grandma and told her about the Story Corner.","translation_ko":"그날 저녁, 준은 할머니께 전화를 걸어 이야기 코너 이야기를 했어요.","audioUrl":"/seed/daily-122-the-story-corner/audio/p11-s1.mp3","wordTimings":[{"word":"That","charStart":0,"charEnd":4,"startMs":0,"endMs":320},{"word":"evening","charStart":5,"charEnd":12,"startMs":320,"endMs":740},{"word":"Jun","charStart":14,"charEnd":17,"startMs":1080,"endMs":1300},{"word":"called","charStart":18,"charEnd":24,"startMs":1300,"endMs":1580},{"word":"Grandma","charStart":25,"charEnd":32,"startMs":1580,"endMs":2060},{"word":"and","charStart":33,"charEnd":36,"startMs":2060,"endMs":2560},{"word":"told","charStart":37,"charEnd":41,"startMs":2560,"endMs":2760},{"word":"her","charStart":42,"charEnd":45,"startMs":2760,"endMs":2940},{"word":"about","charStart":46,"charEnd":51,"startMs":2940,"endMs":3180},{"word":"the","charStart":52,"charEnd":55,"startMs":3180,"endMs":3360},{"word":"Story","charStart":56,"charEnd":61,"startMs":3360,"endMs":3680},{"word":"Corner","charStart":62,"charEnd":68,"startMs":3680,"endMs":4020}]},{"id":"daily-122-the-story-corner-p11-s2","ord":1,"text":"\"You gave them a gift,\" Grandma said softly. \"A story is a gift that never runs out.\"","translation_ko":"\"선물을 주었구나,\" 할머니께서 부드럽게 말씀하셨어요. '이야기는 절대 닳지 않는 선물이란다.'","audioUrl":"/seed/daily-122-the-story-corner/audio/p11-s2.mp3","wordTimings":[{"word":"You","charStart":1,"charEnd":4,"startMs":0,"endMs":300},{"word":"gave","charStart":5,"charEnd":9,"startMs":300,"endMs":580},{"word":"them","charStart":10,"charEnd":14,"startMs":580,"endMs":840},{"word":"a","charStart":15,"charEnd":16,"startMs":840,"endMs":