arEnd":10,"startMs":500,"endMs":760},{"word":"handrail","charStart":11,"charEnd":19,"startMs":760,"endMs":1180},{"word":"so","charStart":20,"charEnd":22,"startMs":1180,"endMs":1520},{"word":"I","charStart":23,"charEnd":24,"startMs":1520,"endMs":1780},{"word":"don't","charStart":25,"charEnd":30,"startMs":1780,"endMs":2060},{"word":"fall","charStart":31,"charEnd":35,"startMs":2060,"endMs":2280}]}]},{"id":"daily-45-riding-the-subway-p8","pageNo":8,"spread":"p8","imageUrl":"/seed/daily-45-riding-the-subway/p8.webp","sentences":[{"id":"daily-45-riding-the-subway-p8-s1","ord":0,"text":"The doors open and we step off.","translation_ko":"문이 열리고 우리는 내려요.","audioUrl":"/seed/daily-45-riding-the-subway/audio/p8-s1.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":260},{"word":"doors","charStart":4,"charEnd":9,"startMs":260,"endMs":520},{"word":"open","charStart":10,"charEnd":14,"startMs":520,"endMs":1000},{"word":"and","charStart":15,"charEnd":18,"startMs":1000,"endMs":1560},{"word":"we","charStart":19,"charEnd":21,"startMs":1560,"endMs":1900},{"word":"step","charStart":22,"charEnd":26,"startMs":1900,"endMs":2040},{"word":"off","charStart":27,"charEnd":30,"startMs":2040,"endMs":2340}]},{"id":"daily-45-riding-the-subway-p8-s2","ord":1,"text":"We step off and climb the stairs.","translation_ko":"우리는 내려서 계단을 올라가요.","audioUrl":"/seed/daily-45-riding-the-subway/audio/p8-s2.mp3","wordTimings":[{"word":"We","charStart":0,"charEnd":2,"startMs":0,"endMs":640},{"word":"step","charStart":3,"charEnd":7,"startMs":640,"endMs":880},{"word":"off","charStart":8,"charEnd":11,"startMs":880,"endMs":1240},{"word":"and","charStart":12,"charEnd":15,"startMs":1240,"endMs":1660},{"word":"climb","charStart":16,"charEnd":21,"startMs":1660,"endMs":1900},{"word":"the","charStart":22,"charEnd":25,"startMs":1900,"endMs":2220},{"word":"stairs","charStart":26,"charEnd":32,"startMs":2220,"endMs":2380}]},{"id":"daily-45-riding-the-subway-p8-s3","ord":2,"text":"The warm sunlight meets us at the top.","translation_ko":"계단 위에서 따뜻한 햇빛이 우리를 맞이해요.","audioUrl":"/seed/daily-45-riding-the-subway/audio/p8-s3.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":240},{"word":"warm","charStart":4,"charEnd":8,"startMs":240,"endMs":620},{"word":"sunlight","charStart":9,"charEnd":17,"startMs":620,"endMs":1000},{"word":"meets","charStart":18,"charEnd":23,"startMs":1000,"endMs":1320},{"word":"us","charStart":24,"charEnd":26,"startMs":1320,"endMs":1520},{"word":"at","charStart":27,"charEnd":29,"startMs":1520,"endMs":1640},{"word":"the","charStart":30,"charEnd":33,"startMs":1640,"endMs":1820},{"word":"top","charStart":34,"charEnd":37,"startMs":1820,"endMs":2040}]},{"id":"daily-45-riding-the-subway-p8-s4","ord":3,"text":"\"We made it!\" I say, and Mom laughs.","translation_ko":"\"다 왔다!\" 내가 외치자 엄마가 웃어요.","audioUrl":"/seed/daily-45-riding-the-subway/audio/p8-s4.mp3","wordTimings":[{"word":"We","charStart":1,"charEnd":3,"startMs":0,"endMs":780},{"word":"made","charStart":4,"charEnd":8,"startMs":780,"endMs":1060},{"word":"it","charStart":9,"charEnd":11,"startMs":1060,"endMs":1800},{"word":"I","charStart":14,"charEnd":15,"startMs":1800,"endMs":2020},{"word":"say","charStart":16,"charEnd":19,"startMs":2020,"endMs":2260},{"word":"and","charStart":21,"charEnd":24,"startMs":2780,"endMs":2960},{"word":"Mom","charStart":25,"charEnd":28,"startMs":2960,"endMs":3240},{"word":"laughs","charStart":29,"charEnd":35,"startMs":3240,"endMs":3700}]}]}],"quiz":[{"question_ko":"누구와 지하철을 탔나요?","type":"mc","options":["친구","선생님","혼자","엄마"],"answerIndex":3,"explain_ko":"with Mom — 엄마와 함께요.","id":"daily-45-riding-the-subway-q1","ord":0},{"question_ko":"개찰구에서 무엇을 했나요?","type":"mc","options":["표를 버렸어요","카드를 찍었어요","잤어요","뛰었어요"],"answerIndex":1,"explain_ko":"tap our cards — 카드를 찍어요.","id":"daily-45-riding-the-subway-q2","ord":1},{"question_ko":"자리는 몇 개를 찾았나요?","type":"mc","options":["다섯 개","없어요","두 개","한 개"],"answerIndex":2,"explain_ko":"two empty seats — 빈자리 두 개예요.","id":"daily-45-riding-the-subway-q3","ord":2},{"question_ko":"친절한 아저씨는 누구에게 자리를 양보했나요?","type":"mc","options":["할머니","아이","엄마","아저씨"],"answerIndex":0,"explain_ko":"gives his seat to her — 할머니께 자리를 양보해요.","id":"daily-45-riding-the-subway-q4","ord":3},{"question_ko":"마지막에 무엇을 올라갔나요?","type":"mc","options":["언덕","나무","사다리","계단"],"answerIndex":3,"explain_ko":"climb the stairs — 계단을 올라가요.","id":"daily-45-riding-the-subway-q5","ord":4}]}