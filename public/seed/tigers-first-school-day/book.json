,"charStart":20,"charEnd":23,"startMs":1360,"endMs":1680},{"word":"tomorrow","charStart":24,"charEnd":32,"startMs":1680,"endMs":1960}]},{"id":"tigers-first-school-day-p8-s2","ord":1,"text":"He has a new friend.","translation_ko":"새 친구가 생겼거든요.","audioUrl":"/seed/tigers-first-school-day/audio/p8-s2.mp3","wordTimings":[{"word":"He","charStart":0,"charEnd":2,"startMs":0,"endMs":340},{"word":"has","charStart":3,"charEnd":6,"startMs":340,"endMs":860},{"word":"a","charStart":7,"charEnd":8,"startMs":860,"endMs":1080},{"word":"new","charStart":9,"charEnd":12,"startMs":1080,"endMs":1280},{"word":"friend","charStart":13,"charEnd":19,"startMs":1280,"endMs":1520}]}]}],"quiz":[{"question_ko":"테오에게 오늘은 어떤 날인가요?","type":"mc","options":["학교 가는 첫날","생일날","이사 가는 날","소풍 가는 날"],"answerIndex":0,"explain_ko":"오늘은 테오가 학교에 처음 가는 날이에요.","id":"tigers-first-school-day-q1","ord":0},{"question_ko":"학교에 가기 전 테오의 기분은 어땠나요?","type":"mc","options":["졸리고 피곤했다","화가 났다","수줍고 무서웠다","신나고 즐거웠다"],"answerIndex":2,"explain_ko":"테오는 수줍고 무서워서 배 속이 간질간질했어요.","id":"tigers-first-school-day-q2","ord":1},{"question_ko":"엄마는 테오에게 무엇을 해 주었나요?","type":"mc","options":["따뜻하게 안아 주었다","노래를 불러 주었다","선물을 주었다","책을 읽어 주었다"],"answerIndex":0,"explain_ko":"\"넌 할 수 있어\"라고 말하며 따뜻하게 안아 주었어요.","id":"tigers-first-school-day-q3","ord":2},{"question_ko":"테오에게 먼저 말을 건 친구는 누구인가요?","type":"mc","options":["작은 토끼","큰 사자","다람쥐","거북이"],"answerIndex":0,"explain_ko":"작은 토끼가 미소 지으며 \"같이 놀래?\"라고 했어요.","id":"tigers-first-school-day-q4","ord":3},{"question_ko":"학교에서 논 뒤 테오의 생각은 어떻게 바뀌었나요?","type":"mc","options":["아무 생각도 없었다","집에 가고 싶어졌다","학교가 재미있다고 느꼈다","학교가 더 무서워졌다"],"answerIndex":2,"explain_ko":"친구와 그리고 노래하고 세며 놀다 보니 학교가 하나도 무섭지 않고 재미있었어요.","id":"tigers-first-school-day-q5","ord":4}]}