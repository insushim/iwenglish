"imageUrl":"/seed/the-wandering-seed-cart/p4.webp","sentences":[{"id":"the-wandering-seed-cart-p4-s1","ord":0,"text":"At the old wall, it rattled until we noticed packets of climbing beans.","translation_ko":"오래된 담장에서는 덩굴콩 봉투를 알아챌 때까지 달그락거렸어요.","audioUrl":"/seed/the-wandering-seed-cart/audio/p4-s1.mp3","wordTimings":[{"word":"At","charStart":0,"charEnd":2,"startMs":0,"endMs":160},{"word":"the","charStart":3,"charEnd":6,"startMs":160,"endMs":340},{"word":"old","charStart":7,"charEnd":10,"startMs":340,"endMs":580},{"word":"wall","charStart":11,"charEnd":15,"startMs":580,"endMs":860},{"word":"it","charStart":17,"charEnd":19,"startMs":1260,"endMs":1480},{"word":"rattled","charStart":20,"charEnd":27,"startMs":1480,"endMs":1780},{"word":"until","charStart":28,"charEnd":33,"startMs":1780,"endMs":2120},{"word":"we","charStart":34,"charEnd":36,"startMs":2120,"endMs":2400},{"word":"noticed","charStart":37,"charEnd":44,"startMs":2400,"endMs":2680},{"word":"packets","charStart":45,"charEnd":52,"startMs":2680,"endMs":3100},{"word":"of","charStart":53,"charEnd":55,"startMs":3100,"endMs":3660},{"word":"climbing","charStart":56,"charEnd":64,"startMs":3660,"endMs":3780},{"word":"beans","charStart":65,"charEnd":70,"startMs":3780,"endMs":4180}]}]},{"id":"the-wandering-seed-cart-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/the-wandering-seed-cart/p5.webp","sentences":[{"id":"the-wandering-seed-cart-p5-s1","ord":0,"text":"I wanted the biggest packet, but the label said, For quiet corners.","translation_ko":"나는 가장 큰 봉투를 원했지만 이름표에는 조용한 구석용이라고 쓰여 있었어요.","audioUrl":"/seed/the-wandering-seed-cart/audio/p5-s1.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":220},{"word":"wanted","charStart":2,"charEnd":8,"startMs":220,"endMs":440},{"word":"the","charStart":9,"charEnd":12,"startMs":440,"endMs":660},{"word":"biggest","charStart":13,"charEnd":20,"startMs":660,"endMs":1020},{"word":"packet","charStart":21,"charEnd":27,"startMs":1020,"endMs":1380},{"word":"but","char