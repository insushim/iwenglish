{"id":"the-broken-compass","slug":"the-broken-compass","title":"The Broken Compass","title_ko":"고장 난 나침반","level":"A2","ageBand":"8-10","coverUrl":"/seed/the-broken-compass/cover.webp","summary_ko":"고장 난 나침반 때문에 길을 잃은 아이들이 주변 단서를 읽으며 길을 찾는 이야기예요.","wordCount":102,"pages":[{"id":"the-broken-compass-p1","pageNo":1,"spread":"p1","imageUrl":"/seed/the-broken-compass/p1.webp","sentences":[{"id":"the-broken-compass-p1-s1","ord":0,"text":"We borrowed Grandpa's brass compass for our forest walk.","translation_ko":"우리는 숲 산책을 위해 할아버지의 황동 나침반을 빌렸어요.","audioUrl":"/seed/the-broken-compass/audio/p1-s1.mp3","wordTimings":[{"word":"We","charStart":0,"charEnd":2,"startMs":0,"endMs":400},{"word":"borrowed","charStart":3,"charEnd":11,"startMs":400,"endMs":740},{"word":"Grandpa's","charStart":12,"charEnd":21,"startMs":740,"endMs":1500},{"word":"brass","charStart":22,"charEnd":27,"startMs":1500,"endMs":1820},{"word":"compass","charStart":28,"charEnd":35,"startMs":1820,"endMs":2160},{"word":"for","charStart":36,"charEnd":39,"startMs":2160,"endMs":2460},{"word":"our","charStart":40,"charEnd":43,"startMs":2460,"endMs":2740},{"word":"forest","charStart":44,"charEnd":50,"startMs":2740,"endMs":3080},{"word":"walk","charStart":51,"charEnd":55,"startMs":3080,"endMs":3400}]}]},{"id":"the-broken-compass-p2","pageNo":2,"spread":"p2","imageUrl":"/seed/the-broken-compass/p2.webp","sentences":[{"id":"the-broken-compass-p2-s1","ord":0,"text":"Its needle shook a little, but we trusted it anyway.","translation_ko":"바늘이 조금 흔들렸지만 우리는 그래도 믿었어요.","audioUrl":"/seed/the-broken-compass/audio/p2-s1.mp3","wordTimings":[{"word":"Its","charStart":0,"charEnd":3,"startMs":0,"endMs":240},{"word":"needle","charStart":4,"charEnd":10,"startMs":240,"endMs":560},{"word":"shook","charStart":11,"charEnd":16,"startMs":560,"endMs":820},{"word":"a","charStart":17,"charEnd":18,"startMs":820,"endMs":1020},{"word":"little","charStart":19,"charEnd":25,"startMs":1020,"endMs":1180},{"word":"but","charStart":27,"charEnd":30,"startMs":1520,"endMs":1580},{"word":"we","charStart":31,"charEnd":33,"startMs":1580,"endMs":1760},{"word":"trusted","charStart":34,"charEnd":41,"startMs":1760,"endMs":2080},{"word":"it","charStart":42,"charEnd":44,"startMs":2080,"endMs":2300},{"word":"anyway","charStart":45,"charEnd":51,"startMs":2300,"endMs":2560}]}]},{"id":"the-broken-compass-p3","pageNo":3,"spread":"p3","imageUrl":"/seed/the-broken-compass/p3.webp","sentences":[{"id":"the-broken-compass-p3-s1","ord":0,"text":"Soon the path looked narrower than before.","translation_ko":"곧 길은 전보다 더 좁아 보였어요.","audioUrl":"/seed/the-broken-compass/audio/p3-s1.mp3","wordTimings":[{"word":"Soon","charStart":0,"charEnd":4,"startMs":0,"endMs":480},{"word":"the","charStart":5,"charEnd":8,"startMs":700,"endMs":1080},{"word":"path","charStart":9,"charEnd":13,"startMs":1080,"endMs":1160},{"word":"looked","charStart":14,"charEnd":20,"startMs":1160,"endMs":1520},{"word":"narrower","charStart":21,"charEnd":29,"startMs":1520,"endMs":2020},{"word":"than","charStart":30,"charEnd":34,"startMs":2020,"endMs":2380},{"word":"before","charStart":35,"charEnd":41,"startMs":2380,"endMs":2740}]}]},{"id":"the-broken-compass-p4","pageNo":4,"spread":"p4","imageUrl":"/seed/the-broken-compass/p4.webp","sentences":[{"id":"the-broken-compass-p4-s1","ord":0,"text":"The compass pointed left, while the creek sounded from the right.","translation_ko":"나침반은 왼쪽을 가리켰지만 개울 소리는 오른쪽에서 들렸어요.","audioUrl":"/seed/the-broken-compass/audio/p4-s1.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":260},{"word":"compass","charStart":4,"charEnd":11,"startMs":260,"endMs":600},{"word":"pointed","charStart":12,"charEnd":19,"startMs":600,"endMs":1040},{"word":"left","charStart":20,"charEnd":24,"startMs":1040,"endMs":1500},{"word":"while","charStart":26,"charEnd":31,"startMs":2100,"endMs":2240},{"word":"the","charStart":32,"charEnd":35,"startMs":2240,"endMs":2420},{"word":"creek","charStart":36,"charEnd":41,"startMs":2420,"endMs":2660},{"word":"sounded","charStart":42,"charEnd":49,"startMs":2660,"endMs":2980},{"word":"from","charStart":50,"charEnd":54,"startMs":2980,"endMs":3220},{"word":"the","charStart":55,"charEnd":58,"startMs":3220,"endMs":3460},{"word":"right","charStart":59,"charEnd":64,"startMs":3460,"endMs":3640}]}]},{"id":"the-broken-compass-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/the-broken-compass/p5.webp","sentences":[{"id":"the-broken-compass-p5-s1","ord":0,"text":"My sister remembered that the bridge was beside the creek.","translation_ko":"누나는 다리가 개울 옆에 있었다는 걸 기억했어요.","audioUrl":"/seed/the-broken-compass/audio/p5-s1.mp3","wordTimings":[{"word":"My","charStart":0,"charEnd":2,"startMs":0,"endMs":280},{"word":"sister","charStart":3,"charEnd":9,"startMs":280,"endMs":580},{"word":"remembered","charStart":10,"charEnd":20,"startMs":580,"endMs":1080},{"word":"that","charStart":21,"charEnd":25,"startMs":1080,"endMs":1540},{"word":"the","charStart":26,"charEnd":29,"startMs":1540,"endMs":1740},{"word":"bridge","charStart":30,"charEnd":36,"startMs":1740,"endMs":1940},{"word":"was","charStart":37,"charEnd":40,"startMs":1940,"endMs":2160},{"word":"beside","charStart":41,"charEnd":47,"startMs":2160,"endMs":2540},{"word":"the","charStart":48,"charEnd":51,"startMs":2540,"endMs":2780},{"word":"creek","charStart":52,"charEnd":57,"startMs":2780,"endMs":2980}]}]},{"id":"the-broken-compass-p6","pageNo":6,"spread":"p6","imageUrl":"/seed/the-broken-compass/p6.webp","sentences":[{"id":"the-broken-compass-p6-s1","ord":0,"text":"We listened carefully and followed the sound of the water.","translation_ko":"우리는 조심히 귀 기울이고 물소리를 따라갔어요.","audioUrl":"/seed/the-broken-compass/audio/p6-s1.mp3","wordTimings":[{"word":"We","charStart":0,"charEnd":2,"startMs":0,"endMs":300},{"word":"listened","charStart":3,"charEnd":11,"startMs":300,"endMs":660},{"word":"carefully","charStart":12,"charEnd":21,"startMs":660,"endMs":1200},{"word":"and","charStart":22,"charEnd":25,"startMs":1200,"endMs":1780},{"word":"followed","charStart":26,"charEnd":34,"startMs":1780,"endMs":1980},{"word":"the","charStart":35,"charEnd":38,"startMs":1980,"endMs":2260},{"word":"sound","charStart":39,"charEnd":44,"startMs":2260,"endMs":2540},{"word":"of","charStart":45,"charEnd":47,"startMs":2540,"endMs":2720},{"word":"the","charStart":48,"charEnd":51,"startMs":2720,"endMs":2840},{"word":"water","charStart":52,"charEnd":57,"startMs":2840,"endMs":3040}]}]},{"id":"the-broken-compass-p7","pageNo":7,"spread":"p7","imageUrl":"/seed/the-broken-compass/p7.webp","sentences":[{"id":"the-broken-compass-p7-s1","ord":0,"text":"The afternoon sun helped us see the mossy side of the trees.","translation_ko":"오후 햇빛은 나무의 이끼 낀 쪽을 보게 해 주었어요.","audioUrl":"/seed/the-broken-compass/audio/p7-s1.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":620},{"word":"afternoon","charStart":4,"charEnd":13,"startMs":620,"endMs":1040},{"word":"sun","charStart":14,"charEnd":17,"startMs":1040,"endMs":1460},{"word":"helped","charStart":18,"charEnd":24,"startMs":1460,"endMs":1760},{"word":"us","charStart":25,"charEnd":27,"startMs":1760,"endMs":2020},{"word":"see","charStart":28,"charEnd":31,"startMs":2020,"endMs":2120},{"word":"the","charStart":32,"charEnd":35,"startMs":2120,"endMs":2500},{"word":"mossy","charStart":36,"charEnd":41,"startMs":2500,"endMs":2700},{"word":"side","charStart":42,"charEnd":46,"startMs":2700,"endMs":2880},{"word":"of","charStart":47,"charEnd":49,"startMs":2880,"endMs":3020},{"word":"the","charStart":50,"charEnd":53,"startMs":3020,"endMs":3420},{"word":"trees","charStart":54,"charEnd":59,"startMs":3420,"endMs":3420}]}]},{"id":"the-broken-compass-p8","pageNo":8,"spread":"p8","imageUrl":"/seed/the-broken-compass/p8.webp","sentences":[{"id":"the-broken-compass-p8-s1","ord":0,"text":"At last, the wooden bridge appeared between two pines.","translation_ko":"마침내 두 소나무 사이에 나무 다리가 나타났어요.","audioUrl":"/seed/the-broken-compass/audio/p8-s1.mp3","wordTimings":[{"word":"At","charStart":0,"charEnd":2,"startMs":0,"endMs":240},{"word":"last","charStart":3,"charEnd":7,"startMs":240,"endMs":600},{"word":"the","charStart":9,"charEnd":12,"startMs":820,"endMs":1060},{"word":"wooden","charStart":13,"charEnd":19,"startMs":1060,"endMs":1180},{"word":"bridge","charStart":20,"charEnd":26,"startMs":1180,"endMs":1500},{"word":"appeared","charStart":27,"charEnd":35,"startMs":1500,"endMs":1980},{"word":"between","charStart":36,"charEnd":43,"startMs":1980,"endMs":2620},{"word":"two","charStart":44,"charEnd":47,"startMs":2620,"endMs":3040},{"word":"pines","charStart":48,"charEnd":53,"startMs":3040,"endMs":3320}]}]},{"id":"the-broken-compass-p9","pageNo":9,"spread":"p9","imageUrl":"/seed/the-broken-compass/p9.webp","sentences":[{"id":"the-broken-compass-p9-s1","ord":0,"text":"Grandpa later fixed the loose needle with a tiny screw.","translation_ko":"나중에 할아버지는 작은 나사로 헐거운 바늘을 고쳤어요.","audioUrl":"/seed/the-broken-compass/audio/p9-s1.mp3","wordTimings":[{"word":"Grandpa","charStart":0,"charEnd":7,"startMs":0,"endMs":580},{"word":"later","charStart":8,"charEnd":13,"startMs":580,"endMs":960},{"word":"fixed","charStart":14,"charEnd":19,"startMs":960,"endMs":1280},{"word":"the","charStart":20,"charEnd":23,"startMs":1280,"endMs":1540},{"word":"loose","charStart":24,"charEnd":29,"startMs":1540,"endMs":1820},{"word":"needle","charStart":30,"charEnd":36,"startMs":1820,"endMs":2040},{"word":"with","charStart":37,"charEnd":41,"startMs":2040,"endMs":2260},{"word":"a","charStart":42,"charEnd":43,"startMs":2260,"endMs":2420},{"word":"tiny","charStart":44,"charEnd":48,"startMs":2420,"endMs":2720},{"word":"screw","charStart":49,"charEnd":54,"startMs":2720,"endMs":3040}]}]},{"id":"the-broken-compass-p10","pageNo":10,"spread":"p10","imageUrl":"/seed/the-broken-compass/p10.webp","sentences":[{"id":"the-broken-compass-p10-s1","ord":0,"text":"We learned that maps and tools are best when our eyes are open too.","translation_ko":"우리는 지도와 도구도 눈을 함께 열 때 가장 좋다는 걸 배웠어요.","audioUrl":"/seed/the-broken-compass/audio/p10-s1.mp3","wordTimings":[{"word":"We","charStart":0,"charEnd":2,"startMs":0,"endMs":660},{"word":"learned","charStart":3,"charEnd":10,"startMs":660,"endMs":1020},{"word":"that","charStart":11,"charEnd":15,"startMs":1020,"endMs":1380},{"word":"maps","charStart":16,"charEnd":20,"startMs":1380,"endMs":1640},{"word":"and","charStart":21,"charEnd":24,"startMs":1640,"endMs":1940},{"word":"tools","charStart":25,"charEnd":30,"startMs":1940,"endMs":2240},{"word":"are","charStart":31,"charEnd":34,"startMs":2240,"endMs":2540},{"word":"best","charStart":35,"charEnd":39,"startMs":2540,"endMs":2840},{"word":"when","charStart":40,"charEnd":44,"startMs":2840,"endMs":3060},{"word":"our","charStart":45,"charEnd":48,"startMs":3060,"endMs":3300},{"word":"eyes","charStart":49,"charEnd":53,"startMs":3300,"endMs":3440},{"word":"are","charStart":54,"charEnd":57,"startMs":3440,"endMs":3640},{"word":"open","charStart":58,"charEnd":62,"startMs":3640,"endMs":3900},{"word":"too","charStart":63,"charEnd":66,"startMs":4040,"endMs":4240}]}]}],"quiz":[{"question_ko":"고장 난 나침반에서 중심이 되는 것은 무엇인가요?","type":"mc","options":["낡은 황동 나침반","낡은 시계","빨간 버스","큰 가방"],"answerIndex":0,"explain_ko":"낡은 황동 나침반이 이야기의 중심이에요.","id":"the-broken-compass-q1","ord":0},{"question_ko":"이야기는 주로 어디에서 펼쳐지나요?","type":"mc","options":["소나무 숲길","병원","기차역","운동장"],"answerIndex":0,"explain_ko":"소나무 숲길에서 중요한 일이 일어나요.","id":"the-broken-compass-q2","ord":1},{"question_ko":"주인공이 만난 문제는 무엇인가요?","type":"mc","options":["나침반 바늘이 흔들려 길을 잃었어요","간식이 없었어요","비밀 편지를 잃었어요","문이 잠겼어요"],"answerIndex":0,"explain_ko":"나침반 바늘이 흔들려 길을 잃었어요","id":"the-broken-compass-q3","ord":2},{"question_ko":"누가 또는 무엇이 도움을 주었나요?","type":"mc","options":["해와 개울 소리","검은 구름","빈 상자","낯선 모자"],"answerIndex":0,"explain_ko":"해와 개울 소리이 해결을 도와요.","id":"the-broken-compass-q4","ord":3},{"question_ko":"이야기가 알려 주는 마음은 무엇인가요?","type":"mc","options":["도구가 틀릴 때 주변을 살피는 마음","빨리 이기는 마음","혼자 숨는 마음","아무것도 하지 않는 마음"],"answerIndex":0,"explain_ko":"도구가 틀릴 때 주변을 살피는 마음을 배워요.","id":"the-broken-compass-q5","ord":4}]}