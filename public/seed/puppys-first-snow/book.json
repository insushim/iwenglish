snow/audio/p3-s3.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":280},{"word":"snow","charStart":4,"charEnd":8,"startMs":280,"endMs":540},{"word":"is","charStart":9,"charEnd":11,"startMs":540,"endMs":840},{"word":"very","charStart":12,"charEnd":16,"startMs":840,"endMs":1200},{"word":"soft","charStart":17,"charEnd":21,"startMs":1200,"endMs":1480}]}]},{"id":"puppys-first-snow-p4","pageNo":4,"spread":"p4","imageUrl":"/seed/puppys-first-snow/p4.webp","sentences":[{"id":"puppys-first-snow-p4-s1","ord":0,"text":"He smells the white snow.","translation_ko":"강아지가 하얀 눈 냄새를 맡아요.","audioUrl":"/seed/puppys-first-snow/audio/p4-s1.mp3","wordTimings":[{"word":"He","charStart":0,"charEnd":2,"startMs":0,"endMs":460},{"word":"smells","charStart":3,"charEnd":9,"startMs":460,"endMs":1100},{"word":"the","charStart":10,"charEnd":13,"startMs":1100,"endMs":1420},{"word":"white","charStart":14,"charEnd":19,"startMs":1420,"endMs":1820},{"word":"snow","charStart":20,"charEnd":24,"startMs":1820,"endMs":2160}]},{"id":"puppys-first-snow-p4-s2","ord":1,"text":"Then he jumps up high.","translation_ko":"그러더니 폴짝 높이 뛰어올라요.","audioUrl":"/seed/puppys-first-snow/audio/p4-s2.mp3","wordTimings":[{"word":"Then","charStart":0,"charEnd":4,"startMs":0,"endMs":480},{"word":"he","charStart":5,"charEnd":7,"startMs":480,"endMs":880},{"word":"jumps","charStart":8,"charEnd":13,"startMs":880,"endMs":1160},{"word":"up","charStart":14,"charEnd":16,"startMs":1160,"endMs":1440},{"word":"high","charStart":17,"charEnd":21,"startMs":1440,"endMs":1700}]}]},{"id":"puppys-first-snow-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/puppys-first-snow/p5.webp","sentences":[{"id":"puppys-first-snow-p5-s1","ord":0,"text":"Puppy rolls in the snow.","translation_ko":"강아지가 눈밭에서 데굴데굴 굴러요.","audioUrl":"/seed/puppys-first-snow/audio/p5-s1.mp3","wordTimings":[{"word":"Puppy","charStart":0,"charEnd":5,"startMs":0,"endMs":460},{"word":"rolls","charStart":6,"charEnd":11,"startMs":460,"endMs":940},{"word":"in","