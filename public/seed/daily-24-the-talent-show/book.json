{"id":"daily-24-the-talent-show","slug":"daily-24-the-talent-show","title":"The Talent Show","title_ko":"장기자랑","level":"B1","ageBand":"8-10","coverUrl":"/seed/daily-24-the-talent-show/cover.webp","summary_ko":"학교 장기자랑에서 피아노 연주를 준비하고 무대에 오르는 이야기. 연습과 용기, 성취감을 풍부한 표현으로 배워요.","wordCount":353,"stage":6,"collection":"daily","pages":[{"id":"daily-24-the-talent-show-p1","pageNo":1,"spread":"p1","imageUrl":"/seed/daily-24-the-talent-show/p1.webp","sentences":[{"id":"daily-24-the-talent-show-p1-s1","ord":0,"text":"Our school is having a talent show next Friday.","translation_ko":"우리 학교에서 다음 주 금요일에 장기자랑이 열려요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p1-s1.mp3","wordTimings":[{"word":"Our","charStart":0,"charEnd":3,"startMs":0,"endMs":240},{"word":"school","charStart":4,"charEnd":10,"startMs":240,"endMs":520},{"word":"is","charStart":11,"charEnd":13,"startMs":520,"endMs":740},{"word":"having","charStart":14,"charEnd":20,"startMs":740,"endMs":940},{"word":"a","charStart":21,"charEnd":22,"startMs":940,"endMs":1120},{"word":"talent","charStart":23,"charEnd":29,"startMs":1120,"endMs":1440},{"word":"show","charStart":30,"charEnd":34,"startMs":1440,"endMs":1700},{"word":"next","charStart":35,"charEnd":39,"startMs":1700,"endMs":2060},{"word":"Friday","charStart":40,"charEnd":46,"startMs":2060,"endMs":2400}]},{"id":"daily-24-the-talent-show-p1-s2","ord":1,"text":"Students can sing, dance, or play an instrument on stage.","translation_ko":"학생들은 무대에서 노래하거나, 춤추거나, 악기를 연주할 수 있어요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p1-s2.mp3","wordTimings":[{"word":"Students","charStart":0,"charEnd":8,"startMs":0,"endMs":500},{"word":"can","charStart":9,"charEnd":12,"startMs":500,"endMs":900},{"word":"sing","charStart":13,"charEnd":17,"startMs":900,"endMs":1200},{"word":"dance","charStart":19,"charEnd":24,"startMs":1880,"endMs":1880},{"word":"or","charStart":26,"charEnd":28,"startMs":2140,"endMs":2300},{"word":"play","charStart":29,"charEnd":33,"startMs":2300,"endMs":2480},{"word":"an","charStart":34,"charEnd":36,"startMs":2480,"endMs":2760},{"word":"instrument","charStart":37,"charEnd":47,"startMs":2760,"endMs":3080},{"word":"on","charStart":48,"charEnd":50,"startMs":3080,"endMs":3540},{"word":"stage","charStart":51,"charEnd":56,"startMs":3540,"endMs":3840}]}]},{"id":"daily-24-the-talent-show-p2","pageNo":2,"spread":"p2","imageUrl":"/seed/daily-24-the-talent-show/p2.webp","sentences":[{"id":"daily-24-the-talent-show-p2-s1","ord":0,"text":"I decide to play a song on the piano.","translation_ko":"나는 피아노로 노래를 연주하기로 해요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p2-s1.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":280},{"word":"decide","charStart":2,"charEnd":8,"startMs":280,"endMs":720},{"word":"to","charStart":9,"charEnd":11,"startMs":720,"endMs":1000},{"word":"play","charStart":12,"charEnd":16,"startMs":1000,"endMs":1120},{"word":"a","charStart":17,"charEnd":18,"startMs":1120,"endMs":1600},{"word":"song","charStart":19,"charEnd":23,"startMs":1600,"endMs":1620},{"word":"on","charStart":24,"charEnd":26,"startMs":1620,"endMs":1840},{"word":"the","charStart":27,"charEnd":30,"startMs":1840,"endMs":2040},{"word":"piano","charStart":31,"charEnd":36,"startMs":2040,"endMs":2260}]},{"id":"daily-24-the-talent-show-p2-s2","ord":1,"text":"I choose a melody I have loved since first grade.","translation_ko":"나는 1학년 때부터 좋아해 온 멜로디를 골라요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p2-s2.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":240},{"word":"choose","charStart":2,"charEnd":8,"startMs":240,"endMs":560},{"word":"a","charStart":9,"charEnd":10,"startMs":560,"endMs":740},{"word":"melody","charStart":11,"charEnd":17,"startMs":740,"endMs":980},{"word":"I","charStart":18,"charEnd":19,"startMs":980,"endMs":1240},{"word":"have","charStart":20,"charEnd":24,"startMs":1240,"endMs":1440},{"word":"loved","charStart":25,"charEnd":30,"startMs":1440,"endMs":1680},{"word":"since","charStart":31,"charE