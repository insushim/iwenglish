"I","charStart":0,"charEnd":1,"startMs":0,"endMs":220},{"word":"play","charStart":2,"charEnd":6,"startMs":220,"endMs":420},{"word":"the","charStart":7,"charEnd":10,"startMs":420,"endMs":640},{"word":"same","charStart":11,"charEnd":15,"startMs":640,"endMs":980},{"word":"part","charStart":16,"charEnd":20,"startMs":980,"endMs":1360},{"word":"over","charStart":21,"charEnd":25,"startMs":1360,"endMs":1860},{"word":"and","charStart":26,"charEnd":29,"startMs":1860,"endMs":2180},{"word":"over","charStart":30,"charEnd":34,"startMs":2180,"endMs":2460},{"word":"until","charStart":35,"charEnd":40,"startMs":2460,"endMs":2960},{"word":"my","charStart":41,"charEnd":43,"startMs":2960,"endMs":3240},{"word":"fingers","charStart":44,"charEnd":51,"startMs":3240,"endMs":3500},{"word":"know","charStart":52,"charEnd":56,"startMs":3500,"endMs":3820},{"word":"exactly","charStart":57,"charEnd":64,"startMs":3820,"endMs":4360},{"word":"where","charStart":65,"charEnd":70,"startMs":4360,"endMs":4580},{"word":"to","charStart":71,"charEnd":73,"startMs":4580,"endMs":4780},{"word":"go","charStart":74,"charEnd":76,"startMs":4780,"endMs":4920}]},{"id":"daily-24-the-talent-show-p3-s3","ord":2,"text":"Some days it sounds beautiful, but some days I make mistakes.","translation_ko":"어떤 날은 아름답게 들리지만, 어떤 날은 실수를 해요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p3-s3.mp3","wordTimings":[{"word":"Some","charStart":0,"charEnd":4,"startMs":420,"endMs":860},{"word":"days","charStart":5,"charEnd":9,"startMs":860,"endMs":1080},{"word":"it","charStart":10,"charEnd":12,"startMs":1080,"endMs":1280},{"word":"sounds","charStart":13,"charEnd":19,"startMs":1280,"endMs":1520},{"word":"beautiful","charStart":20,"charEnd":29,"startMs":1520,"endMs":2020},{"word":"but","charStart":31,"charEnd":34,"startMs":2480,"endMs":2600},{"word":"some","charStart":35,"charEnd":39,"startMs":2600,"endMs":2880},{"word":"days","charStart":40,"charEnd":44,"startMs":2880,"endMs":3060},{"word":"I","charStart":45,"charEnd":46,"startMs":3060,"endMs":3240},{"word":"make","charStart":47,"charEnd":51,"startMs":3240,"endMs":3420},{"word":"mistakes","charStart":52,"charEnd":60,"startMs":3420,"endMs":3880}]}]},{"id":"daily-24-the-talent-show-p4","pageNo":4,"spread":"p4","imageUrl":"/seed/daily-24-the-talent-show/p4.webp","sentences":[{"id":"daily-24-the-talent-show-p4-s1","ord":0,"text":"On the day of the show, my heart beats fast.","translation_ko":"공연 날, 내 심장이 빠르게 뛰어요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p4-s1.mp3","wordTimings":[{"word":"On","charStart":0,"charEnd":2,"startMs":0,"endMs":240},{"word":"the","charStart":3,"charEnd":6,"startMs":240,"endMs":400},{"word":"day","charStart":7,"charEnd":10,"startMs":400,"endMs":660},{"word":"of","charStart":11,"charEnd":13,"startMs":660,"endMs":820},{"word":"the","charStart":14,"charEnd":17,"startMs":820,"endMs":960},{"word":"show","charStart":18,"charEnd":22,"startMs":960,"endMs":1220},{"word":"my","charStart":24,"charEnd":26,"startMs":1500,"endMs":1720},{"word":"heart","charStart":27,"charEnd":32,"startMs":1720,"endMs":1960},{"word":"beats","charStart":33,"charEnd":38,"startMs":1960,"endMs":2340},{"word":"fast","charStart":39,"charEnd":43,"startMs":2340,"endMs":2800}]},{"id":"daily-24-the-talent-show-p4-s2","ord":1,"text":"I eat only a little breakfast because my stomach feels tight.","translation_ko":"배가 긴장되어서 아침을 조금밖에 못 먹어요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p4-s2.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":200},{"word":"eat","charStart":2,"charEnd":5,"startMs":200,"endMs":460},{"word":"only","charStart":6,"charEnd":10,"startMs":460,"endMs":840},{"word":"a","charStart":11,"charEnd":12,"startMs":840,"endMs":1040},{"word":"little","charStart":13,"charEnd":19,"startMs":1040,"endMs":1200},{"word":"breakfast","charStart":20,"charEnd":29,"startMs":1200,"endMs":1720},{"word":"because","charStart":30,"charEnd":37,"startMs":1720,"endMs":2180},{"word":"my","charStart":38,"charEnd":40,"startMs":2180,"endMs":2440},{"word":"stomach","charStart":41,"charEnd":48,"startMs":2440,"endMs":2680},{"word":"feels","charStart":49,"charEnd":54,"startMs":2680,"endMs":3060},{"word":"tight","charStart":55,"charEnd":60,"startMs":3060,"endMs":3380}]},{"id":"daily-24-the-talent-show-p4-s3","ord":2,"text":"I keep telling myself, \"You practiced. You are ready.\"","translation_ko":"나는 계속 속으로 말해요. '연습했잖아. 준비됐어.' 라고요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p4-s3.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":200},{"word":"keep","charStart":2,"charEnd":6,"startMs":200,"endMs":440},{"word":"telling","charStart":7,"charEnd":14,"startMs":440,"endMs":760},{"word":"myself","charStart":15,"charEnd":21,"startMs":760,"endMs":1280},{"word":"You","charStart":24,"charEnd":27,"startMs":1760,"endMs":1880},{"word":"practiced","charStart":28,"charEnd":37,"startMs":1880,"endMs":2400},{"word":"You","charStart":39,"charEnd":42,"startMs":2960,"endMs":3100},{"word":"are","charStart":43,"charEnd":46,"startMs":3100,"endMs":3340},{"word":"ready","charStart":47,"charEnd":52,"startMs":3340,"endMs":3480}]}]},{"id":"daily-24-the-talent-show-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/daily-24-the-talent-show/p5.webp","sentences":[{"id":"daily-24-the-talent-show-p5-s1","ord":0,"text":"The lights are bright and the hall is full.","translation_ko":"조명은 밝고 강당은 가득 찼어요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p5-s1.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":720},{"word":"lights","charStart":4,"charEnd":10,"startMs":720,"endMs":1000},{"word":"are","charStart":11,"charEnd":14,"startMs":1000,"endMs":1320},{"word":"bright","charStart":15,"charEnd":21,"startMs":1320,"endMs":1580},{"word":"and","charStart":22,"charEnd":25,"startMs":1580,"endMs":2140},{"word":"the","charStart":26,"charEnd":29,"startMs":2140,"endMs":2460},{"word":"hall","charStart":30,"charEnd":34,"startMs":2460,"endMs":2460},{"word":"is","charStart":35,"charEnd":37,"startMs":2460,"endMs":2800},{"word":"full","charStart":38,"charEnd":42,"startMs":2800,"endMs":2960}]},{"id":"daily-24-the-talent-show-p5-s2","ord":1,"text":"I can see families sitting in long rows of chairs.","translation_ko":"긴 의자 줄에 가족들이 앉아 있는 게 보여요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p5-s2.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":260},{"word":"can","charStart":2,"charEnd":5,"startMs":260,"endMs":620},{"word":"see","charStart":6,"charEnd":9,"startMs":620,"endMs":940},{"word":"families","charStart":10,"charEnd":18,"startMs":940,"endMs":1500},{"word":"sitting","charStart":19,"charEnd":26,"startMs":1500,"endMs":1800},{"word":"in","charStart":27,"charEnd":29,"startMs":1800,"endMs":2160},{"word":"long","charStart":30,"charEnd":34,"startMs":2160,"endMs":2340},{"word":"rows","charStart":35,"charEnd":39,"startMs":2340,"endMs":2580},{"word":"of","charStart":40,"charEnd":42,"startMs":2580,"endMs":3220},{"word":"chairs","charStart":43,"charEnd":49,"startMs":3220,"endMs":3220}]},{"id":"daily-24-the-talent-show-p5-s3","ord":2,"text":"The noise of the crowd makes everything feel real and exciting.","translation_ko":"관중의 소음이 모든 것을 실감나고 설레게 만들어요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p5-s3.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":200},{"word":"noise","charStart":4,"charEnd":9,"startMs":200,"endMs":560},{"word":"of","charStart":10,"charEnd":12,"startMs":560,"endMs":700},{"word":"the","charStart":13,"charEnd":16,"startMs":700,"endMs":880},{"word":"crowd","charStart":17,"charEnd":22,"startMs":880,"endMs":1200},{"word":"makes","charStart":23,"charEnd":28,"startMs":1200,"endMs":1600},{"word":"everything","charStart":29,"charEnd":39,"startMs":1600,"endMs":2120},{"word":"feel","charStart":40,"charEnd":44,"startMs":2120,"endMs":2520},{"word":"real","charStart":45,"charEnd":49,"startMs":2520,"endMs":2800},{"word":"and","charStart":50,"charEnd":53,"startMs":2800,"endMs":3140},{"word":"exciting","charStart":54,"charEnd":62,"startMs":3140,"endMs":3440}]}]},{"id":"daily-24-the-talent-show-p6","pageNo":6,"spread":"p6","imageUrl":"/seed/daily-24-the-talent-show/p6.webp","sentences":[{"id":"daily-24-the-talent-show-p6-s1","ord":0,"text":"I take a deep breath and begin to play.","translation_ko":"나는 깊게 숨을 쉬고 연주를 시작해요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p6-s1.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":640},{"word":"take","charStart":2,"charEnd":6,"startMs":640,"endMs":860},{"word":"a","charStart":7,"charEnd":8,"startMs":860,"endMs":1100},{"word":"deep","charStart":9,"charEnd":13,"startMs":1100,"endMs":1260},{"word":"breath","charStart":14,"charEnd":20,"startMs":1260,"endMs":1580},{"word":"and","charStart":21,"charEnd":24,"startMs":1580,"endMs":2080},{"word":"begin","charStart":25,"charEnd":30,"startMs":2080,"endMs":2300},{"word":"to","charStart":31,"charEnd":33,"startMs":2300,"endMs":2520},{"word":"play","charStart":34,"charEnd":38,"startMs":2520,"endMs":2700}]},{"id":"daily-24-the-talent-show-p6-s2","ord":1,"text":"For one second I forget everything around me.","translation_ko":"1초 동안 주변의 모든 것이 잊혀져요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p6-s2.mp3","wordTimings":[{"word":"For","charStart":0,"charEnd":3,"startMs":0,"endMs":700},{"word":"one","charStart":4,"charEnd":7,"startMs":700,"endMs":1020},{"word":"second","charStart":8,"charEnd":14,"startMs":1020,"endMs":1300},{"word":"I","charStart":15,"charEnd":16,"startMs":1440,"endMs":1560},{"word":"forget","charStart":17,"charEnd":23,"startMs":1560,"endMs":1820},{"word":"everything","charStart":24,"charEnd":34,"startMs":1820,"endMs":2360},{"word":"around","charStart":35,"charEnd":41,"startMs":2360,"endMs":2660},{"word":"me","charStart":42,"charEnd":44,"startMs":2660,"endMs":2920}]},{"id":"daily-24-the-talent-show-p6-s3","ord":2,"text":"Then the music guides my hands forward.","translation_ko":"그러고 나서 음악이 내 손을 앞으로 이끌어요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p6-s3.mp3","wordTimings":[{"word":"Then","charStart":0,"charEnd":4,"startMs":0,"endMs":360},{"word":"the","charStart":5,"charEnd":8,"startMs":360,"endMs":680},{"word":"music","charStart":9,"charEnd":14,"startMs":680,"endMs":1140},{"word":"guides","charStart":15,"charEnd":21,"startMs":1140,"endMs":1580},{"word":"my","charStart":22,"charEnd":24,"startMs":1580,"endMs":1840},{"word":"hands","charStart":25,"charEnd":30,"startMs":1840,"endMs":2160},{"word":"forward","charStart":31,"charEnd":38,"startMs":2160,"endMs":2620}]}]},{"id":"daily-24-the-talent-show-p7","pageNo":7,"spread":"p7","imageUrl":"/seed/daily-24-the-talent-show/p7.webp","sentences":[{"id":"daily-24-the-talent-show-p7-s1","ord":0,"text":"My fingers move softly across the keys.","translation_ko":"내 손가락이 건반 위를 부드럽게 움직여요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p7-s1.mp3","wordTimings":[{"word":"My","charStart":0,"charEnd":2,"startMs":0,"endMs":340},{"word":"fingers","charStart":3,"charEnd":10,"startMs":340,"endMs":740},{"word":"move","charStart":11,"charEnd":15,"startMs":740,"endMs":1280},{"word":"softly","charStart":16,"charEnd":22,"startMs":1280,"endMs":1840},{"word":"across","charStart":23,"charEnd":29,"startMs":1840,"endMs":2260},{"word":"the","charStart":30,"charEnd":33,"startMs":2260,"endMs":2520},{"word":"keys","charStart":34,"charEnd":38,"startMs":2520,"endMs":2840}]},{"id":"daily-24-the-talent-show-p7-s2","ord":1,"text":"Each note fills the quiet hall with a warm sound.","translation_ko":"하나하나의 음이 조용한 강당을 따뜻한 소리로 채워요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p7-s2.mp3","wordTimings":[{"word":"Each","charStart":0,"charEnd":4,"startMs":0,"endMs":440},{"word":"note","charStart":5,"charEnd":9,"startMs":440,"endMs":780},{"word":"fills","charStart":10,"charEnd":15,"startMs":780,"endMs":1540},{"word":"the","charStart":16,"charEnd":19,"startMs":1540,"endMs":1840},{"word":"quiet","charStart":20,"charEnd":25,"startMs":1840,"endMs":2120},{"word":"hall","charStart":26,"charEnd":30,"startMs":2120,"endMs":2480},{"word":"with","charStart":31,"charEnd":35,"startMs":2480,"endMs":2700},{"word":"a","charStart":36,"charEnd":37,"startMs":2700,"endMs":2920},{"word":"warm","charStart":38,"charEnd":42,"startMs":2920,"endMs":3280},{"word":"sound","charStart":43,"charEnd":48,"startMs":3280,"endMs":3740}]},{"id":"daily-24-the-talent-show-p7-s3","ord":2,"text":"I close my eyes for a moment and feel the rhythm in my whole body.","translation_ko":"잠깐 눈을 감으면 온몸으로 리듬이 느껴져요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p7-s3.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":660},{"word":"close","charStart":2,"charEnd":7,"startMs":660,"endMs":920},{"word":"my","charStart":8,"charEnd":10,"startMs":920,"endMs":1420},{"word":"eyes","charStart":11,"charEnd":15,"startMs":1420,"endMs":1420},{"word":"for","charStart":16,"charEnd":19,"startMs":1420,"endMs":1640},{"word":"a","charStart":20,"charEnd":21,"startMs":1640,"endMs":2020},{"word":"moment","charStart":22,"charEnd":28,"startMs":2020,"endMs":2020},{"word":"and","charStart":29,"charEnd":32,"startMs":2020,"endMs":2680},{"word":"feel","charStart":33,"charEnd":37,"startMs":2680,"endMs":2940},{"word":"the","charStart":38,"charEnd":41,"startMs":2940,"endMs":3380},{"word":"rhythm","charStart":42,"charEnd":48,"startMs":3380,"endMs":3380},{"word":"in","charStart":49,"charEnd":51,"startMs":3380,"endMs":3640},{"word":"my","charStart":52,"charEnd":54,"startMs":3640,"endMs":3820},{"word":"whole","charStart":55,"charEnd":60,"startMs":3820,"endMs":4160},{"word":"body","charStart":61,"charEnd":65,"startMs":4160,"endMs":4340}]}]},{"id":"daily-24-the-talent-show-p8","pageNo":8,"spread":"p8","imageUrl":"/seed/daily-24-the-talent-show/p8.webp","sentences":[{"id":"daily-24-the-talent-show-p8-s1","ord":0,"text":"When I finish, everyone claps loudly.","translation_ko":"내가 끝내자 모두가 크게 박수쳐요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p8-s1.mp3","wordTimings":[{"word":"When","charStart":0,"charEnd":4,"startMs":0,"endMs":200},{"word":"I","charStart":5,"charEnd":6,"startMs":200,"endMs":420},{"word":"finish","charStart":7,"charEnd":13,"startMs":420,"endMs":800},{"word":"everyone","charStart":15,"charEnd":23,"startMs":1140,"endMs":1500},{"word":"claps","charStart":24,"charEnd":29,"startMs":1500,"endMs":1860},{"word":"loudly","charStart":30,"charEnd":36,"startMs":1860,"endMs":2260}]},{"id":"daily-24-the-talent-show-p8-s2","ord":1,"text":"I stand up and bow, and my cheeks feel warm.","translation_ko":"나는 일어나서 인사하는데 뺨이 따뜻하게 달아올라요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p8-s2.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":620},{"word":"stand","charStart":2,"charEnd":7,"startMs":620,"endMs":980},{"word":"up","charStart":8,"charEnd":10,"startMs":980,"endMs":1180},{"word":"and","charStart":11,"charEnd":14,"startMs":1180,"endMs":1620},{"word":"bow","charStart":15,"charEnd":18,"startMs":1620,"endMs":1620},{"word":"and","charStart":20,"charEnd":23,"startMs":2120,"endMs":2180},{"word":"my","charStart":24,"charEnd":26,"startMs":2180,"endMs":2400},{"word":"cheeks","charStart":27,"charEnd":33,"startMs":2400,"endMs":2620},{"word":"feel","charStart":34,"charEnd":38,"startMs":2620,"endMs":2960},{"word":"warm","charStart":39,"charEnd":43,"startMs":2960,"endMs":3260}]},{"id":"daily-24-the-talent-show-p8-s3","ord":2,"text":"The sound of the applause rushes over me like a wave.","translation_ko":"박수 소리가 파도처럼 나를 가득 감싸요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p8-s3.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":800},{"word":"sound","charStart":4,"charEnd":9,"startMs":800,"endMs":1080},{"word":"of","charStart":10,"charEnd":12,"startMs":1080,"endMs":1180},{"word":"the","charStart":13,"charEnd":16,"startMs":1180,"endMs":1480},{"word":"applause","charStart":17,"charEnd":25,"startMs":1480,"endMs":1800},{"word":"rushes","charStart":26,"charEnd":32,"startMs":1800,"endMs":2380},{"word":"over","charStart":33,"charEnd":37,"startMs":2380,"endMs":2520},{"word":"me","charStart":38,"charEnd":40,"startMs":2520,"endMs":2800},{"word":"like","charStart":41,"charEnd":45,"startMs":2800,"endMs":3040},{"word":"a","charStart":46,"charEnd":47,"startMs":3040,"endMs":3440},{"word":"wave","charStart":48,"charEnd":52,"startMs":3440,"endMs":3440}]}]},{"id":"daily-24-the-talent-show-p9","pageNo":9,"spread":"p9","imageUrl":"/seed/daily-24-the-talent-show/p9.webp","sentences":[{"id":"daily-24-the-talent-show-p9-s1","ord":0,"text":"I feel proud that I did my best.","translation_ko":"최선을 다해서 자랑스러워요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p9-s1.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":300},{"word":"feel","charStart":2,"charEnd":6,"startMs":300,"endMs":500},{"word":"proud","charStart":7,"charEnd":12,"startMs":500,"endMs":900},{"word":"that","charStart":13,"charEnd":17,"startMs":900,"endMs":1260},{"word":"I","charStart":18,"charEnd":19,"startMs":1260,"endMs":1440},{"word":"did","charStart":20,"charEnd":23,"startMs":1440,"endMs":1520},{"word":"my","charStart":24,"charEnd":26,"startMs":1520,"endMs":1760},{"word":"best","charStart":27,"charEnd":31,"startMs":1760,"endMs":2000}]},{"id":"daily-24-the-talent-show-p9-s2","ord":1,"text":"I did not play every note perfectly, but I kept going without stopping.","translation_ko":"모든 음을 완벽하게 치지는 못했지만, 멈추지 않고 계속했어요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p9-s2.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":360},{"word":"did","charStart":2,"charEnd":5,"startMs":360,"endMs":580},{"word":"not","charStart":6,"charEnd":9,"startMs":580,"endMs":960},{"word":"play","charStart":10,"charEnd":14,"startMs":960,"endMs":1280},{"word":"every","charStart":15,"charEnd":20,"startMs":1280,"endMs":1680},{"word":"note","charStart":21,"charEnd":25,"startMs":1680,"endMs":1920},{"word":"perfectly","charStart":26,"charEnd":35,"startMs":1920,"endMs":2460},{"word":"but","charStart":37,"charEnd":40,"startMs":2940,"endMs":2980},{"word":"I","charStart":41,"charEnd":42,"startMs":2980,"endMs":3340},{"word":"kept","charStart":43,"charEnd":47,"startMs":3340,"endMs":3420},{"word":"going","charStart":48,"charEnd":53,"startMs":3420,"endMs":3840},{"word":"without","charStart":54,"charEnd":61,"startMs":3840,"endMs":4300},{"word":"stopping","charStart":62,"charEnd":70,"startMs":4300,"endMs":4740}]},{"id":"daily-24-the-talent-show-p9-s3","ord":2,"text":"That feels like a real win to me.","translation_ko":"그게 나에게는 진짜 이긴 것처럼 느껴져요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p9-s3.mp3","wordTimings":[{"word":"That","charStart":0,"charEnd":4,"startMs":0,"endMs":300},{"word":"feels","charStart":5,"charEnd":10,"startMs":300,"endMs":680},{"word":"like","charStart":11,"charEnd":15,"startMs":680,"endMs":900},{"word":"a","charStart":16,"charEnd":17,"startMs":900,"endMs":1120},{"word":"real","charStart":18,"charEnd":22,"startMs":1120,"endMs":1360},{"word":"win","charStart":23,"charEnd":26,"startMs":1360,"endMs":1680},{"word":"to","charStart":27,"charEnd":29,"startMs":1680,"endMs":1860},{"word":"me","charStart":30,"charEnd":32,"startMs":1860,"endMs":2080}]}]},{"id":"daily-24-the-talent-show-p10","pageNo":10,"spread":"p10","imageUrl":"/seed/daily-24-the-talent-show/p10.webp","sentences":[{"id":"daily-24-the-talent-show-p10-s1","ord":0,"text":"After the show, a younger student asks how I stayed brave on stage.","translation_ko":"공연 뒤에 어린 학생이 무대에서 어떻게 용감했는지 물어요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p10-s1.mp3","wordTimings":[{"word":"After","charStart":0,"charEnd":5,"startMs":0,"endMs":420},{"word":"the","charStart":6,"charEnd":9,"startMs":420,"endMs":840},{"word":"show","charStart":10,"charEnd":14,"startMs":840,"endMs":1160},{"word":"a","charStart":16,"charEnd":17,"startMs":1340,"endMs":2020},{"word":"younger","charStart":18,"charEnd":25,"startMs":2020,"endMs":2020},{"word":"student","charStart":26,"charEnd":33,"startMs":2020,"endMs":2420},{"word":"asks","charStart":34,"charEnd":38,"startMs":2420,"endMs":2780},{"word":"how","charStart":39,"charEnd":42,"startMs":2780,"endMs":3040},{"word":"I","charStart":43,"charEnd":44,"startMs":3040,"endMs":3300},{"word":"stayed","charStart":45,"charEnd":51,"startMs":3300,"endMs":3500},{"word":"brave","charStart":52,"charEnd":57,"startMs":3500,"endMs":3800},{"word":"on","charStart":58,"charEnd":60,"startMs":3800,"endMs":4160},{"word":"stage","charStart":61,"charEnd":66,"startMs":4160,"endMs":4440}]},{"id":"daily-24-the-talent-show-p10-s2","ord":1,"text":"I tell her that practice made the room feel less strange.","translation_ko":"나는 연습 덕분에 공연장이 덜 낯설게 느껴졌다고 말해요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p10-s2.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":520},{"word":"tell","charStart":2,"charEnd":6,"startMs":520,"endMs":780},{"word":"her","charStart":7,"charEnd":10,"startMs":780,"endMs":940},{"word":"that","charStart":11,"charEnd":15,"startMs":940,"endMs":1400},{"word":"practice","charStart":16,"charEnd":24,"startMs":1400,"endMs":1800},{"word":"made","charStart":25,"charEnd":29,"startMs":1800,"endMs":2040},{"word":"the","charStart":30,"charEnd":33,"startMs":2040,"endMs":2240},{"word":"room","charStart":34,"charEnd":38,"startMs":2240,"endMs":2440},{"word":"feel","charStart":39,"charEnd":43,"startMs":2440,"endMs":2780},{"word":"less","charStart":44,"charEnd":48,"startMs":2780,"endMs":3040},{"word":"strange","charStart":49,"charEnd":56,"startMs":3040,"endMs":3480}]},{"id":"daily-24-the-talent-show-p10-s3","ord":2,"text":"I also say that feeling nervous is normal and even helpful.","translation_ko":"긴장하는 건 자연스러운 일이고 오히려 도움이 된다고도 말해요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p10-s3.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":180},{"word":"also","charStart":2,"charEnd":6,"startMs":180,"endMs":720},{"word":"say","charStart":7,"charEnd":10,"startMs":720,"endMs":1040},{"word":"that","charStart":11,"charEnd":15,"startMs":1040,"endMs":1340},{"word":"feeling","charStart":16,"charEnd":23,"startMs":1340,"endMs":1680},{"word":"nervous","charStart":24,"charEnd":31,"startMs":1680,"endMs":2040},{"word":"is","charStart":32,"charEnd":34,"startMs":2040,"endMs":2420},{"word":"normal","charStart":35,"charEnd":41,"startMs":2420,"endMs":2780},{"word":"and","charStart":42,"charEnd":45,"startMs":2780,"endMs":3180},{"word":"even","charStart":46,"charEnd":50,"startMs":3180,"endMs":3480},{"word":"helpful","charStart":51,"charEnd":58,"startMs":3480,"endMs":3840}]}]},{"id":"daily-24-the-talent-show-p11","pageNo":11,"spread":"p11","imageUrl":"/seed/daily-24-the-talent-show/p11.webp","sentences":[{"id":"daily-24-the-talent-show-p11-s1","ord":0,"text":"I also tell her that mistakes can happen, even after many rehearsals.","translation_ko":"나는 연습을 많이 해도 실수는 생길 수 있다고 말해요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p11-s1.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":180},{"word":"also","charStart":2,"charEnd":6,"startMs":180,"endMs":600},{"word":"tell","charStart":7,"charEnd":11,"startMs":600,"endMs":840},{"word":"her","charStart":12,"charEnd":15,"startMs":840,"endMs":1000},{"word":"that","charStart":16,"charEnd":20,"startMs":1000,"endMs":1220},{"word":"mistakes","charStart":21,"charEnd":29,"startMs":1220,"endMs":1600},{"word":"can","charStart":30,"charEnd":33,"startMs":1600,"endMs":1860},{"word":"happen","charStart":34,"charEnd":40,"startMs":1860,"endMs":2160},{"word":"even","charStart":42,"charEnd":46,"startMs":2160,"endMs":2600},{"word":"after","charStart":47,"charEnd":52,"startMs":2600,"endMs":2880},{"word":"many","charStart":53,"charEnd":57,"startMs":2880,"endMs":3260},{"word":"rehearsals","charStart":58,"charEnd":68,"startMs":3260,"endMs":3840}]},{"id":"daily-24-the-talent-show-p11-s2","ord":1,"text":"The important thing is to keep playing and breathe.","translation_ko":"중요한 것은 계속 연주하고 숨 쉬는 거예요.","audioUrl":"/seed/daily-24-the-talent-show/audio/p11-s2.mp3","wordTimings":[{"word"