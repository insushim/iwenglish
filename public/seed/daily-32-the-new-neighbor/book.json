s":1980,"endMs":2160},{"word":"engine","charStart":30,"charEnd":36,"startMs":2160,"endMs":2440},{"word":"makes","charStart":37,"charEnd":42,"startMs":2440,"endMs":2700},{"word":"a","charStart":43,"charEnd":44,"startMs":2700,"endMs":2980},{"word":"loud","charStart":45,"charEnd":49,"startMs":2980,"endMs":3180},{"word":"sound","charStart":50,"charEnd":55,"startMs":3180,"endMs":3540}]}]},{"id":"daily-32-the-new-neighbor-p2","pageNo":2,"spread":"p2","imageUrl":"/seed/daily-32-the-new-neighbor/p2.webp","sentences":[{"id":"daily-32-the-new-neighbor-p2-s1","ord":0,"text":"A new girl stands beside many boxes.","translation_ko":"새로 온 여자아이가 많은 상자 옆에 서 있어요.","audioUrl":"/seed/daily-32-the-new-neighbor/audio/p2-s1.mp3","wordTimings":[{"word":"A","charStart":0,"charEnd":1,"startMs":0,"endMs":940},{"word":"new","charStart":2,"charEnd":5,"startMs":940,"endMs":1200},{"word":"girl","charStart":6,"charEnd":10,"startMs":1200,"endMs":1440},{"word":"stands","charStart":11,"charEnd":17,"startMs":1440,"endMs":1780},{"word":"beside","charStart":18,"charEnd":24,"startMs":1780,"endMs":2180},{"word":"many","charStart":25,"charEnd":29,"startMs":2180,"endMs":2540},{"word":"boxes","charStart":30,"charEnd":35,"startMs":2540,"endMs":2820}]},{"id":"daily-32-the-new-neighbor-p2-s2","ord":1,"text":"The boxes are stacked almost as tall as she is.","translation_ko":"상자들이 그 아이 키만큼이나 높이 쌓여 있어요.","audioUrl":"/seed/daily-32-the-new-neighbor/audio/p2-s2.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":180},{"word":"boxes","charStart":4,"charEnd":9,"startMs":180,"endMs":480},{"word":"are","charStart":10,"charEnd":13,"startMs":480,"endMs":940},{"word":"stacked","charStart":14,"charEnd":21,"startMs":940,"endMs":1220},{"word":"almost","charStart":22,"charEnd":28,"startMs":1220,"endMs":1660},{"word":"as","charStart":29,"charEnd":31,"startMs":1660,"endMs":2060},{"word":"tall","charStart":32,"charEnd":36,"startMs":2060,"endMs":2120},{"word":"as","charStart":37,"charEnd":39,"startMs":2120,"endMs":2320},{"word":"she","charStart":40,"charEnd":43,"startMs":2320,"endMs":2480},{"word":"is","charStart":44,"charEnd":46,"startMs":2480,"endMs":2700}]},{"id":"daily-32-the-new-neighbor-p2-s3","ord":2,"text":"She looks around at everything slowly.","translation_ko":"그 아이는 주위를 천천히 둘러봐요.","audioUrl":"/seed/daily-32-the-new-neighbor/audio/p2-s3.mp3","wordTimings":[{"word":"She","charStart":0,"charEnd":3,"startMs":0,"endMs":280},{"word":"looks","charStart":4,"charEnd":9,"startMs":280,"endMs":540},{"word":"around","charStart":10,"charEnd":16,"startMs":540,"endMs":940},{"word":"at","charStart":17,"charEnd":19,"startMs":940,"endMs":1260},{"word":"everything","charStart":20,"charEnd":30,"startMs":1260,"endMs":1640},{"word":"slowly","charStart":31,"charEnd":37,"startMs":1640,"endMs":2040}]}]},{"id":"daily-32-the-new-neighbor-p3","pageNo":3,"spread":"p3","imageUrl":"/seed/daily-32-the-new-neighbor/p3.webp","sentences":[{"id":"daily-32-the-new-neighbor-p3-s1","ord":0,"text":"She looks shy, so I wave and smile first.","translation_ko":"그 아이가 수줍어 보여서 내가 먼저 손을 흔들며 웃어요.","audioUrl":"/seed/daily-32-the-new-neighbor/audio/p3-s1.mp3","wordTimings":[{"word":"She","charStart":0,"charEnd":3,"startMs":0,"endMs":240},{"word":"looks","charStart":4,"charEnd":9,"startMs":240,"endMs":480},{"word":"shy","charStart":10,"charEnd":13,"startMs":480,"endMs":820},{"word":"so","charStart":15,"charEnd":17,"startMs":1340,"endMs":1460},{"word":"I","charStart":18,"charEnd":19,"startMs":1460,"endMs":1820},{"word":"wave","charStart":20,"charEnd":24,"startMs":1820,"endMs":1860},{"word":"and","charStart":25,"charEnd":28,"startMs":1860,"endMs":2180},{"word":"smile","charStart":29,"charEnd":34,"startMs":2180,"endMs":2380},{"word":"first","charStart":35,"charEnd":40,"startMs":2380,"endMs":2860}]},{"id":"daily-32-the-new-neighbor-p3-s2","ord":1,"text":"After a moment, she smiles back and waves too.","translation_ko":"잠시 후, 그 아이도 웃으며 손을 흔들어 줘요.","audioUrl":"/seed/daily-32-the-new-neighbor/audio/p3-s2.mp3","wordTimings":[{"word":"After","charStart":0,"charEnd":5,"startMs":0,"endMs":360},{"word":"a","charStart":6,"charEnd":7,"startMs":360,"endMs":920},{"word":"moment","charStart":8,"charEnd":14,"startMs":920,"endMs":920},{"word":"she","charStart":16,"charEnd":19,"startMs":1300,"endMs":1520},{"word":"smiles","charStart":20,"charEnd":26,"startMs":1520,"endMs":1880},{"word":"back","charStart":27,"charEnd":31,"startMs":1880,"endMs":2300},{"word":"and","charStart":32,"charEnd":35,"startMs":2300,"endMs":2740},{"word":"waves","charStart":36,"charEnd":41,"startMs":2740,"endMs":2960},{"word":"too","charStart":42,"charEnd":45,"startMs":2960,"endMs":3340}]}]},{"id":"daily-32-the-new-neighbor-p4","pageNo":4,"spread":"p4","imageUrl":"/seed/daily-32-the-new-neighbor/p4.webp","sentences":[{"id":"daily-32-the-new-neighbor-p4-s1","ord":0,"text":"Her name is Hana, and she likes drawing.","translation_ko":"그 아이 이름은 하나이고, 그림 그리기를 좋아해요.","audioUrl":"/seed/daily-32-the-new-neighbor/audio/p4-s1.mp3","wordTimings":[{"word":"Her","charStart":0,"charEnd":3,"startMs":0,"endMs":240},{"word":"name","charStart":4,"charEnd":8,"startMs":240,"endMs":600},{"word":"is","charStart":9,"charEnd":11,"startMs":600,"endMs":940},{"word":"Hana","charStart":12,"charEnd":16,"startMs":940,"endMs":1160},{"word":"and","charStart":18,"charEnd":21,"startMs":1420,"endMs":1960},{"word":"she","charStart":22,"charEnd":25,"startMs":1960,"endMs":2180},{"word":"likes","charStart":26,"charEnd":31,"startMs":2180,"endMs":2320},{"word":"drawing","charStart":32,"charEnd":39,"startMs":2320,"endMs":2700}]},{"id":"daily-32-the-new-neighbor-p4-s2","ord":1,"text":"She has two sketchbooks full of colorful pictures.","translation_ko":"색이 풍부한 그림들로 가득 찬 스케치북이 두 권 있어요.","audioUrl":"/seed/daily-32-the-new-neighbor/audio/p4-s2.mp3","wordTimings":[{"word":"She","charStart":0,"charEnd":3,"startMs":0,"endMs":420},{"word":"has","charStart":4,"charEnd":7,"startMs":420,"endMs":760},{"word":"two","charStart":8,"charEnd":11,"startMs":760,"endMs":1220},{"word":"sketchbooks","charStart":12,"charEnd":23,"startMs":1220,"endMs":1820},{"word":"full","charStart":24,"charEnd":28,"startMs":1820,"endMs":2200},{"word":"of","charStart":29,"charEnd":31,"startMs":2200,"endMs":2540},{"word":"colorful","charStart":32,"charEnd":40,"startMs":2540,"endMs":2920},{"word":"pictures","charStart":41,"charEnd":49,"startMs":2920,"endMs":3340}]},{"id":"daily-32-the-new-neighbor-p4-s3","ord":2,"text":"I think we are going to be great friends.","translation_ko":"우리는 정말 좋은 친구가 될 것 같아요.","audioUrl":"/seed/daily-32-the-new-neighbor/audio/p4-s3.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":240},{"word":"think","charStart":2,"charEnd":7,"startMs":240,"endMs":620},{"word":"we","charStart":8,"charEnd":10,"startMs":620,"endMs":920},{"word":"are","charStart":11,"charEnd":14,"startMs":920,"endMs":1040},{"word":"going","charStart":15,"charEnd":20,"startMs":1040,"endMs":1280},{"word":"to","charStart":21,"charEnd":23,"startMs":1280,"endMs":1420},{"word":"be","charStart":24,"charEnd":26,"startMs":1420,"endMs":1560},{"word":"great","charStart":27,"charEnd":32,"startMs":1560,"endMs":1900},{"word":"friends","charStart":33,"charEnd":40,"startMs":1900,"endMs":2420}]}]},{"id":"daily-32-the-new-neighbor-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/daily-32-the-new-neighbor/p5.webp","sentences":[{"id":"daily-32-the-new-neighbor-p5-s1","ord":0,"text":"I help carry a light box to the door.","translation_ko":"나는 가벼운 상자를 문까지 옮기는 걸 도와요.","audioUrl":"/seed/daily-32-the-new-neighbor/audio/p5-s1.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":380},{"word":"help","charStart":2,"charEnd":6,"startMs":380,"endMs":740},{"word":"carry","charStart":7,"charEnd":12,"startMs":740,"endMs":1180},{"word":"a","charStart":13,"charEnd":14,"startMs":1180,"endMs":1440},{"word":"light","charStart":15,"charEnd":20,"startMs":1440,"endMs":1620},{"word":"box","charStart":21,"charEnd":24,"startMs":1620,"endMs":1960},{"word":"to