p6-s1","ord":0,"text":"Later, I show her the small playground near our building.","translation_ko":"나중에 나는 하나에게 건물 근처의 작은 놀이터를 보여줘요.","audioUrl":"/seed/daily-32-the-new-neighbor/audio/p6-s1.mp3","wordTimings":[{"word":"Later","charStart":0,"charEnd":5,"startMs":0,"endMs":400},{"word":"I","charStart":7,"charEnd":8,"startMs":780,"endMs":1000},{"word":"show","charStart":9,"charEnd":13,"startMs":1000,"endMs":1180},{"word":"her","charStart":14,"charEnd":17,"startMs":1180,"endMs":1300},{"word":"the","charStart":18,"charEnd":21,"startMs":1300,"endMs":1560},{"word":"small","charStart":22,"charEnd":27,"startMs":1560,"endMs":1880},{"word":"playground","charStart":28,"charEnd":38,"startMs":1880,"endMs":2340},{"word":"near","charStart":39,"charEnd":43,"startMs":2340,"endMs":2680},{"word":"our","charStart":44,"charEnd":47,"startMs":2680,"endMs":2940},{"word":"building","charStart":48,"charEnd":56,"startMs":2940,"endMs":3140}]},{"id":"daily-32-the-new-neighbor-p6-s2","ord":1,"text":"Hana says she loves it and wants to come back tomorrow.","translation_ko":"하나는 너무 마음에 든다며 내일 또 오고 싶다고 말해요.","audioUrl":"/seed/daily-32-the-new-neighbor/audio/p6-s2.mp3","wordTimings":[{"word":"Hana","charStart":0,"charEnd":4,"startMs":0,"endMs":340},{"word":"says","charStart":5,"charEnd":9,"startMs":340,"endMs":760},{"word":"she","charStart":10,"charEnd":13,"startMs":1120,"endMs":1320},{"word":"loves","charStart":14,"charEnd":19,"startMs":1320,"endMs":1620},{"word":"it","charStart":20,"charEnd":22,"startMs":1620,"endMs":1820},{"word":"and","charStart":23,"charEnd":26,"startMs":1820,"endMs":2280},{"word":"wants","charStart":27,"charEnd":32,"startMs":2280,"endMs":2520},{"word":"to","charStart":33,"charEnd":35,"startMs":2520,"endMs":2720},{"word":"come","charStart":36,"charEnd":40,"startMs":2720,"endMs":2920},{"word":"back","charStart":41,"charEnd":45,"startMs":2920,"endMs":3180},{"word":"tomorrow","charStart":46,"charEnd":54,"startMs":3180,"endMs":3580}]}]},{"id":"daily-32-the-new-neighbor-p7","pageNo":7,"spread":"p7","imageUrl":"/seed/daily-32-the-new-neighbor/p7.webp","sentences":[{"id":"daily-32-the-new-neighbor-p7-s1","ord":0,"text":"We sit on a bench and draw a map of our street together.","translation_ko":"우리는 벤치에 앉아 함께 우리 거리 지도를 그려요.","audioUrl":"/seed/daily-32-the-new-neighbor/audio/p7-s1.mp3","wordTimings":[{"word":"We","charStart":0,"charEnd":2,"startMs":0,"endMs":280},{"word":"sit","charStart":3,"charEnd":6,"startMs":280,"endMs":580},{"word":"on","charStart":7,"charEnd":9,"startMs":580,"endMs":840},{"word":"a","charStart":10,"charEnd":11,"startMs":840,"endMs":1000},{"word":"bench","charStart":12,"charEnd":17,"startMs":1000,"endMs":1280},{"word":"and","charStart":18,"charEnd":21,"startMs":1280,"endMs":1720},{"word":"draw","charStart":22,"charEnd":26,"startMs":1720,"endMs":1860},{"word":"a","charStart":27,"charEnd":28,"startMs":1860,"endMs":2180},{"word":"map","charStart":29,"charEnd":32,"startMs":2180,"endMs":2180},{"word":"of","charStart":33,"charEnd":35,"startMs":2180,"endMs":2320},{"word":"our","charStart":36,"charEnd":39,"startMs":2320,"endMs":2560},{"word":"street","charStart":40,"charEnd":46,"startMs":2560,"endMs":2820},{"word":"together","charStart":47,"charEnd":55,"startMs":2820,"endMs":3200}]},{"id":"daily-32-the-new-neighbor-p7-s2","ord":1,"text":"Hana draws the bakery, the park, and our building on the map.","translation_ko":"하나는 지도에 빵집, 공원, 우리 건물을 그려요.","audioUrl":"/seed/daily-32-the-new-neighbor/audio/p7-s2.mp3","wordTimings":[{"word":"Hana","charStart":0,"charEnd":4,"startMs":0,"endMs":400},{"word":"draws","charStart":5,"charEnd":10,"startMs":400,"endMs":1000},{"word":"the","charStart":11,"charEnd":14,"startMs":1000,"endMs":1240},{"word":"bakery","charStart":15,"charEnd":21,"startMs":1240,"endMs":1580},{"word":"the","charStart":23,"charEnd":26,"startMs":2060,"endMs":2400},{"word":"park","charStart":27,"charEnd":31,"startMs":2400,"endMs":2400},{"word":"and","charStart":33,"charEnd":36,"startMs":2720,"endMs":2780},{"word":"our","charStart":37