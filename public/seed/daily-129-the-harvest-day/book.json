audioUrl":"/seed/daily-129-the-harvest-day/audio/p10-s2.mp3","wordTimings":[{"word":"Every","charStart":0,"charEnd":5,"startMs":0,"endMs":400},{"word":"neighbor","charStart":6,"charEnd":14,"startMs":400,"endMs":740},{"word":"thanked","charStart":15,"charEnd":22,"startMs":740,"endMs":1120},{"word":"them","charStart":23,"charEnd":27,"startMs":1120,"endMs":1380},{"word":"warmly","charStart":28,"charEnd":34,"startMs":1380,"endMs":1820},{"word":"and","charStart":36,"charEnd":39,"startMs":2340,"endMs":2480},{"word":"some","charStart":40,"charEnd":44,"startMs":2480,"endMs":2680},{"word":"looked","charStart":45,"charEnd":51,"startMs":2680,"endMs":2980},{"word":"genuinely","charStart":52,"charEnd":61,"startMs":2980,"endMs":3620},{"word":"surprised","charStart":62,"charEnd":71,"startMs":3620,"endMs":4180}]}]},{"id":"daily-129-the-harvest-day-p11","pageNo":11,"spread":"p11","imageUrl":"/seed/daily-129-the-harvest-day/p11.webp","sentences":[{"id":"daily-129-the-harvest-day-p11-s1","ord":0,"text":"On the way home, Mina said, \"I thought harvesting was just about picking vegetables.\"","translation_ko":"집으로 돌아오는 길에 미나가 말했다. \"수확이 그냥 채소 따는 일인 줄 알았어.\"","audioUrl":"/seed/daily-129-the-harvest-day/audio/p11-s1.mp3","wordTimings":[{"word":"On","charStart":0,"charEnd":2,"startMs":0,"endMs":200},{"word":"the","charStart":3,"charEnd":6,"startMs":200,"endMs":320},{"word":"way","charStart":7,"charEnd":10,"startMs":320,"endMs":520},{"word":"home","charStart":11,"charEnd":15,"startMs":520,"endMs":780},{"word":"Mina","charStart":17,"charEnd":21,"startMs":1100,"endMs":1220},{"word":"said","charStart":22,"charEnd":26,"startMs":1220,"endMs":1580},{"word":"I","charStart":29,"charEnd":30,"startMs":2220,"endMs":2260},{"word":"thought","charStart":31,"charEnd":38,"startMs":2260,"endMs":2480},{"word":"harvesting","charStart":39,"charEnd":49,"startMs":2480,"endMs":2860},{"word":"was","charStart":50,"charEnd":53,"startMs":2860,"endMs":3140},{"word":"just","charStart":54,"charEnd":58,"startMs":3140,"endMs":3360},{"word":"about","charStart":59,"charEnd":64,"startMs":3360,"endMs":3600},{"word":"picking","charStart":65,"charEnd":72,"startMs":3600,"endMs":3900},{"word":"vegetables","charStart":73,"charEnd":83,"startMs":3900,"endMs":4280}]},{"id":"daily-129-the-harvest-day-p11-s2","ord":1,"text":"\"But it's really about sharing what you've grown, isn't it?\" she added.","translation_ko":"\"그런데 사실은 키운 걸 나누는 거잖아, 그렇지?\" 미나가 덧붙였다.","audioUrl":"/seed/daily-129-the-harvest-day/audio/p11-s2.mp3","wordTimings":[{"word":"But","charStart":1,"charEnd":4,"startMs":0,"endMs":580},{"word":"it's","charStart":5,"charEnd":9,"startMs":580,"endMs":760},{"word":"really","charStart":10,"charEnd":16,"startMs":760,"endMs":1160},{"word":"about","charStart":17,"charEnd":22,"startMs":1160,"endMs":1460},{"word":"sharing","charStart":23,"charEnd":30,"startMs":1460,"endMs":1800},{"word":"what","charStart":31,"charEnd":35,"startMs":1800,"endMs":1980},{"word":"you've","charStart":36,"charEnd":42,"startMs":1980,"endMs":2280},{"word":"grown","charStart":43,"charEnd":48,"startMs":2280,"endMs":2560},{"word":"isn't","charStart":50,"charEnd":55,"startMs":2720,"endMs":2860},{"word":"it","charStart":56,"charEnd":58,"startMs":2860,"endMs":3660},{"word":"she","charStart":61,"charEnd":64,"startMs":3660,"endMs":3840},{"word":"added","charStart":65,"charEnd":70,"startMs":3840,"endMs":4080}]}]},{"id":"daily-129-the-harvest-day-p12","pageNo":12,"spread":"p12","imageUrl":"/seed/daily-129-the-harvest-day/p12.webp","sentences":[{"id":"daily-129-the-harvest-day-p12-s1","ord":0,"text":"Grandpa nodded and said, \"A garden truly blooms when you give some of it away.\"","translation_ko":"할아버지가 고개를 끄덕이며 말씀하셨다. \"텃밭은 나눌 때 비로소 피어난단다.\"","audioUrl":"/seed/daily-129-the-harvest-day/audio/p12-s1.mp3","wordTimings":[{"word":"Grandpa","charStart":0,"charEnd":7,"startMs":600,"endMs":1080},{"word":"nodded","charStart":8,"charEnd":14,"startMs":1080,"endMs":1480},{"word":"and","charStart":15,"charEnd":18,"startMs":1480,"endMs":1720