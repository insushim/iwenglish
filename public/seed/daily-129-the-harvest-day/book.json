startMs":4940,"endMs":5100},{"word":"sharing","charStart":69,"charEnd":76,"startMs":5100,"endMs":5360},{"word":"it","charStart":77,"charEnd":79,"startMs":5360,"endMs":5660},{"word":"is","charStart":80,"charEnd":82,"startMs":5660,"endMs":6020},{"word":"even","charStart":83,"charEnd":87,"startMs":6020,"endMs":6240},{"word":"better","charStart":88,"charEnd":94,"startMs":6240,"endMs":6460}]}]}],"quiz":[{"question_ko":"준이 할아버지 텃밭에 가는 날 아침의 날씨는 어떠했나요?","type":"mc","options":["맑고 화창했다","흐리고 바람이 강했다","비가 내렸다","안개가 자욱했다"],"answerIndex":0,"explain_ko":"이야기 첫 페이지에 \"The sky was bright and clear\"라고 나와 있습니다. 하늘이 맑고 화창했습니다.","id":"daily-129-the-harvest-day-q1","ord":0},{"question_ko":"미나가 텃밭에 올 때 가져온 것은 무엇인가요?","type":"mc","options":["큰 바구니와 원예용 장갑","물통과 씨앗","삽과 물뿌리개","모자와 앞치마"],"answerIndex":0,"explain_ko":"미나는 \"a big basket and garden gloves\"를 가져왔다고 했습니다.","id":"daily-129-the-harvest-day-q2","ord":1},{"question_ko":"할아버지가 \"A good harvest takes patience\"라고 말하며 가르쳐 준 것은 무엇인가요?","type":"mc","options":["토마토를 살살 비틀어 따는 방법","고구마를 깊이 파내는 방법","오이 줄기를 가위로 자르는 방법","채소를 봉투에 담는 방법"],"answerIndex":0,"explain_ko":"할아버지는 토마토가 멍들지 않도록 살살 비틀어 따는 방법을 가르쳐 주시면서 참을성이 필요하다고 하셨습니다.","id":"daily-129-the-harvest-day-q3","ord":2},{"question_ko":"준, 미나, 할아버지가 수확한 채소로 한 일은 무엇인가요?","type":"mc","options":["이웃들에게 나눠 주었다","시장에 가서 팔았다","모두 창고에 저장했다","학교 급식실에 기부했다"],"answerIndex":0,"explain_ko":"셋은 채소를 종이봉투에 나눠 담아 골목 이웃들에게 직접 전달했습니다.","id":"daily-129-the-harvest-day-q4","ord":3},{"question_ko":"이야기 끝에서 준이 일기장에 쓴 내용은 무엇인가요?","type":"mc","options":["키우는 것도 좋지만 나눠 주는 것이 더 좋다","텃밭 일은 너무 힘들어서 다시는 안 하겠다","내년에는 더 많은 채소를 심고 싶다","할아버지처럼 농부가 되고 싶다"],"answerIndex":0,"explain_ko":"준은 일기에 \"Growing something is good, but sharing it is even better\"라고 썼습니다. 나눔의 소중함을 깨달은 것입니다.","id":"daily-129-the-harvest-day-q5","ord":4}]}