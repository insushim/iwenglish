e song.","translation_ko":"꽃마다 자기만의 작은 노래를 불러요.","audioUrl":"/seed/the-garden-that-sang/audio/p5-s1.mp3","wordTimings":[{"word":"Each","charStart":0,"charEnd":4,"startMs":0,"endMs":300},{"word":"flower","charStart":5,"charEnd":11,"startMs":300,"endMs":640},{"word":"sings","charStart":12,"charEnd":17,"startMs":640,"endMs":1000},{"word":"its","charStart":18,"charEnd":21,"startMs":1000,"endMs":1200},{"word":"own","charStart":22,"charEnd":25,"startMs":1200,"endMs":1540},{"word":"little","charStart":26,"charEnd":32,"startMs":1540,"endMs":1800},{"word":"song","charStart":33,"charEnd":37,"startMs":1800,"endMs":2100}]},{"id":"the-garden-that-sang-p5-s2","ord":1,"text":"Red flowers hum, and blue flowers chime.","translation_ko":"빨간 꽃은 흥얼거리고, 파란 꽃은 딸랑거려요.","audioUrl":"/seed/the-garden-that-sang/audio/p5-s2.mp3","wordTimings":[{"word":"Red","charStart":0,"charEnd":3,"startMs":0,"endMs":420},{"word":"flowers","charStart":4,"charEnd":11,"startMs":420,"endMs":820},{"word":"hum","charStart":12,"charEnd":15,"startMs":820,"endMs":1160},{"word":"and","charStart":17,"charEnd":20,"startMs":1800,"endMs":2240},{"word":"blue","charStart":21,"charEnd":25,"startMs":2240,"endMs":2460},{"word":"flowers","charStart":26,"charEnd":33,"startMs":2460,"endMs":2880},{"word":"chime","charStart":34,"charEnd":39,"startMs":2880,"endMs":3300}]}]},{"id":"the-garden-that-sang-p6","pageNo":6,"spread":"p6","imageUrl":"/seed/the-garden-that-sang/p6.webp","sentences":[{"id":"the-garden-that-sang-p6-s1","ord":0,"text":"Lily dances among the singing flowers.","translation_ko":"릴리가 노래하는 꽃들 사이에서 춤춰요.","audioUrl":"/seed/the-garden-that-sang/audio/p6-s1.mp3","wordTimings":[{"word":"Lily","charStart":0,"charEnd":4,"startMs":0,"endMs":400},{"word":"dances","charStart":5,"charEnd":11,"startMs":400,"endMs":1020},{"word":"among","charStart":12,"charEnd":17,"startMs":1020,"endMs":1400},{"word":"the","charStart":18,"charEnd":21,"startMs":1400,"endMs":1740},{"word":"singing","charStart":22,"charEnd":29,"startMs":1740,"endMs":1960},{"word":"flowers","charStart":30,"charEnd":37,"startMs":1960,"endMs":2460}]},{"id":"the-garden-that-sang-p6-s2","ord":1,"text":"She laughs with joy.","translation_ko":"릴리는 기뻐서 웃어요.","audioUrl":"/seed/the-garden-that-sang/audio/p6-s2.mp3","wordTimings":[{"word":"She","charStart":0,"charEnd":3,"startMs":0,"endMs":540},{"word":"laughs","charStart":4,"charEnd":10,"startMs":540,"endMs":1040},{"word":"with","charStart":11,"charEnd":15,"startMs":1040,"endMs":1500},{"word":"joy","charStart":16,"charEnd":19,"startMs":1500,"endMs":1780}]}]},{"id":"the-garden-that-sang-p7","pageNo":7,"spread":"p7","imageUrl":"/seed/the-garden-that-sang/p7.webp","sentences":[{"id":"the-garden-that-sang-p7-s1","ord":0,"text":"She runs to bring Grandma.","translation_ko":"릴리는 할머니를 모시러 달려가요.","audioUrl":"/seed/the-garden-that-sang/audio/p7-s1.mp3","wordTimings":[{"word":"She","charStart":0,"charEnd":3,"startMs":0,"endMs":380},{"word":"runs","charStart":4,"charEnd":8,"startMs":380,"endMs":700},{"word":"to","charStart":9,"charEnd":11,"startMs":700,"endMs":1100},{"word":"bring","charStart":12,"charEnd":17,"startMs":1100,"endMs":1280},{"word":"Grandma","charStart":18,"charEnd":25,"startMs":1280,"endMs":1720}]},{"id":"the-garden-that-sang-p7-s2","ord":1,"text":"They listen together and smile.","translation_ko":"둘은 함께 귀 기울이며 미소 지어요.","audioUrl":"/seed/the-garden-that-sang/audio/p7-s2.mp3","wordTimings":[{"word":"They","charStart":0,"charEnd":4,"startMs":0,"endMs":200},{"word":"listen","charStart":5,"charEnd":11,"startMs":200,"endMs":500},{"word":"together","charStart":12,"charEnd":20,"startMs":500,"endMs":900},{"word":"and","charStart":21,"charEnd":24,"startMs":900,"endMs":1480},{"word":"smile","charStart":25,"charEnd":30,"startMs":1480,"endMs":1800}]}]},{"id":"the-garden-that-sang-p8","pageNo":8,"spread":"p8","imageUrl":"/seed/the-garden-that-sang/p8.webp","sentences":[{"id":"the-garden-that-sang-p8-s1","ord":0,"text":"Now every spring, the garden sings.","translation_ko":"이제 봄마다 정원이 노래해요.","au