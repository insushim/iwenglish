ppet-show/audio/p4-s1.mp3","wordTimings":[{"word":"They","charStart":0,"charEnd":4,"startMs":0,"endMs":920},{"word":"glued","charStart":5,"charEnd":10,"startMs":920,"endMs":1140},{"word":"on","charStart":11,"charEnd":13,"startMs":1140,"endMs":1520},{"word":"buttons","charStart":14,"charEnd":21,"startMs":1520,"endMs":1680},{"word":"for","charStart":22,"charEnd":25,"startMs":1680,"endMs":2360},{"word":"eyes","charStart":26,"charEnd":30,"startMs":2360,"endMs":2360},{"word":"and","charStart":31,"charEnd":34,"startMs":2360,"endMs":2960},{"word":"cut","charStart":35,"charEnd":38,"startMs":2960,"endMs":3200},{"word":"paper","charStart":39,"charEnd":44,"startMs":3200,"endMs":3420},{"word":"for","charStart":45,"charEnd":48,"startMs":3420,"endMs":4060},{"word":"ears","charStart":49,"charEnd":53,"startMs":4060,"endMs":4060}]},{"id":"daily-115-the-puppet-show-p4-s2","ord":1,"text":"Jun drew a big smile on his puppet.","translation_ko":"준은 자기 인형에 큰 웃음을 그렸어요.","audioUrl":"/seed/daily-115-the-puppet-show/audio/p4-s2.mp3","wordTimings":[{"word":"Jun","charStart":0,"charEnd":3,"startMs":0,"endMs":500},{"word":"drew","charStart":4,"charEnd":8,"startMs":500,"endMs":740},{"word":"a","charStart":9,"charEnd":10,"startMs":740,"endMs":960},{"word":"big","charStart":11,"charEnd":14,"startMs":960,"endMs":1280},{"word":"smile","charStart":15,"charEnd":20,"startMs":1280,"endMs":1600},{"word":"on","charStart":21,"charEnd":23,"startMs":1600,"endMs":1840},{"word":"his","charStart":24,"charEnd":27,"startMs":1840,"endMs":2020},{"word":"puppet","charStart":28,"charEnd":34,"startMs":2020,"endMs":2260}]}]},{"id":"daily-115-the-puppet-show-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/daily-115-the-puppet-show/p5.webp","sentences":[{"id":"daily-115-the-puppet-show-p5-s1","ord":0,"text":"When the puppets were ready, they needed a stage.","translation_ko":"인형이 다 완성되자 무대가 필요했어요.","audioUrl":"/seed/daily-115-the-puppet-show/audio/p5-s1.mp3","wordTimings":[{"word":"When","charStart":0,"charEnd":4,"startMs":0,"endMs":240},{"word":"the","charStart":5,"charEnd":8,"startMs":240,"endMs":440},{"word":"puppets","charStart":9,"charEnd":16,"startMs":440,"endMs":780},{"word":"were","charStart":17,"charEnd":21,"startMs":780,"endMs":980},{"word":"ready","charStart":22,"charEnd":27,"startMs":980,"endMs":1300},{"word":"they","charStart":29,"charEnd":33,"startMs":1920,"endMs":1980},{"word":"needed","charStart":34,"charEnd":40,"startMs":1980,"endMs":2260},{"word":"a","charStart":41,"charEnd":42,"startMs":2260,"endMs":2520},{"word":"stage","charStart":43,"charEnd":48,"startMs":2520,"endMs":2920}]},{"id":"daily-115-the-puppet-show-p5-s2","ord":1,"text":"They put a box on the floor and covered it with a blanket.","translation_ko":"상자를 바닥에 놓고 담요로 덮었어요.","audioUrl":"/seed/daily-115-the-puppet-show/audio/p5-s2.mp3","wordTimings":[{"word":"They","charStart":0,"charEnd":4,"startMs":0,"endMs":300},{"word":"put","charStart":5,"charEnd":8,"startMs":300,"endMs":500},{"word":"a","charStart":9,"charEnd":10,"startMs":500,"endMs":880},{"word":"box","charStart":11,"charEnd":14,"startMs":880,"endMs":1040},{"word":"on","charStart":15,"charEnd":17,"startMs":1040,"endMs":1300},{"word":"the","charStart":18,"charEnd":21,"startMs":1300,"endMs":1720},{"word":"floor","charStart":22,"charEnd":27,"startMs":1720,"endMs":1720},{"word":"and","charStart":28,"charEnd":31,"startMs":1720,"endMs":2460},{"word":"covered","charStart":32,"charEnd":39,"startMs":2460,"endMs":2660},{"word":"it","charStart":40,"charEnd":42,"startMs":2660,"endMs":2880},{"word":"with","charStart":43,"charEnd":47,"startMs":2880,"endMs":3060},{"word":"a","charStart":48,"charEnd":49,"startMs":3060,"endMs":3500},{"word":"blanket","charStart":50,"charEnd":57,"startMs":3500,"endMs":3500}]}]},{"id":"daily-115-the-puppet-show-p6","pageNo":6,"spread":"p6","imageUrl":"/seed/daily-115-the-puppet-show/p6.webp","sentences":[{"id":"daily-115-the-puppet-show-p6-s1","ord":0,"text":"Jun's puppet was a brave knight and Mina's was a clever dragon.","translation_ko":"준의 인형은 용감한 기사였고, 미나의 인형은 영리한 용이었어요.","audioUrl":"/seed/daily-115-the-puppet-show/audio/p6-s1.mp3","wordTimings":[{"word":"Jun's","charStart":0,"charEnd":5,"startMs":0,"endMs":600},{"word":"puppet","charStart":6,"charEnd":12,"startMs":600,"endMs":800},{"word":"was","charStart":13,"charEnd":16,"startMs":800,"endMs":1080},{"word":"a","charStart":17,"charEnd":18,"startMs":1080,"endMs":1260},{"word":"brave","charStart":19,"charEnd":24,"startMs":1260,"endMs":1500},{"word":"knight","charStart":25,"charEnd":31,"startMs":1500,"endMs":1900},{"word":"and","charStart":32,"charEnd":35,"startMs":2500,"endMs":2680},{"word":"Mina's","charStart":36,"charEnd":42,"startMs":2680,"endMs":3000},{"word":"was","charStart":43,"charEnd":46,"startMs":3000,"endMs":3140},{"word":"a","charStart":47,"charEnd":48,"startMs":3140,"endMs":3380},{"word":"clever","charStart":49,"charEnd":55,"startMs":3380,"endMs":3540},{"word":"dragon","charStart":56,"charEnd":62,"startMs":3540,"endMs":3920}]},{"id":"daily-115-the-puppet-show-p6-s2","ord":1,"text":"\"I am not afraid of you!\" said the knight.","translation_ko":"\"나는 네가 하나도 안 무서워!\" 기사가 말했어요.","audioUrl":"/seed/daily-115-the-puppet-show/audio/p6-s2.mp3","wordTimings":[{"word":"I","charStart":1,"charEnd":2,"startMs":0,"endMs":360},{"word":"am","charStart":3,"charEnd":5,"startMs":360,"endMs":700},{"word":"not","charStart":6,"charEnd":9,"startMs":700,"endMs":1060},{"word":"afraid","charStart":10,"charEnd":16,"startMs":1060,"endMs":1460},{"word":"of","charStart":17,"charEnd":19,"startMs":1460,"endMs":1660},{"word":"you","charStart":20,"charEnd":23,"startMs":1660,"endMs":2460},{"word":"said","charStart":26,"charEnd":30,"startMs":2460,"endMs":2460},{"word":"the","charStart":31,"charEnd":34,"startMs":2460,"endMs":2640},{"word":"knight","charStart":35,"charEnd":41,"startMs":2640,"endMs":2820}]}]},{"id":"daily-115-the-puppet-show-p7","pageNo":7,"spread":"p7","imageUrl":"/seed/daily-115-the-puppet-show/p7.webp","sentences":[{"id":"daily-115-the-puppet-show-p7-s1","ord":0,"text":"\"I don't want to fight. I just want a friend,\" said the dragon.","translation_ko":"\"나는 싸우기 싫어. 그냥 친구가 갖고 싶어.\" 용이 말했어요.","audioUrl":"/seed/daily-115-the-puppet-show/audio/p7-s1.mp3","wordTimings":[{"word":"I","charStart":1,"charEnd":2,"startMs":0,"endMs":160},{"word":"don't","charStart":3,"charEnd":8,"startMs":160,"endMs":560},{"word":"want","charStart":9,"charEnd":13,"startMs":560,"endMs":760},{"word":"to","charStart":14,"charEnd":16,"startMs":760,"endMs":1020},{"word":"fight","charStart":17,"charEnd":22,"startMs":1020,"endMs":1280},{"word":"I","charStart":24,"charEnd":25,"startMs":1700,"endMs":1860},{"word":"just","charStart":26,"charEnd":30,"startMs":1860,"endMs":2180},{"word":"want","charStart":31,"charEnd":35,"startMs":2180,"endMs":2320},{"word":"a","charStart":36,"charEnd":37,"startMs":2320,"endMs":2760},{"word":"friend","charStart":38,"charEnd":44,"startMs":2760,"endMs":3260},{"word":"said","charStart":47,"charEnd":51,"startMs":3260,"endMs":3300},{"word":"the","charStart":52,"charEnd":55,"startMs":3300,"endMs":3460},{"word":"dragon","charStart":56,"charEnd":62,"startMs":3460,"endMs":3700}]},{"id":"daily-115-the-puppet-show-p7-s2","ord":1,"text":"The knight was surprised when he heard that.","translation_ko":"기사는 그 말을 듣고 깜짝 놀랐어요.","audioUrl":"/seed/daily-115-the-puppet-show/audio/p7-s2.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":540},{"word":"knight","charStart":4,"charEnd":10,"startMs":540,"endMs":820},{"word":"was","charStart":11,"charEnd":14,"startMs":820,"endMs":1280},{"word":"surprised","charStart":15,"charEnd":24,"startMs":1280,"endMs":1840},{"word":"when","charStart":25,"charEnd":29,"startMs":1840,"endMs":2080},{"word":"he","charStart":30,"charEnd":32,"startMs":2080,"endMs":2280},{"word":"heard","charStart":33,"charEnd":38,"startMs":2280,"endMs":2480},{"word":"that","charStart":39,"charEnd":43,"startMs":2480,"endMs":2820}]}]},{"id":"daily-115-the-puppet-show-p8","pageNo":8,"spread":"p8","imageUrl":"/seed/daily-115-the-puppet-show/p8.webp","sentences":[{"id":"daily-115-the-puppet-show-p8-s1","ord":0,"text":"In the end, the knight and the dragon became best friends.","translation_ko":"결국 기사와 용은 가장 친한 친구가 되었어요.","audioUrl":"/seed/daily-115-the-puppet-show/audio/p8-s1.mp3","wordTimings":[{"word":"In","charStart":0,"charEnd":2,"startMs":0,"endMs":200},{"word":"the","charStart":3,"charEnd":6,"startMs":200,"endMs":380},{"word":"end","charStart":7,"charEnd":10,"startMs":380,"endMs":660},{"word":"the","charStart":12,"charEnd":15,"startMs":980,"endMs":1180},{"word":"knight","charStart":16,"charEnd":22,"startMs":1180,"endMs":1380},{"word":"and","charStart":23,"charEnd":26,"startMs":1380,"endMs":1700},{"word":"the","charStart":27,"charEnd":30,"startMs":1700,"endMs":2160},{"word":"dragon","charStart":31,"charEnd":37,"startMs":2160,"endMs":2160},{"word":"became","charStart":38,"charEnd":44,"startMs":2160,"endMs":2700},{"word":"best","charStart":45,"charEnd":49,"startMs":2700,"endMs":3060},{"word":"friends","charStart":50,"charEnd":57,"startMs":3060,"endMs":3400}]},{"id":"daily-115-the-puppet-show-p8-s2","ord":1,"text":"Jun and Mina cheered because it was a happy ending.","translation_ko":"해피엔딩으로 끝나서 준과 미나는 환호성을 질렀어요.","audioUrl":"/seed/daily-115-the-puppet-show/audio/p8-s2.mp3","wordTimings":[{"word":"Jun","charStart":0,"charEnd":3,"startMs":0,"endMs":560},{"word":"and","charStart":4,"charEnd":7,"startMs":560,"endMs":820},{"word":"Mina","charStart":8,"charEnd":12,"startMs":820,"endMs":1080},{"word":"cheered","charStart":13,"charEnd":20,"startMs":1080,"endMs":1520},{"word":"because","charStart":21,"charEnd":28,"startMs":1980,"endMs":2080},{"word":"it","charStart":29,"charEnd":31,"startMs":2080,"endMs":2160},{"word":"was","charStart":32,"charEnd":35,"startMs":2160,"endMs":2320},{"word":"a","charStart":36,"charEnd":37,"startMs":2320,"endMs":2480},{"word":"happy","charStart":38,"charEnd":43,"startMs":2480,"endMs":2760},{"word":"ending","charStart":44,"charEnd":50,"startMs