{"id":"daily-115-the-puppet-show","slug":"daily-115-the-puppet-show","title":"The Puppet Show","title_ko":"인형극","level":"A2","ageBand":"9-11","coverUrl":"/seed/daily-115-the-puppet-show/cover.webp","summary_ko":"Jun과 Mina가 양말 인형을 함께 만들어 즐거운 인형극을 공연하는 이야기예요.","wordCount":190,"stage":4,"collection":"daily","pages":[{"id":"daily-115-the-puppet-show-p1","pageNo":1,"spread":"p1","imageUrl":"/seed/daily-115-the-puppet-show/p1.webp","sentences":[{"id":"daily-115-the-puppet-show-p1-s1","ord":0,"text":"Jun and Mina wanted to do something fun after school.","translation_ko":"준과 미나는 방과 후에 재미있는 것을 하고 싶었어요.","audioUrl":"/seed/daily-115-the-puppet-show/audio/p1-s1.mp3","wordTimings":[{"word":"Jun","charStart":0,"charEnd":3,"startMs":0,"endMs":500},{"word":"and","charStart":4,"charEnd":7,"startMs":500,"endMs":860},{"word":"Mina","charStart":8,"charEnd":12,"startMs":860,"endMs":1180},{"word":"wanted","charStart":13,"charEnd":19,"startMs":1180,"endMs":1660},{"word":"to","charStart":20,"charEnd":22,"startMs":1660,"endMs":1860},{"word":"do","charStart":23,"charEnd":25,"startMs":1860,"endMs":1980},{"word":"something","charStart":26,"charEnd":35,"startMs":1980,"endMs":2340},{"word":"fun","charStart":36,"charEnd":39,"startMs":2340,"endMs":2760},{"word":"after","charStart":40,"charEnd":45,"startMs":2760,"endMs":3100},{"word":"school","charStart":46,"charEnd":52,"startMs":3100,"endMs":3460}]},{"id":"daily-115-the-puppet-show-p1-s2","ord":1,"text":"\"Let's make a puppet show!\" said Mina.","translation_ko":"\"인형극을 만들어 보자!\" 미나가 말했어요.","audioUrl":"/seed/daily-115-the-puppet-show/audio/p1-s2.mp3","wordTimings":[{"word":"Let's","charStart":1,"charEnd":6,"startMs":0,"endMs":500},{"word":"make","charStart":7,"charEnd":11,"startMs":500,"endMs":680},{"word":"a","charStart":12,"charEnd":13,"startMs":680,"endMs":900},{"word":"puppet","charStart":14,"charEnd":20,"startMs":900,"endMs":1080},{"word":"show","charStart":21,"charEnd":25,"startMs":1080,"endMs":1960},{"word":"said","charStart":28,"charEnd":