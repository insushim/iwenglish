,"startMs":320,"endMs":560},{"word":"noon","charStart":8,"charEnd":12,"startMs":560,"endMs":840},{"word":"the","charStart":14,"charEnd":17,"startMs":1120,"endMs":1300},{"word":"houses","charStart":18,"charEnd":24,"startMs":1300,"endMs":1580},{"word":"stayed","charStart":25,"charEnd":31,"startMs":1580,"endMs":1960},{"word":"grey","charStart":32,"charEnd":36,"startMs":1960,"endMs":2300},{"word":"and","charStart":37,"charEnd":40,"startMs":2620,"endMs":2720},{"word":"the","charStart":41,"charEnd":44,"startMs":2720,"endMs":3160},{"word":"gardens","charStart":45,"charEnd":52,"startMs":3160,"endMs":3160},{"word":"grew","charStart":53,"charEnd":57,"startMs":3160,"endMs":3480},{"word":"cold","charStart":58,"charEnd":62,"startMs":3480,"endMs":3860}]}]},{"id":"the-girl-who-planted-light-p2","pageNo":2,"spread":"p2","imageUrl":"/seed/the-girl-who-planted-light/p2.webp","sentences":[{"id":"the-girl-who-planted-light-p2-s1","ord":0,"text":"Everyone said nothing bright could ever grow there.","translation_ko":"다들 그곳에서는 밝은 것이 자랄 수 없다고 말했어요.","audioUrl":"/seed/the-girl-who-planted-light/audio/p2-s1.mp3","wordTimings":[{"word":"Everyone","charStart":0,"charEnd":8,"startMs":0,"endMs":440},{"word":"said","charStart":9,"charEnd":13,"startMs":440,"endMs":880},{"word":"nothing","charStart":14,"charEnd":21,"startMs":880,"endMs":1400},{"word":"bright","charStart":22,"charEnd":28,"startMs":1400,"endMs":1800},{"word":"could","charStart":29,"charEnd":34,"startMs":1800,"endMs":2020},{"word":"ever","charStart":35,"charEnd":39,"startMs":2020,"endMs":2400},{"word":"grow","charStart":40,"charEnd":44,"startMs":2400,"endMs":2600},{"word":"there","charStart":45,"charEnd":50,"startMs":2600,"endMs":2860}]},{"id":"the-girl-who-planted-light-p2-s2","ord":1,"text":"But Mira did not believe them.","translation_ko":"그래도 미라는 그 말을 믿지 않았답니다.","audioUrl":"/seed/the-girl-who-planted-light/audio/p2-s2.mp3","wordTimings":[{"word":"But","charStart":0,"charEnd":3,"startMs":0,"endMs":240},{"word":"Mira","charStart":4,