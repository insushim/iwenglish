,"endMs":1960},{"word":"others","charStart":34,"charEnd":40,"startMs":1960,"endMs":2160},{"word":"carry","charStart":41,"charEnd":46,"startMs":2160,"endMs":2460},{"word":"bags","charStart":47,"charEnd":51,"startMs":2460,"endMs":2740},{"word":"of","charStart":52,"charEnd":54,"startMs":2740,"endMs":3040},{"word":"fresh","charStart":55,"charEnd":60,"startMs":3040,"endMs":3200},{"word":"soil","charStart":61,"charEnd":65,"startMs":3200,"endMs":3460}]},{"id":"daily-33-the-community-garden-p3-s3","ord":2,"text":"Together, we have everything needed to get started.","translation_ko":"모두 합치면 시작하는 데 필요한 모든 것이 갖춰져요.","audioUrl":"/seed/daily-33-the-community-garden/audio/p3-s3.mp3","wordTimings":[{"word":"Together","charStart":0,"charEnd":8,"startMs":0,"endMs":760},{"word":"we","charStart":10,"charEnd":12,"startMs":960,"endMs":1060},{"word":"have","charStart":13,"charEnd":17,"startMs":1060,"endMs":1240},{"word":"everything","charStart":18,"charEnd":28,"startMs":1240,"endMs":1760},{"word":"needed","charStart":29,"charEnd":35,"startMs":1760,"endMs":2060},{"word":"to","charStart":36,"charEnd":38,"startMs":2060,"endMs":2280},{"word":"get","charStart":39,"charEnd":42,"startMs":2280,"endMs":2400},{"word":"started","charStart":43,"charEnd":50,"startMs":2400,"endMs":2760}]}]},{"id":"daily-33-the-community-garden-p4","pageNo":4,"spread":"p4","imageUrl":"/seed/daily-33-the-community-garden/p4.webp","sentences":[{"id":"daily-33-the-community-garden-p4-s1","ord":0,"text":"I work with Hana to pull weeds from the corner near the wall.","translation_ko":"나는 하나와 함께 담장 근처 모서리에서 잡초를 뽑아요.","audioUrl":"/seed/daily-33-the-community-garden/audio/p4-s1.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":340},{"word":"work","charStart":2,"charEnd":6,"startMs":340,"endMs":540},{"word":"with","charStart":7,"charEnd":11,"startMs":540,"endMs":800},{"word":"Hana","charStart":12,"charEnd":16,"startMs":800,"endMs":1060},{"word":"to","charStart":17,"charEnd":19,"startMs":1060,"endMs":1540},{"word":"pull","charStart":20,"charEnd":24,"startMs":1540,"endMs":1820},{"word":"weeds","charStart":25,"charEnd":30,"startMs":1820,"endMs":2100},{"word":"from","charStart":31,"charEnd":35,"startMs":2100,"endMs":2320},{"word":"the","charStart":36,"charEnd":39,"startMs":2320,"endMs":2520},{"word":"corner","charStart":40,"charEnd":46,"startMs":2520,"endMs":2760},{"word":"near","charStart":47,"charEnd":51,"startMs":2760,"endMs":3000},{"word":"the","charStart":52,"charEnd":55,"startMs":3000,"endMs":3340},{"word":"wall","charStart":56,"charEnd":60,"startMs":3340,"endMs":3400}]},{"id":"daily-33-the-community-garden-p4-s2","ord":1,"text":"Some weeds are so stubborn that we pull with both hands.","translation_ko":"잡초 중 일부는 너무 질겨서 양손으로 당겨야 해요.","audioUrl":"/seed/daily-33-the-community-garden/audio/p4-s2.mp3","wordTimings":[{"word":"Some","charStart":0,"charEnd":4,"startMs":0,"endMs":440},{"word":"weeds","charStart":5,"charEnd":10,"startMs":440,"endMs":740},{"word":"are","charStart":11,"charEnd":14,"startMs":740,"endMs":980},{"word":"so","charStart":15,"charEnd":17,"startMs":980,"endMs":1420},{"word":"stubborn","charStart":18,"charEnd":26,"startMs":1420,"endMs":1720},{"word":"that","charStart":27,"charEnd":31,"startMs":1720,"endMs":2240},{"word":"we","charStart":32,"charEnd":34,"startMs":2240,"endMs":2440},{"word":"pull","charStart":35,"charEnd":39,"startMs":2440,"endMs":2680},{"word":"with","charStart":40,"charEnd":44,"startMs":2680,"endMs":2920},{"word":"both","charStart":45,"charEnd":49,"startMs":2920,"endMs":3200},{"word":"hands","charStart":50,"charEnd":55,"startMs":3200,"endMs":3600}]},{"id":"daily-33-the-community-garden-p4-s3","ord":2,"text":"When the corner is finally clear, we smile at each other.","translation_ko":"모서리가 드디어 깨끗해지자 우리는 서로 보며 미소를 지어요.","audioUrl":"/seed/daily-33-the-community-garden/audio/p4-s3.mp3","wordTimings":[{"word":"When","charStart":0,"charEnd":4,"startMs":0,"endMs":340},{"word":"the","charStart":5,"charEnd":8,"startMs":340,"endMs":620},{"word":"corner","charStart":9,"charEnd":15,"startMs":620,"endMs":880},{"word":"is","charStart":16,"charEnd":18,"startMs":880,"endMs":1220},{"word":"finally","charStart":19,"charEnd":26,"startMs":1220,"endMs":1560},{"word":"clear","charStart":27,"charEnd":32,"startMs":1560,"endMs":1940},{"word":"we","charStart":34,"charEnd":36,"startMs":2300,"endMs":2500},{"word":"smile","charStart":37,"charEnd":42,"startMs":2500,"endMs":2740},{"word":"at","charStart":43,"charEnd":45,"startMs":2740,"endMs":2980},{"word":"each","charStart":46,"charEnd":50,"startMs":2980,"endMs":3100},{"word":"other","charStart":51,"charEnd":56,"startMs":3100,"endMs":3340}]}]},{"id":"daily-33-the-community-garden-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/daily-33-the-community-garden/p5.webp","sentences":[{"id":"daily-33-the-community-garden-p5-s1","ord":0,"text":"Grandpa shows us how to make straight rows before planting.","translation_ko":"할아버지는 심기 전에 곧은 줄을 만드는 법을 보여주세요.","audioUrl":"/seed/daily-33-the-community-garden/audio/p5-s1.mp3","wordTimings":[{"word":"Grandpa","charStart":0,"charEnd":7,"startMs":0,"endMs":500},{"word":"shows","charStart":8,"charEnd":13,"startMs":500,"endMs":840},{"word":"us","charStart":14,"charEnd":16,"startMs":840,"endMs":1100},{"word":"how","charStart":17,"charEnd":20,"startMs":1100,"endMs":1220},{"word":"to","charStart":21,"charEnd":23,"startMs":1220,"endMs":1420},{"word":"make","charStart":24,"charEnd":28,"startMs":1420,"endMs":1540},{"word":"straight","charStart":29,"charEnd":37,"startMs":1540,"endMs":1940},{"word":"rows","charStart":38,"charEnd":42,"startMs":1940,"endMs":2240},{"word":"before","charStart":43,"charEnd":49,"startMs":2240,"endMs":2620},{"word":"planting","charStart":50,"charEnd":58,"startMs":2620,"endMs":2980}]},{"id":"daily-33-the-community-garden-p5-s2","ord":1,"text":"He uses a long stick and a piece of string to keep the lines even.","translation_ko":"할아버지는 긴 막대와 끈을 써서 줄을 가지런히 맞추어요.","audioUrl":"/seed/daily-33-the-community-garden/audio/p5-s2.mp3","wordTimings":[{"word":"He","charStart":0,"charEnd":2,"startMs":0,"endMs":220},{"word":"uses","charStart":3,"charEnd":7,"startMs":220,"endMs":580},{"word":"a","charStart":8,"charEnd":9,"startMs":580,"endMs":900},{"word":"long","charStart":10,"charEnd":14,"startMs":900,"endMs":1200},{"word":"stick","charStart":15,"charEnd":20,"startMs":1200,"endMs":1480},{"word":"and","charStart":21,"charEnd":24,"startMs":1480,"endMs":1760},{"word":"a","charStart":25,"charEnd":26,"startMs":1760,"endMs":1980},{"word":"piece","charStart":27,"charEnd":32,"startMs":1980,"endMs":2040},{"word":"of","charStart":33,"charEnd":35,"startMs":2040,"endMs":2300},{"word":"string","charStart":36,"charEnd":42,"startMs":2300,"endMs":2540},{"word":"to","charStart":43,"charEnd":45,"startMs":2540,"endMs":3040},{"word":"keep","charStart":46,"charEnd":50,"startMs":3040,"endMs":3180},{"word":"the","charStart":51,"charEnd":54,"startMs":3180,"endMs":3540},{"word":"lines","charStart":55,"charEnd":60,"startMs":3540,"endMs":3680},{"word":"even","charStart":61,"charEnd":65,"startMs":3680,"endMs":4000}]},{"id":"daily-33-the-community-garden-p5-s3","ord":2,"text":"We watch carefully and try to copy his patient movements.","translation_ko":"우리는 할아버지의 꼼꼼한 동작을 유심히 보고 따라해요.","audioUrl":"/seed/daily-33-the-community-garden/audio/p5-s3.mp3","wordTimings":[{"word":"We","charStart":0,"charEnd":2,"startMs":0,"endMs":320},{"word":"watch","charStart":3,"charEnd":8,"startMs":320,"endMs":820},{"word":"carefully","charStart":9,"charEnd":18,"startMs":820,"endMs":1360},{"word":"and","charStart":19,"charEnd":22,"startMs":1360,"endMs":1720},{"word":"try","charStart":23,"charEnd":26,"startMs":1720,"endMs":1900},{"word":"to","charStart":27,"charEnd":29,"startMs":1900,"endMs":2420},{"word":"copy","charStart":30,"charEnd":34,"startMs":2420,"endMs":2420},{"word":"his","charStart":35,"charEnd":38,"startMs":2420,"endMs":2720},{"word":"patient","charStart":39,"charEnd":46,"startMs":2720,"endMs":3120},{"word":"movements","charStart":47,"ch