rStart":11,"charEnd":15,"startMs":680,"endMs":1060},{"word":"smiled","charStart":16,"charEnd":22,"startMs":1060,"endMs":1540},{"word":"and","charStart":23,"charEnd":26,"startMs":1540,"endMs":1840},{"word":"placed","charStart":27,"charEnd":33,"startMs":1840,"endMs":2100},{"word":"a","charStart":34,"charEnd":35,"startMs":2100,"endMs":2300},{"word":"warm","charStart":36,"charEnd":40,"startMs":2300,"endMs":2680},{"word":"living","charStart":42,"charEnd":48,"startMs":3280,"endMs":3280},{"word":"star","charStart":49,"charEnd":53,"startMs":3280,"endMs":3640},{"word":"in","charStart":54,"charEnd":56,"startMs":3640,"endMs":3880},{"word":"Mina's","charStart":57,"charEnd":63,"startMs":3880,"endMs":4220},{"word":"hands","charStart":64,"charEnd":69,"startMs":4220,"endMs":4540}]},{"id":"the-night-market-of-stars-p12-s2","ord":1,"text":"\"You gave without asking for anything, so this is yours to keep.\"","translation_ko":"\"너는 아무 대가도 바라지 않고 베풀었으니, 이 별은 네 것이란다.\"","audioUrl":"/seed/the-night-market-of-stars/audio/p12-s2.mp3","wordTimings":[{"word":"You","charStart":1,"charEnd":4,"startMs":0,"endMs":360},{"word":"gave","charStart":5,"charEnd":9,"startMs":360,"endMs":820},{"word":"without","charStart":10,"charEnd":17,"startMs":820,"endMs":1200},{"word":"asking","charStart":18,"charEnd":24,"startMs":1200,"endMs":1540},{"word":"for","charStart":25,"charEnd":28,"startMs":1540,"endMs":1860},{"word":"anything","charStart":29,"charEnd":37,"startMs":1860,"endMs":2200},{"word":"so","charStart":39,"charEnd":41,"startMs":2620,"endMs":2720},{"word":"this","charStart":42,"charEnd":46,"startMs":2720,"endMs":2920},{"word":"is","charStart":47,"charEnd":49,"startMs":2920,"endMs":3180},{"word":"yours","charStart":50,"charEnd":55,"startMs":3180,"endMs":3400},{"word":"to","charStart":56,"charEnd":58,"startMs":3400,"endMs":3660},{"word":"keep","charStart":59,"charEnd":63,"startMs":3660,"endMs":3820}]}]},{"id":"the-night-market-of-stars-p13","pageNo":13,"spread":"p13","imageUrl":"/seed/the-night-market-o