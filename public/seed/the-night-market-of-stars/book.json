startMs":2600,"endMs":2880},{"word":"things","charStart":35,"charEnd":41,"startMs":2880,"endMs":3140},{"word":"here","charStart":42,"charEnd":46,"startMs":3140,"endMs":3420},{"word":"are","charStart":47,"charEnd":50,"startMs":3420,"endMs":3660},{"word":"never","charStart":51,"charEnd":56,"startMs":3660,"endMs":3960},{"word":"sold","charStart":57,"charEnd":61,"startMs":3960,"endMs":4260}]}]},{"id":"the-night-market-of-stars-p9","pageNo":9,"spread":"p9","imageUrl":"/seed/the-night-market-of-stars/p9.webp","sentences":[{"id":"the-night-market-of-stars-p9-s1","ord":0,"text":"\"Wishes, songs, and kindness cannot truly be bought with coins.\"","translation_ko":"\"소원도, 노래도, 친절도 동전으로는 정말로 살 수 없어.\"","audioUrl":"/seed/the-night-market-of-stars/audio/p9-s1.mp3","wordTimings":[{"word":"Wishes","charStart":1,"charEnd":7,"startMs":0,"endMs":1040},{"word":"songs","charStart":9,"charEnd":14,"startMs":1940,"endMs":1940},{"word":"and","charStart":16,"charEnd":19,"startMs":2380,"endMs":2940},{"word":"kindness","charStart":20,"charEnd":28,"startMs":2940,"endMs":2940},{"word":"cannot","charStart":29,"charEnd":35,"startMs":2940,"endMs":3600},{"word":"truly","charStart":36,"charEnd":41,"startMs":3600,"endMs":3980},{"word":"be","charStart":42,"charEnd":44,"startMs":3980,"endMs":4200},{"word":"bought","charStart":45,"charEnd":51,"startMs":4200,"endMs":4420},{"word":"with","charStart":52,"charEnd":56,"startMs":4420,"endMs":4760},{"word":"coins","charStart":57,"charEnd":62,"startMs":4760,"endMs":4960}]},{"id":"the-night-market-of-stars-p9-s2","ord":1,"text":"\"The finest gifts are given freely, from one heart to another.\"","translation_ko":"\"가장 귀한 선물은 한 마음에서 다른 마음으로 거저 건네지는 거란다.\"","audioUrl":"/seed/the-night-market-of-stars/audio/p9-s2.mp3","wordTimings":[{"word":"The","charStart":1,"charEnd":4,"startMs":0,"endMs":260},{"word":"finest","charStart":5,"charEnd":11,"startMs":260,"endMs":760},{"word":"gifts","charStart":12,"charEnd":17,"startMs":760,"endMs":1140},{"word":"are","charStart":18,