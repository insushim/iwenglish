9,"charEnd":33,"startMs":2800,"endMs":3340},{"word":"sold","charStart":34,"charEnd":38,"startMs":3340,"endMs":3940},{"word":"songs","charStart":39,"charEnd":44,"startMs":3940,"endMs":4480},{"word":"that","charStart":45,"charEnd":49,"startMs":4480,"endMs":4880},{"word":"no","charStart":50,"charEnd":52,"startMs":4880,"endMs":5060},{"word":"one","charStart":53,"charEnd":56,"startMs":5060,"endMs":5220},{"word":"had","charStart":57,"charEnd":60,"startMs":5220,"endMs":5480},{"word":"ever","charStart":61,"charEnd":65,"startMs":5480,"endMs":5980},{"word":"heard","charStart":66,"charEnd":71,"startMs":5980,"endMs":6260}]},{"id":"the-night-market-of-stars-p4-s2","ord":1,"text":"When she leaned close, a melody warmed her like sunlight.","translation_ko":"가까이 다가서자, 한 가락의 선율이 햇살처럼 그녀를 따뜻하게 감쌌어요.","audioUrl":"/seed/the-night-market-of-stars/audio/p4-s2.mp3","wordTimings":[{"word":"When","charStart":0,"charEnd":4,"startMs":0,"endMs":300},{"word":"she","charStart":5,"charEnd":8,"startMs":300,"endMs":640},{"word":"leaned","charStart":9,"charEnd":15,"startMs":640,"endMs":880},{"word":"close","charStart":16,"charEnd":21,"startMs":880,"endMs":1400},{"word":"a","charStart":23,"charEnd":24,"startMs":1740,"endMs":1980},{"word":"melody","charStart":25,"charEnd":31,"startMs":1980,"endMs":2240},{"word":"warmed","charStart":32,"charEnd":38,"startMs":2240,"endMs":2680},{"word":"her","charStart":39,"charEnd":42,"startMs":2680,"endMs":2900},{"word":"like","charStart":43,"charEnd":47,"startMs":2900,"endMs":3220},{"word":"sunlight","charStart":48,"charEnd":56,"startMs":3220,"endMs":3600}]}]},{"id":"the-night-market-of-stars-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/the-night-market-of-stars/p5.webp","sentences":[{"id":"the-night-market-of-stars-p5-s1","ord":0,"text":"Further along, a soft pink star sold jars of pure kindness.","translation_ko":"더 안쪽으로 가니, 은은한 분홍빛 별이 순수한 친절을 병에 담아 팔고 있었어요.","audioUrl":"/seed/the-night-market-of-stars/audio/p5-s1.mp3","wordTimings":[{"word":"Further","charStart":0,"charEnd":7,"startMs":0,"endMs":360},{"word":"along","charStart":8,"charEnd":13,"startMs":360,"endMs":800},{"word":"a","charStart":15,"charEnd":16,"startMs":1220,"endMs":1400},{"word":"soft","charStart":17,"charEnd":21,"startMs":1400,"endMs":1680},{"word":"pink","charStart":22,"charEnd":26,"startMs":1680,"endMs":1960},{"word":"star","charStart":27,"charEnd":31,"startMs":1960,"endMs":2340},{"word":"sold","charStart":32,"charEnd":36,"startMs":2340,"endMs":2980},{"word":"jars","charStart":37,"charEnd":41,"startMs":2980,"endMs":3380},{"word":"of","charStart":42,"charEnd":44,"startMs":3380,"endMs":3740},{"word":"pure","charStart":45,"charEnd":49,"startMs":3740,"endMs":3960},{"word":"kindness","charStart":50,"charEnd":58,"startMs":3960,"endMs":4280}]},{"id":"the-night-market-of-stars-p5-s2","ord":1,"text":"It smelled like fresh bread and a friend's gentle hello.","translation_ko":"그것에서는 갓 구운 빵과 친구의 다정한 인사 같은 냄새가 났어요.","audioUrl":"/seed/the-night-market-of-stars/audio/p5-s2.mp3","wordTimings":[{"word":"It","charStart":0,"charEnd":2,"startMs":0,"endMs":600},{"word":"smelled","charStart":3,"charEnd":10,"startMs":600,"endMs":940},{"word":"like","charStart":11,"charEnd":15,"startMs":940,"endMs":1300},{"word":"fresh","charStart":16,"charEnd":21,"startMs":1300,"endMs":1560},{"word":"bread","charStart":22,"charEnd":27,"startMs":1560,"endMs":1860},{"word":"and","charStart":28,"charEnd":31,"startMs":1860,"endMs":2340},{"word":"a","charStart":32,"charEnd":33,"startMs":2340,"endMs":2560},{"word":"friend's","charStart":34,"charEnd":42,"startMs":2560,"endMs":3040},{"word":"gentle","charStart":43,"charEnd":49,"startMs":3040,"endMs":3180},{"word":"hello","charStart":50,"charEnd":55,"startMs":3180,"endMs":3520}]}]},{"id":"the-night-market-of-stars-p6","pageNo":6,"spread":"p6","imageUrl":"/seed/the-night-market-of-stars/p6.webp","sentences":[{"id":"the-night-market-of-stars-p6-s1","ord":0,"text":"Mina reached into her pockets, but they were completely empty.","translation_ko":"미나는 주머니를 뒤졌지만, 주머니는 텅 비어 있었어요.","audioUrl":"/seed/the-night-market-of-stars/audio/p6-s1.mp3","wordTimings":[{"word":"Mina","charStart":0,"charEnd":4,"startMs":0,"endMs":400},{"word":"reached","charStart":5,"charEnd":12,"startMs":400,"endMs":760},{"word":"into","charStart":13,"charEnd":17,"startMs":760,"endMs":980},{"word":"her","charStart":18,"charEnd":21,"startMs":980,"endMs":1200},{"word":"pockets","charStart":22,"charEnd":29,"startMs":1200,"endMs":1560},{"word":"but","charStart":31,"charEnd":34,"startMs":2120,"endMs":2220},{"word":"they","charStart":35,"charEnd":39,"startMs":2220,"endMs":2340},{"word":"were","charStart":40,"charEnd":44,"startMs":2340,"endMs":2500},{"word":"completely","charStart":45,"charEnd":55,"startMs":2500,"endMs":2980},{"word":"empty","charStart":56,"charEnd":61,"startMs":2980,"endMs":3320}]},{"id":"the-night-market-of-stars-p6-s2","ord":1,"text":"She had no coins, no money, and nothing at all to trade.","translation_ko":"동전도 돈도 없었고, 바꿀 만한 것이라곤 아무것도 없었어요.","audioUrl":"/seed/the-night-market-of-stars/audio/p6-s2.mp3","wordTimings":[{"word":"She","charStart":0,"charEnd":3,"startMs":0,"endMs":240},{"word":"had","charStart":4,"charEnd":7,"startMs":240,"endMs":420},{"word":"no","charStart":8,"charEnd":10,"startMs":420,"endMs":680},{"word":"coins","charStart":11,"charEnd":16,"startMs":680,"endMs":1120},{"word":"no","charStart":18,"charEnd":20,"startMs":1560,"endMs":1720},{"word":"money","charStart":21,"charEnd":26,"startMs":1720,"endMs":1920},{"word":"and","charStart":28,"charEnd":31,"startMs":2380,"endMs":2560},{"word":"nothing","charStart":32,"charEnd":39,"startMs":2560,"endMs":2760},{"word":"at","charStart":40,"charEnd":42,"startMs":2760,"endMs":2940},{"word":"all","charStart":43,"charEnd":46,"startMs":2940,"endMs":3060},{"word":"to","charStart":47,"charEnd":49,"startMs":3060,"endMs":3200},{"word":"trade","charStart":50,"charEnd":55,"startMs":3200,"endMs":3460}]}]},{"id":"the-night-market-of-stars-p7","pageNo":7,"spread":"p7","imageUrl":"/seed/the-night-market-of-stars/p7.webp","sentences":[{"id":"the-night-market-of-stars-p7-s1","ord":0,"text":"Her shoulders dropped, because everything here seemed far beyond her reach.","translation_ko":"이곳의 모든 것이 자기 손에 닿지 않을 것 같아, 미나는 어깨가 축 처졌어요.","audioUrl":"/seed/the-night-market-of-stars/audio/p7-s1.mp3","wordTimings":[{"word":"Her","charStart":0,"charEnd":3,"startMs":0,"endMs":260},{"word":"shoulders","charStart":4,"charEnd":13,"startMs":260,"endMs":600},{"word":"dropped","charStart":14,"charEnd":21,"startMs":600,"endMs":1120},{"word":"because","charStart":23,"charEnd":30,"startMs":1120,"endMs":1700},{"word":"everything","charStart":31,"charEnd":41,"startMs":1700,"endMs":2120},{"word":"here","charStart":42,"charEnd":46,"startMs":2120,"endMs":2560},{"word":"seemed","charStart":47,"charEnd":53,"startMs":2560,"endMs":2700},{"word":"far","charStart":54,"charEnd":57,"startMs":2700,"endMs":3220},{"word":"beyond","charStart":58,"charEnd":64,"startMs":3220,"endMs":3440},{"word":"her","charStart":65,"charEnd":68,"startMs":3440,"endMs":3740},{"word":"reach","charStart":69,"charEnd":74,"startMs":3740,"endMs":4020}]},{"id":"the-night-market-of-stars-p7-s2","ord":1,"text":"\"I cannot buy a single thing,\" she whispered sadly.","translation_ko":"\"하나도 살 수가 없네.\" 미나가 슬프게 속삭였어요.","audioUrl":"/seed/the-night-market-of-stars/audio/p7-s2.mp3","wordTimings":[{"word":"I","charStart":1,"charEnd":2,"startMs":0,"endMs":200},{"word":"cannot","charStart":3,"charEnd":9,"startMs":200,"endMs":580},{"word":"buy","charStart":10,"charEnd":13,"startMs":580,"endMs":880},{"word":"a","charStart":14,"charEnd":15,"startMs":880,"endMs":1100},{"word":"single","charStart":16,"charEnd":22,"startMs":1100,"endMs":1360},{"word":"thing","charStart":23,"charEnd":28,"startMs":1360,"endMs":2420},{"word":"she","charStart":31,"charEnd":34,"startMs":2420,"endMs":2540},{"word":"whispered","charStart":35,"charEnd":44,"startMs":2540,"endMs":2960},{"word":"sadly","charStart":45,"charEnd":50,"startMs":2960,"endMs":3320}]}]},{"id":