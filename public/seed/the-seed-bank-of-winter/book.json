tMs":4020,"endMs":4280},{"word":"in","charStart":58,"charEnd":60,"startMs":4280,"endMs":4600},{"word":"socks","charStart":61,"charEnd":66,"startMs":4600,"endMs":4960},{"word":"and","charStart":68,"charEnd":71,"startMs":5400,"endMs":5880},{"word":"flower","charStart":72,"charEnd":78,"startMs":5880,"endMs":5940},{"word":"seeds","charStart":79,"charEnd":84,"startMs":5940,"endMs":6280},{"word":"folded","charStart":85,"charEnd":91,"startMs":6280,"endMs":6680},{"word":"inside","charStart":92,"charEnd":98,"startMs":6680,"endMs":7200},{"word":"old","charStart":99,"charEnd":102,"startMs":7200,"endMs":7620},{"word":"calendars","charStart":103,"charEnd":112,"startMs":7620,"endMs":8020}]}]},{"id":"the-seed-bank-of-winter-p4","pageNo":4,"spread":"p4","imageUrl":"/seed/the-seed-bank-of-winter/p4.webp","sentences":[{"id":"the-seed-bank-of-winter-p4-s1","ord":0,"text":"At first the collection looked messy, more like lost crumbs than a bank. Then we began writing labels with names, dates, and stories.","translation_ko":"처음에 그 모음은 은행이라기보다 잃어버린 부스러기처럼 어수선했어요. 그러다 우리는 이름과 날짜, 이야기를 적은 표를 쓰기 시작했어요.","audioUrl":"/seed/the-seed-bank-of-winter/audio/p4-s1.mp3","wordTimings":[{"word":"At","charStart":0,"charEnd":2,"startMs":0,"endMs":620},{"word":"first","charStart":3,"charEnd":8,"startMs":620,"endMs":960},{"word":"the","charStart":9,"charEnd":12,"startMs":1220,"endMs":1400},{"word":"collection","charStart":13,"charEnd":23,"startMs":1400,"endMs":1680},{"word":"looked","charStart":24,"charEnd":30,"startMs":1680,"endMs":1980},{"word":"messy","charStart":31,"charEnd":36,"startMs":1980,"endMs":2320},{"word":"more","charStart":38,"charEnd":42,"startMs":2740,"endMs":2780},{"word":"like","charStart":43,"charEnd":47,"startMs":2780,"endMs":3020},{"word":"lost","charStart":48,"charEnd":52,"startMs":3020,"endMs":3300},{"word":"crumbs","charStart":53,"charEnd":59,"startMs":3300,"endMs":3600},{"word":"than","charStart":60,"charEnd":64,"startMs":3600,"endMs":3800},{"word":"a","charStart":65,"charEnd":66,"startMs":3800,"endMs":4080},{"word":"bank","charStart":67,"charEnd":71,"startMs":4080,"endMs":4180},{"word":"Then","charStart":73,"charEnd":77,"startMs":5000,"endMs":5120},{"word":"we","charStart":78,"charEnd":80,"startMs":5120,"endMs":5300},{"word":"began","charStart":81,"charEnd":86,"startMs":5300,"endMs":5520},{"word":"writing","charStart":87,"charEnd":94,"startMs":5520,"endMs":5840},{"word":"labels","charStart":95,"charEnd":101,"startMs":5840,"endMs":6160},{"word":"with","charStart":102,"charEnd":106,"startMs":6160,"endMs":6480},{"word":"names","charStart":107,"charEnd":112,"startMs":6480,"endMs":6820},{"word":"dates","charStart":114,"charEnd":119,"startMs":7540,"endMs":7540},{"word":"and","charStart":121,"charEnd":124,"startMs":7820,"endMs":8180},{"word":"stories","charStart":125,"charEnd":132,"startMs":8180,"endMs":8280}]}]},{"id":"the-seed-bank-of-winter-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/the-seed-bank-of-winter/p5.webp","sentences":[{"id":"the-seed-bank-of-winter-p5-s1","ord":0,"text":"Mrs. Park's beans climbed best near fences. My uncle's marigolds kept bugs from tomatoes. Each fact made the seeds less silent.","translation_ko":"박 할머니의 콩은 울타리 근처에서 가장 잘 자랐어요. 삼촌의 금잔화는 토마토에서 벌레를 막아 주었어요. 사실 하나하나가 씨앗을 덜 조용하게 만들었어요.","audioUrl":"/seed/the-seed-bank-of-winter/audio/p5-s1.mp3","wordTimings":[{"word":"Mrs","charStart":0,"charEnd":3,"startMs":0,"endMs":400},{"word":"Park's","charStart":5,"charEnd":11,"startMs":660,"endMs":1000},{"word":"beans","charStart":12,"charEnd":17,"startMs":1000,"endMs":1260},{"word":"climbed","charStart":18,"charEnd":25,"startMs":1260,"endMs":1760},{"word":"best","charStart":26,"charEnd":30,"startMs":1760,"endMs":2260},{"word":"near","charStart":31,"charEnd":35,"startMs":2260,"endMs":2580},{"word":"fences","charStart":36,"charEnd":42,"startMs":2580,"endMs":3000},{"word":"My","charStart":44,"charEnd":46,"startMs":3840,"endMs":4020},{"word":"uncle's","charStart":47,"charEnd":54,"startMs":4020,"endMs":4460},{"word":"marigolds","charStart":55,"charEnd":64,"startMs":4460,"endMs":4960},{"word":"kept","charStart":65,"charEnd":69,"startMs":4960,"endMs":5280},{"word":"bugs","charStart":70,"charEnd":74,"startMs":5280,"endMs":5620},{"word":"from","charStart":75,"charEnd":79,"startMs":5620,"endMs":5920},{"word":"tomatoes","charStart":80,"charEnd":88,"startMs":5920,"endMs":6300},{"word":"Each","charStart":90,"charEnd":94,"startMs":7260,"endMs":7360},{"word":"fact","charStart":95,"charEnd":99,"startMs":7360,"endMs":7740},{"word":"made","charStart":100,"charEnd":104,"startMs":7740,"endMs":7980},{"word":"the","charStart":105,"charEnd":108,"startMs":7980,"endMs":8220},{"word":"seeds","charStart":109,"charEnd":114,"startMs":8220,"endMs":8440},{"word":"less","charStart":115,"charEnd":119,"startMs":8440,"endMs":8780},{"word":"silent","charStart":120,"charEnd":126,"startMs":8780,"endMs":9100}]}]},{"id":"the-seed-bank-of-winter-p6","pageNo":6,"spread":"p6","imageUrl":"/seed/the-seed-bank-of-winter/p6.webp","sentences":[{"id":"the-seed-bank-of-winter-p6-s1","ord":0,"text":"Moisture was our enemy, so we dried orange peels and placed them in jars as gentle guards. We checked the lids every Friday.","translation_ko":"습기가 우리의 적이어서 우리는 오렌지 껍질을 말려 부드러운 지킴이처럼 병에 넣었어요. 우리는 금요일마다 뚜껑을 확인했어요.","audioUrl":"/seed/the-seed-bank-of-winter/audio/p6-s1.mp3","wordTimings":[{"word":"Moisture","charStart":0,"charEnd":8,"startMs":0,"endMs":980},{"word":"was","charStart":9,"charEnd":12,"startMs":980,"endMs":1160},{"word":"our","charStart":13,"charEnd":16,"startMs":1160,"endMs":1380},{"word":"enemy","charStart":17,"charEnd":22,"startMs":1380,"endMs":1620},{"word":"so","charStart":24,"charEnd":26,"startMs":2200,"endMs":2280},{"word":"we","charStart":27,"charEnd":29,"startMs":2280,"endMs":2540},{"word":"dried","charStart":30,"charEnd":35,"startMs":2540,"endMs":2800},{"word":"orange","charStart":36,"charEnd":42,"startMs":2800,"endMs":3240},{"word":"peels","charStart":43,"charEnd":48,"startMs":3240,"endMs":3560},{"word":"and","charStart":49,"charEnd":52,"startMs":3560,"endMs":4120},{"word":"placed","charStart":53,"charEnd":59,"startMs":4120,"endMs":4420},{"word":"them","charStart":60,"charEnd":64,"startMs":4420,"endMs":4600},{"word":"in","charStart":65,"charEnd":67,"startMs":4600,"endMs":4840},{"word":"jars","charStart":68,"charEnd":72,"startMs":4840,"endMs":5120},{"word":"as","charStart":73,"charEnd":75,"startMs":5120,"endMs":5400},{"word":"gentle","charStart":76,"charEnd":82,"startMs":5400,"endMs":5700},{"word":"guards","charStart":83,"charEnd":89,"startMs":5700,"endMs":6120},{"word":"We","charStart":91,"charEnd":93,"startMs":6860,"endMs":6920},{"word":"checked","charStart":94,"charEnd":101,"startMs":6920,"endMs":7140},{"word":"the","charStart":102,"charEnd":105,"startMs":7140,"endMs":7440},{"word":"lids","charStart":106,"charEnd":110,"startMs":7440,"endMs":7520},{"word":"every","charStart":111,"charEnd":116,"startMs":7520,"endMs":7920},{"word":"Friday","charStart":117,"charEnd":123,"startMs":7920,"endMs":8200}]}]},{"id":"the-seed-bank-of-winter-p7","pageNo":7,"spread":"p7","imageUrl":"/seed/the-seed-bank-of-winter/p7.webp","sentences":[{"id":"the-seed-bank-of-winter-p7-s1","ord":0,"text":"Younger children drew pictures for people who could not read every label. A blue bean packet showed a vine curling up a fence.","translation_ko":"어린아이들은 모든 표를 읽을 수 없는 사람들을 위해 그림을 그렸어요. 파란 콩 봉투에는 울타리를 감고 오르는 덩굴이 그려졌어요.","audioUrl":"/seed/the-seed-bank-of-winter/audio/p7-s1.mp3","wordTimings":[{"word":"Younger","charStart":0,"charEnd":7,"startMs":0,"endMs":680},{"word":"children","charStart":8,"charEnd":16,"startMs":680,"endMs":920},{"word":"drew","charStart":17,"charEnd":21,"startMs":920,"endMs":1220},{"word":"pictures","charStart":22,"charEnd":30,"startMs":1220,"endMs":1660},{"word":"for","charStart":31,"charEnd":34,"startMs":1660,"endMs":1940},{"word":"people","charStart":35,"charEnd":41,"startMs":1940,"endMs":2240},{"word":"who","charStart":42,"charEnd":45,"startMs":2240,"endMs":2480},{"word":"could","charStar