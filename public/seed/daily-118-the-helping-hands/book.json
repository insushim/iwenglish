arStart":6,"charEnd":12,"startMs":820,"endMs":1700},{"word":"said","charStart":15,"charEnd":19,"startMs":1700,"endMs":1840},{"word":"Jun","charStart":20,"charEnd":23,"startMs":1840,"endMs":2180},{"word":"because","charStart":25,"charEnd":32,"startMs":2540,"endMs":2820},{"word":"the","charStart":33,"charEnd":36,"startMs":2820,"endMs":3040},{"word":"bags","charStart":37,"charEnd":41,"startMs":3040,"endMs":3220},{"word":"were","charStart":42,"charEnd":46,"startMs":3220,"endMs":3480},{"word":"heavy","charStart":47,"charEnd":52,"startMs":3480,"endMs":3700}]},{"id":"daily-118-the-helping-hands-p4-s2","ord":1,"text":"Jun and Mina each carried a bag up the stairs.","translation_ko":"준과 미나는 가방을 하나씩 들고 계단을 올라갔어요.","audioUrl":"/seed/daily-118-the-helping-hands/audio/p4-s2.mp3","wordTimings":[{"word":"Jun","charStart":0,"charEnd":3,"startMs":500,"endMs":980},{"word":"and","charStart":4,"charEnd":7,"startMs":980,"endMs":1240},{"word":"Mina","charStart":8,"charEnd":12,"startMs":1240,"endMs":1480},{"word":"each","charStart":13,"charEnd":17,"startMs":1480,"endMs":1940},{"word":"carried","charStart":18,"charEnd":25,"startMs":1940,"endMs":2180},{"word":"a","charStart":26,"charEnd":27,"startMs":2180,"endMs":2600},{"word":"bag","charStart":28,"charEnd":31,"startMs":2600,"endMs":2620},{"word":"up","charStart":32,"charEnd":34,"startMs":2620,"endMs":2860},{"word":"the","charStart":35,"charEnd":38,"startMs":2860,"endMs":3100},{"word":"stairs","charStart":39,"charEnd":45,"startMs":3100,"endMs":3380}]}]},{"id":"daily-118-the-helping-hands-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/daily-118-the-helping-hands/p5.webp","sentences":[{"id":"daily-118-the-helping-hands-p5-s1","ord":0,"text":"When they reached the top, Grandma opened her door.","translation_ko":"꼭대기에 도착하자 할머니가 문을 열어주셨어요.","audioUrl":"/seed/daily-118-the-helping-hands/audio/p5-s1.mp3","wordTimings":[{"word":"When","charStart":0,"charEnd":4,"startMs":0,"endMs":340},{"word":"they","charStart":5,"charEnd":9,"startMs":340,"endMs":580},{"word":"reached","charStart":10,"charEnd":17,"startMs":580,"endMs":880},{"word":"the","charStart":18,"charEnd":21,"startMs":880,"endMs":1100},{"word":"top","charStart":22,"charEnd":25,"startMs":1100,"endMs":1420},{"word":"Grandma","charStart":27,"charEnd":34,"startMs":2080,"endMs":2460},{"word":"opened","charStart":35,"charEnd":41,"startMs":2460,"endMs":2920},{"word":"her","charStart":42,"charEnd":45,"startMs":2920,"endMs":3180},{"word":"door","charStart":46,"charEnd":50,"startMs":3180,"endMs":3400}]},{"id":"daily-118-the-helping-hands-p5-s2","ord":1,"text":"\"Come in and rest,\" she said warmly.","translation_ko":"\"들어와 쉬어라.\" 할머니가 따뜻하게 말씀하셨어요.","audioUrl":"/seed/daily-118-the-helping-hands/audio/p5-s2.mp3","wordTimings":[{"word":"Come","charStart":1,"charEnd":5,"startMs":0,"endMs":440},{"word":"in","charStart":6,"charEnd":8,"startMs":440,"endMs":800},{"word":"and","charStart":9,"charEnd":12,"startMs":800,"endMs":1140},{"word":"rest","charStart":13,"charEnd":17,"startMs":1140,"endMs":1560},{"word":"she","charStart":20,"charEnd":23,"startMs":1560,"endMs":1980},{"word":"said","charStart":24,"charEnd":28,"startMs":1980,"endMs":2140},{"word":"warmly","charStart":29,"charEnd":35,"startMs":2140,"endMs":2600}]}]},{"id":"daily-118-the-helping-hands-p6","pageNo":6,"spread":"p6","imageUrl":"/seed/daily-118-the-helping-hands/p6.webp","sentences":[{"id":"daily-118-the-helping-hands-p6-s1","ord":0,"text":"Grandma took out fruit and shared it with them.","translation_ko":"할머니는 과일을 꺼내 아이들과 나눠 드셨어요.","audioUrl":"/seed/daily-118-the-helping-hands/audio/p6-s1.mp3","wordTimings":[{"word":"Grandma","charStart":0,"charEnd":7,"startMs":0,"endMs":460},{"word":"took","charStart":8,"charEnd":12,"startMs":460,"endMs":780},{"word":"out","charStart":13,"charEnd":16,"startMs":780,"endMs":1060},{"word":"fruit","charStart":17,"charEnd":22,"startMs":1060,"endMs":1400},{"word":"and","charStart":23,"charEnd":26,"startMs":1400,"endMs":1800},{"word":"shared","charStart":27,"charEnd":33,"startMs"