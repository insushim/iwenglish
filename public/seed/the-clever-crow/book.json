{"id":"the-clever-crow","slug":"the-clever-crow","title":"The Clever Crow","title_ko":"영리한 까마귀","level":"A2","ageBand":"8-10","coverUrl":"/seed/the-clever-crow/cover.webp","summary_ko":"물이 조금밖에 없는 깊은 병 앞에서 까마귀가 돌을 하나씩 넣어 지혜롭게 물을 마시는 이야기.","wordCount":187,"pages":[{"id":"the-clever-crow-p1","pageNo":1,"spread":"p1","imageUrl":"/seed/the-clever-crow/p1.webp","sentences":[{"id":"the-clever-crow-p1-s1","ord":0,"text":"One hot day, a black crow flew over the dry fields.","translation_ko":"어느 더운 날, 까만 까마귀 한 마리가 메마른 들판 위를 날았어요.","audioUrl":"/seed/the-clever-crow/audio/p1-s1.mp3","wordTimings":[{"word":"One","charStart":0,"charEnd":3,"startMs":0,"endMs":320},{"word":"hot","charStart":4,"charEnd":7,"startMs":320,"endMs":660},{"word":"day","charStart":8,"charEnd":11,"startMs":660,"endMs":960},{"word":"a","charStart":13,"charEnd":14,"startMs":1360,"endMs":1460},{"word":"black","charStart":15,"charEnd":20,"startMs":1460,"endMs":1740},{"word":"crow","charStart":21,"charEnd":25,"startMs":1740,"endMs":2000},{"word":"flew","charStart":26,"charEnd":30,"startMs":2000,"endMs":2340},{"word":"over","charStart":31,"charEnd":35,"startMs":2340,"endMs":2620},{"word":"the","charStart":36,"charEnd":39,"startMs":2620,"endMs":2820},{"word":"dry","charStart":40,"charEnd":43,"startMs":2820,"endMs":3100},{"word":"fields","charStart":44,"charEnd":50,"startMs":3100,"endMs":3460}]},{"id":"the-clever-crow-p1-s2","ord":1,"text":"She was very thirsty because there was no rain.","translation_ko":"비가 오지 않아서 까마귀는 무척 목이 말랐어요.","audioUrl":"/seed/the-clever-crow/audio/p1-s2.mp3","wordTimings":[{"word":"She","charStart":0,"charEnd":3,"startMs":0,"endMs":320},{"word":"was","charStart":4,"charEnd":7,"startMs":320,"endMs":640},{"word":"very","charStart":8,"charEnd":12,"startMs":640,"endMs":1160},{"word":"thirsty","charStart":13,"charEnd":20,"startMs":1160,"endMs":1540},{"word":"because","charStart":21,"charEnd":28,"startMs":1540,"endMs":2100},{"word":"there","charStart":29,"charEnd":34,"startMs":2100,"endMs":2240},{"word":"was","charStart":35,"charEnd":38,"startMs":2240,"endMs":2460},{"word":"no","charStart":39,"charEnd":41,"startMs":2460,"endMs":2700},{"word":"rain","charStart":42,"charEnd":46,"startMs":2700,"endMs":3000}]}]},{"id":"the-clever-crow-p2","pageNo":2,"spread":"p2","imageUrl":"/seed/the-clever-crow/p2.webp","sentences":[{"id":"the-clever-crow-p2-s1","ord":0,"text":"The crow looked for water everywhere, but she found none.","translation_ko":"까마귀는 어디든 물을 찾았지만, 아무 데도 없었어요.","audioUrl":"/seed/the-clever-crow/audio/p2-s1.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":320},{"word":"crow","charStart":4,"charEnd":8,"startMs":320,"endMs":620},{"word":"looked","charStart":9,"charEnd":15,"startMs":620,"endMs":960},{"word":"for","charStart":16,"charEnd":19,"startMs":960,"endMs":1320},{"word":"water","charStart":20,"charEnd":25,"startMs":1320,"endMs":1560},{"word":"everywhere","charStart":26,"charEnd":36,"startMs":1560,"endMs":2120},{"word":"but","charStart":38,"charEnd":41,"startMs":2580,"endMs":2720},{"word":"she","charStart":42,"charEnd":45,"startMs":2720,"endMs":2960},{"word":"found","charStart":46,"charEnd":51,"startMs":2960,"endMs":3140},{"word":"none","charStart":52,"charEnd":56,"startMs":3140,"endMs":3400}]},{"id":"the-clever-crow-p2-s2","ord":1,"text":"Then she saw a tall jug near an old house.","translation_ko":"그때 낡은 집 옆에 서 있는 키 큰 병 하나가 눈에 들어왔어요.","audioUrl":"/seed/the-clever-crow/audio/p2-s2.mp3","wordTimings":[{"word":"Then","charStart":0,"charEnd":4,"startMs":0,"endMs":360},{"word":"she","charStart":5,"charEnd":8,"startMs":360,"endMs":680},{"word":"saw","charStart":9,"charEnd":12,"startMs":680,"endMs":960},{"word":"a","charStart":13,"charEnd":14,"startMs":960,"endMs":1200},{"word":"tall","charStart":15,"charEnd":19,"startMs":1200,"endMs":1540},{"word":"jug","charStart":20,"charEnd":23,"startMs":1540,"endMs":1900},{"word":"near","charStart":24,"charEnd":28,"startMs":1900,"endMs":2300},{"word":"an","charStart":29,"charEnd":31,"startMs":2300,"endMs":2560},{"word":"old","charStart":32,"charEnd":35,"startMs":2560,"endMs":2760},{"word":"house","charStart":36,"charEnd":41,"startMs":2760,"endMs":3120}]}]},{"id":"the-clever-crow-p3","pageNo":3,"spread":"p3","imageUrl":"/seed/the-clever-crow/p3.webp","sentences":[{"id":"the-clever-crow-p3-s1","ord":0,"text":"She flew down and looked inside the jug.","translation_ko":"까마귀는 날아 내려와 병 안을 들여다보았어요.","audioUrl":"/seed/the-clever-crow/audio/p3-s1.mp3","wordTimings":[{"word":"She","charStart":0,"charEnd":3,"startMs":0,"endMs":420},{"word":"flew","charStart":4,"charEnd":8,"startMs":420,"endMs":880},{"word":"down","charStart":9,"charEnd":13,"startMs":880,"endMs":1260},{"word":"and","charStart":14,"charEnd":17,"startMs":1260,"endMs":1720},{"word":"looked","charStart":18,"charEnd":24,"startMs":1720,"endMs":1900},{"word":"inside","charStart":25,"charEnd":31,"startMs":1900,"endMs":2320},{"word":"the","charStart":32,"charEnd":35,"startMs":2320,"endMs":2760},{"word":"jug","charStart":36,"charEnd":39,"startMs":2760,"endMs":2760}]},{"id":"the-clever-crow-p3-s2","ord":1,"text":"There was a little water at the bottom.","translation_ko":"병 바닥에 물이 조금 남아 있었어요.","audioUrl":"/seed/the-clever-crow/audio/p3-s2.mp3","wordTimings":[{"word":"There","charStart":0,"charEnd":5,"startMs":0,"endMs":240},{"word":"was","charStart":6,"charEnd":9,"startMs":240,"endMs":420},{"word":"a","charStart":10,"charEnd":11,"startMs":420,"endMs":620},{"word":"little","charStart":12,"charEnd":18,"startMs":620,"endMs":760},{"word":"water","charStart":19,"charEnd":24,"startMs":760,"endMs":1080},{"word":"at","charStart":25,"charEnd":27,"startMs":1080,"endMs":1320},{"word":"the","charStart":28,"charEnd":31,"startMs":1320,"endMs":1720},{"word":"bottom","charStart":32,"charEnd":38,"startMs":1720,"endMs":1720}]}]},{"id":"the-clever-crow-p4","pageNo":4,"spread":"p4","imageUrl":"/seed/the-clever-crow/p4.webp","sentences":[{"id":"the-clever-crow-p4-s1","ord":0,"text":"The crow put her beak into the jug.","translation_ko":"까마귀는 부리를 병 안으로 넣었어요.","audioUrl":"/seed/the-clever-crow/audio/p4-s1.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":260},{"word":"crow","charStart":4,"charEnd":8,"startMs":260,"endMs":500},{"word":"put","charStart":9,"charEnd":12,"startMs":500,"endMs":820},{"word":"her","charStart":13,"charEnd":16,"startMs":820,"endMs":1060},{"word":"beak","charStart":17,"charEnd":21,"startMs":1060,"endMs":1380},{"word":"into","charStart":22,"charEnd":26,"startMs":1380,"endMs":1820},{"word":"the","charStart":27,"charEnd":30,"startMs":1820,"endMs":2040},{"word":"jug","charStart":31,"charEnd":34,"startMs":2040,"endMs":2260}]},{"id":"the-clever-crow-p4-s2","ord":1,"text":"But the water was too low, and she could not reach it.","translation_ko":"하지만 물이 너무 아래에 있어서 닿지가 않았어요.","audioUrl":"/seed/the-clever-crow/audio/p4-s2.mp3","wordTimings":[{"word":"But","charStart":0,"charEnd":3,"startMs":0,"endMs":320},{"word":"the","charStart":4,"charEnd":7,"startMs":320,"endMs":620},{"word":"water","charStart":8,"charEnd":13,"startMs":620,"endMs":860},{"word":"was","charStart":14,"charEnd":17,"startMs":860,"endMs":1120},{"word":"too","charStart":18,"charEnd":21,"startMs":1120,"endMs":1480},{"word":"low","charStart":22,"charEnd":25,"startMs":1480,"endMs":1760},{"word":"and","charStart":27,"charEnd":30,"startMs":1760,"endMs":2280},{"word":"she","charStart":31,"charEnd":34,"startMs":2280,"endMs":2540},{"word":"could","charStart":35,"charEnd":40,"startMs":2540,"endMs":2780},{"word":"not","charStart":41,"charEnd":44,"startMs":2780,"endMs":3060},{"word":"reach","charStart":45,"charEnd":50,"startMs":3060,"endMs":3260},{"word":"it","charStart":51,"charEnd":53,"startMs":3260,"endMs":3460}]}]},{"id":"the-clever-crow-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/the-clever-crow/p5.webp","sentences":[{"id":"the-clever-crow-p5-s1","ord":0,"text":"She pushed the jug, but it was too heavy to move.","translation_ko":"까마귀가 병을 밀어 보았지만, 너무 무거워서 움직이지 않았어요.","audioUrl":"/seed/the-clever-crow/audio/p5-s1.mp3","wordTimings":[{"word":"She","charStart":0,"charEnd":3,"startMs":0,"endMs":300},{"word":"pushed","charStart":4,"charEnd":10,"startMs":300,"endMs":600},{"word":"the","charStart":11,"charEnd":14,"startMs":600,"endMs":1080},{"word":"jug","charStart":15,"charEnd":18,"startMs":1080,"endMs":1120},{"word":"but","charStart":20,"charEnd":23,"startMs":1320,"endMs":1540},{"word":"it","charStart":24,"charEnd":26,"startMs":1540,"endMs":1640},{"word":"was","charStart":27,"charEnd":30,"startMs":1640,"endMs":1880},{"word":"too","charStart":31,"charEnd":34,"startMs":1880,"endMs":2180},{"word":"heavy","charStart":35,"charEnd":40,"startMs":2180,"endMs":2360},{"word":"to","charStart":41,"charEnd":43,"startMs":2360,"endMs":2700},{"word":"move","charStart":44,"charEnd":48,"startMs":2700,"endMs":2940}]},{"id":"the-clever-crow-p5-s2","ord":1,"text":"\"What can I do?\" she said.","translation_ko":"\"어떻게 하면 좋을까?\" 까마귀가 말했어요.","audioUrl":"/seed/the-clever-crow/audio/p5-s2.mp3","wordTimings":[{"word":"What","charStart":1,"charEnd":5,"startMs":0,"endMs":320},{"word":"can","charStart":6,"charEnd":9,"startMs":320,"endMs":620},{"word":"I","charStart":10,"charEnd":11,"startMs":620,"endMs":860},{"word":"do","charStart":12,"charEnd":14,"startMs":860,"endMs":1080},{"word":"she","charStart":17,"charEnd":20,"startMs":1400,"endMs":1560},{"word":"said","charStart":21,"charEnd":25,"startMs":1560,"endMs":1820}]}]},{"id":"the-clever-crow-p6","pageNo":6,"spread":"p6","imageUrl":"/seed/the-clever-crow/p6.webp","sentences":[{"id":"the-clever-crow-p6-s1","ord":0,"text":"The crow sat down and thought for a long time.","translation_ko":"까마귀는 자리에 앉아 한참을 곰곰이 생각했어요.","audioUrl":"/seed/the-clever-crow/audio/p6-s1.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":280},{"word":"crow","charStart":4,"charEnd":8,"startMs":280,"endMs":540},{"word":"sat","charStart":9,"charEnd":12,"startMs":540,"endMs":920},{"word":"down","charStart":13,"charEnd":17,"startMs":920,"endMs":1280},{"word":"and","charStart":18,"charEnd":21,"startMs":1280,"endMs":1580},{"word":"thought","charStart":22,"charEnd":29,"startMs":1580,"endMs":1780},{"word":"for","charStart":30,"charEnd":33,"startMs":1780,"endMs":2040},{"word":"a","charStart":34,"charEnd":35,"startMs":2040,"endMs":2180},{"word":"long","charStart":36,"charEnd":40,"startMs":2180,"endMs":2400},{"word":"time","charStart":41,"charEnd":45,"startMs":2400,"endMs":2740}]},{"id":"the-clever-crow-p6-s2","ord":1,"text":"Near her feet, she saw many small pebbles.","translation_ko":"발밑에는 작은 조약돌이 잔뜩 보였어요.","audioUrl":"/seed/the-clever-crow/audio/p6-s2.mp3","wordTimings":[{"word":"Near","charStart":0,"charEnd":4,"startMs":0,"endMs":620},{"word":"her","charStart":5,"charEnd":8,"startMs":620,"endMs":880},{"word":"feet","charStart":9,"charEnd":13,"startMs":880,"endMs":1160},{"word":"she","charStart":15,"charEnd":18,"startMs":1420,"endMs":1720},{"word":"saw","charStart":19,"charEnd":22,"startMs":1720,"endMs":1900},{"word":"many","charStart":23,"charEnd":27,"startMs":1900,"endMs":2340},{"word":"small","charStart":28,"charEnd":33,"startMs":2340,"endMs":2720},{"word":"pebbles","charStart":34,"charEnd":41,"startMs":2720,"endMs":3040}]}]},{"id":"the-clever-crow-p7","pageNo":7,"spread":"p7","imageUrl":"/seed/the-clever-crow/p7.webp","sentences":[{"id":"the-clever-crow-p7-s1","ord":0,"text":"She picked up one pebble and dropped it into the jug.","translation_ko":"까마귀는 조약돌 하나를 집어 병 안에 떨어뜨렸어요.","audioUrl":"/seed/the-clever-crow/audio/p7-s1.mp3","wordTimings":[{"word":"She","charStart":0,"charEnd":3,"startMs":0,"endMs":300},{"word":"picked","charStart":4,"charEnd":10,"startMs":300,"endMs":540},{"word":"up","charStart":11,"charEnd":13,"startMs":540,"endMs":840},{"word":"one","charStart":14,"charEnd":17,"startMs":840,"endMs":1140},{"word":"pebble","charStart":18,"charEnd":24,"startMs":1140,"endMs":1440},{"word":"and","charStart":25,"charEnd":28,"startMs":1440,"endMs":1860},{"word":"dropped","charStart":29,"charEnd":36,"startMs":1860,"endMs":2160},{"word":"it","charStart":37,"charEnd":39,"startMs":2160,"endMs":2360},{"word":"into","charStart":40,"charEnd":44,"startMs":2360,"endMs":2580},{"word":"the","charStart":45,"charEnd":48,"startMs":2580,"endMs":2760},{"word":"jug","charStart":49,"charEnd":52,"startMs":2760,"endMs":2960}]},{"id":"the-clever-crow-p7-s2","ord":1,"text":"When the pebble fell, the water rose a little.","translation_ko":"조약돌이 떨어지자 물이 조금 올라왔어요.","audioUrl":"/seed/the-clever-crow/audio/p7-s2.mp3","wordTimings":[{"word":"When","charStart":0,"charEnd":4,"startMs":0,"endMs":460},{"word":"the","charStart":5,"charEnd":8,"startMs":460,"endMs":1040},{"word":"pebble","charStart":9,"charEnd":15,"startMs":1040,"endMs":1220},{"word":"fell","charStart":16,"charEnd":20,"startMs":1220,"endMs":1660},{"word":"the","charStart":22,"charEnd":25,"startMs":2300,"endMs":2500},{"word":"water","charStart":26,"charEnd":31,"startMs":2500,"endMs":2840},{"word":"rose","charStart":32,"charEnd":36,"startMs":2840,"endMs":3300},{"word":"a","charStart":37,"charEnd":38,"startMs":3300,"endMs":3660},{"word":"little","charStart":39,"charEnd":45,"startMs":3660,"endMs":3720}]}]},{"id":"the-clever-crow-p8","pageNo":8,"spread":"p8","imageUrl":"/seed/the-clever-crow/p8.webp","sentences":[{"id":"the-clever-crow-p8-s1","ord":0,"text":"So the clever crow dropped more and more pebbles.","translation_ko":"그래서 영리한 까마귀는 조약돌을 점점 더 많이 떨어뜨렸어요.","audioUrl":"/seed/the-clever-crow/audio/p8-s1.mp3","wordTimings":[{"word":"So","charStart":0,"charEnd":2,"startMs":0,"endMs":400},{"word":"the","charStart":3,"charEnd":6,"startMs":400,"endMs":600},{"word":"clever","charStart":7,"charEnd":13,"startMs":600,"endMs":940},{"word":"crow","charStart":14,"charEnd":18,"startMs":940,"endMs":1260},{"word":"dropped","charStart":19,"charEnd":26,"startMs":1260,"endMs":1640},{"word":"more","charStart":27,"charEnd":31,"startMs":1640,"endMs":2060},{"word":"and","charStart":32,"charEnd":35,"startMs":2060,"endMs":2260},{"word":"more","charStart":36,"charEnd":40,"startMs":2260,"endMs":2540},{"word":"pebbles","charStart":41,"charEnd":48,"startMs":2540,"endMs":2980}]},{"id":"the-clever-crow-p8-s2","ord":1,"text":"Each time, the water came up higher.","translation_ko":"그럴 때마다 물이 더 높이 올라왔어요.","audioUrl":"/seed/the-clever-crow/audio/p8-s2.mp3","wordTimings":[{"word":"Each","charStart":0,"charEnd":4,"startMs":0,"endMs":420},{"word":"time","charStart":5,"charEnd":9,"startMs":420,"endMs":1020},{"word":"the","charStart":11,"charEnd":14,"startMs":1020,"endMs":1460},{"word":"water","charStart":15,"charEnd":20,"startMs":1460,"endMs":1680},{"word":"came","charStart":21,"charEnd":25,"startMs":1680,"endMs":1980},{"word":"up","charStart":26,"charEnd":28,"startMs":1980,"endMs":2280},{"word":"higher","charStart":29,"charEnd":35,"startMs":2280,"endMs":2500}]}]},{"id":"the-clever-crow-p9","pageNo":9,"spread":"p9","imageUrl":"/seed/the-clever-crow/p9.webp","sentences":[{"id":"the-clever-crow-p9-s1","ord":0,"text":"At last, the water was near the top of the jug.","translation_ko":"마침내 물이 병 입구 가까이까지 차올랐어요.","audioUrl":"/seed/the-clever-crow/audio/p9-s1.mp3","wordTimings":[{"word":"At","charStart":0,"charEnd":2,"startMs":0,"endMs":260},{"word":"last","charStart":3,"charEnd":7,"startMs":260,"endMs":660},{"word":"the","charStart":9,"charEnd":12,"startMs":1020,"endMs":1220},{"word":"water","charStart":13,"charEnd":18,"startMs":1220,"endMs":1460},{"word":"was","charStart":19,"charEnd":22,"startMs":1460,"endMs":1760},{"word":"near","charStart":23,"charEnd":27,"startMs":1760,"endMs":1880},{"word":"the","charStart":28,"charEnd":31,"startMs":1880,"endMs":2300},{"word":"top","charStart":32,"charEnd":35,"startMs":2300,"endMs":2320},{"word":"of","charStart":36,"charEnd":38,"startMs":2320,"endMs":2580},{"word":"the","charStart":39,"charEnd":42,"startMs":2580,"endMs":2820},{"word":"jug","charStart":43,"charEnd":46,"startMs":2820,"endMs":2820}]},{"id":"the-clever-crow-p9-s2","ord":1,"text":"The crow leaned in and drank until she was happy.","t