{"id":"the-paper-dragon-race","slug":"the-paper-dragon-race","title":"The Paper Dragon Race","title_ko":"종이 용 경주","level":"A2","ageBand":"8-10","coverUrl":"/seed/the-paper-dragon-race/cover.webp","summary_ko":"종이 용을 만들어 개울에 띄우며 빠름보다 설계와 배려가 중요하다는 걸 배우는 이야기예요.","wordCount":94,"pages":[{"id":"the-paper-dragon-race-p1","pageNo":1,"spread":"p1","imageUrl":"/seed/the-paper-dragon-race/p1.webp","sentences":[{"id":"the-paper-dragon-race-p1-s1","ord":0,"text":"For the spring fair, our class folded paper dragons.","translation_ko":"봄 축제를 위해 우리 반은 종이 용을 접었어요.","audioUrl":"/seed/the-paper-dragon-race/audio/p1-s1.mp3","wordTimings":[{"word":"For","charStart":0,"charEnd":3,"startMs":0,"endMs":300},{"word":"the","charStart":4,"charEnd":7,"startMs":300,"endMs":560},{"word":"spring","charStart":8,"charEnd":14,"startMs":560,"endMs":860},{"word":"fair","charStart":15,"charEnd":19,"startMs":860,"endMs":1180},{"word":"our","charStart":21,"charEnd":24,"startMs":1480,"endMs":1680},{"word":"class","charStart":25,"charEnd":30,"startMs":1680,"endMs":2020},{"word":"folded","charStart":31,"charEnd":37,"startMs":2020,"endMs":2400},{"word":"paper","charStart":38,"charEnd":43,"startMs":2400,"endMs":2820},{"word":"dragons","charStart":44,"charEnd":51,"startMs":2820,"endMs":3120}]}]},{"id":"the-paper-dragon-race-p2","pageNo":2,"spread":"p2","imageUrl":"/seed/the-paper-dragon-race/p2.webp","sentences":[{"id":"the-paper-dragon-race-p2-s1","ord":0,"text":"Each dragon had a long tail and a painted face.","translation_ko":"용마다 긴 꼬리와 색칠한 얼굴이 있었어요.","audioUrl":"/seed/the-paper-dragon-race/audio/p2-s1.mp3","wordTimings":[{"word":"Each","charStart":0,"charEnd":4,"startMs":0,"endMs":360},{"word":"dragon","charStart":5,"charEnd":11,"startMs":360,"endMs":680},{"word":"had","charStart":12,"charEnd":15,"startMs":680,"endMs":920},{"word":"a","charStart":16,"charEnd":17,"startMs":920,"endMs":1100},{"word":"long","charStart":18,"charEnd":22,"startMs":1100,"endMs":1400},{"word":"tail","charStart":23,"charEnd":27,"startMs":1400,"endMs":1740},{"word":"and","charStart":28,"charEnd":31,"startMs":1740,"endMs":2360},{"word":"a","charStart":32,"charEnd":33,"startMs":2360,"endMs":2760},{"word":"painted","charStart":34,"charEnd":41,"startMs":2760,"endMs":2760},{"word":"face","charStart":42,"charEnd":46,"startMs":2760,"endMs":3200}]}]},{"id":"the-paper-dragon-race-p3","pageNo":3,"spread":"p3","imageUrl":"/seed/the-paper-dragon-race/p3.webp","sentences":[{"id":"the-paper-dragon-race-p3-s1","ord":0,"text":"We placed them in the stream behind the school.","translation_ko":"우리는 학교 뒤 개울에 그것들을 띄웠어요.","audioUrl":"/seed/the-paper-dragon-race/audio/p3-s1.mp3","wordTimings":[{"word":"We","charStart":0,"charEnd":2,"startMs":0,"endMs":280},{"word":"placed","charStart":3,"charEnd":9,"startMs":280,"endMs":740},{"word":"them","charStart":10,"charEnd":14,"startMs":740,"endMs":1100},{"word":"in","charStart":15,"charEnd":17,"startMs":1100,"endMs":1440},{"word":"the","charStart":18,"charEnd":21,"startMs":1440,"endMs":1660},{"word":"stream","charStart":22,"charEnd":28,"startMs":1660,"endMs":2180},{"word":"behind","charStart":29,"charEnd":35,"startMs":2180,"endMs":2860},{"word":"the","charStart":36,"charEnd":39,"startMs":2860,"endMs":3100},{"word":"school","charStart":40,"charEnd":46,"startMs":3100,"endMs":3500}]}]},{"id":"the-paper-dragon-race-p4","pageNo":4,"spread":"p4","imageUrl":"/seed/the-paper-dragon-race/p4.webp","sentences":[{"id":"the-paper-dragon-race-p4-s1","ord":0,"text":"Mine rushed ahead but soon tipped sideways.","translation_ko":"내 용은 앞서 나갔지만 곧 옆으로 기울었어요.","audioUrl":"/seed/the-paper-dragon-race/audio/p4-s1.mp3","wordTimings":[{"word":"Mine","charStart":0,"charEnd":4,"startMs":0,"endMs":440},{"word":"rushed","charStart":5,"charEnd":11,"startMs":440,"endMs":800},{"word":"ahead","charStart":12,"charEnd":17,"startMs":800,"endMs":1160},{"word":"but","charStart":18,"charEnd":21,"startMs":1160,"endMs":1500},{"word":"soon","charStart":22,"charEnd":26,"startMs":1500,"endMs":1780},{"word":"tipped","charStart":27,"charEnd":33,"startMs":1780,"endMs":2020},{"word":"sideways","charStart":34,"charEnd":42,"startMs":2020,"endMs":2540}]}]},{"id":"the-paper-dragon-race-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/the-paper-dragon-race/p5.webp","sentences":[{"id":"the-paper-dragon-race-p5-s1","ord":0,"text":"Sora's dragon moved slowly because its tail dragged in the water.","translation_ko":"소라의 용은 꼬리가 물에 끌려서 천천히 움직였어요.","audioUrl":"/seed/the-paper-dragon-race/audio/p5-s1.mp3","wordTimings":[{"word":"Sora's","charStart":0,"charEnd":6,"startMs":0,"endMs":840},{"word":"dragon","charStart":7,"charEnd":13,"startMs":840,"endMs":840},{"word":"moved","charStart":14,"charEnd":19,"startMs":840,"endMs":1220},{"word":"slowly","charStart":20,"charEnd":26,"startMs":1220,"endMs":1720},{"word":"because","charStart":27,"charEnd":34,"startMs":1720,"endMs":2360},{"word":"its","charStart":35,"charEnd":38,"startMs":2360,"endMs":2620},{"word":"tail","charStart":39,"charEnd":43,"startMs":2620,"endMs":3000},{"word":"dragged","charStart":44,"charEnd":51,"startMs":3000,"endMs":3360},{"word":"in","charStart":52,"charEnd":54,"startMs":3360,"endMs":3540},{"word":"the","charStart":55,"charEnd":58,"startMs":3540,"endMs":3720},{"word":"water","charStart":59,"charEnd":64,"startMs":3720,"endMs":3900}]}]},{"id":"the-paper-dragon-race-p6","pageNo":6,"spread":"p6","imageUrl":"/seed/the-paper-dragon-race/p6.webp","sentences":[{"id":"the-paper-dragon-race-p6-s1","ord":0,"text":"Instead of laughing, we pulled them out and studied the folds.","translation_ko":"우리는 웃지 않고 용들을 꺼내 접힌 곳을 살펴보았어요.","audioUrl":"/seed/the-paper-dragon-race/audio/p6-s1.mp3","wordTimings":[{"word":"Instead","charStart":0,"charEnd":7,"startMs":0,"endMs":320},{"word":"of","charStart":8,"charEnd":10,"startMs":320,"endMs":540},{"word":"laughing","charStart":11,"charEnd":19,"startMs":540,"endMs":880},{"word":"we","charStart":21,"charEnd":23,"startMs":1140,"endMs":1340},{"word":"pulled","charStart":24,"charEnd":30,"startMs":1340,"endMs":1480},{"word":"them","charStart":31,"charEnd":35,"startMs":1480,"endMs":1660},{"word":"out","charStart":36,"charEnd":39,"startMs":1660,"endMs":1880},{"word":"and","charStart":40,"charEnd":43,"startMs":1880,"endMs":2220},{"word":"studied","charStart":44,"charEnd":51,"startMs":2220,"endMs":2420},{"word":"the","charStart":52,"charEnd":55,"startMs":2420,"endMs":2660},{"word":"folds","charStart":56,"charEnd":61,"startMs":2660,"endMs":2940}]}]},{"id":"the-paper-dragon-race-p7","pageNo":7,"spread":"p7","imageUrl":"/seed/the-paper-dragon-race/p7.webp","sentences":[{"id":"the-paper-dragon-race-p7-s1","ord":0,"text":"We made wider wings and shorter tails for the second race.","translation_ko":"두 번째 경주를 위해 날개를 더 넓게, 꼬리를 더 짧게 만들었어요.","audioUrl":"/seed/the-paper-dragon-race/audio/p7-s1.mp3","wordTimings":[{"word":"We","charStart":0,"charEnd":2,"startMs":0,"endMs":320},{"word":"made","charStart":3,"charEnd":7,"startMs":320,"endMs":540},{"word":"wider","charStart":8,"charEnd":13,"startMs":540,"endMs":980},{"word":"wings","charStart":14,"charEnd":19,"startMs":980,"endMs":1420},{"word":"and","charStart":20,"charEnd":23,"startMs":1420,"endMs":2020},{"word":"shorter","charStart":24,"charEnd":31,"startMs":2020,"endMs":2260},{"word":"tails","charStart":32,"charEnd":37,"startMs":2260,"endMs":2700},{"word":"for","charStart":38,"charEnd":41,"startMs":2700,"endMs":3060},{"word":"the","charStart":42,"charEnd":45,"startMs":3060,"endMs":3320},{"word":"second","charStart":46,"charEnd":52,"startMs":3320,"endMs":3540},{"word":"race","charStart":53,"charEnd":57,"startMs":3540,"endMs":3820}]}]},{"id":"the-paper-dragon-race-p8","pageNo":8,"spread":"p8","imageUrl":"/seed/the-paper-dragon-race/p8.webp","sentences":[{"id":"the-paper-dragon-race-p8-s1","ord":0,"text":"This time the dragons floated side by side.","translation_ko":"이번에는 용들이 나란히 떠갔어요.","audioUrl":"/seed/the-paper-dragon-race/audio/p8-s1.mp3","wordTimings":[{"word":"This","charStart":0,"charEnd":4,"startMs":0,"endMs":360},{"word":"time","charStart":5,"charEnd":9,"startMs":360,"endMs":700},{"word":"the","charStart":10,"charEnd":13,"startMs":960,"endMs":1260},{"word":"dragons","charStart":14,"charEnd":21,"startMs":1260,"endMs":1480},{"word":"floated","charStart":22,"charEnd":29,"startMs":1480,"endMs":1880},{"word":"side","charStart":30,"charEnd":34,"startMs":1880,"endMs":2340},{"word":"by","charStart":35,"charEnd":37,"startMs":2340,"endMs":2600},{"word":"side","charStart":38,"charEnd":42,"startMs":2600,"endMs":2860}]}]},{"id":"the-paper-dragon-race-p9","pageNo":9,"spread":"p9","imageUrl":"/seed/the-paper-dragon-race/p9.webp","sentences":[{"id":"the-paper-dragon-race-p9-s1","ord":0,"text":"No one knew whose dragon won, but everyone cheered.","translation_ko":"누구의 용이 이겼는지는 몰랐지만 모두가 환호했어요.","audioUrl":"/seed/the-paper-dragon-race/audio/p9-s1.mp3","wordTimings":[{"word":"No","charStart":0,"charEnd":2,"startMs":0,"endMs":340},{"word":"one","charStart":3,"charEnd":6,"startMs":340,"endMs":620},{"word":"knew","charStart":7,"charEnd":11,"startMs":620,"endMs":860},{"word":"whose","charStart":12,"charEnd":17,"startMs":860,"endMs":1180},{"word":"dragon","charStart":18,"charEnd":24,"startMs":1180,"endMs":1480},{"word":"won","charStart":25,"charEnd":28,"startMs":1480,"endMs":1880},{"word":"but","charStart":30,"charEnd":33,"startMs":2180,"endMs":2400},{"word":"everyone","charStart":34,"charEnd":42,"startMs":2400,"endMs":2820},{"word":"cheered","charStart":43,"charEnd":50,"startMs":2820,"endMs":3180}]}]},{"id":"the-paper-dragon-race-p10","pageNo":10,"spread":"p10","imageUrl":"/seed/the-paper-dragon-race/p10.webp","sentences":[{"id":"the-paper-dragon-race-p10-s1","ord":0,"text":"The best race was the one we fixed together.","translation_ko":"가장 좋은 경주는 우리가 함께 고친 경주였어요.","audioUrl":"/seed/the-paper-dragon-race/audio/p10-s1.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":260},{"word":"best","charStart":4,"charEnd":8,"startMs":260,"endMs":660},{"word":"race","charStart":9,"charEnd":13,"startMs"