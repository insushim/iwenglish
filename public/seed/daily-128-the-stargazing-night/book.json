 of hot cocoa.","translation_ko":"밤공기가 점점 서늘해지자, 아빠가 따뜻한 코코아 세 잔을 들고 올라오셨어요.","audioUrl":"/seed/daily-128-the-stargazing-night/audio/p9-s1.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":440},{"word":"night","charStart":4,"charEnd":9,"startMs":440,"endMs":720},{"word":"air","charStart":10,"charEnd":13,"startMs":720,"endMs":860},{"word":"grew","charStart":14,"charEnd":18,"startMs":860,"endMs":1060},{"word":"cooler","charStart":19,"charEnd":25,"startMs":1060,"endMs":1400},{"word":"so","charStart":27,"charEnd":29,"startMs":1760,"endMs":1900},{"word":"Dad","charStart":30,"charEnd":33,"startMs":1900,"endMs":2120},{"word":"brought","charStart":34,"charEnd":41,"startMs":2120,"endMs":2360},{"word":"up","charStart":42,"charEnd":44,"startMs":2360,"endMs":2540},{"word":"three","charStart":45,"charEnd":50,"startMs":2540,"endMs":2800},{"word":"mugs","charStart":51,"charEnd":55,"startMs":2800,"endMs":3000},{"word":"of","charStart":56,"charEnd":58,"startMs":3000,"endMs":3300},{"word":"hot","charStart":59,"charEnd":62,"startMs":3300,"endMs":3440},{"word":"cocoa","charStart":63,"charEnd":68,"startMs":3440,"endMs":3680}]},{"id":"daily-128-the-stargazing-night-p9-s2","ord":1,"text":"They sat in folding chairs, sipping cocoa and watching the sky in silence.","translation_ko":"세 사람은 접이식 의자에 앉아 코코아를 홀짝이며 조용히 하늘을 바라봤어요.","audioUrl":"/seed/daily-128-the-stargazing-night/audio/p9-s2.mp3","wordTimings":[{"word":"They","charStart":0,"charEnd":4,"startMs":0,"endMs":340},{"word":"sat","charStart":5,"charEnd":8,"startMs":340,"endMs":640},{"word":"in","charStart":9,"charEnd":11,"startMs":640,"endMs":1100},{"word":"folding","charStart":12,"charEnd":19,"startMs":1100,"endMs":1300},{"word":"chairs","charStart":20,"charEnd":26,"startMs":1300,"endMs":1820},{"word":"sipping","charStart":28,"charEnd":35,"startMs":2460,"endMs":2600},{"word":"cocoa","charStart":36,"charEnd":41,"startMs":2600,"endMs":2980},{"word":"and","charStart":42,"charEnd":45,"startMs":2980,"endMs":3340},{"word":"watching","charStart":46,"charEnd":54,"startMs":3340,"endMs":3560},{"word":"the","charStart":55,"charEnd":58,"startMs":3560,"endMs":3880},{"word":"sky","charStart":59,"charEnd":62,"startMs":3880,"endMs":4140},{"word":"in","charStart":63,"charEnd":65,"startMs":4140,"endMs":4900},{"word":"silence","charStart":66,"charEnd":73,"startMs":4900,"endMs":4900}]}]},{"id":"daily-128-the-stargazing-night-p10","pageNo":10,"spread":"p10","imageUrl":"/seed/daily-128-the-stargazing-night/p10.webp","sentences":[{"id":"daily-128-the-stargazing-night-p10-s1","ord":0,"text":"Suddenly, a streak of light crossed the sky.","translation_ko":"갑자기 빛줄기 하나가 하늘을 가로질렀어요.","audioUrl":"/seed/daily-128-the-stargazing-night/audio/p10-s1.mp3","wordTimings":[{"word":"Suddenly","charStart":0,"charEnd":8,"startMs":0,"endMs":620},{"word":"a","charStart":10,"charEnd":11,"startMs":880,"endMs":1160},{"word":"streak","charStart":12,"charEnd":18,"startMs":1160,"endMs":1400},{"word":"of","charStart":19,"charEnd":21,"startMs":1400,"endMs":1680},{"word":"light","charStart":22,"charEnd":27,"startMs":1680,"endMs":1840},{"word":"crossed","charStart":28,"charEnd":35,"startMs":1840,"endMs":2220},{"word":"the","charStart":36,"charEnd":39,"startMs":2220,"endMs":2460},{"word":"sky","charStart":40,"charEnd":43,"startMs":2460,"endMs":2720}]},{"id":"daily-128-the-stargazing-night-p10-s2","ord":1,"text":"\"A shooting star!\" Jun and Mina shouted at the same moment.","translation_ko":"\"유성이다!\" 준과 미나가 동시에 외쳤어요.","audioUrl":"/seed/daily-128-the-stargazing-night/audio/p10-s2.mp3","wordTimings":[{"word":"A","charStart":1,"charEnd":2,"startMs":0,"endMs":740},{"word":"shooting","charStart":3,"charEnd":11,"startMs":740,"endMs":1000},{"word":"star","charStart":12,"charEnd":16,"startMs":1000,"endMs":1500},{"word":"Jun","charStart":19,"charEnd":22,"startMs":2400,"endMs":2400},{"word":"and","charStart":23,"charEnd":26,"startMs":2400,"endMs":2700},{"word":"Mina","charStart":27,"charEnd":31,"startMs":2700,"endMs":2900},{"word":"shouted","charStart":32,"charEnd":39,"startMs":2900,"endMs":3360},{"word":"at","charStart":40,"charEnd":42,"startMs":3360,"endMs":3560},{"word":"the","charStart":43,"charEnd":46,"startMs":3560,"endMs":3720},{"word":"same","charStart":47,"charEnd":51,"startMs":3720,"endMs":4020},{"word":"moment","charStart":52,"charEnd":58,"startMs":4020,"endMs":4320}]},{"id":"daily-128-the-stargazing-night-p10-s3","ord":2,"text":"They looked at each other and burst out laughing.","translation_ko":"두 사람은 눈이 마주치더니 웃음을 터뜨렸어요.","audioUrl":"/seed/daily-128-the-stargazing-night/audio/p10-s3.mp3","wordTimings":[{"word":"They","charStart":0,"charEnd":4,"startMs":0,"endMs":320},{"word":"looked","charStart":5,"charEnd":11,"startMs":320,"endMs":640},{"word":"at","charStart":12,"charEnd":14,"startMs":640,"endMs":920},{"word":"each","charStart":15,"charEnd":19,"startMs":920,"endMs":1100},{"word":"other","charStart":20,"charEnd":25,"startMs":1100,"endMs":1360},{"word":"and","charStart":26,"charEnd":29,"startMs":1360,"endMs":1720},{"word":"burst","charStart":30,"charEnd":35,"startMs":1720,"endMs":1900},{"word":"out","charStart":36,"charEnd":39,"startMs":1900,"endMs":2220},{"word":"laughing","charStart":40,"charEnd":48,"startMs":2220,"endMs":2500}]}]},{"id":"daily-128-the-stargazing-night-p11","pageNo":11,"spread":"p11","imageUrl":"/seed/daily-128-the-stargazing-night/p11.webp","sentences":[{"id":"daily-128-the-stargazing-night-p11-s1","ord":0,"text":"\"Did you make a wish?\" Mina asked with a smile.","translation_ko":"\"소원 빌었어?\" 미나가 웃으며 물었어요.","audioUrl":"/seed/daily-128-the-stargazing-night/audio/p11-s1.mp3","wordTimings":[{"word":"Did","charStart":1,"charEnd":4,"startMs":0,"endMs":580},{"word":"you","charStart":5,"charEnd":8,"startMs":580,"endMs":780},{"word":"make","charStart":9,"charEnd":13,"startMs":780,"endMs":940},{"word":"a","charStart":14,"charEnd":15,"startMs":940,"endMs":1200},{"word":"wish","charStart":16,"charEnd":20,"startMs":1200,"endMs":1420},{"word":"Mina","charStart":23,"charEnd":27,"startMs":2200,"endMs":2280},{"word":"asked","charStart":28,"charEnd":33,"startMs":2280,"endMs":2740},{"word":"with","charStart":34,"charEnd":38,"startMs":2740,"endMs":2960},{"word":"a","charStart":39,"charEnd":40,"startMs":2960,"endMs":3260},{"word":"smile","charStart":41,"charEnd":46,"startMs":3260,"endMs":3460}]},{"id":"daily-128-the-stargazing-night-p11-s2","ord":1,"text":"\"Yes, but I'm not telling,\" Jun said with a grin.","translation_ko":"\"응, 그런데 말 안 해,\" 준이 씩 웃으며 말했어요.","audioUrl":"/seed/daily-128-the-stargazing-night/audio/p11-s2.mp3","wordTimings":[{"word":"Yes","charStart":1,"charEnd":4,"startMs":0,"endMs":440},{"word":"but","charStart":6,"charEnd":9,"startMs":760,"endMs":1200},{"word":"I'm","charStart":10,"charEnd":13,"startMs":1200,"endMs":1400},{"word":"not","charStart":14,"charEnd":17,"startMs":1400,"endMs":1680},{"word":"telling","charStart":18,"charEnd":25,"startMs":1680,"endMs":2740},{"word":"Jun","charStart":28,"charEnd":31,"startMs":2740,"endMs":2740},{"word":"said","charStart":32,"charEnd":36,"startMs":2740,"endMs":3000},{"word":"with","charStart":37,"charEnd":41,"startMs":3000,"endMs":3140},{"word":"a","charStart":42,"charEnd":43,"startMs":3140,"endMs":3480},{"word":"grin","charStart":44,"charEnd":48,"startMs":3480,"endMs":3480}]}]},{"id":"daily-128-the-stargazing-night-p12","pageNo":12,"spread":"p12","imageUrl":"/seed/daily-128-the-stargazing-night/p12.webp","sentences":[{"id":"daily-128-the-stargazing-night-p12-s1","ord":0,"text":"Before they went inside, Mina read back everything from her notebook.","translation_ko":"안으로 들어가기 전에, 미나가 공책에 적은 내용을 소리 내어 읽었어요.","audioUrl":"/seed/daily-128-the-stargazing-night/audio/p12-s1.mp3","wordTimings":[{"word":"Before","charStart":0,"charEnd":6,"startMs":0,"endMs":600},{"word":"they","charStart":7,"charEnd":11,"startMs":600,"endMs":820},{"word":"went","charStart":12,"charEnd":16,"startMs":820,"endMs":1080},{"word":"inside","charStart":17,"charEnd":23,"startMs":1080,"endMs":1640},{"word":"Mina","charStart":25,"charEnd":29,"startMs":2300,"endMs":2380},{"word":"read","charStart":30,"charEnd":34,"startMs":2380,"endMs":2640},{"word":"back","charStart":35,"charEnd":39,"startMs":2640,"endMs":2920},{"word":"everything","charStart":40,"charEnd":50,"startMs":2920,"endMs":3500},{"word":"from","charStart":51,"charEnd":55,"startMs":3500,"endMs":3740},{"word":"her","charStart":56,"charEnd":59,"startMs":3740,"endMs":3900},{"word":"notebook","charStart":60,"charEnd":68,"startMs":3900,"endMs":4240}]},{"id":"daily-128-the-stargazing-night-p12-s2","ord":1,"text":"Orion's belt, the Big Dipper, the North Star, and one shooting star.","translation_ko":"오리온의 허리띠, 북두칠성, 북극성, 그리고 유성 하나.","audioUrl":"/seed/daily-128-the-stargazing-night/audio/p12-s2.mp3","wordTimings":[{"word":"Orion's","charStart":0,"charEnd":7,"startMs":640,"endMs":1080},{"word":"belt","charStart":8,"charEnd":12,"startMs":1080,"endMs":1260},{"word":"the","charStart":14,"charEnd":17,"startMs":1900,"endMs":2020},{"word":"Big","charStart":18,"charEnd":21,"startMs":2020,"endMs":2220},{"word":"Dipper","charStart":22,"charEnd":28,"startMs":2220,"endMs":2380},{"word":"the","charStart":30,"charEnd":33,"startMs":2760,"endMs":2880},{"word":"North","charStart":34,"charEnd":39,"startMs":2880,"endMs":3100},{"word":"Star","charStart":40,"charEnd":44,"startMs":3100,"endMs":3400},{"word":"and","charStart":46,"charEnd":49,"startMs":3840,"endMs":4020},{"word":"one","charStart":50,"charEnd":53,"startMs":4020,"endMs":4240},{"word":"shooting","charStart":54,"charEnd":62,"startMs":4240,"endMs":4440},{"word":"star","charStart":63,"charEnd":67,"startMs":4440,"endMs":4820}]},{"id":"daily-128-the-stargazing-night-p12-s3","ord":2,"text":"\"Not bad for one night,\" Dad said, wrapping an arm around each of them.","translation_ko":"\"하룻밤치고 나쁘지 않은걸,\" 아빠가 두 아이의 어깨를 한 팔씩 감싸며 말씀하셨어요.","audioUrl":"/seed/daily-128-the-stargazing-night/audio/p12-s3.mp3","wordTimings":[{"word":"Not","charStart":1,"charEnd":4,"startMs":0,"endMs":340},{"word":"bad","charStart":5,"charEnd":8,"startMs":340,"endMs":780},{"word":"for","charStart":9,"charEnd":12,"startMs":780,"endMs":960},{"word":"one","charStart":13,"charEnd":16,"startMs":960,"endMs":1260},{"word":"night","charStart":17,"charEnd":22,"startMs":1260,"endMs":1560},{"word":"Dad","charStart":25,"charEnd":28,"startMs":1960,"endMs":2060},{"word":"said","charStart":29,"charEnd":33,"startMs":2060,"endMs":2380},{"word":"wrapping","charStart":35,"charEnd":43,"startMs":3000,"endMs":3000},{"word":"an","charStart":44,"charEnd":46,"startMs":3000,"endMs":3360},{"word":"arm","charStart":47,"charEnd":50,"startMs":3360,"endMs":3460},{"word":"around","charStart":51,"charEnd":57,"startMs":3460,"endMs":3720},{"word":"each","charStart":58,"charEnd":62,"startMs":3720,"endMs":3980},{"word":"of","charStart":63,"charEnd":65,"startMs":3980,"endMs":4160},{"word":"them","charStart":66,"charEnd":70,"startMs":4160,"endMs":4280}]}]}],"quiz":[{"question_ko":"준과 미나가 별을 관측한 장소는 어디인가요?","type":"mc","options":["공원 잔디밭","도서관 앞마당","아파트 옥상","학교 운동장"],"answerIndex":2,"explain_ko":"아빠는 아파트 옥상에 망원경을 설치하셨고, 세 사람은 그곳에서 별을 관측했어요.","id":"daily-128-the-stargazing-night-q1","ord":0},{"question_ko":"오리온자리에서 허리띠를 이루는 별은 몇 개인가요?","type":"mc","options":["5개","2개","3개","7개"],"answerIndex":2,"explain_ko":"아빠가 설명해 주셨어요. 일렬로 늘어선 별 세 개가 오리온의 허리띠를 이룬답니다.","id":"daily-128-the-stargazing-night-q2","ord":1},{"question_ko":"미나가 망원경을 들여다보며 한 말은 무엇인가요?","type":"mc","options":["우주가 귀를 기울이고 있는 것 같다","도시라서 별이 별로 없다","별이 너무 작아서 보이지 않는다","눈이 아파서 더 이상 못 보겠다"],"answerIndex":0,"explain_ko":"미나는 렌즈를 오래 들여다본 뒤 '우주가 진짜로 귀를 기울이고 있는 것 같아'라고 속삭였어요.","id":"daily-128-the-stargazing-night-q3","ord":2},{"question_ko":"준과 미나가 유성을 보았을 때 어떤 반응을 했나요?","type":"mc","options":["조용히 눈을 감고 소원을 빌었다","망원경으로 따라가며 관찰했다","아빠께 즉시 사진을 찍어 달라고 했다","동시에 소리를 지르고 웃음을 터뜨렸다"],"answerIndex":3,"explain_ko":"준과 미나는 정확히 같은 순간에 '유성이다!'라고 외쳤고, 눈이 마주치자 함께 웃음을 터뜨렸어요.","id":"daily-128-the-stargazing-night-q4","ord":3},{"question_ko":"미나의 공책에 기록되지 않은 것은 무엇인가요?","type":"mc","options":["오리온의 허리띠","북두칠성","유성","달의 이름"],"answerIndex":3,"explain_ko":"미나의 공책에는 오리온의 허리띠, 북두칠성, 북극성, 유성이 기록되어 있었어요. 달은 기록하지 않았어요.","id":"daily-128-the-stargazing-night-q5","ord":4}]}