endMs":5380},{"word":"looked","charStart":94,"charEnd":100,"startMs":5380,"endMs":5660},{"word":"messy","charStart":101,"charEnd":106,"startMs":5660,"endMs":6080},{"word":"but","charStart":107,"charEnd":110,"startMs":6480,"endMs":6620},{"word":"alive","charStart":111,"charEnd":116,"startMs":6620,"endMs":7000}]}]},{"id":"the-boy-who-mapped-the-wind-p6","pageNo":6,"spread":"p6","imageUrl":"/seed/the-boy-who-mapped-the-wind/p6.webp","sentences":[{"id":"the-boy-who-mapped-the-wind-p6-s1","ord":0,"text":"When kite day arrived, the younger children argued about where to stand. Tae placed them on the gentle side of the hill.","translation_ko":"연 날리기 날이 오자 어린아이들은 어디에 서야 할지 다투었어요. 태오는 그들을 언덕의 부드러운 쪽에 세웠어요.","audioUrl":"/seed/the-boy-who-mapped-the-wind/audio/p6-s1.mp3","wordTimings":[{"word":"When","charStart":0,"charEnd":4,"startMs":0,"endMs":380},{"word":"kite","charStart":5,"charEnd":9,"startMs":380,"endMs":740},{"word":"day","charStart":10,"charEnd":13,"startMs":740,"endMs":960},{"word":"arrived","charStart":14,"charEnd":21,"startMs":960,"endMs":1380},{"word":"the","charStart":23,"charEnd":26,"startMs":1620,"endMs":1820},{"word":"younger","charStart":27,"charEnd":34,"startMs":1820,"endMs":2100},{"word":"children","charStart":35,"charEnd":43,"startMs":2100,"endMs":2520},{"word":"argued","charStart":44,"charEnd":50,"startMs":2520,"endMs":2960},{"word":"about","charStart":51,"charEnd":56,"startMs":2960,"endMs":3300},{"word":"where","charStart":57,"charEnd":62,"startMs":3300,"endMs":3600},{"word":"to","charStart":63,"charEnd":65,"startMs":3600,"endMs":4200},{"word":"stand","charStart":66,"charEnd":71,"startMs":4200,"endMs":4200},{"word":"Tae","charStart":73,"charEnd":76,"startMs":5080,"endMs":5080},{"word":"placed","charStart":77,"charEnd":83,"startMs":5080,"endMs":5420},{"word":"them","charStart":84,"charEnd":88,"startMs":5420,"endMs":5640},{"word":"on","charStart":89,"charEnd":91,"startMs":5640,"endMs":5800},{"word":"the","charStart":92,"charEnd":95,"startMs":5800,"endMs":6020},{"word":"gentle","charStart":96,"charEnd":102,"startMs":6020,"endMs":6280},{"word":"side","charStart":103,"charEnd":107,"startMs":6280,"endMs":6600},{"word":"of","charStart":108,"charEnd":110,"startMs":6600,"endMs":6760},{"word":"the","charStart":111,"charEnd":114,"startMs":6760,"endMs":6980},{"word":"hill","charStart":115,"charEnd":119,"startMs":6980,"endMs":7020}]}]},{"id":"the-boy-who-mapped-the-wind-p7","pageNo":7,"spread":"p7","imageUrl":"/seed/the-boy-who-mapped-the-wind/p7.webp","sentences":[{"id":"the-boy-who-mapped-the-wind-p7-s1","ord":0,"text":"Their kites rose smoothly, while older students on the wrong side kept running in circles. Soon everyone asked to see the wind map.","translation_ko":"그들의 연은 매끄럽게 올랐고, 잘못된 쪽의 큰 학생들은 계속 빙빙 뛰었어요. 곧 모두가 바람 지도를 보자고 했어요.","audioUrl":"/seed/the-boy-who-mapped-the-wind/audio/p7-s1.mp3","wordTimings":[{"word":"Their","charStart":0,"charEnd":5,"startMs":0,"endMs":240},{"word":"kites","charStart":6,"charEnd":11,"startMs":240,"endMs":540},{"word":"rose","charStart":12,"charEnd":16,"startMs":540,"endMs":940},{"word":"smoothly","charStart":17,"charEnd":25,"startMs":940,"endMs":1340},{"word":"while","charStart":27,"charEnd":32,"startMs":1780,"endMs":1900},{"word":"older","charStart":33,"charEnd":38,"startMs":1900,"endMs":2260},{"word":"students","charStart":39,"charEnd":47,"startMs":2260,"endMs":2600},{"word":"on","charStart":48,"charEnd":50,"startMs":2600,"endMs":2740},{"word":"the","charStart":51,"charEnd":54,"startMs":2740,"endMs":2880},{"word":"wrong","charStart":55,"charEnd":60,"startMs":2880,"endMs":3160},{"word":"side","charStart":61,"charEnd":65,"startMs":3160,"endMs":3520},{"word":"kept","charStart":66,"charEnd":70,"startMs":3520,"endMs":3960},{"word":"running","charStart":71,"charEnd":78,"startMs":3960,"endMs":4280},{"word":"in","charStart":79,"charEnd":81,"startMs":4280,"endMs":4540},{"word":"circles","charStart":82,"charEnd":89,"startMs":4540,"endMs":4940},{"word":"Soon","charStart":91,"charEnd":95,"startMs":57