rEnd":29,"startMs":1820,"endMs":2160},{"word":"with","charStart":30,"charEnd":34,"startMs":2160,"endMs":2480},{"word":"shiny","charStart":35,"charEnd":40,"startMs":2480,"endMs":2860},{"word":"red","charStart":41,"charEnd":44,"startMs":2860,"endMs":3120},{"word":"and","charStart":45,"charEnd":48,"startMs":3120,"endMs":3360},{"word":"green","charStart":49,"charEnd":54,"startMs":3360,"endMs":3500},{"word":"apples","charStart":55,"charEnd":61,"startMs":3500,"endMs":3800}]},{"id":"daily-5-at-the-market-p4-s2","ord":1,"text":"\"How much are the apples?\" Mom asks.","translation_ko":"\"사과는 얼마예요?\" 엄마가 물어요.","audioUrl":"/seed/daily-5-at-the-market/audio/p4-s2.mp3","wordTimings":[{"word":"How","charStart":1,"charEnd":4,"startMs":0,"endMs":200},{"word":"much","charStart":5,"charEnd":9,"startMs":200,"endMs":400},{"word":"are","charStart":10,"charEnd":13,"startMs":400,"endMs":540},{"word":"the","charStart":14,"charEnd":17,"startMs":540,"endMs":1000},{"word":"apples","charStart":18,"charEnd":24,"startMs":1000,"endMs":1020},{"word":"Mom","charStart":27,"charEnd":30,"startMs":1740,"endMs":1940},{"word":"asks","charStart":31,"charEnd":35,"startMs":1940,"endMs":2300}]}]},{"id":"daily-5-at-the-market-p5","pageNo":5,"spread":"p5","imageUrl":"/seed/daily-5-at-the-market/p5.webp","sentences":[{"id":"daily-5-at-the-market-p5-s1","ord":0,"text":"\"Five apples for two dollars,\" says the man.","translation_ko":"\"사과 다섯 개에 2달러예요,\" 아저씨가 말해요.","audioUrl":"/seed/daily-5-at-the-market/audio/p5-s1.mp3","wordTimings":[{"word":"Five","charStart":1,"charEnd":5,"startMs":0,"endMs":420},{"word":"apples","charStart":6,"charEnd":12,"startMs":420,"endMs":740},{"word":"for","charStart":13,"charEnd":16,"startMs":740,"endMs":980},{"word":"two","charStart":17,"charEnd":20,"startMs":980,"endMs":1180},{"word":"dollars","charStart":21,"charEnd":28,"startMs":1180,"endMs":1580},{"word":"says","charStart":31,"charEnd":35,"startMs":2160,"endMs":2260},{"word":"the","charStart":36,"charEnd":39,"startMs":2260,"endMs":2420},{"word":"man","charStart":40,"charEnd":43,"startMs":2420,"endMs":2580}]},{"id":"daily-5-at-the-market-p5-s2","ord":1,"text":"He holds up two fingers and nods to show the price is fair.","translation_ko":"아저씨는 손가락 두 개를 들어 보이며 가격이 적당하다는 듯 고개를 끄덕여요.","audioUrl":"/seed/daily-5-at-the-market/audio/p5-s2.mp3","wordTimings":[{"word":"He","charStart":0,"charEnd":2,"startMs":0,"endMs":260},{"word":"holds","charStart":3,"charEnd":8,"startMs":260,"endMs":540},{"word":"up","charStart":9,"charEnd":11,"startMs":540,"endMs":860},{"word":"two","charStart":12,"charEnd":15,"startMs":860,"endMs":1100},{"word":"fingers","charStart":16,"charEnd":23,"startMs":1100,"endMs":1480},{"word":"and","charStart":24,"charEnd":27,"startMs":1480,"endMs":2040},{"word":"nods","charStart":28,"charEnd":32,"startMs":2040,"endMs":2400},{"word":"to","charStart":33,"charEnd":35,"startMs":2400,"endMs":2580},{"word":"show","charStart":36,"charEnd":40,"startMs":2580,"endMs":2760},{"word":"the","charStart":41,"charEnd":44,"startMs":2760,"endMs":2940},{"word":"price","charStart":45,"charEnd":50,"startMs":2940,"endMs":3220},{"word":"is","charStart":51,"charEnd":53,"startMs":3220,"endMs":3620},{"word":"fair","charStart":54,"charEnd":58,"startMs":3620,"endMs":3660}]},{"id":"daily-5-at-the-market-p5-s3","ord":2,"text":"\"They came in this morning, so they are very fresh,\" he adds proudly.","translation_ko":"\"오늘 아침에 들어온 거라서 아주 신선해요,\" 아저씨가 자랑스럽게 말해요.","audioUrl":"/seed/daily-5-at-the-market/audio/p5-s3.mp3","wordTimings":[{"word":"They","charStart":1,"charEnd":5,"startMs":0,"endMs":240},{"word":"came","charStart":6,"charEnd":10,"startMs":240,"endMs":540},{"word":"in","charStart":11,"charEnd":13,"startMs":540,"endMs":720},{"word":"this","charStart":14,"charEnd":18,"startMs":720,"endMs":920},{"word":"morning","charStart":19,"charEnd":26,"startMs":920,"endMs":1220},{"word":"so","charStart":28,"charEnd":30,"startMs":1560,"endMs":1680},{"word":"they","charStart":31,"charEnd":35,"startMs":1680,"endMs":1820},{"word":"are","charStart":36,"charEnd":39,"startMs":1820,"endMs":1960},{"word":"very","charStart":40,"charEnd":44,"startMs":1960,"endMs":2360},{"word":"fresh","charStart":45,"charEnd":50,"startMs":2360,"endMs":3140},{"word":"he","charStart":53,"charEnd":55,"startMs":3140,"endMs":3260},{"word":"adds","charStart":56,"charEnd":60,"startMs":3260,"endMs":3440},{"word":"proudly","charStart":61,"charEnd":68,"startMs":3440,"endMs":3820}]}]},{"id":"daily-5-at-the-market-p6","pageNo":6,"spread":"p6","imageUrl":"/seed/daily-5-at-the-market/p6.webp","sentences":[{"id":"daily-5-at-the-market-p6-s1","ord":0,"text":"I pick the biggest, reddest apples I can find.","translation_ko":"나는 찾을 수 있는 가장 크고 빨간 사과를 골라요.","audioUrl":"/seed/daily-5-at-the-market/audio/p6-s1.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":340},{"word":"pick","charStart":2,"charEnd":6,"startMs":340,"endMs":480},{"word":"the","charStart":7,"charEnd":10,"startMs":480,"endMs":740},{"word":"biggest","charStart":11,"charEnd":18,"startMs":740,"endMs":1360},{"word":"reddest","charStart":20,"charEnd":27,"startMs":1580,"endMs":1960},{"word":"apples","charStart":28,"charEnd":34,"startMs":1960,"endMs":2300},{"word":"I","charStart":35,"charEnd":36,"startMs":2300,"endMs":2600},{"word":"can","charStart":37,"charEnd":40,"startMs":2600,"endMs":2800},{"word":"find","charStart":41,"charEnd":45,"startMs":2800,"endMs":3100}]},{"id":"daily-5-at-the-market-p6-s2","ord":1,"text":"I squeeze each one gently to check that it is firm and not too soft.","translation_ko":"나는 사과마다 살짝 눌러 보며 단단하고 너무 물렁하지 않은지 확인해요.","audioUrl":"/seed/daily-5-at-the-market/audio/p6-s2.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":280},{"word":"squeeze","charStart":2,"charEnd":9,"startMs":280,"endMs":640},{"word":"each","charStart":10,"charEnd":14,"startMs":640,"endMs":960},{"word":"one","charStart":15,"charEnd":18,"startMs":960,"endMs":1220},{"word":"gently","charStart":19,"charEnd":25,"startMs":1220,"endM