{"id":"daily-5-at-the-market","slug":"daily-5-at-the-market","title":"At the Market","title_ko":"시장에서","level":"B1","ageBand":"8-10","coverUrl":"/seed/daily-5-at-the-market/cover.webp","summary_ko":"엄마와 시장에 가서 과일을 고르고 값을 묻고 계산하는 이야기. 숫자와 가격, 사고파는 대화를 배워요.","wordCount":311,"stage":5,"collection":"daily","pages":[{"id":"daily-5-at-the-market-p1","pageNo":1,"spread":"p1","imageUrl":"/seed/daily-5-at-the-market/p1.webp","sentences":[{"id":"daily-5-at-the-market-p1-s1","ord":0,"text":"On Saturday, I go to the market with my mom.","translation_ko":"토요일에 나는 엄마와 시장에 가요.","audioUrl":"/seed/daily-5-at-the-market/audio/p1-s1.mp3","wordTimings":[{"word":"On","charStart":0,"charEnd":2,"startMs":0,"endMs":240},{"word":"Saturday","charStart":3,"charEnd":11,"startMs":240,"endMs":640},{"word":"I","charStart":13,"charEnd":14,"startMs":940,"endMs":1020},{"word":"go","charStart":15,"charEnd":17,"startMs":1020,"endMs":1140},{"word":"to","charStart":18,"charEnd":20,"startMs":1140,"endMs":1240},{"word":"the","charStart":21,"charEnd":24,"startMs":1240,"endMs":1400},{"word":"market","charStart":25,"charEnd":31,"startMs":1400,"endMs":1620},{"word":"with","charStart":32,"charEnd":36,"startMs":1620,"endMs":1880},{"word":"my","charStart":37,"charEnd":39,"startMs":1880,"endMs":2040},{"word":"mom","charStart":40,"charEnd":43,"startMs":2040,"endMs":2300}]},{"id":"daily-5-at-the-market-p1-s2","ord":1,"text":"I love market day because the streets smell like fresh fruit and warm bread.","translation_ko":"시장 날이 좋아요. 길에서 신선한 과일과 따뜻한 빵 냄새가 나거든요.","audioUrl":"/seed/daily-5-at-the-market/audio/p1-s2.mp3","wordTimings":[{"word":"I","charStart":0,"charEnd":1,"startMs":0,"endMs":560},{"word":"love","charStart":2,"charEnd":6,"startMs":560,"endMs":800},{"word":"market","charStart":7,"charEnd":13,"startMs":800,"endMs":1120},{"word":"day","charStart":14,"charEnd":17,"startMs":1120,"endMs":1340},{"word":"because","charStart":18,"charEnd":25,"startMs":1340,"endMs":1720},{"word":"the","charStart":26,"charEnd":29,"startMs":1720,"endMs":2020},{"word":"streets","charStart":30,"charEnd":37,"startMs":2020,"endMs":2260},{"word":"smell","charStart":38,"charEnd":43,"startMs":2260,"endMs":2600},{"word":"like","charStart":44,"charEnd":48,"startMs":2600,"endMs":2920},{"word":"fresh","charStart":49,"charEnd":54,"startMs":2920,"endMs":3160},{"word":"fruit","charStart":55,"charEnd":60,"startMs":3160,"endMs":3420},{"word":"and","charStart":61,"charEnd":64,"startMs":3420,"endMs":3780},{"word":"warm","charStart":65,"charEnd":69,"startMs":3780,"endMs":4080},{"word":"bread","charStart":70,"charEnd":75,"startMs":4080,"endMs":4300}]}]},{"id":"daily-5-at-the-market-p2","pageNo":2,"spread":"p2","imageUrl":"/seed/daily-5-at-the-market/p2.webp","sentences":[{"id":"daily-5-at-the-market-p2-s1","ord":0,"text":"The market is busy and full of color.","translation_ko":"시장은 북적이고 색깔로 가득해요.","audioUrl":"/seed/daily-5-at-the-market/audio/p2-s1.mp3","wordTimings":[{"word":"The","charStart":0,"charEnd":3,"startMs":0,"endMs":280},{"word":"market","charStart":4,"charEnd":10,"startMs":280,"endMs":600},{"word":"is","charStart":11,"charEnd":13,"startMs":600,"endMs":1060},{"word":"busy","charStart":14,"charEnd":18,"startMs":1060,"endMs":1460},{"word":"and","charStart":19,"charEnd":22,"startMs":1460,"endMs":1880},{"word":"full","charStart":23,"charEnd":27,"startMs":1880,"endMs":2060},{"word":"of","charStart":28,"charEnd":30,"startMs":2060,"endMs":2280},{"word":"color","charStart":31,"charEnd":36,"startMs":2280,"endMs":2500}]},{"id":"daily-5-at-the-market-p2-s2","ord":1,"text":"Red tomatoes, yellow bananas, and green vegetables fill every stall.","translation_ko":"빨간 토마토, 노란 바나나, 초록 채소가 모든 가판대마다 가득해요.","audioUrl":"/seed/daily-5-at-the-market/audio/p2-s2.mp3","wordTimings":[{"word":"Red","charStart":0,"charEnd":3,"startMs":0,"endMs":300},{"word":"tomatoes","charStart":4,"charEnd":12,"startMs":300,"endMs":800},{"word":"yellow","charStart":14,"charEnd":20,"startMs":1280,"endMs":1420},{"word":"bananas","charStart":21,"charEnd":28,"startMs":1420,"endMs":1760},{"word":"and","charStart":30,"charEnd":33,"startMs":2260,"endMs":2500},{"word":"green","charStart":34,"charEnd":39,"startMs":2500,"endMs":2740},{"word":"vegetables","charStart":40,"charEnd":50,"startMs":2740,"endMs":3120},{"word":"fill","charStart":51,"charEnd":55,"startMs":3120,"endMs":3500},{"word":"every","charStart":56,"charEnd":61,"startMs":3500,"endMs":3960},{"word":"stall","charStart":62,"charEnd":67,"startMs":3960,"endMs":4200}]}]},{"id":"daily-5-at-the-market-p3","pageNo":3,"spread":"p3","imageUrl":"/seed/daily-5-at-the-market/p3.webp","sentences":[{"id":"daily-5-at-the-market-p3-s1","ord":0,"text":"\"We need some apples and bread,\" says Mom.","translation_ko":"\"사과와 빵이 좀 필요해,\" 엄마가 말해요.","audioUrl":"/seed/daily-5-at-the-market/audio/p3-s1.mp3","wordTimings":[{"word":"We","charStart":1,"charEnd":3,"startMs":0,"endMs":240},{"word":"need","charStart":4,"charEnd":8,"startMs":240,"endMs":540},{"word":"some","charStart":9,"charEnd":13,"startMs":540,"endMs":900},{"word":"apples","charStart":14,"charEnd":20,"startMs":900,"endMs":1120},{"word":"and","charStart":21,"charEnd":24,"startMs":1120,"endMs":1700},{"word":"bread","charStart":25,"charEnd":30,"startMs":1700,"endMs":1700},{"word":"says","charStart":33,"charEnd":37,"startMs":2400,"endMs":2480},{"word":"Mom","charStart":38,"charEnd":41,"startMs":2480,"endMs":2760}]},{"id":"daily-5-at-the-market-p3-s2","ord":1,"text":"She opens her shopping bag and checks her list.","translation_ko":"엄마는 장바구니를 열고 목록을 확인해요.","audioUrl":"/seed/daily-5-at-the-market/audio/p3-s2.mp3","wordTimings":[{"word":"She","charStart":0,"charEnd":3,"startMs":0,"endMs":520},{"word":"opens","charStart":4,"charEnd":9,"startMs":520,"endMs":860},{"word":"her","charStart":10,"charEnd":13,"startMs":860,"endMs":1100},{"word":"shopping","charStart":14,"charEnd":22,"startMs":1100,"endMs":1320},{"word":"bag","charStart":23,"charEnd":26,"startMs":1320,"endMs":1720},{"word":"and","charStart":27,"charEnd":30,"startMs":17