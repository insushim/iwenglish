  "quiz": [
    {
      "question_ko": "강아지가 깨어나서 밖을 보았을 때 세상은 어떤 색이었나요?",
      "type": "mc",
      "options": [
        "파란색",
        "초록색",
        "하얀색",
        "노란색"
      ],
      "answerIndex": 2,
      "explain_ko": "눈이 내려서 온 세상이 하얗고 폭신했어요."
    },
    {
      "question_ko": "강아지가 눈을 처음 만졌을 때 눈은 어떤 느낌이었나요?",
      "type": "mc",
      "options": [
        "딱딱했어요",
        "뜨거웠어요",
        "차갑고 보송보송했어요",
        "끈적였어요"
      ],
      "answerIndex": 2,
      "explain_ko": "강아지가 발을 내디뎠을 때 눈은 차갑고 보송보송했어요."
    },
    {
      "question_ko": "강아지가 눈밭에서 한 행동이 아닌 것은 무엇인가요?",
      "type": "mc",
      "options": [
        "데굴데굴 굴렀어요",
        "잠을 잤어요",
        "냄새를 맡았어요",
        "높이 뛰었어요"
      ],
      "answerIndex": 1,
      "explain_ko": "강아지는 냄새를 맡고, 뛰고, 굴렀지만 눈밭에서 자지는 않았어요."
    },
    {
      "question_ko": "눈송이가 강아지의 어디에 내려앉았나요?",
      "type": "mc",
      "options": [
        "꼬리",
        "코",
        "귀",
        "발"
      ],
      "answerIndex": 1,
      "explain_ko": "눈송이 하나가 강아지의 코에 내려앉아 코가 차가웠어요."
    },
    {
      "question_ko": "이 이야기가 전하는 따뜻한 느낌은 무엇일까요?",
      "type": "mc",
      "options": [
        "혼자 노는 것이 제일 좋아요",
        "눈은 위험해요",
        "집 밖은 무서워요",
        "처음 겪는 일은 신나고 즐거워요"
      ],
      "answerIndex": 3,
      "explain_ko": "강아지가 첫눈을 신나게 즐기는 모습에서 새로운 경험의 즐거움을 느낄 수 있어요."
    }
